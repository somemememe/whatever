direction: right

title: "Figure A1. Agent Roles and Quality Controls"

classes: {
  group: {
    style: {
      fill: transparent
      stroke: "#c9d3df"
      stroke-dash: 3
      border-radius: 8
      font-size: 13
      font-color: "#2f3f52"
      bold: true
    }
  }
  role: {
    style: {
      fill: "#f4f7fb"
      stroke: "#3d5f84"
      border-radius: 6
      font-size: 12
    }
  }
  gate: {
    shape: diamond
    style: {
      fill: "#ffffff"
      stroke: "#627386"
      font-size: 12
    }
  }
  artifact: {
    shape: cylinder
    style: {
      fill: "#f5f7fa"
      stroke: "#7a8795"
      font-size: 12
    }
  }
  rule: {
    style: {
      fill: "#ffffff"
      stroke: "#6f8093"
      border-radius: 6
      font-size: 12
    }
  }
}

discovery: "Discovery Layer" {
  class: group
  codex: "Codex Worker(s)" { class: role }
  opencode: "OpenCode Worker(s)" { class: role }
}

adjudication: "Adjudication Layer" {
  class: group
  merge: "Merge Reviewer\n(merge.py)" { class: role }
  quality: "Reportable Security Impact?" { class: gate }
  findings: "findings_acc.json" { class: artifact }
  rejected: "merge_rejections.json" { class: artifact }
  merge -> quality: "candidate findings"
  quality -> findings: "retain"
  quality -> rejected: "reject with reason"
}

memory: "Summary Layer" {
  class: group
  summary: "Round Summarizer\n(summarize_round.py)" { class: role }
  round_sum: "round_summary.md" { class: artifact }
  global_sum: "global_summary.md" { class: artifact }
  summary -> round_sum: "write"
  summary -> global_sum: "update"
}

constraints: "Control Rules" {
  class: group
  c1: "Audit scope restricted to target Solidity directory." { class: rule }
  c2: "No external reports/docs outside target directory." { class: rule }
  c3: "Documented behavior and owner-only config are filtered unless user-facing security harm exists." { class: rule }
}

discovery.codex -> adjudication.merge: "outputs"
discovery.opencode -> adjudication.merge: "outputs"
adjudication.findings -> memory.summary: "retained findings"
memory.round_sum -> discovery.codex: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.global_sum -> discovery.codex: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.round_sum -> discovery.opencode: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.global_sum -> discovery.opencode: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}

constraints.c1 -> discovery.codex: "constraint"
constraints.c1 -> discovery.opencode: "constraint"
constraints.c2 -> discovery.codex: "constraint"
constraints.c2 -> discovery.opencode: "constraint"
constraints.c3 -> adjudication.quality: "constraint"
