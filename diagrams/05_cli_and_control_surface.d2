direction: right

title: "Figure A2. CLI Control Surface"

classes: {
  group: {
    style: {
      fill: transparent
      stroke: "#c9d3df"
      stroke-dash: 3
      border-radius: 8
      font-size: 13
      font-color: "#2f3f52"
      bold: true
    }
  }
  knob: {
    style: {
      fill: "#f4f7fb"
      stroke: "#3d5f84"
      border-radius: 6
      font-size: 12
    }
  }
  env: {
    style: {
      fill: "#f5f7fa"
      stroke: "#7a8795"
      border-radius: 6
      font-size: 12
    }
  }
  effect: {
    style: {
      fill: "#ffffff"
      stroke: "#6f8093"
      border-radius: 6
      font-size: 12
    }
  }
}

cli: "CLI Arguments (`audithound.py run`)" {
  class: group
  k1: "agents and workers" { class: knob }
  k2: "discovery / merge / summary models" { class: knob }
  k3: "reasoning effort levels" { class: knob }
  k4: "round budget and convergence threshold" { class: knob }
  k5: "exclude globs, resume, target/output paths" { class: knob }
}

wiring: "Environment Wiring" {
  class: group
  e1: "AUDITHOUND_AGENT_TYPES\nAUDITHOUND_AGENT_TYPE" { class: env }
  e2: "AUDITHOUND_*_MODEL" { class: env }
  e3: "CODEX_REASONING_EFFORT\nAUDITHOUND_SUMMARY_REASONING_EFFORT" { class: env }
  e4: "AUDITHOUND_RESUME\nAUDITHOUND_EXCLUDE_GLOBS" { class: env }
}

runtime: "Runtime Effects" {
  class: group
  r1: "run_agent.sh\nworker dispatch and model selection" { class: effect }
  r2: "merge.py\nmerge model and scope filtering" { class: effect }
  r3: "summarize_round.py\nsummary agent/model separation" { class: effect }
  r4: "run_convergence_loop.sh\nconvergence and resume control" { class: effect }
}

cli.k1 -> wiring.e1
cli.k2 -> wiring.e2
cli.k3 -> wiring.e3
cli.k4 -> wiring.e4
cli.k5 -> wiring.e4

wiring.e1 -> runtime.r1
wiring.e2 -> runtime.r1
wiring.e2 -> runtime.r2
wiring.e2 -> runtime.r3
wiring.e3 -> runtime.r1
wiring.e3 -> runtime.r3
wiring.e4 -> runtime.r2
wiring.e4 -> runtime.r4
