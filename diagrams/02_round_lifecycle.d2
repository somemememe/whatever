direction: right

title: "Figure 2. Round Lifecycle and Convergence Control"

classes: {
  step: {
    style: {
      fill: "#f4f7fb"
      stroke: "#3d5f84"
      border-radius: 6
      font-size: 12
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#ffffff"
      stroke: "#627386"
      font-size: 12
    }
  }
  store: {
    shape: cylinder
    style: {
      fill: "#f5f7fa"
      stroke: "#7a8795"
      font-size: 12
    }
  }
  out: {
    style: {
      fill: "#ffffff"
      stroke: "#6f8093"
      border-radius: 6
      font-size: 12
    }
  }
}

start: "Start/Resume\n(audithound.py)" { class: step }
prepare: "Prepare Round\n(state + code_map)" { class: step }
prompt: "Build Prompt\n(gen_prompt.py)" { class: step }
agents: "Run Workers\n(run_agent.sh x N)" { class: step }
merge: "Merge\n(merge.py)" { class: step }
update: "Update Round State\n(summary + findings + checkpoints)" { class: step }
new_gate: "new findings?" { class: decision }
conv_gate: "converged?" { class: decision }
stop: "Stop" { class: step }
report: "Generate Report\n(gen_report.py)" { class: out }

start -> prepare: "initialize"
prepare -> prompt: "round context"
prompt -> agents: "prompt.md"
agents -> merge: "candidate findings"
merge -> update: "retained findings"
update -> new_gate: "delta"
new_gate -> prompt: "yes" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
new_gate -> conv_gate: "no"
conv_gate -> stop: "yes"
conv_gate -> prompt: "no" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
stop -> report: "finalize"

findings: "findings_acc.json" { class: store }
round_sum: "round_summary.md" { class: store }
global_sum: "global_summary.md" { class: store }
loop_state: "loop_state.json" { class: store }

findings -> prompt: "known findings"
round_sum -> prompt: "optional context"
global_sum -> prompt: "optional context"
loop_state -> prepare: "resume state"
update -> findings: "update"
update -> round_sum: "write"
update -> global_sum: "update"
update -> loop_state: "checkpoint"
