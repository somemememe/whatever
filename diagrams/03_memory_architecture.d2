direction: right

title: "Figure 3. Memory Architecture"

classes: {
  group: {
    style: {
      fill: transparent
      stroke: "#c9d3df"
      stroke-dash: 3
      border-radius: 8
      font-size: 13
      font-color: "#2f3f52"
      bold: true
    }
  }
  actor: {
    style: {
      fill: "#f4f7fb"
      stroke: "#3d5f84"
      border-radius: 6
      font-size: 12
    }
  }
  reader: {
    style: {
      fill: "#ffffff"
      stroke: "#6f8093"
      border-radius: 6
      font-size: 12
    }
  }
  canonical: {
    shape: cylinder
    style: {
      fill: "#edf3fa"
      stroke: "#3d5f84"
      stroke-width: 2
      font-size: 12
    }
  }
  store: {
    shape: cylinder
    style: {
      fill: "#f5f7fa"
      stroke: "#7a8795"
      font-size: 12
    }
  }
}

writers: "Writers" {
  class: group
  merge: "merge.py" { class: actor }
  summary: "summarize_round.py" { class: actor }
  loop: "run_convergence_loop.sh" { class: actor }
}

stores: "Memory Stores" {
  class: group
  direction: down
  canonical: "findings_acc.json\n(canonical memory)" { class: canonical }
  context: "context memory\nround_summary.md\nglobal_summary.md\nmerge_rejections.json" { class: store }
  runtime: "runtime state\nround_state.json\nloop_state.json" { class: store }
  trace: "trace logs\nagent/merge/summary stdout|stderr" { class: store }
}

readers: "Readers" {
  class: group
  prompt_builder: "gen_prompt.py" { class: reader }
  harness: "run_convergence_loop.sh" { class: reader }
  reporter: "gen_report.py" { class: reader }
  reviewer: "Human reviewer" { class: reader }
}

writers.merge -> stores.canonical: "update"
writers.summary -> stores.context: "update"
writers.loop -> stores.runtime: "update"
writers.merge -> stores.trace: "emit"
writers.summary -> stores.trace: "emit"

stores.canonical -> readers.prompt_builder: "required"
stores.context -> readers.prompt_builder: "optional" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
stores.runtime -> readers.harness: "resume"
stores.canonical -> readers.reporter: "report source"
stores.trace -> readers.reviewer: "inspection"
stores.context -> readers.reviewer: "inspection"

legend: "Legend" {
  class: group
  l1: "Canonical vulnerability memory: findings_acc.json only" { class: canonical }
  l2: "Contextual memory is advisory, not a coverage guarantee" { class: reader }
}
