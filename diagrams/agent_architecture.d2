direction: right

title: "AuditHoundV2 Agent Architecture"

classes: {
  group: {
    style: {
      fill: transparent
      stroke: "#c9d3df"
      stroke-dash: 3
      border-radius: 8
      font-size: 13
      font-color: "#2f3f52"
      bold: true
    }
  }
  proc: {
    style: {
      fill: "#f4f7fb"
      stroke: "#3d5f84"
      border-radius: 6
      font-size: 12
    }
  }
  data: {
    style: {
      fill: "#ffffff"
      stroke: "#6f8093"
      border-radius: 6
      font-size: 12
    }
  }
  canonical: {
    shape: cylinder
    style: {
      fill: "#edf3fa"
      stroke: "#3d5f84"
      stroke-width: 2
      font-size: 12
    }
  }
  aux: {
    shape: cylinder
    style: {
      fill: "#f5f7fa"
      stroke: "#7a8795"
      font-size: 12
    }
  }
}

scope: "Input Scope" {
  class: group
  target: "Target Solidity Directory" { class: data }
  excludes: "Exclude Globs" { class: data }
  map: "code_map.md" { class: data }
  target -> map: "scan"
  excludes -> map: "filter"
}

pipeline: "Convergence Pipeline" {
  class: group
  direction: right
  cli: "audithound.py" { class: proc }
  loop: "run_convergence_loop.sh" { class: proc }
  prompt: "gen_prompt.py" { class: proc }
  agents: "Parallel Workers\n(Codex / OpenCode)" { class: proc }
  merge: "merge.py" { class: proc }
  summary: "summarize_round.py" { class: proc }
  cli -> loop: "initialize"
  loop -> prompt: "round context"
  prompt -> agents: "prompt.md"
  agents -> merge: "candidate findings"
  merge -> summary: "retained findings"
}

memory: "State and Outputs" {
  class: group
  findings: "findings_acc.json\n(canonical)" { class: canonical }
  rejections: "merge_rejections.json" { class: aux }
  round_summary: "round_summary.md" { class: aux }
  global_summary: "global_summary.md" { class: aux }
  loop_state: "loop_state.json" { class: aux }
  report: "final_report.md" { class: data }
}

scope.map -> pipeline.loop: "scope"
pipeline.merge -> memory.findings: "update"
pipeline.merge -> memory.rejections: "write"
pipeline.summary -> memory.round_summary: "write"
pipeline.summary -> memory.global_summary: "update"
pipeline.loop -> memory.loop_state: "checkpoint"
memory.findings -> pipeline.prompt: "known findings"
memory.round_summary -> pipeline.prompt: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.global_summary -> pipeline.prompt: "optional context" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.loop_state -> pipeline.loop: "resume" {
  style.stroke-dash: 4
  style.stroke: "#6d6d6d"
}
memory.findings -> memory.report: "report generation"
