direction: right

# ==========================================
# 论文级配色和形状规范 (Academic Palette)
# ==========================================
classes: {
  layer_group: {
    style: {
      fill: transparent
      stroke: "#90caf9"
      stroke-dash: 5
      border-radius: 8
      font-size: 15
      font-color: "#1565c0"
      bold: true
    }
  }
  proc_node: {
    shape: rectangle
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      border-radius: 4
      font-size: 13
      shadow: true
    }
  }
  agent_node: {
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#2e7d32"
      border-radius: 6
      font-size: 13
      bold: true
      shadow: true
    }
  }
  static_file: {
    shape: rectangle
    style: {
      fill: "#f5f5f5"
      stroke: "#9e9e9e"
      border-radius: 2
      font-size: 12
    }
  }
  db_canonical: {
    shape: cylinder
    style: {
      fill: "#ffe0b2"
      stroke: "#f57c00"
      stroke-width: 2
      font-size: 13
      bold: true
      shadow: true
    }
  }
  db_memory: {
    shape: cylinder
    style: {
      fill: "#f3e5f5"
      stroke: "#8e24aa"
      font-size: 13
      shadow: true
    }
  }
  db_aux: {
    shape: cylinder
    style: {
      fill: "#eceff1"
      stroke: "#78909c"
      font-size: 12
    }
  }
}

# ==========================================
# 左侧：静态输入层
# ==========================================
Input_Layer: "Input Scope Layer" {
  class: layer_group
  direction: down
  
  target: "Target Protocol\n(Solidity Codebase)" { class: static_file }
  excludes: "Exclude Globs" { class: static_file }
  map: "code_map.md\n(Noise-Filtered Views)" { class: static_file; style.stroke-width: 2 }
  
  target -> map: "Extract & Chunk" { style: { font-size: 11; stroke: "#9e9e9e" } }
  excludes -> map: "Filter" { style: { font-size: 11; stroke: "#9e9e9e" } }
}

# ==========================================
# 中间：核心收敛流水线
# ==========================================
Pipeline: "Convergence Pipeline (Per Iteration K)" {
  class: layer_group
  direction: down

  harness: "Thin Harness Controller\n(audithound.py / run_convergence_loop.sh)" { class: proc_node; style.fill: "#ffebee"; style.stroke: "#c62828" }
  prompt: "Prompt Assembler\n(gen_prompt.py)" { class: proc_node }
  
  agents: "Autonomous Exploration Swarm\n(Codex / OpenCode Agents)" { class: agent_node }
  
  merge: "Synthesis Engine\n(merge.py)" { class: proc_node }
  summary: "Context Compressor\n(summarize_round.py)" { class: proc_node }

  # Pipeline 内部顺流
  harness -> prompt: "Trigger Round" { style: { font-size: 11 } }
  prompt -> agents: "Inject Task & Map" { style: { font-size: 11 } }
  agents -> merge: "Diverse Vulnerability Signals" { style: { font-size: 11 } }
  merge -> summary: "Retained Defensible Findings" { style: { font-size: 11 } }
}

# ==========================================
# 右侧：状态沉淀与记忆层
# ==========================================
State_Storage: "State Memory & Storage Layer" {
  class: layer_group
  direction: down

  findings: "Accumulated Findings JSON\n(Verified Vulnerabilities)" { class: db_canonical }
  context_mem: "Dynamic Context Memory\n(Round / Global Summaries)" { class: db_memory }
  
  sys_log: "System Checkpoints\n(Loop State / Invalid Logs)" { class: db_aux }
  report: "Final Audit Report\n(Markdown)" { class: static_file; style.stroke-width: 2; style.stroke: "#2e7d32"; style.fill: "#e8f5e9" }
}

# ==========================================
# 跨域数据流 (前向传播)
# ==========================================
Input_Layer.map -> Pipeline.prompt: "Static Map" { style: { stroke-width: 2; font-size: 11; stroke: "#9e9e9e" } }

Pipeline.harness -> State_Storage.sys_log: "Save State" { style: { font-size: 10; stroke: "#78909c" } }

Pipeline.merge -> State_Storage.findings: "Retain & Accumulate" { style: { stroke-width: 2; stroke: "#f57c00"; font-color: "#f57c00"; font-size: 11 } }
Pipeline.merge -> State_Storage.sys_log: "Eject Candidates" { style: { font-size: 10; stroke: "#78909c" } }

Pipeline.summary -> State_Storage.context_mem: "Persist Traces" { style: { stroke-width: 2; stroke: "#8e24aa"; font-color: "#8e24aa"; font-size: 11 } }

State_Storage.findings -> State_Storage.report: "Report Generation" { style: { stroke-width: 2; stroke: "#2e7d32"; font-size: 11 } }

# ==========================================
# 反馈回路 (自回归收敛的核心)
# ==========================================
State_Storage.sys_log -> Pipeline.harness: "Resume From" { style: { stroke-dash: 5; font-size: 10; stroke: "#78909c" } }

State_Storage.findings -> Pipeline.merge: "Deduplication Baseline" { 
  style: { stroke-dash: 5; font-size: 11; stroke: "#f57c00"; font-color: "#f57c00" } 
}

State_Storage.context_mem -> Pipeline.prompt: "Prior Discoveries\n(Search Extent)" { 
  style: { stroke-dash: 5; stroke-width: 2; stroke: "#8e24aa"; font-color: "#8e24aa"; font-size: 11 } 
}
