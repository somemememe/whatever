// SPDX-License-Identifier: MIT

pragma solidity ^0.7.6;

import "./IERC20.sol";
import "./SafeMath.sol";
import "./ReentrancyGuard.sol";
import "./CTokenInterface.sol";
import "./SafeERC20.sol";
import "./EIP20NonStandardInterface.sol";


contract Staking is ReentrancyGuard {
