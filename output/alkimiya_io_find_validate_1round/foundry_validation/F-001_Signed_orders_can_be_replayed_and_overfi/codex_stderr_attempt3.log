function inn(amountOut,resIn,resOut){let ao=BigInt(amountOut),ri=BigInt(resIn),ro=BigInt(resOut); if(ao<=0n||ao>=ro) return null; return (ri*ao*1000n)/((ro-ao)*997n)+1n;}
