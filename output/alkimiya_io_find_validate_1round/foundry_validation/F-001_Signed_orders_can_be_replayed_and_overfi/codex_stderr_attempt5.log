MAKER=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
TYPEHASH=$(cast keccak "Permit(address holder,address spender,uint256 nonce,uint256 expiry,bool allowed)")
NAMEHASH=$(cast keccak "Dai Stablecoin")
VERSIONHASH=$(cast keccak "1")
DOMAINTYPE=$(cast keccak "EIP712Domain(string name,string version,uint256 chainId,address verifyingContract)")
DOMAIN=$(cast abi-encode "f(bytes32,bytes32,bytes32,uint256,address)" $DOMAINTYPE $NAMEHASH $VERSIONHASH 1 $DAI | cast keccak)
