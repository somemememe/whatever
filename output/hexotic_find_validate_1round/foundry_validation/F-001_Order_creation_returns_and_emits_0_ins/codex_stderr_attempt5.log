        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = HEX;

        uint256 beforeBal = IERC20(HEX).balanceOf(address(this));
        IUniswapV2RouterLike(router).swapExactETHForTokensSupportingFeeOnTransferTokens{value: VALIDATION_HEX_BUDGET}(
            0,
            path,
            address(this),
