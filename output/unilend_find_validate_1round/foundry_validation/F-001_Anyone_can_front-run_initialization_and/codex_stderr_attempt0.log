    bool public hypothesisValidated;

    uint8 public failureCode;
    // 0: no terminal failure
    // 1: target was already initialized at fork block, so front-run path is unavailable on-chain
    // 2: hostile init succeeded and late initializer was locked out, but target held no drainable tracked balances
    // 3: hostile init succeeded, but a second initializer was not blocked by the one-time init flag

    address public selectedToken0;
