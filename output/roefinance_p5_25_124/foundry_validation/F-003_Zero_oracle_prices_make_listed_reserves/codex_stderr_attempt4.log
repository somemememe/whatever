cat > /private/tmp/roef_debug/test/Debug.t.sol <<'EOF'
// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

import "../src/FlawVerifier.sol";

interface Vm {
    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
    function envString(string calldata name) external returns (string memory);
}

address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));

interface ISourceOracleLike {
    function getSourceOfAsset(address asset) external view returns (address);
    function getFallbackOracle() external view returns (address);
}

contract DebugTest {
    Vm constant vm = Vm(HEVM_ADDRESS);

    event log_named_address(string key, address val);
    event log_named_uint(string key, uint256 val);

    function testDump() public {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 16384469);

        ILendingPoolLike pool = ILendingPoolLike(0x5F360c6b7B25DfBfA4F10039ea0F7ecfB9B02E60);
        address oracle = pool.getAddressesProvider().getPriceOracle();
        address[] memory reserves = pool.getReservesList();

        emit log_named_address("oracle", oracle);
        emit log_named_uint("reserve_count", reserves.length);
        emit log_named_address("fallback", ISourceOracleLike(oracle).getFallbackOracle());

        for (uint256 i = 0; i < reserves.length; ++i) {
            address asset = reserves[i];
            AaveDataTypes.ReserveConfigurationMap memory c = pool.getConfiguration(asset);
            AaveDataTypes.ReserveData memory r = pool.getReserveData(asset);
            uint256 price = IPriceOracleLike(oracle).getAssetPrice(asset);
            emit log_named_uint("i", i);
            emit log_named_address("asset", asset);
            emit log_named_address("source", ISourceOracleLike(oracle).getSourceOfAsset(asset));
            emit log_named_uint("price", price);
            emit log_named_uint("config", c.data);
            emit log_named_address("aToken", r.aTokenAddress);
            emit log_named_uint("liq", IERC20Like(asset).balanceOf(r.aTokenAddress));
        }
    }
}
