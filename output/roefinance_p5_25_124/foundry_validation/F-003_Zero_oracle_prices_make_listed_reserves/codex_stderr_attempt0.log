+    function _tryFlashCollateralFallback(
+        ILendingPoolLike pool,
+        address oracle,
+        address[] memory reserves,
+        TargetCandidate memory target
+    ) internal {
+        uint256 premiumRate = pool.FLASHLOAN_PREMIUM_TOTAL();
