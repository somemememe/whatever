+            return candidate;
+        }
+
+        if (reserveData.aTokenAddress == address(0) || reserveData.aTokenAddress.code.length == 0) {
+            return candidate;
+        }
+
+        uint256 price;
+        try IPriceOracleLike(oracle).getAssetPrice(asset) returns (uint256 p) {
