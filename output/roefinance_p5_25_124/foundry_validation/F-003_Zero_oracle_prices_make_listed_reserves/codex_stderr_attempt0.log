+contract FlawVerifier is IFlashLoanReceiverLike {
+    uint256 private constant VARIABLE_RATE_MODE = 2;
+    address private constant TARGET_POOL = 0x5F360c6b7B25DfBfA4F10039ea0F7ecfB9B02E60;
