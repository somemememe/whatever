+    ) external override returns (bool) {
+        require(msg.sender == TARGET_POOL, "caller not pool");
+        require(initiator == address(this), "bad initiator");
+        require(assets.length == 1 && amounts.length == 1 && premiums.length == 1, "bad flash arrays");
