+                continue;
+            }
+
+            try this._attemptDirect(
+                collateral.asset,
+                collateral.minRequired,
+                target.asset,
+                target.availableLiquidity
+            ) returns (bool success) {
+                if (success) {
+                    return true;
+                }
+            } catch {}
+        }
+
+        return false;
+    }
