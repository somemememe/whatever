/Users/zhanglongqin/AuditHoundV2/output/uwerx_p5_25_124/foundry_validation/F-001_Pool-directed_transferFrom_can_burn_more/codex_stderr_attempt2.log:1849:/Users/zhanglongqin/AuditHoundV2/output/uwerx_p5_25_124/foundry_validation/F-001_Pool-directed_transferFrom_can_burn_more/codex_stderr_attempt0.log:1615:/Users/zhanglongqin/AuditHoundV2/output/uwerx_p5_25_124/rounds/round_1/merge_stderr.log:123:[{"id": "F-001", "severity": "High", "confidence": "high", "title": "Owner can arbitrarily set pool address enabling fund theft", "locations": ["0x4306b12f8e824ce1fa9604bbd88f2ad4f0fe3c54/Contract.sol:282-284"], "claim": "The setUniswapPoolAddress function allows the owner to set any address as the Uniswap pool, which controls where the 3% sell tax (2% marketing + 1% burn) is applied.", "impact": "Owner can set the pool address to a malicious contract with callback hooks that can re-enter the transfer function or manipulate state to steal user funds. Additionally, owner can redirect the tax mechanism to collect fees or disable it entirely at will.", "paths": ["1. Owner calls setUniswapPoolAddress() to set pool to a malicious contract\n2. User transfers tokens to pool (selling)\n3. Malicious contract executes callback during transfer\n4. Attacker extracts additional value from user"]}, {"id": "F-002", "severity": "High", "confidence": "high", "title": "Owner can arbitrarily redirect marketing fee to any address", "locations": ["0x4306b12f8e824ce1fa9604bbd88f2ad4f0fe3c54/Contract.sol:286-288"], "claim": "The setMarketingWallet function allows the owner to change the marketing wallet address that receives 2% of each sell transaction.", "impact": "Owner can redirect the 2% marketing fee to any address, allowing collection of fees that should go to a designated marketing address. This creates a direct fund theft vector where owner can collect the fee portion of user transfers.", "paths": ["1. Owner calls setMarketingWallet() to set wallet to their own address\n2. User transfers tokens to pool (selling)\n3. 2% marketing fee is sent to owner's address instead of intended wallet"]}, {"id": "F-003", "severity": "Medium", "confidence": "high", "title": "No timelock on critical administrative functions", "locations": ["0x4306b12f8e824ce1fa9604bbd88f2ad4f0fe3c54/Contract.sol:282-288"], "claim": "setUniswapPoolAddress and setMarketingWallet execute immediately with no delay mechanism.", "impact": "Changes to critical protocol parameters (pool address, marketing wallet) take effect instantly. This allows owner to front-run large transfers or react instantly to market conditions, extracting maximum value before reverting changes. Users have no time to react to malicious parameter changes.", "paths": ["1. Owner monitors mempool for large pending transfer\n2. Owner front-runs by changing pool/marketing address\n3. Large transfer executes with modified parameters\n4. Owner reverts changes after extracting value"]}, {"id": "F-004", "severity": "Low", "confidence": "medium", "title": "Missing events for critical parameter changes", "locations": ["0x4306b12f8e824ce1fa9604bbd88f2ad4f0fe3c54/Contract.sol:282-288"], "claim": "setUniswapPoolAddress and setMarketingWallet do not emit events when changing state.", "impact": "No on-chain record of pool address or marketing wallet changes makes it difficult to track historical changes off-chain via event logs. This reduces transparency and makes it harder to detect suspicious changes.", "paths": []}, {"id": "F-005", "severity": "Informational", "confidence": "high", "title": "High owner concentration - single point of failure", "locations": ["0x4306b12f8e824ce1fa9604bbd88f2ad4f0fe3c54/Contract.sol:282-288"], "claim": "The owner has unrestricted control over critical token parameters including tax mechanism and fee collection.", "impact": "Single compromised owner key or malicious owner can completely control the token's economic parameters. No governance, multi-sig, or timelock protections exist. This is a centralization risk typical of pre-launch tokens but creates significant trust assumptions.", "paths": []}]
