        }
        executed = true;
        _profitToken = TARGET;

        configuredPool = _configuredPool();
        if (configuredPool == address(0)) {
            status = "NO_CONFIG";
            return;
        }

        fundingPair = _findFundingPair();
        if (fundingPair == address(0)) {
