audius/manifest.json:5:  \"fork_block_number\": 15201793,\n../../../audius/manifest.json:4:  \"chain\": \"mainnet\",\n../../../audius/manifest.json:5:  \"fork_block_number\": 15201793,\n/Users/zhanglongqin/AuditHoundV2/cases/SBRToken/src/FlawVerifier.sol:136:        // On the forked state from the finding, `skim(pair)` does not increase the attacker's raw\n../../../SBRToken/src/FlawVerifier.sol:136:        // On the forked state from the finding, `skim(pair)` does not increase the attacker's raw\n/Users/zhanglongqin/AuditHoundV2/cases/SBRToken/src/SBRToken.sol:26:        vm.createSelectFork(\"mainnet\", 21_991_722 - 1);\n../../../SBRToken/src/SBRToken.sol:26:        vm.createSelectFork(\"mainnet\", 21_991_722 - 1);\n/Users/zhanglongqin/AuditHoundV2/cases/SBRToken/manifest.json:4:  \"chain\": \"mainnet\",\n/Users/zhanglongqin/AuditHoundV2/cases/SBRToken/manifest.json:5:  \"fork_block_number\": 21991721,\n../../../SBRToken/manifest.json:4:  \"chain\": \"mainnet\",\n../../../SBRToken/manifest.json:5:  \"fork_block_number\": 21991721,\n/Users/zhanglongqin/AuditHoundV2/cases/xcarnival/src/onchain_auto/src/FlawVerifier.sol:225:        // On the stripped implementation fork there is no live xToken cash market wired in,\n/Users/zhanglongqin/AuditHoundV2/cases/xcarnival/src/onchain_auto/src/FlawVerifier.sol:331:        // Preferred route for this attempt: if this fork still has public ETH/WETH liquidity already\n/Users/zhanglongqin/AuditHoundV2/cases/xcarnival/src/onchain_auto/src/FlawVerifier.sol:356:        // This fork exposes only the uninitialized implementation, not the live controller/xToken cash pool.\n../../../xcarnival/src/onchain_auto/src/FlawVerifier.sol:225:        // On the stripped implementation fork there is no live xToken cash market wired in,\n../../../xcarnival/src/onchain_auto/src/FlawVerifier.sol:331:        // Preferred route for this attempt: if this fork still has public ETH/WETH liquidity already\n../../../xcarnival/src/onchain_auto/src/FlawVerifier