        }

        if (_attemptBalancerRedeemPath()) {
            return;
        }

        if (_attemptBalancerBorrowPath()) {
            return;
        }

        if (bytes(lastFailure).length == 0) {
            _setFailure("NO_PATH_SUCCEEDED");
        }
    }

