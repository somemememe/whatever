    bytes4 private constant ENTER_MARKETS_BAO_SELECTOR = bytes4(keccak256("enterMarkets(address[],address)"));
    bytes4 private constant ENTER_MARKETS_STANDARD_SELECTOR = bytes4(keccak256("enterMarkets(address[])"));

