        }

        _profitToken = chosenVictimUnderlying;
        _profitAmount = currentBalance - baselineVictimBalance;
        exploitPathUsed = label;
        hypothesisValidated = true;
        activePath = PathMode.None;
        activeFunding = FundingMode.None;
        return true;
    }

