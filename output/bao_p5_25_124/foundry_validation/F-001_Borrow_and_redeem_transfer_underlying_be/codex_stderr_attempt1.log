                uint256 cash = _safeGetCash(market);
                if (cash == 0) {
                    continue;
                }

                uint256 priorBalance = underlying_ == targetUnderlying
                    ? callbackTargetUnderlyingBalance
                    : _safeBalanceOf(underlying_, address(this));

                for (uint256 j = 0; j < denominators.length; ++j) {
