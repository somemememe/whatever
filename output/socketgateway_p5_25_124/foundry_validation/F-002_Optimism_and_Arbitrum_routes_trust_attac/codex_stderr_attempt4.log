            metadata: bytes32("OPSTACK"),
            receiverAddress: address(this),
            toChainId: 10,
            bridgeHash: keccak256("malicious-opstack"),
            customBridgeAddress: address(maliciousBridge),
            token: token,
            l2Gas: 0,
            l2Token: token,
            data: bytes("")
