            uint64(uint32(bytes4(msg.data[60:64]))), // toChainId
            uint64(uint32(bytes4(msg.data[64:68]))), // nonce
            uint32(bytes4(msg.data[68:72])) // max slippage
        );

        emit SocketBridge(
