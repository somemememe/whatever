   200	    function extractDeloopFromSwapData(bytes[] memory _swapData) private pure returns (address[] memory, uint256[] memory, uint256[] memory, address[] memory, uint256[] memory) {
   201	        uint256 length = _swapData.length;
   202	        
   203	        address[] memory debtTokens = new address[](length);
   204	        uint256[] memory debtAmounts = new uint256[](length);
   205	        uint256[] memory debtRateMode = new uint256[](length);
   206	        address[] memory collateralTokens = new address[](length);
   207	        uint256[] memory collateralAmounts = new uint256[](length);
   208	        
   209	        uint256 actualAdded = 0;
   210	
   211	        FlashloanVars memory flashloanVars;
   212	        for (uint i = 0; i < _swapData.length;) {
   213	            (flashloanVars.srcToken, flashloanVars.destToken, flashloanVars.srcAmount, flashloanVars.destAmount,,,) = _getParaswapData(_swapData[i]);
   214	            debtTokens[actualAdded] = flashloanVars.destToken;
   215	            debtAmounts[actualAdded] = flashloanVars.destAmount - (flashloanVars.destAmount / 1000); // Request 1 extra wei to ensure full repayment
   216	            debtRateMode[actualAdded] = DoughCore.FLASHLOAN_RATE_MODE;
   217	            collateralTokens[actualAdded] = flashloanVars.srcToken;
   218	            collateralAmounts[actualAdded] = flashloanVars.srcAmount; // add 10% buffer for slippage
   219	            actualAdded++;
   220	            unchecked { i++; }
   221	        }
   222	
   223	        // Resize arrays to actual size
   224	        assembly {
   225	            mstore(debtTokens, actualAdded)
   226	            mstore(debtAmounts, actualAdded)
   227	            mstore(debtRateMode, actualAdded)
   228	            mstore(collateralTokens, actualAdded)
   229	            mstore(collateralAmounts, actualAdded)
   230	        }
   231	
   232	        return (debtTokens, debtAmounts, debtRateMode, collateralTokens, collateralAmounts);
   233	    }
