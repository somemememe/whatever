   235	    function repayWithCollateral(uint256 length, address[] memory whitelistedTokenList) private {
   236	        for (uint256 i = 0; i < length;) {
   237	            address tokenAddress = whitelistedTokenList[i];
   238	            (uint256 currentATokenBalance, , uint256 currentVariableDebt, , , , , ,) = DoughCore._I_AAVE_V3_DATA_PROVIDER.getUserReserveData(tokenAddress, address(this));
   239	
   240	            if (currentATokenBalance > 0) {
