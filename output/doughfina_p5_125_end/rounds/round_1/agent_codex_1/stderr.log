   347	    function repayAllDebtAssetsWithFlashLoan(bool opt, address dsaAddress, address[] memory assets, uint256[] memory amounts) private {
   348	        for (uint i = 0; i < assets.length;) {
   349	            IERC20(assets[i]).safeIncreaseAllowance(dsaAddress, amounts[i]);
