   283	    function repayFlashloansAndTransferToTreasury(bool opt, address _dsaAddress, address[] memory assets, uint256[] memory amounts, uint256[] memory premiums) private {
   284	        address[] memory whitelistedTokenList = IDoughIndex(doughIndex).getWhitelistedTokenList();
   285	        address treasury = IDoughIndex(doughIndex).treasury();
   286	
   287	        for (uint i = 0; i < whitelistedTokenList.length; i++) {
   288	            address token = whitelistedTokenList[i];
   289	            uint256 balance = IERC20(token).balanceOf(address(this));
   290	
   291	            if (balance > 0) {
   292	                // Initialize the transfer amount to the full balance
   293	                uint256 transferAmount = balance;
   294	
   295	                // Look through the assets to check if this token was involved in a flash loan
   296	                for (uint j = 0; j < assets.length; j++) {
   297	                    if (token == assets[j]) {
   298	                        uint256 repaymentTotal = amounts[j] + premiums[j];
   299	                        if (balance >= repaymentTotal) {
   300	                            transferAmount = balance - repaymentTotal;
   301	                        }
   302	                        IERC20(token).safeIncreaseAllowance(address(POOL), repaymentTotal);
   303	                        break;  // Break once the token is found in the assets array
   304	                    }
   305	                }
   306	
   307	                // Perform the transfer if there is any amount to transfer
   308	                if (transferAmount > 0) {
   309	                    if(opt) {
   310	                        // Transfer to treasury
   311	                        IERC20(token).safeTransfer(treasury, transferAmount);
   312	                    } else {
   313	                        // Supply to AaveV3
   314	                        IERC20(token).safeIncreaseAllowance(DoughCore.AAVE_V3_POOL_ADDRESS, transferAmount);
   315	                        DoughCore._I_AAVE_V3_POOL.supply(token, transferAmount, _dsaAddress, 0);
   316	                    }
   317	                }
   318	            }
   319	        }
   320	    }
