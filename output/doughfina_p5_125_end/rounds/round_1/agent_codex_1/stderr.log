   380	    * @param _asset The address of the ETH/ERC20 token
   381	    * @param _treasury The address of the treasury
   382	    * @param _amount The amount of ETH/ERC20 token to withdraw
   383	    */
   384	    function withdrawToken(address _asset, address _treasury, uint256 _amount) external {
   385	        if (msg.sender != IDoughIndex(doughIndex).multisig()) revert CustomError("not multisig of doughIndex");
   386	        if (_treasury == address(0)) revert CustomError("invalid _treasury");
   387	        if (_amount == 0) revert CustomError("must be greater than zero");
   388	        if (_asset == DoughCore.ETH) {
   389	            payable(_treasury).transfer(_amount);
   390	        } else {
   391	            uint256 balanceOfToken = IERC20(_asset).balanceOf(address(this));
   392	            uint256 transferAmount = _amount;
   393	            if (_amount > balanceOfToken) {
   394	                transferAmount = balanceOfToken;
   395	            }
   396	            IERC20(_asset).safeTransfer(_treasury, transferAmount);
   397	        }
   398	    }
