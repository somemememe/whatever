\n27: \n28:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n29:     using Liquidity for Liquidity.Data;\n30:     using Point for mapping(int24 =>Point.Data);\n31:     using Point for Point.Data;\n32:     using PointBitmap for mapping(int16 =>uint256);\n33:     using LimitOrder for LimitOrder.Data;\n34:     using UserEarn for UserEarn.Data;\n35:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n36:     using Oracle for Oracle.Observation[65535];\n37:     using OrderOrEndpoint for mapping(int24 =>int24);\n38: \n39:     int24 internal constant LEFT_MOST_PT = -800000;\n40:     int24 internal constant RIGHT_MOST_PT = 800000;\n41: \n42:     /// @notice left most point regularized by pointDelta\n43:     int24 public leftMostPt;\n44:     /// @notice right most point regularized by pointDelta\n45:     int24 public rightMostPt;\n46:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n47:     uint128 public maxLiquidPt;\n48: \n49:     /// @notice address of iZiSwapFactory\n50:     address public factory;\n51: \n52:     /// @notice address of tokenX\n53:     address public tokenX;\n54:     /// @notice address of tokenY\n55:     address public tokenY;\n56:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n57:     uint24 public fee;\n58: \n59:     /// @notice minimum number of distance between initialized or limitorder points \n60:     int24 public pointDelta;\n61: \n62:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n63:     uint256 public feeScaleX_128;\n64:     /// @notice the fee growth as a 128-bit fixpoint fees of tokenY collected per 1 liquidity of the pool\n65:     uint256 public feeScaleY_128;\n66: \n67:     /// @notice sqrt(1.0001), 96 bit fixpoint number\n68:     uint160 public override sqrtRate_96;\n69: \n70:     /// @notice state of pool, see library State or IiZiSwapPool#state for more infomation\n71:     State public override state;\n72: \n73:     /// @notice the information about a liquidity by the liquidity's key\n74:     mapping(bytes32 =>Liquidity.Data) public override liquidity;\n75: \n76:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n77:     mapping(int16 =>uint256) public override pointBitmap;\n78: \n79:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n80:     mapping(int24 =>Point.Data) public override points;\n81:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n82:     mapping(int24 =>int24) public override orderOrEndpoint;\n83:     /// @notice limitOrder info on a given point\n84:     mapping(int24 =>LimitOrder.Data) public override limitOrderData;\n85:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n86:     mapping(bytes32 => UserEarn.Data) public override userEarnX;\n87:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n88:     mapping(bytes32 => UserEarn.Data) public override userEarnY;\n89: \n90:     /// @notice observation data array\n91:     Oracle.Observation[65535] public override observations;\n92: \n93:     uint256 public override totalFeeXCharged;\n94:     uint256 public override totalFeeYCharged;\n95: \n96:     address private original;\n97: \n98:     address private swapModuleX2Y;\n99:     address private swapModuleY2X;\n100:     address private liquidityModule;\n101:     address private limitOrderModule;\n102:     address private flashModule;\n103: \n104:     /// @notice percent to charge from miner's fee\n105:     uint24 public override feeChargePercent;\n106: \n107:     modifier lock() {\n108:         require(!state.locked, 'LKD');\n109:         state.locked = true;\n110:         _;\n111:         state.locked = false;\n112:     }\n113: \n114:     modifier noDelegateCall() {\n115:         require(address(this) == original);\n116:         _;\n117:     }\n118: \n119:     function _setRange(int24 pd) private {\n120:         rightMostPt = RIGHT_MOST_PT / pd * pd;\n121:         leftMostPt = - rightMostPt;\n122:         uint24 pointNum = uint24((rightMostPt - leftMostPt) / pd) + 1;\n123:         maxLiquidPt = type(uint128).max / pointNum;\n124:     }\n125: \n126:     /// @notice Construct a pool\n127:     constructor() {\n128:         (address _tokenX, address _tokenY, uint24 _fee, int24 currentPoint, int24 _pointDelta, uint24 _feeChargePercent) = IiZiSwapFactory(msg.sender).deployPoolParams();\n129:         require(_tokenX < _tokenY, 'x<y');\n130:         require(_pointDelta > 0, 'pd0');\n131:         original = address(this);\n132:         factory = msg.sender;\n133:         swapModuleX2Y = IiZiSwapFactory(msg.sender).swapX2YModule();\n134:         swapModuleY2X = IiZiSwapFactory(msg.sender).swapY2XModule();\n135:         liquidityModule = IiZiSwapFactory(msg.sender).liquidityModule();\n136:         limitOrderModule = IiZiSwapFactory(msg.sender).limitOrderModule();\n137:         flashModule = IiZiSwapFactory(msg.sender).flashModule();\n138: \n139:         tokenX = _tokenX;\n140:         tokenY = _tokenY;\n141:         fee = _fee;\n142:         pointDelta = _pointDelta;\n143:         _setRange(_pointDelta);\n144: \n145:         require(currentPoint >= leftMostPt, \"LO\");\n146:         require(currentPoint <= rightMostPt, \"HO\");\n147: \n148:         // current state\n149:         state.currentPoint = currentPoint;\n150:         state.sqrtPrice_96 = LogPowMath.getSqrtPrice(currentPoint);\n151:         state.liquidity = 0;\n152:         state.liquidityX = 0;\n153: \n154:         sqrtRate_96 = LogPowMath.getSqrtPrice(1);\n155: \n156:         (state.observationQueueLen, state.observationNextQueueLen) = observations.init(uint32(block.timestamp));\n157:         state.observationCurrentIndex = 0;\n158:         feeChargePercent = _feeChargePercent;\n159:     }\n160: \n161:     function balanceX() private view returns (uint256) {\n162:         (bool success, bytes memory data) =\n163:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n164:         require(success && data.length >= 32);\n165:         return abi.decode(data, (uint256));\n166:     }\n167: \n168:     function balanceY() private view returns (uint256) {\n169:         (bool success, bytes memory data) =\n170:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n171:         require(success && data.length >= 32);\n172:         return abi.decode(data, (uint256));\n173:     }\n174: \n175:     function revertDCData(bytes memory data) private pure {\n176:         if (data.length != 64) {\n177:             if (data.length < 68) revert('dc');\n178:             assembly {\n179:                 data := add(data, 0x04)\n180:             }\n181:             revert(abi.decode(data, (string)));\n182:         }\n183:         assembly {\n184:             data:= add(data, 0x20)\n185:             let w := mload(data)\n186:             let t := mload(0x40)\n187:             mstore(t, w)\n188:             let w2 := mload(add(data, 0x20))\n189:             mstore(add(t, 0x20), w2)\n190:             revert(t, 64)\n191:         }\n192:     }\n193: \n194:     /// @inheritdoc IiZiSwapPool\n195:     function assignLimOrderEarnY(\n196:         int24 point,\n197:         uint128 assignY,\n198:         bool fromLegacy\n199:     ) external override noDelegateCall lock returns (uint128 actualAssignY) {\n200:         \n201:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n202:             abi.encodeWithSignature(\"assignLimOrderEarnY(int24,uint128,bool)\", point, assignY, fromLegacy)\n203:         );\n204:         if (success) {\n205:             actualAssignY = abi.decode(d, (uint128));\n206:         } else {\n207:             revertDCData(d);\n208:         }\n209:     }\n210: \n211:     /// @inheritdoc IiZiSwapPool\n212:     function assignLimOrderEarnX(\n213:         int24 point,\n214:         uint128 assignX,\n215:         bool fromLegacy\n216:     ) external override noDelegateCall lock returns (uint128 actualAssignX) {\n217:         \n218:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n219:             abi.encodeWithSignature(\"assignLimOrderEarnX(int24,uint128,bool)\", point, assignX, fromLegacy)\n220:         );\n221:         if (success) {\n222:             actualAssignX = abi.decode(d, (uint128));\n223:         } else {\n224:             revertDCData(d);\n225:         }\n226:     }\n227: \n228:     /// @inheritdoc IiZiSwapPool\n229:     function decLimOrderWithX(\n230:         int24 point,\n231:         uint128 deltaX\n232:     ) external override noDelegateCall lock returns (uint128 actualDeltaX, uint256 legacyAccEarn) {\n233:         \n234:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n235:             abi.encodeWithSignature(\"decLimOrderWithX(int24,uint128)\", point, deltaX)\n236:         );\n237:         if (success) {\n238:             uint128 claimSold;\n239:             uint128 claimEarn;\n240:             (actualDeltaX, legacyAccEarn, claimSold, claimEarn) = abi.decode(d, (uint128, uint256, uint128, uint128));\n241:             emit DecLimitOrder(msg.sender, actualDeltaX, point, claimSold, claimEarn, true);\n242:         } else {\n243:             revertDCData(d);\n244:         }\n245: \n246:     }\n247: \n248:     /// @inheritdoc IiZiSwapPool\n249:     function decLimOrderWithY(\n250:         int24 point,\n251:         uint128 deltaY\n252:     ) external override noDelegateCall lock returns (uint128 actualDeltaY, uint256 legacyAccEarn) {\n253:         \n254:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n255:             abi.encodeWithSignature(\"decLimOrderWithY(int24,uint128)\", point, deltaY)\n256:         );\n257:         if (success) {\n258:             uint128 claimSold;\n259:             uint128 claimEarn;\n260:             (actualDeltaY, legacyAccEarn, claimSold, claimEarn) = abi.decode(d, (uint128, uint256, uint128, uint128));\n261:             emit DecLimitOrder(msg.sender, actualDeltaY, point, claimSold, claimEarn, false);\n262:         } else {\n263:             revertDCData(d);\n264:         }\n265:         \n266:     }\n267: \n268:     /// @inheritdoc IiZiSwapPool\n269:     function addLimOrderWithX(\n270:         address recipient,\n271:         int24 point,\n272:         uint128 amountX,\n273:         bytes calldata data\n274:     ) external override noDelegateCall lock returns (uint128 orderX, uint128 acquireY) {\n275:         \n276:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n277:             abi.encodeWithSignature(\"addLimOrderWithX(address,int24,uint128,bytes)\", recipient, point, amountX, data)\n278:         );\n279:         if (success) {\n280:             uint128 claimSold;\n281:             uint128 claimEarn;\n282:             (orderX, acquireY, claimSold, claimEarn) = abi.decode(d, (uint128, uint128, uint128, uint128));\n283:             emit AddLimitOrder(recipient, orderX, acquireY, point, claimSold, claimEarn, true);\n284:         } else {\n285:             revertDCData(d);\n286:         }\n287:         \n288:     }\n289:     \n290:     /// @inheritdoc IiZiSwapPool\n291:     function addLimOrderWithY(\n292:         address recipient,\n293:         int24 point,\n294:         uint128 amountY,\n295:         bytes calldata data\n296:     ) external override noDelegateCall lock returns (uint128 orderY, uint128 acquireX) {\n297:         \n298:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n299:             abi.encodeWithSignature(\"addLimOrderWithY(address,int24,uint128,bytes)\", recipient, point, amountY, data)\n300:         );\n301:         if (success) {\n302:             uint128 claimSold;\n303:             uint128 claimEarn;\n304:             (orderY, acquireX, claimSold, claimEarn) = abi.decode(d, (uint128, uint128, uint128, uint128));\n305:             emit AddLimitOrder(recipient, orderY, acquireX, point, claimSold, claimEarn, false);\n306:         } else {\n307:             revertDCData(d);\n308:         }\n309:         \n310:     }\n311: \n312:     /// @inheritdoc IiZiSwapPool\n313:     function collectLimOrder(\n314:         address recipient, int24 point, uint128 collectDec, uint128 collectEarn, bool isEarnY\n315:     ) external override noDelegateCall lock returns(uint128 actualCollectDec, uint128 actualCollectEarn) {\n316:         (bool success, bytes memory d) = limitOrderModule.delegatecall(\n317:             abi.encodeWithSignature(\"collectLimOrder(address,int24,uint128,uint128,bool)\", recipient, point, collectDec, collectEarn, isEarnY)\n318:         );\n319:         if (success) {\n320:             (actualCollectDec, actualCollectEarn) = abi.decode(d, (uint128, uint128));\n321:             emit CollectLimitOrder(msg.sender, recipient, point, actualCollectDec, actualCollectEarn, isEarnY);\n322:         } else {\n323:             revertDCData(d);\n324:         }\n325:     }\n326:     \n327:     /// @inheritdoc IiZiSwapPool\n328:     function mint(\n329:         address recipient,\n330:         int24 leftPt,\n331:         int24 rightPt,\n332:         uint128 liquidDelta,\n333:         bytes calldata data\n334:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n335:         (bool success, bytes memory d) = liquidityModule.delegatecall(\n336:             abi.encodeWithSignature(\"mint(address,int24,int24,uint128,bytes)\", recipient, leftPt, rightPt,liquidDelta,data)\n337:         );\n338:         if (success) {\n339:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n340:             emit Mint(msg.sender, recipient, leftPt, rightPt, liquidDelta, amountX, amountY);\n341:         } else {\n342:             revertDCData(d);\n343:         }\n344:     }\n345: \n346:     /// @inheritdoc IiZiSwapPool\n347:     function burn(\n348:         int24 leftPt,\n349:         int24 rightPt,\n350:         uint128 liquidDelta\n351:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n352:         (bool success, bytes memory d) = liquidityModule.delegatecall(\n353:             abi.encodeWithSignature(\"burn(int24,int24,uint128)\", leftPt, rightPt, liquidDelta)\n354:         );\n355:         if (success) {\n356:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n357:             emit Burn(msg.sender, leftPt, rightPt, liquidDelta, amountX, amountY);\n358:         } else {\n359:             revertDCData(d);\n360:         }\n361:     }\n362: \n363:     /// @inheritdoc IiZiSwapPool\n364:     function collect(\n365:         address recipient,\n366:         int24 leftPt,\n367:         int24 rightPt,\n368:         uint256 amountXLim,\n369:         uint256 amountYLim\n370:     ) external override noDelegateCall lock returns (uint256 actualAmountX, uint256 actualAmountY) {\n371:         (bool success, bytes memory d) = liquidityModule.delegatecall(\n372:             abi.encodeWithSignature(\"collect(address,int24,int24,uint256,uint256)\", recipient, leftPt, rightPt, amountXLim, amountYLim)\n373:         );\n374:         if (success) {\n375:             (actualAmountX, actualAmountY) = abi.decode(d, (uint256, uint256));\n376:             emit CollectLiquidity(msg.sender, recipient, leftPt, rightPt, actualAmountX, actualAmountY);\n377:         } else {\n378:             revertDCData(d);\n379:         }\n380:     }\n381: \n382:     /// @inheritdoc IiZiSwapPool\n383:     function swapY2X(\n384:         address recipient,\n385:         uint128 amount,\n386:         int24 highPt,\n387:         bytes calldata data\n388:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n389:         (bool success, bytes memory d) = swapModuleY2X.delegatecall(\n390:             abi.encodeWithSignature(\"swapY2X(address,uint128,int24,bytes)\", \n391:             recipient, amount, highPt, data)\n392:         );\n393:         if (success) {\n394:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n395:             emit Swap(tokenX, tokenY, fee, false, amountX, amountY, state.currentPoint);\n396:         } else {\n397:             revertDCData(d);\n398:         }\n399:     }\n400: \n401:     /// @inheritdoc IiZiSwapPool\n402:     function swapY2XDesireX(\n403:         address recipient,\n404:         uint128 desireX,\n405:         int24 highPt,\n406:         bytes calldata data\n407:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n408:         (bool success, bytes memory d) = swapModuleY2X.delegatecall(\n409:             abi.encodeWithSignature(\"swapY2XDesireX(address,uint128,int24,bytes)\", \n410:             recipient, desireX, highPt, data)\n411:         );\n412:         if (success) {\n413:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n414:             emit Swap(tokenX, tokenY, fee, false, amountX, amountY, state.currentPoint);\n415:         } else {\n416:             revertDCData(d);\n417:         }\n418:     }\n419: \n420:     /// @inheritdoc IiZiSwapPool\n421:     function swapX2Y(\n422:         address recipient,\n423:         uint128 amount,\n424:         int24 lowPt,\n425:         bytes calldata data\n426:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n427:         (bool success, bytes memory d) = swapModuleX2Y.delegatecall(\n428:             abi.encodeWithSignature(\"swapX2Y(address,uint128,int24,bytes)\", \n429:             recipient, amount, lowPt, data)\n430:         );\n431:         if (success) {\n432:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n433:             emit Swap(tokenX, tokenY, fee, true, amountX, amountY, state.currentPoint);\n434:         } else {\n435:             revertDCData(d);\n436:         }\n437:     }\n438: \n439:     /// @inheritdoc IiZiSwapPool\n440:     function swapX2YDesireY(\n441:         address recipient,\n442:         uint128 desireY,\n443:         int24 lowPt,\n444:         bytes calldata data\n445:     ) external override noDelegateCall lock returns (uint256 amountX, uint256 amountY) {\n446:         (bool success, bytes memory d) = swapModuleX2Y.delegatecall(\n447:             abi.encodeWithSignature(\"swapX2YDesireY(address,uint128,int24,bytes)\", recipient, desireY, lowPt,data)\n448:         );\n449:         if (success) {\n450:             (amountX, amountY) = abi.decode(d, (uint256, uint256));\n451:             emit Swap(tokenX, tokenY, fee, true, amountX, amountY, state.currentPoint);\n452:         } else {\n453:             revertDCData(d);\n454:         }\n455:     }\n456: \n457:     /// @inheritdoc IiZiSwapPool\n458:     function observe(uint32[] calldata secondsAgos)\n459:         external\n460:         view\n461:         override\n462:         noDelegateCall\n463:         returns (int56[] memory accPoints)\n464:     {\n465:         return\n466:             observations.observe(\n467:                 uint32(block.timestamp),\n468:                 secondsAgos,\n469:                 state.currentPoint,\n470:                 state.observationCurrentIndex,\n471:                 state.observationQueueLen\n472:             );\n473:     }\n474: \n475:     /// @inheritdoc IiZiSwapPool\n476:     function expandObservationQueue(uint16 newNextQueueLen) external override noDelegateCall lock {\n477:         uint16 oldNextQueueLen = state.observationNextQueueLen;\n478:         if (newNextQueueLen > oldNextQueueLen) {\n479:             observations.expand(oldNextQueueLen, newNextQueueLen);\n480:             state.observationNextQueueLen = newNextQueueLen;\n481:         }\n482:     }\n483: \n484:     /// @inheritdoc IiZiSwapPool\n485:     function liquiditySnapshot(int24 leftPoint, int24 rightPoint) external override view returns(int128[] memory deltaLiquidities) {\n486:         require(leftPoint < rightPoint, \"L<R\");\n487:         require(leftPoint >= leftMostPt, \"LO\");\n488:         require(rightPoint <= rightMostPt, \"RO\");\n489:         require(leftPoint % pointDelta == 0, \"LD0\");\n490:         require(rightPoint % pointDelta == 0, \"RD0\");\n491:         uint256 len = uint256(int256((rightPoint - leftPoint) / pointDelta));\n492:         deltaLiquidities = new int128[](len);\n493:         uint256 idx = 0;\n494:         for (int24 i = leftPoint; i < rightPoint; i += pointDelta) {\n495:             deltaLiquidities[idx] = points[i].liquidDelta;\n496:             idx ++;\n497:         }\n498:     }\n499: \n500:     /// @inheritdoc IiZiSwapPool\n501:     function limitOrderSnapshot(int24 leftPoint, int24 rightPoint) external override view returns(LimitOrderStruct[] memory limitOrders) {\n502:         require(leftPoint < rightPoint, \"L<R\");\n503:         require(leftPoint >= leftMostPt, \"LO\");\n504:         require(rightPoint <= rightMostPt, \"RO\");\n505:         require(leftPoint % pointDelta == 0, \"LD0\");\n506:         require(rightPoint % pointDelta == 0, \"RD0\");\n507:         uint256 len = uint256(int256((rightPoint - leftPoint) / pointDelta));\n508:         limitOrders = new LimitOrderStruct[](len);\n509:         uint256 idx = 0;\n510:         for (int24 i = leftPoint; i < rightPoint; i += pointDelta) {\n511:             limitOrders[idx] = LimitOrderStruct({\n512:                 sellingX: limitOrderData[i].sellingX,\n513:                 earnY: limitOrderData[i].earnY,\n514:                 accEarnY: limitOrderData[i].accEarnY,\n515:                 sellingY: limitOrderData[i].sellingY,\n516:                 earnX: limitOrderData[i].earnX,\n517:                 accEarnX: limitOrderData[i].accEarnX\n518:             });\n519:             idx ++;\n520:         }\n521:     }\n522: \n523:     /// @inheritdoc IiZiSwapPool\n524:     function collectFeeCharged() external override noDelegateCall lock {\n525:         require(msg.sender == IiZiSwapFactory(factory).chargeReceiver(), \"NR\");\n526:         TokenTransfer.transferToken(tokenX, msg.sender, totalFeeXCharged);\n527:         TokenTransfer.transferToken(tokenY, msg.sender, totalFeeYCharged);\n528:         totalFeeXCharged = 0;\n529:         totalFeeYCharged = 0;\n530:     }\n531: \n532:     /// @inheritdoc IiZiSwapPool\n533:     function modifyFeeChargePercent(uint24 newFeeChargePercent) external override noDelegateCall lock {\n534:         require(msg.sender == IOwnable(factory).owner(), \"NON\");\n535:         require(newFeeChargePercent >= 0, \"FP0\");\n536:         require(newFeeChargePercent <= 100, \"FP0\");\n537:         feeChargePercent = newFeeChargePercent;\n538:     }\n539: \n540:     /// @inheritdoc IiZiSwapPool\n541:     function flash(\n542:         address recipient,\n543:         uint256 amountX,\n544:         uint256 amountY,\n545:         bytes calldata data\n546:     ) external override noDelegateCall lock {\n547:         (bool success, bytes memory d) = flashModule.delegatecall(\n548:             abi.encodeWithSignature(\"flash(address,uint256,uint256,bytes)\", \n549:             recipient, amountX, amountY, data)\n550:         );\n551:         if (success) {\n552:             (uint256 actualAmountX, uint256 actualAmountY, uint256 paidX, uint256 paidY) = abi.decode(d, (uint256, uint256, uint256, uint256));\n553:             emit Flash(msg.sender, recipient, actualAmountX, actualAmountY, paidX, paidY);\n554:         } else {\n555:             revertDCData(d);\n556:         }\n557:     }\n558:     \n559: }\n\n(End of file - total 559 lines)\n</content>"},{"type":"tool_result","tool_use_id":"call_function_taep2vvbj6iq_2","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/iZiSwapFactory.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapFactory.sol\";\n5: import \"./iZiSwapPool.sol\";\n6: \n7: import \"@openzeppelin/contracts/access/Ownable.sol\";\n8: \n9: struct DeployPoolParams {\n10:     address tokenX;\n11:     address tokenY;\n12:     uint24 fee;\n13:     int24 currentPoint;\n14:     int24 pointDelta;\n15:     uint24 feeChargePercent;\n16: }\n17: \n18: contract iZiSwapFactory is Ownable, IiZiSwapFactory {\n19: \n20:     /// @notice charge receiver of all pools in this factory\n21:     address public override chargeReceiver;\n22: \n23:     /// @notice tokenX/tokenY/fee => pool address\n24:     mapping(address => mapping(address => mapping(uint24 => address))) public override pool;\n25: \n26:     /// @notice mapping from fee amount to pointDelta\n27:     mapping(uint24 => int24) public override fee2pointDelta;\n28: \n29:     /// @notice mark contract address in constructor to avoid delegate call\n30:     address public only_addr_;\n31: \n32:     /// @notice address of module to support swapX2Y(DesireY)\n33:     address public override swapX2YModule;\n34: \n35:     /// @notice address of module to support swapY2X(DesireX)\n36:     address public override swapY2XModule;\n37: \n38:     /// @notice address of module to support liquidity\n39:     address public override liquidityModule;\n40: \n41:     /// @notice address of module for user to manage limit orders\n42:     address public override limitOrderModule;\n43: \n44:     /// @notice address of module to support flash loan\n45:     address public override flashModule;\n46: \n47:     /// @notice default fee rate from miner's fee gain * 100\n48:     uint24 public override defaultFeeChargePercent;\n49: \n50:     DeployPoolParams public override deployPoolParams;\n51: \n52:     /// @notice Construct the factory\n53:     /// @param _swapX2YModule swap module to support swapX2Y(DesireY)\n54:     /// @param _swapY2XModule swap module to support swapY2X(DesireX)\n55:     /// @param _liquidityModule liquidity module to support mint/burn/collect\n56:     /// @param _limitOrderModule module for user to manage limit orders\n57:     /// @param _flashModule module for user to flash\n58:     /// @param _defaultFeeChargePercent default fee rate from miner's fee gain * 100\n59:     constructor(\n60:         address _chargeReceiver, \n61:         address _swapX2YModule, \n62:         address _swapY2XModule, \n63:         address _liquidityModule, \n64:         address _limitOrderModule, \n65:         address _flashModule,\n66:         uint24 _defaultFeeChargePercent\n67:     ) {\n68:         only_addr_ = address(this);\n69:         fee2pointDelta[100] = 1;\n70:         fee2pointDelta[400] = 8;\n71:         fee2pointDelta[2000] = 40;\n72:         fee2pointDelta[10000] = 200;\n73:         swapX2YModule = _swapX2YModule;\n74:         swapY2XModule = _swapY2XModule;\n75:         liquidityModule = _liquidityModule;\n76:         chargeReceiver = _chargeReceiver;\n77:         limitOrderModule = _limitOrderModule;\n78:         flashModule = _flashModule;\n79:         defaultFeeChargePercent = _defaultFeeChargePercent;\n80:     }\n81: \n82:     modifier noDelegateCall() {\n83:         require(address(this) == only_addr_);\n84:         _;\n85:     }\n86: \n87:     /// @inheritdoc IiZiSwapFactory\n88:     function enableFeeAmount(uint24 fee, uint24 pointDelta) external override noDelegateCall onlyOwner {\n89:         require(pointDelta > 0, \"P0\");\n90:         require(fee2pointDelta[fee] == 0, \"FD0\");\n91:         fee2pointDelta[fee] = int24(pointDelta);\n92:     }\n93: \n94:     /// @inheritdoc IiZiSwapFactory\n95:     function newPool(\n96:         address tokenX,\n97:         address tokenY,\n98:         uint24 fee,\n99:         int24 currentPoint\n100:     ) external override noDelegateCall returns (address addr) {\n101:         require(tokenX != tokenY, \"SmTK\");\n102:         if (tokenX > tokenY) {\n103:             (tokenX, tokenY) = (tokenY, tokenX);\n104:         }\n105:         require(pool[tokenX][tokenY][fee] == address(0));\n106:         int24 pointDelta = fee2pointDelta[fee];\n107: \n108:         require(pointDelta > 0, 'pd');\n109:         // now creating\n110:         bytes32 salt = keccak256(abi.encode(tokenX, tokenY, fee));\n111:         \n112:         deployPoolParams = DeployPoolParams({\n113:             tokenX: tokenX,\n114:             tokenY: tokenY,\n115:             fee: fee,\n116:             currentPoint: currentPoint,\n117:             pointDelta: pointDelta,\n118:             feeChargePercent: defaultFeeChargePercent\n119:         });\n120:         addr = address(new iZiSwapPool{salt: salt}());\n121:         delete deployPoolParams;\n122: \n123:         pool[tokenX][tokenY][fee] = addr;\n124:         pool[tokenY][tokenX][fee] = addr;\n125:         emit NewPool(tokenX, tokenY, fee, uint24(pointDelta), addr);\n126:     }\n127: \n128:     /// @inheritdoc IiZiSwapFactory\n129:     function modifyChargeReceiver(address _chargeReceiver) external override onlyOwner {\n130:         chargeReceiver = _chargeReceiver;\n131:     }\n132: \n133:     /// @inheritdoc IiZiSwapFactory\n134:     function modifyDefaultFeeChargePercent(uint24 _defaultFeeChargePercent) external override onlyOwner {\n135:         defaultFeeChargePercent = _defaultFeeChargePercent;\n136:     }\n137:     \n138: }\n\n(End of file - total 138 lines)\n</content>"},{"type":"tool_result","tool_use_id":"call_function_taep2vvbj6iq_3","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/flash.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapPool.sol\";\n5: import \"./interfaces/IiZiSwapFlashCallback.sol\";\n6: import \"./interfaces/IiZiSwapCallback.sol\";\n7: \n8: import \"./libraries/Liquidity.sol\";\n9: import \"./libraries/Point.sol\";\n10: import \"./libraries/PointBitmap.sol\";\n11: import \"./libraries/LogPowMath.sol\";\n12: import \"./libraries/MulDivMath.sol\";\n13: import \"./libraries/TwoPower.sol\";\n14: import \"./libraries/LimitOrder.sol\";\n15: import \"./libraries/SwapMathY2X.sol\";\n16: import \"./libraries/SwapMathX2Y.sol\";\n17: import \"./libraries/SwapMathY2XDesire.sol\";\n18: import \"./libraries/SwapMathX2YDesire.sol\";\n19: import \"./libraries/TokenTransfer.sol\";\n20: import \"./libraries/UserEarn.sol\";\n21: import \"./libraries/State.sol\";\n22: import \"./libraries/Oracle.sol\";\n23: import \"./libraries/OrderOrEndpoint.sol\";\n24: import \"./libraries/MaxMinMath.sol\";\n25: \n26: contract FlashModule {\n27: \n28:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n29:     using Liquidity for Liquidity.Data;\n30:     using Point for mapping(int24 =>Point.Data);\n31:     using Point for Point.Data;\n32:     using PointBitmap for mapping(int16 =>uint256);\n33:     using LimitOrder for LimitOrder.Data;\n34:     using UserEarn for UserEarn.Data;\n35:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n36:     using SwapMathY2X for SwapMathY2X.RangeRetState;\n37:     using SwapMathX2Y for SwapMathX2Y.RangeRetState;\n38:     using Oracle for Oracle.Observation[65535];\n39:     using OrderOrEndpoint for mapping(int24 =>int24);\n40: \n41:     int24 internal constant LEFT_MOST_PT = -800000;\n42:     int24 internal constant RIGHT_MOST_PT = 800000;\n43: \n44:     /// @notice left most point regularized by pointDelta\n45:     int24 public leftMostPt;\n46:     /// @notice right most point regularized by pointDelta\n47:     int24 public rightMostPt;\n48:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n49:     uint128 public maxLiquidPt;\n50: \n51:     /// @notice address of iZiSwapFactory\n52:     address public factory;\n53: \n54:     /// @notice address of tokenX\n55:     address public tokenX;\n56:     /// @notice address of tokenY\n57:     address public tokenY;\n58:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n59:     uint24 public fee;\n60: \n61:     /// @notice minimum number of distance between initialized or limitorder points \n62:     int24 public pointDelta;\n63: \n64:     /// @notice The fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n65:     uint256 public feeScaleX_128;\n66:     /// @notice The fee growth as a 128-bit fixpoing fees of tokenY collected per 1 liquidity of the pool\n67:     uint256 public feeScaleY_128;\n68: \n69:     uint160 sqrtRate_96;\n70: \n71:     /// @notice some values of pool\n72:     /// see library State or IiZiSwapPool#state for more infomation\n73:     State public state;\n74: \n75:     /// @notice the information about a liquidity by the liquidity's key\n76:     mapping(bytes32 =>Liquidity.Data) public liquidities;\n77: \n78:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n79:     mapping(int16 =>uint256) public pointBitmap;\n80: \n81:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n82:     mapping(int24 =>Point.Data) public points;\n83:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n84:     mapping(int24 =>int24) public orderOrEndpoint;\n85:     /// @notice limitOrder info on a given point\n86:     mapping(int24 =>LimitOrder.Data) public limitOrderData;\n87:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n88:     mapping(bytes32 => UserEarn.Data) public userEarnX;\n89:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n90:     mapping(bytes32 => UserEarn.Data) public userEarnY;\n91:     /// @notice observation data array\n92:     Oracle.Observation[65535] public observations;\n93: \n94:     uint256 public totalFeeXCharged;\n95:     uint256 public totalFeeYCharged;\n96: \n97:     address private original;\n98: \n99:     address private swapModuleX2Y;\n100:     address private swapModuleY2X;\n101:     address private liquidityModule;\n102:     address private limitOrderModule;\n103:     address private flashModule;\n104: \n105:     /// @notice percent to charge from miner's fee\n106:     uint24 public feeChargePercent;\n107: \n108:     function balanceX() private view returns (uint256) {\n109:         (bool success, bytes memory data) =\n110:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n111:         require(success && data.length >= 32);\n112:         return abi.decode(data, (uint256));\n113:     }\n114: \n115:     function balanceY() private view returns (uint256) {\n116:         (bool success, bytes memory data) =\n117:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n118:         require(success && data.length >= 32);\n119:         return abi.decode(data, (uint256));\n120:     }\n121: \n122: \n123:     /// Delegate call implementation for IiZiSwapPool#flash.\n124:     function flash(\n125:         address recipient,\n126:         uint256 amountX,\n127:         uint256 amountY,\n128:         bytes calldata data\n129:     ) external returns (uint256 actualAmountX, uint256 actualAmountY, uint256 paidX, uint256 paidY) {\n130:         uint128 currentLiquidity = state.liquidity;\n131:         require(currentLiquidity > 0, 'L');\n132: \n133:         // even the balance if not enough, the full fees are required to pay\n134:         uint256 feeX = MulDivMath.mulDivCeil(amountX, fee, 1e6);\n135:         uint256 feeY = MulDivMath.mulDivCeil(amountY, fee, 1e6);\n136:         uint256 balanceXBefore = balanceX();\n137:         uint256 balanceYBefore = balanceY();\n138: \n139:         actualAmountX = MaxMinMath.min256(amountX, balanceXBefore);\n140:         actualAmountY = MaxMinMath.min256(amountY, balanceYBefore);\n141: \n142:         if (actualAmountX > 0) TokenTransfer.transferToken(tokenX, recipient, actualAmountX);\n143:         if (actualAmountY > 0) TokenTransfer.transferToken(tokenY, recipient, actualAmountY);\n144: \n145:         IiZiSwapFlashCallback(msg.sender).flashCallback(feeX, feeY, data);\n146:         uint256 balanceXAfter = balanceX();\n147:         uint256 balanceYAfter = balanceY();\n148: \n149:         require(balanceXBefore + feeX <= balanceXAfter, 'FX');\n150:         require(balanceYBefore + feeY <= balanceYAfter, 'FY');\n151: \n152:         paidX = balanceXAfter - balanceXBefore;\n153:         paidY = balanceYAfter - balanceYBefore;\n154: \n155:         if (paidX > 0) {\n156:             uint256 chargedFeeAmount = paidX * feeChargePercent / 100;\n157:             totalFeeXCharged += chargedFeeAmount;\n158:             feeScaleX_128 = feeScaleX_128 + MulDivMath.mulDivFloor(paidX - chargedFeeAmount, TwoPower.Pow128, currentLiquidity);\n159:         }\n160:         if (paidY > 0) {\n161:             uint256 chargedFeeAmount = paidY * feeChargePercent / 100;\n162:             totalFeeYCharged += chargedFeeAmount;\n163:             feeScaleY_128 = feeScaleY_128 + MulDivMath.mulDivFloor(paidY - chargedFeeAmount, TwoPower.Pow128, currentLiquidity);\n164:         }\n165: \n166:     }\n167: }\n\n(End of file - total 167 lines)\n</content>"}]},{"role":"assistant","content":[{"type":"thinking","thinking":"The user wants me to find security vulnerabilities in the contracts listed in the task file. Let me read the remaining key files to look for vulnerabilities.\n\nLet me continue reading other important contracts.","signature":"d7d7b3a220ebed0bf7d3ec785a606f3e8580c93d61f28d894f789575cd423e70"},{"type":"tool_use","id":"call_function_6julwezx5dnf_1","name":"read","input":{"filePath":"/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/swapY2X.sol"}},{"type":"tool_use","id":"call_function_6julwezx5dnf_2","name":"read","input":{"filePath":"/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/swapX2Y.sol"}},{"type":"tool_use","id":"call_function_6julwezx5dnf_3","name":"read","input":{"filePath":"/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/liquidity.sol"}}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_6julwezx5dnf_1","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/swapY2X.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapPool.sol\";\n5: import \"./interfaces/IiZiSwapCallback.sol\";\n6: \n7: import \"./libraries/Liquidity.sol\";\n8: import \"./libraries/Point.sol\";\n9: import \"./libraries/PointBitmap.sol\";\n10: import \"./libraries/LogPowMath.sol\";\n11: import \"./libraries/MulDivMath.sol\";\n12: import \"./libraries/TwoPower.sol\";\n13: import \"./libraries/LimitOrder.sol\";\n14: import \"./libraries/SwapMathY2X.sol\";\n15: import \"./libraries/SwapMathX2Y.sol\";\n16: import \"./libraries/SwapMathY2XDesire.sol\";\n17: import \"./libraries/SwapMathX2YDesire.sol\";\n18: import \"./libraries/TokenTransfer.sol\";\n19: import \"./libraries/UserEarn.sol\";\n20: import \"./libraries/State.sol\";\n21: import \"./libraries/Oracle.sol\";\n22: import \"./libraries/OrderOrEndpoint.sol\";\n23: import \"./libraries/MaxMinMath.sol\";\n24: import \"./libraries/SwapCache.sol\";\n25: \n26: contract SwapY2XModule {\n27: \n28:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n29:     using Liquidity for Liquidity.Data;\n30:     using Point for mapping(int24 =>Point.Data);\n31:     using Point for Point.Data;\n32:     using PointBitmap for mapping(int16 =>uint256);\n33:     using LimitOrder for LimitOrder.Data;\n34:     using UserEarn for UserEarn.Data;\n35:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n36:     using SwapMathY2X for SwapMathY2X.RangeRetState;\n37:     using SwapMathX2Y for SwapMathX2Y.RangeRetState;\n38:     using Oracle for Oracle.Observation[65535];\n39:     using OrderOrEndpoint for mapping(int24 =>int24);\n40: \n41:     int24 internal constant LEFT_MOST_PT = -800000;\n42:     int24 internal constant RIGHT_MOST_PT = 800000;\n43: \n44:     /// @notice left most point regularized by pointDelta\n45:     int24 public leftMostPt;\n46:     /// @notice right most point regularized by pointDelta\n47:     int24 public rightMostPt;\n48:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n49:     uint128 public maxLiquidPt;\n50: \n51:     /// @notice address of iZiSwapFactory\n52:     address public factory;\n53: \n54:     /// @notice address of tokenX\n55:     address public tokenX;\n56:     /// @notice address of tokenY\n57:     address public tokenY;\n58:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n59:     uint24 public fee;\n60: \n61:     /// @notice minimum number of distance between initialized or limitorder points \n62:     int24 public pointDelta;\n63: \n64:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n65:     uint256 public feeScaleX_128;\n66:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenY collected per 1 liquidity of the pool\n67:     uint256 public feeScaleY_128;\n68: \n69:     uint160 sqrtRate_96;\n70: \n71:     /// @notice some values of pool\n72:     /// see library State or IiZiSwapPool#state for more infomation\n73:     State public state;\n74: \n75:     /// @notice the information about a liquidity by the liquidity's key\n76:     mapping(bytes32 =>Liquidity.Data) public liquidities;\n77: \n78:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n79:     mapping(int16 =>uint256) public pointBitmap;\n80: \n81:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n82:     mapping(int24 =>Point.Data) public points;\n83:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n84:     mapping(int24 =>int24) public orderOrEndpoint;\n85:     /// @notice limitOrder info on a given point\n86:     mapping(int24 =>LimitOrder.Data) public limitOrderData;\n87:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n88:     mapping(bytes32 => UserEarn.Data) public userEarnX;\n89:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n90:     mapping(bytes32 => UserEarn.Data) public userEarnY;\n91:     /// @notice observation data array\n92:     Oracle.Observation[65535] public observations;\n93:     \n94:     uint256 public totalFeeXCharged;\n95:     uint256 public totalFeeYCharged;\n96: \n97:     address private original;\n98: \n99:     address private swapModuleX2Y;\n100:     address private swapModuleY2X;\n101:     address private liquidityModule;\n102:     address private limitOrderModule;\n103:     address private flashModule;\n104: \n105:     /// @notice percent to charge from miner's fee\n106:     uint24 public feeChargePercent;\n107:     \n108:     function balanceX() private view returns (uint256) {\n109:         (bool success, bytes memory data) =\n110:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n111:         require(success && data.length >= 32);\n112:         return abi.decode(data, (uint256));\n113:     }\n114: \n115:     function balanceY() private view returns (uint256) {\n116:         (bool success, bytes memory data) =\n117:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n118:         require(success && data.length >= 32);\n119:         return abi.decode(data, (uint256));\n120:     }\n121: \n122:     /// Delegate call implementation for IiZiSwapPool#swapY2X.\n123:     function swapY2X(\n124:         address recipient,\n125:         uint128 amount,\n126:         int24 highPt,\n127:         bytes calldata data\n128:     ) external returns (uint256 amountX, uint256 amountY) {\n129:         require(amount > 0, \"AP\");\n130: \n131:         highPt = MaxMinMath.min(highPt, rightMostPt);\n132:         amountX = 0;\n133:         amountY = 0;\n134:         State memory st = state;\n135:         SwapCache memory cache;\n136:         cache.currFeeScaleX_128 = feeScaleX_128;\n137:         cache.currFeeScaleY_128 = feeScaleY_128;\n138:         \n139:         cache.finished = false;\n140:         cache._sqrtRate_96 = sqrtRate_96;\n141:         cache.pointDelta = pointDelta;\n142:         cache.currentOrderOrEndpt = orderOrEndpoint.getOrderOrEndptVal(st.currentPoint, cache.pointDelta);\n143:         cache.startPoint = st.currentPoint;\n144:         cache.startLiquidity = st.liquidity;\n145:         cache.timestamp = uint32(block.timestamp);\n146:         while (st.currentPoint < highPt && !cache.finished) {\n147: \n148:             if (cache.currentOrderOrEndpt & 2 > 0) {\n149:                 // amount <= uint128.max\n150:                 uint128 amountNoFee = uint128(uint256(amount) * (1e6 - fee) / 1e6);\n151:                 if (amountNoFee > 0) {\n152:                     // clear limit order first\n153:                     LimitOrder.Data storage od = limitOrderData[st.currentPoint];\n154:                     uint128 currX = od.sellingX;\n155:                     (uint128 costY, uint128 acquireX) = SwapMathY2X.y2XAtPrice(\n156:                         amountNoFee, st.sqrtPrice_96, currX\n157:                     );\n158:                     if (acquireX < currX || costY >= amountNoFee) {\n159:                         cache.finished = true;\n160:                     }\n161:                     uint128 feeAmount;\n162:                     if (costY >= amountNoFee) {\n163:                         feeAmount = amount - costY;\n164:                     } else {\n165:                         // amount <= uint128.max\n166:                         feeAmount = uint128(uint256(costY) * fee / (1e6 - fee));\n167:                         uint256 mod = uint256(costY) * fee % (1e6 - fee);\n168:                         if (mod > 0) {\n169:                             feeAmount += 1;\n170:                         }\n171:                     }\n172:                     totalFeeYCharged += feeAmount;\n173:                     amount -= (costY + feeAmount);\n174:                     amountY = amountY + costY + feeAmount;\n175:                     amountX += acquireX;\n176:                     currX -= acquireX;\n177:                     od.sellingX = currX;\n178:                     od.earnY += costY;\n179:                     od.accEarnY += costY;\n180:                     if (currX == 0) {\n181:                         od.legacyEarnY += od.earnY;\n182:                         od.earnY = 0;\n183:                         od.legacyAccEarnY = od.accEarnY;\n184:                         if (od.sellingY == 0) {\n185:                             int24 newVal = cache.currentOrderOrEndpt & 1;\n186:                             orderOrEndpoint.setOrderOrEndptVal(st.currentPoint, cache.pointDelta, newVal);\n187:                             if (newVal == 0) {\n188:                                 pointBitmap.setZero(st.currentPoint, cache.pointDelta);\n189:                             }\n190:                         }\n191:                     }\n192:                 } else {\n193:                     cache.finished = true;\n194:                 }\n195:             }\n196: \n197:             if (cache.finished) {\n198:                 break;\n199:             }\n200: \n201:             int24 nextPoint = pointBitmap.nearestRightOneOrBoundary(st.currentPoint, cache.pointDelta);\n202:             int24 nextVal = orderOrEndpoint.getOrderOrEndptVal(nextPoint, cache.pointDelta);\n203:             if (nextPoint > highPt) {\n204:                 nextVal = 0;\n205:                 nextPoint = highPt;\n206:             }\n207: \n208:             // in [st.currentPoint, nextPoint)\n209:             if (st.liquidity == 0) {\n210:                 // no liquidity in the range [st.currentPoint, nextPoint)\n211:                 st.currentPoint = nextPoint;\n212:                 st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n213:                 if (nextVal & 1 > 0) {\n214:                     Point.Data storage endPt = points[nextPoint];\n215:                     // pass next point from left to right\n216:                     endPt.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n217:                     // we should add delta liquid of nextPoint\n218:                     int128 liquidDelta = endPt.liquidDelta;\n219:                     st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, liquidDelta);\n220:                     st.liquidityX = st.liquidity;\n221:                 }\n222:                 cache.currentOrderOrEndpt = nextVal;\n223:             } else {\n224:                 // amount <= uint128.max\n225:                 uint128 amountNoFee = uint128(uint256(amount) * (1e6 - fee) / 1e6);\n226:                 if (amountNoFee > 0) {\n227:                     SwapMathY2X.RangeRetState memory retState = SwapMathY2X.y2XRange(\n228:                         st, nextPoint, cache._sqrtRate_96, amountNoFee\n229:                     );\n230: \n231:                     cache.finished = retState.finished;\n232:                     uint128 feeAmount;\n233:                     if (retState.costY >= amountNoFee) {\n234:                         feeAmount = amount - retState.costY;\n235:                     } else {\n236:                         // retState.costY <= uint128.max\n237:                         feeAmount = uint128(uint256(retState.costY) * fee / (1e6 - fee));\n238:                         uint256 mod = uint256(retState.costY) * fee % (1e6 - fee);\n239:                         if (mod > 0) {\n240:                             feeAmount += 1;\n241:                         }\n242:                     }\n243: \n244:                     amountX += retState.acquireX;\n245:                     amountY = amountY + retState.costY + feeAmount;\n246:                     amount -= (retState.costY + feeAmount);\n247: \n248:                     uint256 chargedFeeAmount = uint256(feeAmount) * feeChargePercent / 100;\n249:                     totalFeeYCharged += chargedFeeAmount;\n250: \n251:                     cache.currFeeScaleY_128 = cache.currFeeScaleY_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n252: \n253:                     st.currentPoint = retState.finalPt;\n254:                     st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n255:                     st.liquidityX = retState.liquidityX;\n256:                 } else {\n257:                     cache.finished = true;\n258:                 }\n259: \n260:                 if (st.currentPoint == nextPoint) {\n261:                     if ((nextVal & 1) > 0) {\n262:                         Point.Data storage endPt = points[nextPoint];\n263:                         // pass next point from left to right\n264:                         endPt.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n265:                         st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, endPt.liquidDelta);\n266:                     }\n267:                     st.liquidityX = st.liquidity;\n268:                 }\n269:                 if (st.currentPoint == nextPoint) {\n270:                     cache.currentOrderOrEndpt = nextVal;\n271:                 } else {\n272:                     // not necessary, because finished must be true\n273:                     cache.currentOrderOrEndpt = 0;\n274:                 }\n275:             }\n276:         }\n277:         if (cache.startPoint != st.currentPoint) {\n278:             (st.observationCurrentIndex, st.observationQueueLen) = observations.append(\n279:                 st.observationCurrentIndex,\n280:                 cache.timestamp,\n281:                 cache.startPoint,\n282:                 st.observationQueueLen,\n283:                 st.observationNextQueueLen\n284:             );\n285:         }\n286:         // write back fee scale, no fee of x\n287:         feeScaleY_128 = cache.currFeeScaleY_128;\n288:         // write back state\n289:         state = st;\n290:         require(amountX > 0, \"PR\");\n291:         // transfer x to trader\n292:         TokenTransfer.transferToken(tokenX, recipient, amountX);\n293:         // trader pay y\n294:         require(amountY > 0, \"PP\");\n295:         uint256 by = balanceY();\n296:         IiZiSwapCallback(msg.sender).swapY2XCallback(amountX, amountY, data);\n297:         require(balanceY() >= by + amountY, \"YE\");\n298:     }\n299: \n300:     /// Delegate call implementation for IiZiSwapPool#swapY2XDesireX.\n301:     function swapY2XDesireX(\n302:         address recipient,\n303:         uint128 desireX,\n304:         int24 highPt,\n305:         bytes calldata data\n306:     ) external returns (uint256 amountX, uint256 amountY) {\n307:         require (desireX > 0, \"XP\");\n308: \n309:         highPt = MaxMinMath.min(highPt, rightMostPt);\n310:         amountX = 0;\n311:         amountY = 0;\n312:         State memory st = state;\n313:         SwapCache memory cache;\n314:         cache.currFeeScaleX_128 = feeScaleX_128;\n315:         cache.currFeeScaleY_128 = feeScaleY_128;\n316:         cache.finished = false;\n317:         cache._sqrtRate_96 = sqrtRate_96;\n318:         cache.pointDelta = pointDelta;\n319:         cache.currentOrderOrEndpt = orderOrEndpoint.getOrderOrEndptVal(st.currentPoint, cache.pointDelta);\n320:         cache.startPoint = st.currentPoint;\n321:         cache.startLiquidity = st.liquidity;\n322:         cache.timestamp = uint32(block.timestamp);\n323:         while (st.currentPoint < highPt && !cache.finished) {\n324:             if (cache.currentOrderOrEndpt & 2 > 0) {\n325:                 // clear limit order first\n326:                 LimitOrder.Data storage od = limitOrderData[st.currentPoint];\n327:                 uint128 currX = od.sellingX;\n328:                 (uint128 costY, uint128 acquireX) = SwapMathY2XDesire.y2XAtPrice(\n329:                     desireX, st.sqrtPrice_96, currX\n330:                 );\n331:                 if (acquireX >= desireX) {\n332:                     cache.finished = true;\n333:                 }\n334:                 uint256 feeAmount = MulDivMath.mulDivCeil(costY, fee, 1e6 - fee);\n335:                 totalFeeYCharged += feeAmount;\n336:                 desireX = (desireX <= acquireX) ? 0 : desireX - acquireX;\n337:                 amountY += (costY + feeAmount);\n338:                 amountX += acquireX;\n339:                 currX -= acquireX;\n340:                 od.sellingX = currX;\n341:                 od.earnY += costY;\n342:                 od.accEarnY += costY;\n343:                 if (currX == 0) {\n344:                     od.legacyEarnY += od.earnY;\n345:                     od.earnY = 0;\n346:                     od.legacyAccEarnY = od.accEarnY;\n347:                     if (od.sellingY == 0) {\n348:                         int24 newVal = cache.currentOrderOrEndpt & 1;\n349:                         orderOrEndpoint.setOrderOrEndptVal(st.currentPoint, cache.pointDelta, newVal);\n350:                         if (newVal == 0) {\n351:                             pointBitmap.setZero(st.currentPoint, cache.pointDelta);\n352:                         }\n353:                     }\n354:                 }\n355:             }\n356: \n357:             if (cache.finished) {\n358:                 break;\n359:             }\n360:             int24 nextPoint = pointBitmap.nearestRightOneOrBoundary(st.currentPoint, cache.pointDelta);\n361:             int24 nextVal = orderOrEndpoint.getOrderOrEndptVal(nextPoint, cache.pointDelta);\n362:             if (nextPoint > highPt) {\n363:                 nextVal = 0;\n364:                 nextPoint = highPt;\n365:             }\n366:             // in [st.currentPoint, nextPoint)\n367:             if (st.liquidity == 0) {\n368:                 // no liquidity in the range [st.currentPoint, nextPoint)\n369:                 st.currentPoint = nextPoint;\n370:                 st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n371:                 if (nextVal & 1 > 0) {\n372:                     Point.Data storage endPt = points[nextPoint];\n373:                     // pass next point from left to right\n374:                     endPt.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n375:                     // we should add delta liquid of nextPoint\n376:                     int128 liquidDelta = endPt.liquidDelta;\n377:                     st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, liquidDelta);\n378:                     st.liquidityX = st.liquidity;\n379:                 }\n380:                 cache.currentOrderOrEndpt = nextVal;\n381:             } else {\n382:                 // desireX > 0\n383:                 if (desireX > 0) {\n384:                     SwapMathY2XDesire.RangeRetState memory retState = SwapMathY2XDesire.y2XRange(\n385:                         st, nextPoint, cache._sqrtRate_96, desireX\n386:                     );\n387:                     cache.finished = retState.finished;\n388:                     uint256 feeAmount = MulDivMath.mulDivCeil(retState.costY, fee, 1e6 - fee);\n389:                     uint256 chargedFeeAmount = feeAmount * feeChargePercent / 100;\n390:                     totalFeeYCharged += chargedFeeAmount;\n391: \n392:                     amountX += retState.acquireX;\n393:                     amountY += (retState.costY + feeAmount);\n394:                     desireX -= MaxMinMath.min(desireX, retState.acquireX);\n395:                     \n396:                     cache.currFeeScaleY_128 = cache.currFeeScaleY_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n397: \n398:                     st.currentPoint = retState.finalPt;\n399:                     st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n400:                     st.liquidityX = retState.liquidityX;\n401:                 } else {\n402:                     cache.finished = true;\n403:                 }\n404: \n405:                 if (st.currentPoint == nextPoint) {\n406:                     if ((nextVal & 1) > 0) {\n407:                         Point.Data storage endPt = points[nextPoint];\n408:                         // pass next point from left to right\n409:                         endPt.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n410:                         st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, endPt.liquidDelta);\n411:                     }\n412:                     st.liquidityX = st.liquidity;\n413:                 }\n414:                 if (st.currentPoint == nextPoint) {\n415:                     cache.currentOrderOrEndpt = nextVal;\n416:                 } else {\n417:                     // not necessary, because finished must be true\n418:                     cache.currentOrderOrEndpt = 0;\n419:                 }\n420:             }\n421:         }\n422:         if (cache.startPoint != st.currentPoint) {\n423:             (st.observationCurrentIndex, st.observationQueueLen) = observations.append(\n424:                 st.observationCurrentIndex,\n425:                 cache.timestamp,\n426:                 cache.startPoint,\n427:                 st.observationQueueLen,\n428:                 st.observationNextQueueLen\n429:             );\n430:         }\n431:         // write back fee scale, no fee of x\n432:         feeScaleY_128 = cache.currFeeScaleY_128;\n433:         // write back state\n434:         state = st;\n435:         // transfer x to trader\n436:         require(amountX > 0, \"PR\");\n437:         TokenTransfer.transferToken(tokenX, recipient, amountX);\n438:         // trader pay y\n439:         require(amountY > 0, \"PP\");\n440:         uint256 by = balanceY();\n441:         IiZiSwapCallback(msg.sender).swapY2XCallback(amountX, amountY, data);\n442:         require(balanceY() >= by + amountY, \"YE\");\n443:     }\n444: \n445: }\n\n(End of file - total 445 lines)\n</content>"},{"type":"tool_result","tool_use_id":"call_function_6julwezx5dnf_2","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/swapX2Y.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapPool.sol\";\n5: import \"./interfaces/IiZiSwapCallback.sol\";\n6: \n7: import \"./libraries/Liquidity.sol\";\n8: import \"./libraries/Point.sol\";\n9: import \"./libraries/PointBitmap.sol\";\n10: import \"./libraries/LogPowMath.sol\";\n11: import \"./libraries/MulDivMath.sol\";\n12: import \"./libraries/TwoPower.sol\";\n13: import \"./libraries/LimitOrder.sol\";\n14: import \"./libraries/SwapMathY2X.sol\";\n15: import \"./libraries/SwapMathX2Y.sol\";\n16: import \"./libraries/SwapMathY2XDesire.sol\";\n17: import \"./libraries/SwapMathX2YDesire.sol\";\n18: import \"./libraries/TokenTransfer.sol\";\n19: import \"./libraries/UserEarn.sol\";\n20: import \"./libraries/State.sol\";\n21: import \"./libraries/Oracle.sol\";\n22: import \"./libraries/OrderOrEndpoint.sol\";\n23: import \"./libraries/MaxMinMath.sol\";\n24: import \"./libraries/SwapCache.sol\";\n25: \n26: contract SwapX2YModule {\n27: \n28:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n29:     using Liquidity for Liquidity.Data;\n30:     using Point for mapping(int24 =>Point.Data);\n31:     using Point for Point.Data;\n32:     using PointBitmap for mapping(int16 =>uint256);\n33:     using LimitOrder for LimitOrder.Data;\n34:     using UserEarn for UserEarn.Data;\n35:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n36:     using SwapMathY2X for SwapMathY2X.RangeRetState;\n37:     using SwapMathX2Y for SwapMathX2Y.RangeRetState;\n38:     using Oracle for Oracle.Observation[65535];\n39:     using OrderOrEndpoint for mapping(int24 =>int24);\n40: \n41:     int24 internal constant LEFT_MOST_PT = -800000;\n42:     int24 internal constant RIGHT_MOST_PT = 800000;\n43: \n44:     /// @notice left most point regularized by pointDelta\n45:     int24 public leftMostPt;\n46:     /// @notice right most point regularized by pointDelta\n47:     int24 public rightMostPt;\n48:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n49:     uint128 public maxLiquidPt;\n50: \n51:     /// @notice address of iZiSwapFactory\n52:     address public factory;\n53: \n54:     /// @notice address of tokenX\n55:     address public tokenX;\n56:     /// @notice address of tokenY\n57:     address public tokenY;\n58:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n59:     uint24 public fee;\n60: \n61:     /// @notice minimum number of distance between initialized or limitorder points \n62:     int24 public pointDelta;\n63: \n64:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n65:     uint256 public feeScaleX_128;\n66:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenY collected per 1 liquidity of the pool\n67:     uint256 public feeScaleY_128;\n68: \n69:     uint160 sqrtRate_96;\n70: \n71:     /// @notice some values of pool\n72:     /// see library State or IiZiSwapPool#state for more infomation\n73:     State public state;\n74: \n75:     /// @notice the information about a liquidity by the liquidity's key\n76:     mapping(bytes32 =>Liquidity.Data) public liquidities;\n77: \n78:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n79:     mapping(int16 =>uint256) public pointBitmap;\n80: \n81:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n82:     mapping(int24 =>Point.Data) public points;\n83:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n84:     mapping(int24 =>int24) public orderOrEndpoint;\n85:     /// @notice limitOrder info on a given point\n86:     mapping(int24 =>LimitOrder.Data) public limitOrderData;\n87:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n88:     mapping(bytes32 => UserEarn.Data) public userEarnX;\n89:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n90:     mapping(bytes32 => UserEarn.Data) public userEarnY;\n91:     /// @notice observation data array\n92:     Oracle.Observation[65535] public observations;\n93:     \n94:     uint256 public totalFeeXCharged;\n95:     uint256 public totalFeeYCharged;\n96: \n97:     address private original;\n98: \n99:     address private swapModuleX2Y;\n100:     address private swapModuleY2X;\n101:     address private liquidityModule;\n102:     address private limitOrderModule;\n103:     address private flashModule;\n104: \n105:     /// @notice percent to charge from miner's fee\n106:     uint24 public feeChargePercent;\n107: \n108:     function balanceX() private view returns (uint256) {\n109:         (bool success, bytes memory data) =\n110:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n111:         require(success && data.length >= 32);\n112:         return abi.decode(data, (uint256));\n113:     }\n114: \n115:     function balanceY() private view returns (uint256) {\n116:         (bool success, bytes memory data) =\n117:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n118:         require(success && data.length >= 32);\n119:         return abi.decode(data, (uint256));\n120:     }\n121: \n122:     /// Delegate call implementation for IiZiSwapPool#swapX2Y.\n123:     function swapX2Y(\n124:         address recipient,\n125:         uint128 amount,\n126:         int24 lowPt,\n127:         bytes calldata data\n128:     ) external returns (uint256 amountX, uint256 amountY) {\n129:         require(amount > 0, \"AP\");\n130: \n131:         lowPt = MaxMinMath.max(lowPt, leftMostPt);\n132:         amountX = 0;\n133:         amountY = 0;\n134:         State memory st = state;\n135:         SwapCache memory cache;\n136:         cache.currFeeScaleX_128 = feeScaleX_128;\n137:         cache.currFeeScaleY_128 = feeScaleY_128;\n138:         cache.finished = false;\n139:         cache._sqrtRate_96 = sqrtRate_96;\n140:         cache.pointDelta = pointDelta;\n141:         cache.currentOrderOrEndpt = orderOrEndpoint.getOrderOrEndptVal(st.currentPoint, cache.pointDelta);\n142:         cache.startPoint = st.currentPoint;\n143:         cache.startLiquidity = st.liquidity;\n144:         cache.timestamp = uint32(block.timestamp);\n145: \n146:         while (lowPt <= st.currentPoint && !cache.finished) {\n147: \n148:             // step1: fill limit order \n149:             if (cache.currentOrderOrEndpt & 2 > 0) {\n150:                 // amount <= uint128.max\n151:                 uint128 amountNoFee = uint128(uint256(amount) * (1e6 - fee) / 1e6);\n152:                 if (amountNoFee > 0) {\n153:                     LimitOrder.Data storage od = limitOrderData[st.currentPoint];\n154:                     uint128 currY = od.sellingY;\n155:                     (uint128 costX, uint128 acquireY) = SwapMathX2Y.x2YAtPrice(\n156:                         amountNoFee, st.sqrtPrice_96, currY\n157:                     );\n158:                     if (acquireY < currY || costX >= amountNoFee) {\n159:                         cache.finished = true;\n160:                     }\n161:                     uint128 feeAmount;\n162:                     if (costX >= amountNoFee) {\n163:                         feeAmount = amount - costX;\n164:                     } else {\n165:                         // costX <= amountX <= uint128.max\n166:                         feeAmount = uint128(uint256(costX) * fee / (1e6 - fee));\n167:                         uint256 mod = uint256(costX) * fee % (1e6 - fee);\n168:                         if (mod > 0) {\n169:                             feeAmount += 1;\n170:                         }\n171:                     }\n172:                     totalFeeXCharged += feeAmount;\n173:                     amount -= (costX + feeAmount);\n174:                     amountX = amountX + costX + feeAmount;\n175:                     amountY += acquireY;\n176:                     currY -= acquireY;\n177:                     od.sellingY = currY;\n178:                     od.earnX += costX;\n179:                     od.accEarnX += costX;\n180:                     if (currY == 0) {\n181:                         od.legacyEarnX += od.earnX;\n182:                         od.legacyAccEarnX = od.accEarnX;\n183:                         od.earnX = 0;\n184:                         if (od.sellingX == 0) {\n185:                             int24 newVal = cache.currentOrderOrEndpt & 1;\n186:                             orderOrEndpoint.setOrderOrEndptVal(st.currentPoint, cache.pointDelta, newVal);\n187:                             if (newVal == 0) {\n188:                                 pointBitmap.setZero(st.currentPoint, cache.pointDelta);\n189:                             }\n190:                         }\n191:                     }\n192:                 } else {\n193:                     cache.finished = true;\n194:                 }\n195:             }\n196:             if (cache.finished) {\n197:                 break;\n198:             }\n199:             int24 searchStart = st.currentPoint - 1;\n200: \n201:             // step2: clear the liquidity if the currentPoint is an endpoint\n202:             if (cache.currentOrderOrEndpt & 1 > 0) {\n203:                 // amount <= uint128.max\n204:                 uint128 amountNoFee = uint128(uint256(amount) * (1e6 - fee) / 1e6);\n205:                 if (amountNoFee > 0) {\n206:                     if (st.liquidity > 0) {\n207:                         SwapMathX2Y.RangeRetState memory retState = SwapMathX2Y.x2YRange(\n208:                             st,\n209:                             st.currentPoint,\n210:                             cache._sqrtRate_96,\n211:                             amountNoFee\n212:                         );\n213:                         cache.finished = retState.finished;\n214:                         uint128 feeAmount;\n215:                         if (retState.costX >= amountNoFee) {\n216:                             feeAmount = amount - retState.costX;\n217:                         } else {\n218:                             // retState.costX <= amount <= uint128.max\n219:                             feeAmount = uint128(uint256(retState.costX) * fee / (1e6 - fee));\n220:                             uint256 mod = uint256(retState.costX) * fee % (1e6 - fee);\n221:                             if (mod > 0) {\n222:                                 feeAmount += 1;\n223:                             }\n224:                         }\n225:                         uint256 chargedFeeAmount = uint256(feeAmount) * feeChargePercent / 100;\n226:                         totalFeeXCharged += chargedFeeAmount;\n227: \n228:                         cache.currFeeScaleX_128 = cache.currFeeScaleX_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n229:                         amountX = amountX + retState.costX + feeAmount;\n230:                         amountY += retState.acquireY;\n231:                         amount -= (retState.costX + feeAmount);\n232:                         st.currentPoint = retState.finalPt;\n233:                         st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n234:                         st.liquidityX = retState.liquidityX;\n235:                     }\n236:                     if (!cache.finished) {\n237:                         Point.Data storage pointdata = points[st.currentPoint];\n238:                         pointdata.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n239:                         st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, - pointdata.liquidDelta);\n240:                         st.currentPoint = st.currentPoint - 1;\n241:                         st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n242:                         st.liquidityX = 0;\n243:                     }\n244:                 } else {\n245:                     cache.finished = true;\n246:                 }\n247:             }\n248:             if (cache.finished || st.currentPoint < lowPt) {\n249:                 break;\n250:             }\n251:             int24 nextPt= pointBitmap.nearestLeftOneOrBoundary(searchStart, cache.pointDelta);\n252:             if (nextPt < lowPt) {\n253:                 nextPt = lowPt;\n254:             }\n255:             int24 nextVal = orderOrEndpoint.getOrderOrEndptVal(nextPt, cache.pointDelta);\n256:             \n257:             // in [nextPt, st.currentPoint)\n258:             if (st.liquidity == 0) {\n259:                 // no liquidity in the range [nextPt, st.currentPoint]\n260:                 st.currentPoint = nextPt;\n261:                 st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n262:                 // st.liquidityX must be 0\n263:                 cache.currentOrderOrEndpt = nextVal;\n264:             } else {\n265:                 // amount > 0\n266:                 // amountNoFee <= amount <= uint128.max\n267:                 uint128 amountNoFee = uint128(uint256(amount) * (1e6 - fee) / 1e6);\n268:                 if (amountNoFee > 0) {\n269:                     SwapMathX2Y.RangeRetState memory retState = SwapMathX2Y.x2YRange(\n270:                         st, nextPt, cache._sqrtRate_96, amountNoFee\n271:                     );\n272:                     cache.finished = retState.finished;\n273:                     uint128 feeAmount;\n274:                     if (retState.costX >= amountNoFee) {\n275:                         feeAmount = amount - retState.costX;\n276:                     } else {\n277:                         // feeAmount <= retState.costX <= amount <= uint128.max\n278:                         feeAmount = uint128(uint256(retState.costX) * fee / (1e6 - fee));\n279:                         uint256 mod = uint256(retState.costX) * fee % (1e6 - fee);\n280:                         if (mod > 0) {\n281:                             feeAmount += 1;\n282:                         }\n283:                     }\n284:                     amountY += retState.acquireY;\n285:                     amountX = amountX + retState.costX + feeAmount;\n286:                     amount -= (retState.costX + feeAmount);\n287: \n288:                     uint256 chargedFeeAmount = uint256(feeAmount) * feeChargePercent / 100;\n289:                     totalFeeXCharged += chargedFeeAmount;\n290:                     \n291:                     cache.currFeeScaleX_128 = cache.currFeeScaleX_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n292:                     st.currentPoint = retState.finalPt;\n293:                     st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n294:                     st.liquidityX = retState.liquidityX;\n295:                 } else {\n296:                     cache.finished = true;\n297:                 }\n298:                 if (st.currentPoint == nextPt) {\n299:                     cache.currentOrderOrEndpt = nextVal;\n300:                 } else {\n301:                     // not necessary, because finished must be true\n302:                     cache.currentOrderOrEndpt = 0;\n303:                 }\n304:             }\n305:             if (st.currentPoint <= lowPt) {\n306:                 break;\n307:             }\n308:         }\n309: \n310:         if (cache.startPoint != st.currentPoint) {\n311:             (st.observationCurrentIndex, st.observationQueueLen) = observations.append(\n312:                 st.observationCurrentIndex,\n313:                 cache.timestamp,\n314:                 cache.startPoint,\n315:                 st.observationQueueLen,\n316:                 st.observationNextQueueLen\n317:             );\n318:         }\n319: \n320:         // write back fee scale, no fee of y\n321:         feeScaleX_128 = cache.currFeeScaleX_128;\n322:         // write back state\n323:         state = st;\n324:         require(amountY > 0, \"PR\");\n325:         // transfer y to trader\n326:         TokenTransfer.transferToken(tokenY, recipient, amountY);\n327:         // trader pay x\n328:         require(amountX > 0, \"PP\");\n329:         uint256 bx = balanceX();\n330:         IiZiSwapCallback(msg.sender).swapX2YCallback(amountX, amountY, data);\n331:         require(balanceX() >= bx + amountX, \"XE\");\n332:         \n333:     }\n334:     \n335:     /// Delegate call implementation for IiZiSwapPool#swapX2YDesireY.\n336:     function swapX2YDesireY(\n337:         address recipient,\n338:         uint128 desireY,\n339:         int24 lowPt,\n340:         bytes calldata data\n341:     ) external returns (uint256 amountX, uint256 amountY) {\n342:         require(desireY > 0, \"AP\");\n343: \n344:         lowPt = MaxMinMath.max(lowPt, leftMostPt);\n345:         amountX = 0;\n346:         amountY = 0;\n347:         State memory st = state;\n348:         SwapCache memory cache;\n349:         cache.currFeeScaleX_128 = feeScaleX_128;\n350:         cache.currFeeScaleY_128 = feeScaleY_128;\n351:         cache.finished = false;\n352:         cache._sqrtRate_96 = sqrtRate_96;\n353:         cache.pointDelta = pointDelta;\n354:         cache.currentOrderOrEndpt = orderOrEndpoint.getOrderOrEndptVal(st.currentPoint, cache.pointDelta);\n355:         cache.startPoint = st.currentPoint;\n356:         cache.startLiquidity = st.liquidity;\n357:         cache.timestamp = uint32(block.timestamp);\n358:         while (lowPt <= st.currentPoint && !cache.finished) {\n359:             // clear limit order first\n360:             if (cache.currentOrderOrEndpt & 2 > 0) {\n361:                 LimitOrder.Data storage od = limitOrderData[st.currentPoint];\n362:                 uint128 currY = od.sellingY;\n363:                 (uint128 costX, uint128 acquireY) = SwapMathX2YDesire.x2YAtPrice(\n364:                     desireY, st.sqrtPrice_96, currY\n365:                 );\n366:                 if (acquireY >= desireY) {\n367:                     cache.finished = true;\n368:                 }\n369: \n370:                 uint256 feeAmount = MulDivMath.mulDivCeil(costX, fee, 1e6 - fee);\n371:                 totalFeeXCharged += feeAmount;\n372:                 desireY = (desireY <= acquireY) ? 0 : desireY - acquireY;\n373:                 amountX += (costX + feeAmount);\n374:                 amountY += acquireY;\n375:                 currY -= acquireY;\n376:                 od.sellingY = currY;\n377:                 od.earnX += costX;\n378:                 od.accEarnX += costX;\n379:                 if (currY == 0) {\n380:                     od.legacyEarnX += od.earnX;\n381:                     od.earnX = 0;\n382:                     od.legacyAccEarnX = od.accEarnX;\n383:                     if (od.sellingX == 0) {\n384:                         int24 newVal = cache.currentOrderOrEndpt & 1;\n385:                         orderOrEndpoint.setOrderOrEndptVal(st.currentPoint, cache.pointDelta, newVal);\n386:                         if (newVal == 0) {\n387:                             pointBitmap.setZero(st.currentPoint, cache.pointDelta);\n388:                         }\n389:                     }\n390:                 }\n391:             }\n392:             if (cache.finished) {\n393:                 break;\n394:             }\n395:             int24 searchStart = st.currentPoint - 1;\n396:             // second, clear the liquid if the currentPoint is an endpoint\n397:             if (cache.currentOrderOrEndpt & 1 > 0) {\n398:                 if (st.liquidity > 0) {\n399:                     SwapMathX2YDesire.RangeRetState memory retState = SwapMathX2YDesire.x2YRange(\n400:                         st,\n401:                         st.currentPoint,\n402:                         cache._sqrtRate_96,\n403:                         desireY\n404:                     );\n405:                     cache.finished = retState.finished;\n406:                     \n407:                     uint256 feeAmount = MulDivMath.mulDivCeil(retState.costX, fee, 1e6 - fee);\n408:                     uint256 chargedFeeAmount = feeAmount * feeChargePercent / 100;\n409:                     totalFeeXCharged += chargedFeeAmount;\n410: \n411:                     cache.currFeeScaleX_128 = cache.currFeeScaleX_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n412:                     amountX += (retState.costX + feeAmount);\n413:                     amountY += retState.acquireY;\n414:                     desireY -= MaxMinMath.min(desireY, retState.acquireY);\n415:                     st.currentPoint = retState.finalPt;\n416:                     st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n417:                     st.liquidityX = retState.liquidityX;\n418:                 }\n419:                 if (!cache.finished) {\n420:                     Point.Data storage pointdata = points[st.currentPoint];\n421:                     pointdata.passEndpoint(cache.currFeeScaleX_128, cache.currFeeScaleY_128);\n422:                     st.liquidity = Liquidity.liquidityAddDelta(st.liquidity, - pointdata.liquidDelta);\n423:                     st.currentPoint = st.currentPoint - 1;\n424:                     st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n425:                     st.liquidityX = 0;\n426:                 }\n427:             }\n428:             if (cache.finished || st.currentPoint < lowPt) {\n429:                 break;\n430:             }\n431:             int24 nextPt = pointBitmap.nearestLeftOneOrBoundary(searchStart, cache.pointDelta);\n432:             if (nextPt < lowPt) {\n433:                 nextPt = lowPt;\n434:             }\n435:             int24 nextVal = orderOrEndpoint.getOrderOrEndptVal(nextPt, cache.pointDelta);\n436: \n437:             // in [nextPt, st.currentPoint)\n438:             if (st.liquidity == 0) {\n439:                 // no liquidity in the range [nextPt, st.currentPoint]\n440:                 st.currentPoint = nextPt;\n441:                 st.sqrtPrice_96 = LogPowMath.getSqrtPrice(st.currentPoint);\n442:                 // st.liquidityX must be 0\n443:                 cache.currentOrderOrEndpt = nextVal;\n444:             } else {\n445:                 // amount > 0\n446:                 SwapMathX2YDesire.RangeRetState memory retState = SwapMathX2YDesire.x2YRange(\n447:                     st, nextPt, cache._sqrtRate_96, desireY\n448:                 );\n449:                 cache.finished = retState.finished;\n450:                     \n451:                 uint256 feeAmount = MulDivMath.mulDivCeil(retState.costX, fee, 1e6 - fee);\n452:                 uint256 chargedFeeAmount = feeAmount * feeChargePercent / 100;\n453:                 totalFeeXCharged += chargedFeeAmount;\n454:                     \n455:                 amountY += retState.acquireY;\n456:                 amountX += (retState.costX + feeAmount);\n457:                 desireY -= MaxMinMath.min(desireY, retState.acquireY);\n458:                     \n459:                 cache.currFeeScaleX_128 = cache.currFeeScaleX_128 + MulDivMath.mulDivFloor(feeAmount - chargedFeeAmount, TwoPower.Pow128, st.liquidity);\n460: \n461:                 st.currentPoint = retState.finalPt;\n462:                 st.sqrtPrice_96 = retState.sqrtFinalPrice_96;\n463:                 st.liquidityX = retState.liquidityX;\n464: \n465:                 if (st.currentPoint == nextPt) {\n466:                     cache.currentOrderOrEndpt = nextVal;\n467:                 } else {\n468:                     // not necessary, because finished must be true\n469:                     cache.currentOrderOrEndpt = 0;\n470:                 }\n471:             }\n472:             if (st.currentPoint <= lowPt) {\n473:                 break;\n474:             }\n475:         }\n476:         if (cache.startPoint != st.currentPoint) {\n477:             (st.observationCurrentIndex, st.observationQueueLen) = observations.append(\n478:                 st.observationCurrentIndex,\n479:                 cache.timestamp,\n480:                 cache.startPoint,\n481:                 st.observationQueueLen,\n482:                 st.observationNextQueueLen\n483:             );\n484:         }\n485: \n486:         // write back fee scale, no fee of y\n487:         feeScaleX_128 = cache.currFeeScaleX_128;\n488:         // write back state\n489:         state = st;\n490:         require(amountY > 0, \"PR\");\n491:         // transfer y to trader\n492:         TokenTransfer.transferToken(tokenY, recipient, amountY);\n493:         // trader pay x\n494:         require(amountX > 0, \"PP\");\n495:         uint256 bx = balanceX();\n496:         IiZiSwapCallback(msg.sender).swapX2YCallback(amountX, amountY, data);\n497:         require(balanceX() >= bx + amountX, \"XE\");\n498:     }\n499:     \n500: }\n\n(End of file - total 500 lines)\n</content>"},{"type":"tool_result","tool_use_id":"call_function_6julwezx5dnf_3","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/liquidity.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapPool.sol\";\n5: import \"./interfaces/IiZiSwapCallback.sol\";\n6: \n7: import \"./libraries/Liquidity.sol\";\n8: import \"./libraries/Point.sol\";\n9: import \"./libraries/PointBitmap.sol\";\n10: import \"./libraries/LogPowMath.sol\";\n11: import \"./libraries/MulDivMath.sol\";\n12: import \"./libraries/TwoPower.sol\";\n13: import \"./libraries/LimitOrder.sol\";\n14: import \"./libraries/SwapMathY2X.sol\";\n15: import \"./libraries/SwapMathX2Y.sol\";\n16: import \"./libraries/SwapMathY2XDesire.sol\";\n17: import \"./libraries/SwapMathX2YDesire.sol\";\n18: import \"./libraries/TokenTransfer.sol\";\n19: import \"./libraries/UserEarn.sol\";\n20: import \"./libraries/State.sol\";\n21: import \"./libraries/Oracle.sol\";\n22: import \"./libraries/OrderOrEndpoint.sol\";\n23: import \"./libraries/MaxMinMath.sol\";\n24: \n25: contract LiquidityModule {\n26: \n27:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n28:     using Liquidity for Liquidity.Data;\n29:     using Point for mapping(int24 =>Point.Data);\n30:     using Point for Point.Data;\n31:     using PointBitmap for mapping(int16 =>uint256);\n32:     using LimitOrder for LimitOrder.Data;\n33:     using UserEarn for UserEarn.Data;\n34:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n35:     using SwapMathY2X for SwapMathY2X.RangeRetState;\n36:     using SwapMathX2Y for SwapMathX2Y.RangeRetState;\n37:     using Oracle for Oracle.Observation[65535];\n38:     using OrderOrEndpoint for mapping(int24 =>int24);\n39: \n40:     int24 internal constant LEFT_MOST_PT = -800000;\n41:     int24 internal constant RIGHT_MOST_PT = 800000;\n42: \n43:     /// @notice left most point regularized by pointDelta\n44:     int24 public leftMostPt;\n45:     /// @notice right most point regularized by pointDelta\n46:     int24 public rightMostPt;\n47:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n48:     uint128 public maxLiquidPt;\n49: \n50:     /// @notice address of iZiSwapFactory\n51:     address public factory;\n52: \n53:     /// @notice address of tokenX\n54:     address public tokenX;\n55:     /// @notice address of tokenY\n56:     address public tokenY;\n57:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n58:     uint24 public fee;\n59: \n60:     /// @notice minimum number of distance between initialized or limitorder points \n61:     int24 public pointDelta;\n62: \n63:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n64:     uint256 public feeScaleX_128;\n65:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenY collected per 1 liquidity of the pool\n66:     uint256 public feeScaleY_128;\n67: \n68:     uint160 sqrtRate_96;\n69: \n70:     /// @notice some values of pool\n71:     /// see library State or IiZiSwapPool#state for more infomation\n72:     State public state;\n73: \n74:     /// @notice the information about a liquidity by the liquidity's key\n75:     mapping(bytes32 =>Liquidity.Data) public liquidities;\n76: \n77:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n78:     mapping(int16 =>uint256) public pointBitmap;\n79: \n80:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n81:     mapping(int24 =>Point.Data) public points;\n82:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n83:     mapping(int24 =>int24) public orderOrEndpoint;\n84:     /// @notice limitOrder info on a given point\n85:     mapping(int24 =>LimitOrder.Data) public limitOrderData;\n86:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n87:     mapping(bytes32 => UserEarn.Data) public userEarnX;\n88:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n89:     mapping(bytes32 => UserEarn.Data) public userEarnY;\n90:     /// @notice observation data array\n91:     Oracle.Observation[65535] public observations;\n92: \n93:     uint256 public totalFeeXCharged;\n94:     uint256 public totalFeeYCharged;\n95: \n96:     address private original;\n97: \n98:     address private swapModuleX2Y;\n99:     address private swapModuleY2X;\n100:     address private liquidityModule;\n101:     address private limitOrderModule;\n102:     address private flashModule;\n103: \n104:     /// @notice percent to charge from miner's fee\n105:     uint24 public feeChargePercent;\n106: \n107:     // data used when removing liquidity\n108:     struct WithdrawRet {\n109:         // total amount of tokenX refund after withdraw\n110:         uint256 x;\n111:         // total amount of tokenY refund after withdraw\n112:         uint256 y;\n113:         // amount of refund tokenX at current point after withdraw\n114:         uint256 xc;\n115:         // amount of refund tokenY at current point after withdraw\n116:         uint256 yc;\n117:         // value of liquidityX at current point after withdraw\n118:         uint128 liquidityX;\n119:     }\n120: \n121:     function balanceX() private view returns (uint256) {\n122:         (bool success, bytes memory data) =\n123:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n124:         require(success && data.length >= 32);\n125:         return abi.decode(data, (uint256));\n126:     }\n127: \n128:     function balanceY() private view returns (uint256) {\n129:         (bool success, bytes memory data) =\n130:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n131:         require(success && data.length >= 32);\n132:         return abi.decode(data, (uint256));\n133:     }\n134: \n135:     /// @dev Add / Dec liquidity \n136:     /// @param minter the minter of the liquidity\n137:     /// @param leftPoint left endpoint of the segment\n138:     /// @param rightPoint right endpoint of the segment, [leftPoint, rightPoint)\n139:     /// @param delta delta liquidity, positive for adding\n140:     /// @param currentPoint current price point on the axies\n141:     function _updateLiquidity(\n142:         address minter,\n143:         int24 leftPoint,\n144:         int24 rightPoint,\n145:         int128 delta,\n146:         int24 currentPoint\n147:     ) private {\n148:         int24 pd = pointDelta;\n149:         Liquidity.Data storage lq = liquidities.get(minter, leftPoint, rightPoint);\n150:         (uint256 mFeeScaleX_128, uint256 mFeeScaleY_128) = (feeScaleX_128, feeScaleY_128);\n151:         bool leftFlipped;\n152:         bool rightFlipped;\n153:         // update points\n154:         if (delta != 0) {\n155:             // add / dec liquidity\n156:             leftFlipped = points.updateEndpoint(leftPoint, true, currentPoint, delta, maxLiquidPt, mFeeScaleX_128, mFeeScaleY_128);\n157:             rightFlipped = points.updateEndpoint(rightPoint, false, currentPoint, delta, maxLiquidPt, mFeeScaleX_128, mFeeScaleY_128);\n158:         }\n159:         // get sub fee scale of the range\n160:         (uint256 accFeeXIn_128, uint256 accFeeYIn_128) = \n161:             points.getSubFeeScale(\n162:                 leftPoint, rightPoint, currentPoint, mFeeScaleX_128, mFeeScaleY_128\n163:             );\n164:         lq.update(delta, accFeeXIn_128, accFeeYIn_128);\n165:         // update bitmap\n166:         if (leftFlipped) {\n167:             int24 leftVal = orderOrEndpoint.getOrderOrEndptVal(leftPoint, pd);\n168:             if (delta > 0) {\n169:                 orderOrEndpoint.setOrderOrEndptVal(leftPoint, pd, leftVal | 1);\n170:                 if (leftVal == 0) {\n171:                     pointBitmap.setOne(leftPoint, pd);\n172:                 }\n173:             } else {\n174:                 int24 newVal = leftVal & 2;\n175:                 orderOrEndpoint.setOrderOrEndptVal(leftPoint, pd, newVal);\n176:                 if (newVal == 0) {\n177:                     pointBitmap.setZero(leftPoint, pd);\n178:                 }\n179:                 delete points[leftPoint];\n180:             }\n181:         }\n182:         if (rightFlipped) {\n183:             int24 rightVal = orderOrEndpoint.getOrderOrEndptVal(rightPoint, pd);\n184:             if (delta > 0) {\n185:                 orderOrEndpoint.setOrderOrEndptVal(rightPoint, pd, rightVal | 1);\n186:                 if (rightVal == 0) {\n187:                     pointBitmap.setOne(rightPoint, pd);\n188:                 }\n189:             } else {\n190:                 int24 newVal = rightVal & 2;\n191:                 orderOrEndpoint.setOrderOrEndptVal(rightPoint, pd, newVal);\n192:                 if (newVal == 0) {\n193:                     pointBitmap.setZero(rightPoint, pd);\n194:                 }\n195:                 delete points[rightPoint];\n196:             }\n197:         }\n198:     }\n199: \n200:     function _computeDepositYc(\n201:         uint128 liquidDelta,\n202:         uint160 sqrtPrice_96\n203:     ) private pure returns (uint128 y) {\n204:         // to simplify computation, \n205:         // minter is required to deposit only token y in point of current price\n206:         uint256 amount = MulDivMath.mulDivCeil(\n207:             liquidDelta,\n208:             sqrtPrice_96,\n209:             TwoPower.Pow96\n210:         );\n211:         y = uint128(amount);\n212:         require (y == amount, \"YC OFL\");\n213:     }\n214: \n215:     /// @dev [leftPoint, rightPoint)\n216:     function _computeDepositXY(\n217:         uint128 liquidDelta,\n218:         int24 leftPoint,\n219:         int24 rightPoint,\n220:         State memory currentState\n221:     ) private view returns (uint128 x, uint128 y, uint128 yc) {\n222:         x = 0;\n223:         uint256 amountY = 0;\n224:         int24 pc = currentState.currentPoint;\n225:         uint160 sqrtPrice_96 = currentState.sqrtPrice_96;\n226:         uint160 sqrtPriceR_96 = LogPowMath.getSqrtPrice(rightPoint);\n227:         uint160 _sqrtRate_96 = sqrtRate_96;\n228:         if (leftPoint < pc) {\n229:             uint160 sqrtPriceL_96 = LogPowMath.getSqrtPrice(leftPoint);\n230:             uint256 yl;\n231:             if (rightPoint < pc) {\n232:                 yl = AmountMath.getAmountY(liquidDelta, sqrtPriceL_96, sqrtPriceR_96, _sqrtRate_96, true);\n233:             } else {\n234:                 yl = AmountMath.getAmountY(liquidDelta, sqrtPriceL_96, sqrtPrice_96, _sqrtRate_96, true);\n235:             }\n236:             amountY += yl;\n237:         }\n238:         if (rightPoint > pc) {\n239:             // we need compute XR\n240:             int24 xrLeft = (leftPoint > pc) ? leftPoint : pc + 1;\n241:             uint256 xr = AmountMath.getAmountX(\n242:                 liquidDelta,\n243:                 xrLeft,\n244:                 rightPoint,\n245:                 sqrtPriceR_96,\n246:                 _sqrtRate_96,\n247:                 true\n248:             );\n249:             x = uint128(xr);\n250:             require(x == xr, \"XOFL\");\n251:         }\n252:         if (leftPoint <= pc && rightPoint > pc) {\n253:             // we need compute yc at point of current price\n254:             yc = _computeDepositYc(\n255:                 liquidDelta,\n256:                 sqrtPrice_96\n257:             );\n258:             amountY += yc;\n259:         } else {\n260:             yc = 0;\n261:         }\n262:         y = uint128(amountY);\n263:         require(y == amountY, \"YOFL\");\n264:     }\n265: \n266:     /// @notice Compute some values (refund token amount, currX/currY in state) when removing liquidity\n267:     /// @param liquidDelta amount of liquidity user wants to withdraw\n268:     /// @param leftPoint left endpoint of liquidity\n269:     /// @param rightPoint right endpoint of liquidity\n270:     /// @param currentState current state values of pool\n271:     /// @return withRet a WithdrawRet struct object containing values computed, see WithdrawRet for more information\n272:     function _computeWithdrawXY(\n273:         uint128 liquidDelta,\n274:         int24 leftPoint,\n275:         int24 rightPoint,\n276:         State memory currentState\n277:     ) private view returns (WithdrawRet memory withRet) {\n278:         uint256 amountY = 0;\n279:         uint256 amountX = 0;\n280:         int24 pc = currentState.currentPoint;\n281:         uint160 sqrtPrice_96 = currentState.sqrtPrice_96;\n282:         uint160 sqrtPriceR_96 = LogPowMath.getSqrtPrice(rightPoint);\n283:         uint160 _sqrtRate_96 = sqrtRate_96;\n284:         if (leftPoint < pc) {\n285:             uint160 sqrtPriceL_96 = LogPowMath.getSqrtPrice(leftPoint);\n286:             uint256 yl;\n287:             if (rightPoint < pc) {\n288:                 yl = AmountMath.getAmountY(liquidDelta, sqrtPriceL_96, sqrtPriceR_96, _sqrtRate_96, false);\n289:             } else {\n290:                 yl = AmountMath.getAmountY(liquidDelta, sqrtPriceL_96, sqrtPrice_96, _sqrtRate_96, false);\n291:             }\n292:             amountY += yl;\n293:         }\n294:         if (rightPoint > pc) {\n295:             // we need compute XR\n296:             int24 xrLeft = (leftPoint > pc) ? leftPoint : pc + 1;\n297:             uint256 xr = AmountMath.getAmountX(\n298:                 liquidDelta,\n299:                 xrLeft,\n300:                 rightPoint,\n301:                 sqrtPriceR_96,\n302:                 _sqrtRate_96,\n303:                 false\n304:             );\n305:             amountX += xr;\n306:         }\n307:         if (leftPoint <= pc && rightPoint > pc) {\n308:             uint128 originLiquidityY = currentState.liquidity - currentState.liquidityX;\n309:             uint128 withdrawedLiquidityY = (originLiquidityY < liquidDelta) ? originLiquidityY : liquidDelta;\n310:             uint128 withdrawedLiquidityX = liquidDelta - withdrawedLiquidityY;\n311:             withRet.yc = MulDivMath.mulDivFloor(withdrawedLiquidityY, sqrtPrice_96, TwoPower.Pow96);\n312:             // withdrawedLiquidityX * 2^96 < 2^128*2^96=2^224<2^256\n313:             withRet.xc = uint256(withdrawedLiquidityX) * TwoPower.Pow96 / sqrtPrice_96;\n314:             withRet.liquidityX = currentState.liquidityX - withdrawedLiquidityX;\n315:             amountY += withRet.yc;\n316:             amountX += withRet.xc;\n317:         } else {\n318:             withRet.yc = 0;\n319:             withRet.xc = 0;\n320:             withRet.liquidityX = currentState.liquidityX;\n321:         }\n322:         withRet.y = uint128(amountY);\n323:         require(withRet.y == amountY, \"YOFL\");\n324:         withRet.x = uint128(amountX);\n325:         require(withRet.x == amountX, \"XOFL\");\n326:     }\n327: \n328:     /// Delegate call implementation for IiZiSwapPool#mint.\n329:     function mint(\n330:         address recipient,\n331:         int24 leftPt,\n332:         int24 rightPt,\n333:         uint128 liquidDelta,\n334:         bytes calldata data\n335:     ) external returns (uint256 amountX, uint256 amountY) {\n336:         require(leftPt < rightPt, \"LR\");\n337:         require(leftPt >= leftMostPt, \"LO\");\n338:         require(rightPt <= rightMostPt, \"HO\");\n339:         require(int256(rightPt) - int256(leftPt) < RIGHT_MOST_PT, \"TL\");\n340:         int24 pd = pointDelta;\n341:         require(leftPt % pd == 0, \"LPD\");\n342:         require(rightPt % pd == 0, \"RPD\");\n343:         int128 ld = int128(liquidDelta);\n344:         require(ld > 0, \"LP\");\n345:         if (recipient == address(0)) {\n346:             recipient = msg.sender;\n347:         }\n348:         State memory currentState = state;\n349:         // add a liquidity segment to the pool\n350:         _updateLiquidity(\n351:             recipient,\n352:             leftPt,\n353:             rightPt,\n354:             ld,\n355:             currentState.currentPoint\n356:         );\n357:         // compute amount of tokenx and tokeny should be paid from minter\n358:         (uint256 x, uint256 y, uint256 yc) = _computeDepositXY(\n359:             liquidDelta,\n360:             leftPt,\n361:             rightPt,\n362:             currentState\n363:         );\n364:         // update state\n365:         if (yc > 0) {\n366:             // if (!currentState.allX) {\n367:             //     state.currY = currentState.currY + yc;\n368:             // } else {\n369:             //     state.allX = false;\n370:             //     state.currX = MulDivMath.mulDivFloor(currentState.liquidity, TwoPower.Pow96, currentState.sqrtPrice_96);\n371:             //     state.currY = yc;\n372:             // }\n373:             state.liquidity = currentState.liquidity + liquidDelta;\n374:         }\n375:         uint256 bx;\n376:         uint256 by;\n377:         if (x > 0) {\n378:             bx = balanceX();\n379:         }\n380:         if (y > 0) {\n381:             by = balanceY();\n382:         }\n383:         if (x > 0 || y > 0) {\n384:             // minter's callback to pay\n385:             IiZiSwapMintCallback(msg.sender).mintDepositCallback(x, y, data);\n386:         }\n387:         if (x > 0) {\n388:             require(bx + x <= balanceX(), \"NEX\"); // not enough x from minter\n389:         }\n390:         if (y > 0) {\n391:             require(by + y <= balanceY(), \"NEY\"); // not enough y from minter\n392:         }\n393:         amountX = x;\n394:         amountY = y;\n395:     }\n396: \n397:     /// Delegate call implementation for IiZiSwapPool#burn.\n398:     function burn(\n399:         int24 leftPt,\n400:         int24 rightPt,\n401:         uint128 liquidDelta\n402:     ) external returns (uint256 amountX, uint256 amountY) {\n403:         // it is not necessary to check leftPt rightPt with [leftMostPt, rightMostPt]\n404:         // because we haved checked it in the mint(...)\n405:         require(leftPt < rightPt, \"LR\");\n406:         int24 pd = pointDelta;\n407:         require(leftPt % pd == 0, \"LPD\");\n408:         require(rightPt % pd == 0, \"RPD\");\n409:         State memory currentState = state;\n410:         uint128 liquidity = currentState.liquidity;\n411:         // add a liquidity segment to the pool\n412:         require(liquidDelta <= uint128(type(int128).max), 'LQ127');\n413:         int256 nlDelta = -int256(uint256(liquidDelta));\n414:         require(int128(nlDelta) == nlDelta, \"DO\");\n415:         _updateLiquidity(\n416:             msg.sender,\n417:             leftPt,\n418:             rightPt,\n419:             int128(nlDelta),\n420:             currentState.currentPoint\n421:         );\n422:         // compute amount of tokenx and tokeny should be paid from minter\n423:         WithdrawRet memory withRet = _computeWithdrawXY(\n424:             liquidDelta,\n425:             leftPt,\n426:             rightPt,\n427:             currentState\n428:         );\n429:         // update state\n430:         if (withRet.yc > 0 || withRet.xc > 0) {\n431:             state.liquidity = liquidity - liquidDelta;\n432:             state.liquidityX = withRet.liquidityX;\n433:         }\n434:         if (withRet.x > 0 || withRet.y > 0) {\n435:             Liquidity.Data storage lq = liquidities.get(msg.sender, leftPt, rightPt);\n436:             lq.tokenOwedX += withRet.x;\n437:             lq.tokenOwedY += withRet.y;\n438:         }\n439:         return (withRet.x, withRet.y);\n440:     }\n441: \n442:     /// Delegate call implementation for IiZiSwapPool#collect.\n443:     function collect(\n444:         address recipient,\n445:         int24 leftPt,\n446:         int24 rightPt,\n447:         uint256 amountXLim,\n448:         uint256 amountYLim\n449:     ) external returns (uint256 actualAmountX, uint256 actualAmountY) {\n450:         require(amountXLim > 0 || amountYLim > 0, \"X+Y>0\");\n451:         Liquidity.Data storage lq = liquidities.get(msg.sender, leftPt, rightPt);\n452:         actualAmountX = amountXLim;\n453:         if (actualAmountX > lq.tokenOwedX) {\n454:             actualAmountX = lq.tokenOwedX;\n455:         }\n456:         actualAmountY = amountYLim;\n457:         if (actualAmountY > lq.tokenOwedY) {\n458:             actualAmountY = lq.tokenOwedY;\n459:         }\n460:         lq.tokenOwedX -= actualAmountX;\n461:         lq.tokenOwedY -= actualAmountY;\n462: \n463:         actualAmountX = MaxMinMath.min256(actualAmountX, balanceX());\n464:         actualAmountY = MaxMinMath.min256(actualAmountY, balanceY());\n465:         if (actualAmountX > 0) {\n466:             TokenTransfer.transferToken(tokenX, recipient, actualAmountX);\n467:         }\n468:         if (actualAmountY > 0) {\n469:             TokenTransfer.transferToken(tokenY, recipient, actualAmountY);\n470:         }\n471:     }\n472:     \n473: }\n\n(End of file - total 473 lines)\n</content>"}]},{"role":"assistant","content":[{"type":"thinking","thinking":"Let me continue reading more files to understand the codebase better and identify potential security vulnerabilities.","signature":"fe8a763a23502432d9c69f89626c8af4fb7e738087560a5321a08869c7d8169c"},{"type":"tool_use","id":"call_function_clf27u2byfs1_1","name":"read","input":{"filePath":"/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/limitOrder.sol"}}]},{"role":"user","content":[{"type":"tool_result","tool_use_id":"call_function_clf27u2byfs1_1","content":"<path>/Users/lu/Desktop/Red_V1G/iZiSwap-core/contracts/limitOrder.sol</path>\n<type>file</type>\n<content>\n1: // SPDX-License-Identifier: BUSL-1.1\n2: pragma solidity ^0.8.4;\n3: \n4: import \"./interfaces/IiZiSwapPool.sol\";\n5: import \"./interfaces/IiZiSwapCallback.sol\";\n6: \n7: import \"./libraries/Liquidity.sol\";\n8: import \"./libraries/Point.sol\";\n9: import \"./libraries/PointBitmap.sol\";\n10: import \"./libraries/LogPowMath.sol\";\n11: import \"./libraries/MulDivMath.sol\";\n12: import \"./libraries/TwoPower.sol\";\n13: import \"./libraries/LimitOrder.sol\";\n14: import \"./libraries/SwapMathY2X.sol\";\n15: import \"./libraries/SwapMathX2Y.sol\";\n16: import \"./libraries/SwapMathY2XDesire.sol\";\n17: import \"./libraries/SwapMathX2YDesire.sol\";\n18: import \"./libraries/TokenTransfer.sol\";\n19: import \"./libraries/UserEarn.sol\";\n20: import \"./libraries/State.sol\";\n21: import \"./libraries/Oracle.sol\";\n22: import \"./libraries/OrderOrEndpoint.sol\";\n23: import \"./libraries/MaxMinMath.sol\";\n24: \n25: contract LimitOrderModule {\n26: \n27:     using Liquidity for mapping(bytes32 =>Liquidity.Data);\n28:     using Liquidity for Liquidity.Data;\n29:     using Point for mapping(int24 =>Point.Data);\n30:     using Point for Point.Data;\n31:     using PointBitmap for mapping(int16 =>uint256);\n32:     using LimitOrder for LimitOrder.Data;\n33:     using UserEarn for UserEarn.Data;\n34:     using UserEarn for mapping(bytes32 =>UserEarn.Data);\n35:     using SwapMathY2X for SwapMathY2X.RangeRetState;\n36:     using SwapMathX2Y for SwapMathX2Y.RangeRetState;\n37:     using Oracle for Oracle.Observation[65535];\n38:     using OrderOrEndpoint for mapping(int24 =>int24);\n39: \n40:     int24 internal constant LEFT_MOST_PT = -800000;\n41:     int24 internal constant RIGHT_MOST_PT = 800000;\n42: \n43:     /// @notice left most point regularized by pointDelta\n44:     int24 public leftMostPt;\n45:     /// @notice right most point regularized by pointDelta\n46:     int24 public rightMostPt;\n47:     /// @notice maximum liquidSum for each point, see points() in IiZiSwapPool or library Point\n48:     uint128 public maxLiquidPt;\n49: \n50:     /// @notice address of iZiSwapFactory\n51:     address public factory;\n52: \n53:     /// @notice address of tokenX\n54:     address public tokenX;\n55:     /// @notice address of tokenY\n56:     address public tokenY;\n57:     /// @notice fee amount of this swap pool, 3000 means 0.3%\n58:     uint24 public fee;\n59: \n60:     /// @notice minimum number of distance between initialized or limitorder points \n61:     int24 public pointDelta;\n62: \n63:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenX collected per 1 liquidity of the pool\n64:     uint256 public feeScaleX_128;\n65:     /// @notice the fee growth as a 128-bit fixpoing fees of tokenY collected per 1 liquidity of the pool\n66:     uint256 public feeScaleY_128;\n67: \n68:     uint160 sqrtRate_96;\n69: \n70:     /// @notice some values of pool\n71:     /// see library State or IiZiSwapPool#state for more infomation\n72:     State public state;\n73: \n74:     /// @notice the information about a liquidity by the liquidity's key\n75:     mapping(bytes32 =>Liquidity.Data) public liquidities;\n76: \n77:     /// @notice 256 packed point (orderOrEndpoint>0) boolean values. See PointBitmap for more information\n78:     mapping(int16 =>uint256) public pointBitmap;\n79: \n80:     /// @notice returns infomation of a point in the pool, see Point library of IiZiSwapPool#poitns for more information\n81:     mapping(int24 =>Point.Data) public points;\n82:     /// @notice infomation about a point whether has limit order and whether as an liquidity's endpoint\n83:     mapping(int24 =>int24) public orderOrEndpoint;\n84:     /// @notice limitOrder info on a given point\n85:     mapping(int24 =>LimitOrder.Data) public limitOrderData;\n86:     /// @notice information about a user's limit order (sell tokenY and earn tokenX)\n87:     mapping(bytes32 => UserEarn.Data) public userEarnX;\n88:     /// @notice information about a user's limit order (sell tokenX and earn tokenY)\n89:     mapping(bytes32 => UserEarn.Data) public userEarnY;\n90:     /// @notice observation data array\n91:     Oracle.Observation[65535] public observations;\n92: \n93:     uint256 public totalFeeXCharged;\n94:     uint256 public totalFeeYCharged;\n95: \n96:     address private original;\n97: \n98:     address private swapModuleX2Y;\n99:     address private swapModuleY2X;\n100:     address private liquidityModule;\n101:     address private limitOrderModule;\n102:     address private flashModule;\n103: \n104:     /// @notice percent to charge from miner's fee\n105:     uint24 public feeChargePercent;\n106: \n107:     function balanceX() private view returns (uint256) {\n108:         (bool success, bytes memory data) =\n109:             tokenX.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n110:         require(success && data.length >= 32);\n111:         return abi.decode(data, (uint256));\n112:     }\n113: \n114:     function balanceY() private view returns (uint256) {\n115:         (bool success, bytes memory data) =\n116:             tokenY.staticcall(abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, address(this)));\n117:         require(success && data.length >= 32);\n118:         return abi.decode(data, (uint256));\n119:     }\n120: \n121:     /// Delegate call implementation for IiZiSwapPool#assignLimOrderEarnY.\n122:     function assignLimOrderEarnY(\n123:         int24 point,\n124:         uint128 assignY,\n125:         bool fromLegacy\n126:     ) external returns (uint128 actualAssignY) {\n127:         actualAssignY = assignY;\n128:         UserEarn.Data storage ue = userEarnY.get(msg.sender, point);\n129:         if (fromLegacy) {\n130:             if (actualAssignY > ue.legacyEarn) {\n131:                 actualAssignY = ue.legacyEarn;\n132:             }\n133:             ue.legacyEarn -= actualAssignY;\n134:         } else {\n135:             if (actualAssignY > ue.earn) {\n136:                 actualAssignY = ue.earn;\n137:             }\n138:             ue.earn -= actualAssignY;\n139:         }\n140:         ue.earnAssign += actualAssignY;\n141:     }\n142: \n143:     /// Delegate call implementation for IiZiSwapPool#assignLimOrderEarnX.\n144:     function assignLimOrderEarnX(\n145:         int24 point,\n146:         uint128 assignX,\n147:         bool fromLegacy\n148:     ) external returns (uint128 actualAssignX) {\n149:         actualAssignX = assignX;\n150:         UserEarn.Data storage ue = userEarnX.get(msg.sender, point);\n151:         if (fromLegacy) {\n152:             if (actualAssignX > ue.legacyEarn) {\n153:                 actualAssignX = ue.legacyEarn;\n154:             }\n155:             ue.legacyEarn -= actualAssignX;\n156:         } else {\n157:             if (actualAssignX > ue.earn) {\n158:                 actualAssignX = ue.earn;\n159:             }\n160:             ue.earn -= actualAssignX;\n161:         }\n162:         ue.earnAssign += actualAssignX;\n163:     }\n164: \n165:     /// Delegate call implementation for IiZiSwapPool#decLimOrderWithX.\n166:     function decLimOrderWithX(\n167:         int24 point,\n168:         uint128 deltaX\n169:     ) external returns (uint128 actualDeltaX, uint256 legacyAccEarn, uint128 claimSold, uint128 claimEarn) {\n170:         require(point % pointDelta == 0, \"PD\");\n171: \n172:         UserEarn.Data storage ue = userEarnY.get(msg.sender, point);\n173:         LimitOrder.Data storage pointOrder = limitOrderData[point];\n174:         uint160 sqrtPrice_96 = LogPowMath.getSqrtPrice(point);\n175:         legacyAccEarn = pointOrder.legacyAccEarnY;\n176:         if (legacyAccEarn > ue.lastAccEarn) {\n177:             (pointOrder.legacyEarnY, claimSold, claimEarn) = ue.updateLegacyOrder(0, pointOrder.accEarnY, sqrtPrice_96, pointOrder.legacyEarnY, true);\n178:         } else {\n179:             (actualDeltaX, pointOrder.earnY, claimSold, claimEarn) = ue.decUnlegacyOrder(deltaX, pointOrder.accEarnY, sqrtPrice_96, pointOrder.earnY, true);\n180:             pointOrder.sellingX -= actualDeltaX;\n181:             \n182:             if (actualDeltaX > 0 && pointOrder.sellingX == 0) {\n183:                 int24 newVal = orderOrEndpoint.getOrderOrEndptVal(point, pointDelta) & 1;\n184:                 orderOrEndpoint.setOrderOrEndptVal(point, pointDelta, newVal);\n185:                 if (newVal == 0) {\n186:                     pointBitmap.setZero(point, pointDelta);\n187:                 }\n188:             }\n189:         }\n190: \n191:     }\n192: \n193:     /// Delegate call implementation for IiZiSwapPool#decLimOrderWithY.\n194:     function decLimOrderWithY(\n195:         int24 point,\n196:         uint128 deltaY\n197:     ) external returns (uint128 actualDeltaY, uint256 legacyAccEarn, uint128 claimSold, uint128 claimEarn) {\n198:         require(point % pointDelta == 0, \"PD\");\n199: \n200:         UserEarn.Data storage ue = userEarnX.get(msg.sender, point);\n201:         LimitOrder.Data storage pointOrder = limitOrderData[point];\n202:         uint160 sqrtPrice_96 = LogPowMath.getSqrtPrice(point);\n203:         legacyAccEarn = pointOrder.legacyAccEarnX;\n204:         if (legacyAccEarn > ue.lastAccEarn) {\n205:             (pointOrder.legacyEarnX, claimSold, claimEarn) = ue.updateLegacyOrder(0, pointOrder.accEarnX, sqrtPrice_96, pointOrder.legacyEarnX, false);\n206:         } else {\n207:             (actualDeltaY, pointOrder.earnX, claimSold, claimEarn) = ue.decUnlegacyOrder(deltaY, pointOrder.accEarnX, sqrtPrice_96, pointOrder.earnX, false);\n208: \n209:             pointOrder.sellingY -= actualDeltaY;\n210:             \n211:             if (actualDeltaY > 0 && pointOrder.sellingY == 0) {\n212:                 int24 newVal = orderOrEndpoint.getOrderOrEndptVal(point, pointDelta) & 1;\n213:                 orderOrEndpoint.setOrderOrEndptVal(point, pointDelta, newVal);\n214:                 if (newVal == 0) {\n215:                     pointBitmap.setZero(point, pointDelta);\n216:                 }\n217:             }\n218:         }\n219:         \n220:     }\n221: \n222:     struct AddLimOrderCacheData {\n223:         uint128 currX;\n224:         uint128 currY;\n225:         uint128 costOffset;\n226:     }\n227: \n228:     /// Delegate call implementation for IiZiSwapPool#allLimOrderWithX.\n229:     function addLimOrderWithX(\n230:         address recipient,\n231:         int24 point,\n232:         uint128 amountX,\n233:         bytes calldata data\n234:     ) external returns (uint128 orderX, uint128 acquireY, uint128 claimSold, uint128 claimEarn) {\n235:         require(point % pointDelta == 0, \"PD\");\n236:         require(point >= state.currentPoint, \"PG\");\n237:         require(point <= rightMostPt, \"HO\");\n238: 