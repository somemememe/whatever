+            }
+        }
+
+        _attemptJoinPoolDust(tokens, taxedToken);
+        _attemptSwapExactAmountInLoops(taxedToken);
+        _attemptSwapExactAmountOut(taxedToken);
+        _attemptJoinSwapExternAmountIn(taxedToken);
+        _attemptJoinSwapPoolAmountOut(taxedToken);
