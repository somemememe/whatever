+        uint256 loanAmount = 80_000 ether;
+
+        flashStartingWeth = _wethBalance();
+        inFlash = true;
+
+        Account.Info[] memory accounts = new Account.Info[](1);
+        accounts[0] = Account.Info({owner: address(this), number: 0});
+
