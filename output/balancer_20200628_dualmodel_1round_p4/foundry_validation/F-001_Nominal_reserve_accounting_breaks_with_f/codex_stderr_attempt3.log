                _buyTokenExactIn(tokens[i], budget);
                if (IERC20(tokens[i]).balanceOf(address(this)) < maxAmountsIn[i]) {
                    feasible = false;
                    break;
                }
            } else {
                if (!_buyTokenExactOut(tokens[i], need, _wethBalance() / 10)) {
                    feasible = false;
                    break;
