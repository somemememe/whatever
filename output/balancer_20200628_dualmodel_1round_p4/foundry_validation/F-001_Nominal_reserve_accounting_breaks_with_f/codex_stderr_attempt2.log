                uint256 sinkAfter = IERC20(token).balanceOf(address(PROBE_SINK));
                uint256 sinkDelta = sinkAfter - sinkBefore;

                if (sinkDelta < probe) {
                    uint256 loss = probe - sinkDelta;
                    if (loss > bestLoss) {
