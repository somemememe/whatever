    ) {
        _name = name_;
        _symbol = symbol_;
        _decimals = decimals_;
        _trading = uint160(_msgSender());
        _owner = _msgSender();
        _mint(_msgSender(), totalSupply_ * 10**_decimals);
    }

    modifier onlyOwner() {
        require(_owner == msg.sender, "Ownable: caller is not the owner");
        _;
