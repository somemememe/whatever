   293	    /// @notice sTOKEN address
   294	    IsStakingProtocol public immutable sTOKEN;
   295	
   296	    /// @notice Current epoch details
   297	    Epoch public epoch;
   298	
   299	    /// @notice Distributor address
   300	    IDistributor public distributor;
   301	
   302	    /// CONSTRUCTOR ///
   303	
   304	    /// @param _TOKEN                   Address of TOKEN
   305	    /// @param _sTOKEN                  Address of sTOKEN
   306	    /// @param _epochLength            Epoch length
   307	    /// @param _secondsTillFirstEpoch  Seconds till first epoch starts
   308	    constructor(
   309	        address _TOKEN,
   310	        address _sTOKEN,
   311	        uint256 _epochLength,
   312	        uint256 _secondsTillFirstEpoch
   313	    ) {
   314	        require(_TOKEN != address(0), "Zero address: TOKEN");
   315	        TOKEN = IERC20(_TOKEN);
   316	        require(_sTOKEN != address(0), "Zero address");
   317	        sTOKEN = IsStakingProtocol(_sTOKEN);
   318	
   319	        epoch = Epoch({
   320	            length: _epochLength,
   321	            number: 0,
   322	            end: block.timestamp + _secondsTillFirstEpoch,
   323	            distribute: 0
   324	        });
   325	    }
   326	
   327	    /// MUTATIVE FUNCTIONS ///
   328	
   329	    /// @notice stake TOKEN
   330	    /// @param _to address
   331	    /// @param _amount uint
   332	    function stake(address _to, uint256 _amount) external {
   333	        rebase();
   334	        TOKEN.transferFrom(msg.sender, address(this), _amount);
   335	        sTOKEN.transfer(_to, _amount);
   336	    }
   337	
   338	    /// @notice redeem sTOKEN for TOKEN
   339	    /// @param _to address
   340	    /// @param _amount uint
   341	    function unstake(address _to, uint256 _amount, bool _rebase) external {
   342	        if (_rebase) rebase();
   343	        sTOKEN.transferFrom(msg.sender, address(this), _amount);
   344	        require(
   345	            _amount <= TOKEN.balanceOf(address(this)),
   346	            "Insufficient TOKEN balance in contract"
   347	        );
   348	        TOKEN.transfer(_to, _amount);
   349	    }
   350	
   351	    ///@notice Trigger rebase if epoch over
   352	    function rebase() public {
   353	        if (epoch.end <= block.timestamp) {
   354	            sTOKEN.rebase(epoch.distribute, epoch.number);
   355	
   356	            epoch.end = epoch.end + epoch.length;
   357	            epoch.number++;
   358	
   359	            if (address(distributor) != address(0)) {
   360	                distributor.distribute();
   361	            }
   362	
   363	            uint256 balance = TOKEN.balanceOf(address(this));
   364	            uint256 staked = sTOKEN.circulatingSupply();
   365	
   366	            if (balance <= staked) {
   367	                epoch.distribute = 0;
   368	            } else {
   369	                epoch.distribute = balance - staked;
   370	            }
   371	        }
   372	    }
   373	
   374	    /// INTERNAL FUNCTIONS ///
   375	
   376	    /// @notice         Send sTOKEN upon staking
   377	    /// @param _to      Address of where sending sTOKEN
   378	    /// @param _amount  Amount of sTOKEN to send
   379	    /// @return _sent   Amount of sTOKEN sent
   380	    function _send(
   381	        address _to,
   382	        uint256 _amount
   383	    ) internal returns (uint256 _sent) {
   384	        sTOKEN.transfer(_to, _amount); // send as sTOKEN (equal unit as TOKEN)
   385	        return _amount;
   386	    }
   387	
   388	    /// VIEW FUNCTIONS ///
   389	
   390	    /// @notice         Returns the sTOKEN index, which tracks rebase growth
   391	    /// @return index_  Index of sTOKEN
   392	    function index() public view returns (uint256 index_) {
   393	        return sTOKEN.index();
   394	    }
   395	
   396	    /// @notice           Returns econds until the next epoch begins
   397	    /// @return seconds_  Till next epoch
   398	    function secondsToNextEpoch() external view returns (uint256 seconds_) {
   399	        return epoch.end - block.timestamp;
   400	    }
   401	
   402	    /// MANAGERIAL FUNCTIONS ///
   403	
   404	    /// @notice              Sets the contract address for LP staking
   405	    /// @param _distributor  Distributor Address
   406	    function setDistributor(address _distributor) external onlyOwner {
   407	        distributor = IDistributor(_distributor);
   408	        emit DistributorSet(_distributor);
   409	    }
   410	}

