            uint256 tokenReserve = IUniswapV2PairLike(pair).token0() == TOKEN ? reserve0 : reserve1;

            if (tokenReserve > bestTokenReserve) {
                bestPair = pair;
                bestTokenReserve = tokenReserve;
            }
        }
    }

