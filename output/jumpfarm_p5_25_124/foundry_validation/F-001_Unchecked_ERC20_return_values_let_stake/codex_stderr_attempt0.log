+            );
+            require(ok && (data.length == 0 || abi.decode(data, (bool))), "approve failed");
+        }
+    }
+
+    function _boundAmount(uint256 maxAvailable) internal pure returns (uint256) {
+        if (maxAvailable == 0) {
+            return 0;
+        }
+        return 1;
+    }
+
+    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
+        return a < b ? a : b;
+    }
+}

