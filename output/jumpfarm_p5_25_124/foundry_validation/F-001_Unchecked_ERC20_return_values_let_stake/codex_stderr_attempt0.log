+        (bool ok, ) = TARGET.call(
+            abi.encodeWithSelector(
+                IStakingTarget.unstake.selector,
+                address(this),
+                amount,
+                false
+            )
+        );
+
+        if (!ok) {
+            unstakeTokenTransferFalseProbeResult = PathResult.Reverted;
+            return;
+        }
+
