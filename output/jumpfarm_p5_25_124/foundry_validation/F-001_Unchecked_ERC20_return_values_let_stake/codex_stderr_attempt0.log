+
+        (ok, ) = TARGET.call(
+            abi.encodeWithSelector(
+                IStakingTarget.unstake.selector,
+                address(this),
+                minted,
+                false
+            )
+        );
+
+        if (ok) {
+            uint256 tokenAfterRedeem = IERC20Like(token).balanceOf(address(this));
+            if (tokenAfterRedeem > tokenBefore) {
