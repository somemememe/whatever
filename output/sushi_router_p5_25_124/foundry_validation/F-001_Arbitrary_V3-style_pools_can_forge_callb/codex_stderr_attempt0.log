+// SPDX-License-Identifier: UNLICENSED
+pragma solidity 0.8.10;
+
+interface Vm {
+    function createSelectFork(string calldata url, uint256 blockNumber) external returns (uint256);
+}
+
+interface IERC20Probe {
+    function balanceOf(address account) external view returns (uint256);
+    function allowance(address owner, address spender) external view returns (uint256);
+}
+
+contract ProbeTest {
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+    address internal constant ROUTER = 0x044b75f554b886A065b9567891e45c79542d7357;
+
+    function testProbe() external {
+        vm.createSelectFork("https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk", 17007841);
+
+        address[8] memory tokens = [
+            0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,
+            0xdAC17F958D2ee523a2206206994597C13D831ec7,
+            0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2,
+            0x6B175474E89094C44Da98b954EedeAC495271d0F,
+            0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599,
+            0x514910771AF9Ca656af840dff83E8264EcF986CA,
+            0xC011A72400E58ecD99Ee497CF89E3775d4bd732F,
+            0x6B3595068778DD592e39A122f4f5a5Cf09C90fE2
+        ];
+
+        for (uint256 i = 0; i < tokens.length; ++i) {
+            uint256 bal = IERC20Probe(tokens[i]).balanceOf(ROUTER);
+            if (bal > 0) {
+                revert(string(abi.encodePacked("token balance found at index ", bytes1(uint8(48 + i)))));
+            }
+        }
+    }
+}

