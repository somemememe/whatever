   264	  /// @notice UniswapV2 pool swap
   265	  /// @param stream [pool, direction, recipient]
   266	  /// @param from Where to take liquidity for swap
   267	  /// @param tokenIn Input token
   268	  /// @param amountIn Amount of tokenIn to take for swap
   269	  function swapUniV2(uint256 stream, address from, address tokenIn, uint256 amountIn) private {
   270	    address pool = stream.readAddress();
   271	    uint8 direction = stream.readUint8();
   272	    address to = stream.readAddress();
   273	
   274	    (uint256 r0, uint256 r1, ) = IUniswapV2Pair(pool).getReserves();
   275	    require(r0 > 0 && r1 > 0, 'Wrong pool reserves');
   276	    (uint256 reserveIn, uint256 reserveOut) = direction == 1 ? (r0, r1) : (r1, r0);
   277	
   278	    if (amountIn != 0) {
   279	      if (from == address(this)) IERC20(tokenIn).safeTransfer(pool, amountIn);
   280	      else IERC20(tokenIn).safeTransferFrom(from, pool, amountIn);
   281	    } else amountIn = IERC20(tokenIn).balanceOf(pool) - reserveIn;  // tokens already were transferred
   282	
   283	    uint256 amountInWithFee = amountIn * 997;
   284	    uint256 amountOut = (amountInWithFee * reserveOut) / (reserveIn * 1000 + amountInWithFee);
   285	    (uint256 amount0Out, uint256 amount1Out) = direction == 1 ? (uint256(0), amountOut) : (amountOut, uint256(0));
   286	    IUniswapV2Pair(pool).swap(amount0Out, amount1Out, to, new bytes(0));
   287	  }
