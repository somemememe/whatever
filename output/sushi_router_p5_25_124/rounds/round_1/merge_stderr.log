   237	  /// @param from Where to take liquidity for swap
   238	  /// @param tokenIn Input token
   239	  /// @param amountIn Amount of tokenIn to take for swap
   240	  function bentoBridge(uint256 stream, address from, address tokenIn, uint256 amountIn) private {
   241	    uint8 direction = stream.readUint8();
   242	    address to = stream.readAddress();
   243	
   244	    if (direction > 0) {  // outside to Bento
   245	      // deposit to arbitrary recipient is possible only from address(bentoBox)
   246	      if (amountIn != 0) {
   247	        if (from == address(this)) IERC20(tokenIn).safeTransfer(address(bentoBox), amountIn);
   248	        else IERC20(tokenIn).safeTransferFrom(from, address(bentoBox), amountIn);
   249	      } else {
   250	        // tokens already are at address(bentoBox)
   251	        amountIn = IERC20(tokenIn).balanceOf(address(bentoBox)) +
   252	        bentoBox.strategyData(tokenIn).balance -
   253	        bentoBox.totals(tokenIn).elastic;
   254	      }
   255	      bentoBox.deposit(tokenIn, address(bentoBox), to, amountIn, 0);
