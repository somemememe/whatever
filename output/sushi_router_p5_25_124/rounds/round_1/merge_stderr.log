   213	  /// @notice Wraps/unwraps native token
   214	  /// @param stream [direction & fake, recipient, wrapToken?]
   215	  /// @param from Where to take liquidity for swap
   216	  /// @param tokenIn Input token
   217	  /// @param amountIn Amount of tokenIn to take for swap
   218	  function wrapNative(uint256 stream, address from, address tokenIn, uint256 amountIn) private {
   219	    uint8 directionAndFake = stream.readUint8();
   220	    address to = stream.readAddress();
   221	
   222	    if (directionAndFake & 1 == 1) {  // wrap native
   223	      address wrapToken = stream.readAddress();
   224	      if (directionAndFake & 2 == 0) IWETH(wrapToken).deposit{value: amountIn}();
   225	      if (to != address(this)) IERC20(wrapToken).safeTransfer(to, amountIn);
   226	    } else { // unwrap native
   227	      if (directionAndFake & 2 == 0) {
   228	        if (from != address(this)) IERC20(tokenIn).safeTransferFrom(from, address(this), amountIn);
   229	        IWETH(tokenIn).withdraw(amountIn);
   230	      }
   231	      payable(to).transfer(address(this).balance);
   232	    }
   233	  }
