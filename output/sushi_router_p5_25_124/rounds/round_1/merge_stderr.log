   197	  /// @notice Makes swap
   198	  /// @param stream Streamed process program
   199	  /// @param from Where to take liquidity for swap
   200	  /// @param tokenIn Input token
   201	  /// @param amountIn Amount of tokenIn to take for swap
   202	  function swap(uint256 stream, address from, address tokenIn, uint256 amountIn) private {
   203	    uint8 poolType = stream.readUint8();
   204	    if (poolType == 0) swapUniV2(stream, from, tokenIn, amountIn);
   205	    else if (poolType == 1) swapUniV3(stream, from, tokenIn, amountIn);
   206	    else if (poolType == 2) wrapNative(stream, from, tokenIn, amountIn);
   207	    else if (poolType == 3) bentoBridge(stream, from, tokenIn, amountIn);
   208	    else if (poolType == 4) swapTrident(stream, from, tokenIn, amountIn);
   209	    else if (poolType == 5) swapTridentCL(stream, from, tokenIn, amountIn);
