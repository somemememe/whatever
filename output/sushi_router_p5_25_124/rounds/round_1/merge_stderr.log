   308	  /// @param tokenIn Input token
   309	  /// @param amountIn Amount of tokenIn to take for swap
   310	  function swapUniV3(uint256 stream, address from, address tokenIn, uint256 amountIn) private {
   311	    address pool = stream.readAddress();
   312	    bool zeroForOne = stream.readUint8() > 0;
   313	    address recipient = stream.readAddress();
   314	
   315	    lastCalledPool = pool;
   316	    IUniswapV3Pool(pool).swap(
   317	      recipient,
