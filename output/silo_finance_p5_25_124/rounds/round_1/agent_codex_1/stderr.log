   660	    /// @notice Accrue interest for asset
   661	    /// @dev Silo Interest Rate Model implements dynamic interest rate that changes every second. Returned
   662	    /// interest rate by the model is compounded rate so it can be used in math calculations as if it was
   663	    /// static. Rate is calculated for the time range between last update and current timestamp.
   664	    /// @param _asset address of the asset for which interest should be accrued
   665	    /// @return accruedInterest total accrued interest
   666	    function _accrueInterest(address _asset) internal returns (uint256 accruedInterest) {
   667	        /// @dev `_accrueInterest` is called on every user action, including liquidation. It's enough to check
   668	        /// if Silo is paused in this function.
   669	        if (IGuardedLaunch(address(siloRepository)).isSiloPaused(address(this), _asset)) {
   670	            revert Paused();
   671	        }
   672	
   673	        AssetStorage storage _state = _assetStorage[_asset];
   674	        AssetInterestData storage _assetInterestData = _interestData[_asset];
   675	        uint256 lastTimestamp = _assetInterestData.interestRateTimestamp;
   676	
   677	        // This is the first time, so we can return early and save some gas
   678	        if (lastTimestamp == 0) {
   679	            _assetInterestData.interestRateTimestamp = uint64(block.timestamp);
   680	            return 0;
   681	        }
   682	
   683	        // Interest has already been accrued this block
   684	        if (lastTimestamp == block.timestamp) {
   685	            return 0;
   686	        }
   687	
   688	        uint256 rcomp = _getModel(_asset).getCompoundInterestRateAndUpdate(_asset, block.timestamp);
   689	        uint256 protocolShareFee = siloRepository.protocolShareFee();
   690	
   691	        uint256 totalBorrowAmountCached = _state.totalBorrowAmount;
   692	        uint256 protocolFeesCached = _assetInterestData.protocolFees;
   693	        uint256 newProtocolFees;
   694	        uint256 protocolShare;
   695	        uint256 depositorsShare;
   696	
   697	        accruedInterest = totalBorrowAmountCached * rcomp / Solvency._PRECISION_DECIMALS;
   698	
   699	        unchecked {
   700	            // If we overflow on multiplication it should not revert tx, we will get lower fees
   701	            protocolShare = accruedInterest * protocolShareFee / Solvency._PRECISION_DECIMALS;
   702	            newProtocolFees = protocolFeesCached + protocolShare;
   703	
   704	            if (newProtocolFees < protocolFeesCached) {
   705	                protocolShare = type(uint256).max - protocolFeesCached;
   706	                newProtocolFees = type(uint256).max;
   707	            }
   708	    
   709	            depositorsShare = accruedInterest - protocolShare;
   710	        }
   711	
   712	        // update contract state
   713	        _state.totalBorrowAmount = totalBorrowAmountCached + accruedInterest;
   714	        _state.totalDeposits = _state.totalDeposits + depositorsShare;
   715	        _assetInterestData.protocolFees = newProtocolFees;
   716	        _assetInterestData.interestRateTimestamp = uint64(block.timestamp);
   717	    }
