    80	        // value of theoretical debt user can have depending on TypeofLTV
    81	        uint256 borrowAvailableTotalValue = _getTotalAvailableToBorrowValue(
    82	            _params.siloRepository,
    83	            address(_params.silo),
    84	            _params.assets,
    85	            _secondLtvType,
    86	            collateralValues
    87	        );
    88	
    89	        currentUserLTV = borrowTotalValue * _PRECISION_DECIMALS / collateralTotalValue;
    90	
    91	        // one of Solvency.TypeofLTV
    92	        secondLTV = borrowAvailableTotalValue * _PRECISION_DECIMALS / collateralTotalValue;
