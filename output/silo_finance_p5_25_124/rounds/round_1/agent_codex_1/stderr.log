   375	        if (_assets.length != _collateralValues.length) revert DifferentArrayLength();
   376	
   377	        for (uint256 i = 0; i < _assets.length; i++) {
   378	            totalAvailableToBorrowValue += _getAvailableToBorrowValue(
   379	                _siloRepository,
   380	                _silo,
   381	                _assets[i],
   382	                _ltvType,
   383	                _collateralValues[i]
   384	            );
   385	        }
   386	    }
