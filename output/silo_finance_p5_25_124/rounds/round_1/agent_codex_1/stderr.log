   336	    /// @param _collateralValue value of collateral deposit (in quote token)
   337	    /// @return availableToBorrow value (in quote token) that user can borrow against collateral value
   338	    function _getAvailableToBorrowValue(
   339	        ISiloRepository _siloRepository,
   340	        address _silo,
   341	        address _asset,
   342	        TypeofLTV _type,
   343	        uint256 _collateralValue
   344	    ) private view returns (uint256 availableToBorrow) {
   345	        uint256 assetLTV;
   346	
   347	        if (_type == TypeofLTV.MaximumLTV) {
   348	            assetLTV = _siloRepository.getMaximumLTV(_silo, _asset);
   349	        } else if (_type == TypeofLTV.LiquidationThreshold) {
   350	            assetLTV = _siloRepository.getLiquidationThreshold(_silo, _asset);
   351	        } else {
   352	            revert UnsupportedLTVType();
   353	        }
   354	
   355	        // value that can be borrowed against the deposit
   356	        // ie. for assetLTV = 50%, 1 ETH * 50% = 0.5 ETH of available to borrow
   357	        availableToBorrow = _collateralValue * assetLTV / _PRECISION_DECIMALS;
