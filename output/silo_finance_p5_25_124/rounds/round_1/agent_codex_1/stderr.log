   630	    /// @param _asset asset we want to harvest fees from
   631	    /// @param _receiver address of fees receiver
   632	    /// @return harvestedFees harvested fee
   633	    function _harvestProtocolFees(address _asset, address _receiver)
   634	        internal
   635	        nonReentrant
   636	        returns (uint256 harvestedFees)
   637	    {
   638	        AssetInterestData storage data = _interestData[_asset];
   639	
   640	        harvestedFees = data.protocolFees - data.harvestedProtocolFees;
   641	
   642	        uint256 currentLiquidity = liquidity(_asset);
   643	
   644	        if (harvestedFees > currentLiquidity) {
   645	            harvestedFees = currentLiquidity;
   646	        }
   647	
   648	        if (harvestedFees == 0) {
   649	            return 0;
   650	        }
   651	
   652	        unchecked {
   653	            // This can't overflow because this addition is less than or equal to data.protocolFees
   654	            data.harvestedProtocolFees += harvestedFees;
   655	        }
   656	
   657	        ERC20(_asset).safeTransfer(_receiver, harvestedFees);
   658	    }
