   726	    /// @dev calculates amount to repay based on user shares, we do not apply virtual balances here,
   727	    /// if needed, they need to be apply beforehand
   728	    /// @param _state asset storage struct
   729	    /// @param _borrower borrower address
   730	    /// @param _amount proposed amount of asset to repay. Based on that,`repayShare` is calculated.
   731	    /// @return amount amount of asset to repay
   732	    /// @return repayShare amount of debt token representing debt ownership
   733	    function _calculateDebtAmountAndShare(AssetStorage storage _state, address _borrower, uint256 _amount)
   734	        internal
   735	        view
   736	        returns (uint256 amount, uint256 repayShare)
   737	    {
   738	        uint256 borrowerDebtShare = _state.debtToken.balanceOf(_borrower);
   739	        uint256 debtTokenTotalSupply = _state.debtToken.totalSupply();
   740	        uint256 totalBorrowed = _state.totalBorrowAmount;
   741	        uint256 maxAmount = borrowerDebtShare.toAmountRoundUp(totalBorrowed, debtTokenTotalSupply);
   742	
   743	        if (_amount >= maxAmount) {
   744	            amount = maxAmount;
   745	            repayShare = borrowerDebtShare;
   746	        } else {
   747	            amount = _amount;
   748	            repayShare = _amount.toShare(totalBorrowed, debtTokenTotalSupply);
   749	        }
   750	    }
