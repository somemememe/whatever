   307	    /// @notice Calculates protocol liquidation fee and new protocol total fees collected
   308	    /// @param _protocolEarnedFees amount of total collected fees so far
   309	    /// @param _amount amount on which we will apply fee
   310	    /// @param _liquidationFee liquidation fee in Solvency._PRECISION_DECIMALS
   311	    /// @return liquidationFeeAmount calculated interest
   312	    /// @return newProtocolEarnedFees the new total amount of protocol fees
   313	    function calculateLiquidationFee(uint256 _protocolEarnedFees, uint256 _amount, uint256 _liquidationFee)
   314	        internal
   315	        pure
   316	        returns (uint256 liquidationFeeAmount, uint256 newProtocolEarnedFees)
   317	    {
   318	        unchecked {
   319	            // If we overflow on multiplication it should not revert tx, we will get lower fees
   320	            liquidationFeeAmount = _amount * _liquidationFee / Solvency._PRECISION_DECIMALS;
   321	
   322	            if (_protocolEarnedFees > type(uint256).max - liquidationFeeAmount) {
   323	                newProtocolEarnedFees = type(uint256).max;
   324	                liquidationFeeAmount = type(uint256).max - _protocolEarnedFees;
   325	            } else {
   326	                newProtocolEarnedFees = _protocolEarnedFees + liquidationFeeAmount;
   327	            }
   328	        }
