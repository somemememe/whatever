   602	    /// @notice Calculates liquidations fee and returns amount of asset transferred to liquidator
   603	    /// @param _asset asset address
   604	    /// @param _amount amount on which we will apply fee
   605	    /// @param _protocolLiquidationFee liquidation fee in Solvency._PRECISION_DECIMALS
   606	    /// @return change amount left after subtracting liquidation fee
   607	    function _applyLiquidationFee(address _asset, uint256 _amount, uint256 _protocolLiquidationFee)
   608	        internal
   609	        returns (uint256 change)
   610	    {
   611	        if (_protocolLiquidationFee == 0) {
   612	            return _amount;
   613	        }
   614	
   615	        uint256 liquidationFeeAmount;
   616	
   617	        (
   618	            liquidationFeeAmount,
   619	            _interestData[_asset].protocolFees
   620	        ) = Solvency.calculateLiquidationFee(_interestData[_asset].protocolFees, _amount, _protocolLiquidationFee);
   621	
   622	        unchecked {
   623	            // if fees will not be higher than 100% this will not underflow, this is responsibility of siloRepository
   624	            // in case we do underflow, we can expect liquidator reject tx because of too little change
   625	            change = _amount - liquidationFeeAmount;
   626	        }
   627	    }
