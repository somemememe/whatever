   541	    /// @dev Utility function for withdrawing an asset
   542	    /// @param _asset asset to withdraw
   543	    /// @param _assetAmount amount of asset to withdraw
   544	    /// @param _depositor wallet address that is an owner of the deposit
   545	    /// @param _receiver wallet address that is receiving the token
   546	    /// @param _collateralOnly true if withdraw collateral only.
   547	    /// @param _protocolLiquidationFee if provided (!=0) liquidation fees will be applied and returned
   548	    /// `withdrawnAmount` will be decreased
   549	    /// @return withdrawnAmount amount of asset that has been sent to receiver
   550	    /// @return burnedShare burned share based on `withdrawnAmount`
   551	    function _withdrawAsset(
   552	        address _asset,
   553	        uint256 _assetAmount,
   554	        address _depositor,
   555	        address _receiver,
   556	        bool _collateralOnly,
   557	        uint256 _protocolLiquidationFee
   558	    )
   559	        internal
   560	        returns (uint256 withdrawnAmount, uint256 burnedShare)
   561	    {
   562	        (uint256 assetTotalDeposits, IShareToken shareToken, uint256 availableLiquidity) =
   563	            _getWithdrawAssetData(_asset, _collateralOnly);
   564	
   565	        if (_assetAmount == type(uint256).max) {
   566	            burnedShare = shareToken.balanceOf(_depositor);
   567	            withdrawnAmount = burnedShare.toAmount(assetTotalDeposits, shareToken.totalSupply());
   568	        } else {
   569	            burnedShare = _assetAmount.toShareRoundUp(assetTotalDeposits, shareToken.totalSupply());
   570	            withdrawnAmount = _assetAmount;
   571	        }
   572	
   573	        if (withdrawnAmount == 0) {
   574	            // we can not revert here, because liquidation will fail when one of collaterals will be empty
   575	            return (0, 0);
   576	        }
   577	
   578	        if (assetTotalDeposits < withdrawnAmount) revert NotEnoughDeposits();
   579	
   580	        unchecked {
   581	            // can be unchecked because of the `if` above
   582	            assetTotalDeposits -=  withdrawnAmount;
   583	        }
   584	
   585	        uint256 amountToTransfer = _applyLiquidationFee(_asset, withdrawnAmount, _protocolLiquidationFee);
   586	
   587	        if (availableLiquidity < amountToTransfer) revert NotEnoughLiquidity();
   588	
   589	        AssetStorage storage _state = _assetStorage[_asset];
   590	
   591	        if (_collateralOnly) {
   592	            _state.collateralOnlyDeposits = assetTotalDeposits;
   593	        } else {
   594	            _state.totalDeposits = assetTotalDeposits;
   595	        }
   596	
   597	        shareToken.burn(_depositor, burnedShare);
   598	        // in case token sent in fee-on-transfer type of token we do not care when withdrawing
   599	        ERC20(_asset).safeTransfer(_receiver, amountToTransfer);
   600	    }
