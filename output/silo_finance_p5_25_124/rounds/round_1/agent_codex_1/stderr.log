   779	            shareToken = _state.collateralOnlyToken;
   780	            availableLiquidity = assetTotalDeposits;
   781	        } else {
   782	            assetTotalDeposits = _state.totalDeposits;
   783	            shareToken = _state.collateralToken;
   784	            availableLiquidity = liquidity(_asset);
