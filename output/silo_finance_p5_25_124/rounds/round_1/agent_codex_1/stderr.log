   758	                siloRepository,
   759	                ISilo(address(this)),
   760	                assets,
   761	                assetsStates,
   762	                _user
   763	            ),
   764	            Solvency.TypeofLTV.MaximumLTV
   765	        );
   766	
   767	        if (userLTV > maximumAllowedLTV) revert MaximumLTVReached();
   768	    }
