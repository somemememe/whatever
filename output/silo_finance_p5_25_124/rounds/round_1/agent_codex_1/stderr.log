    38	    /// @dev is value that used for integer calculations and decimal points for utilization ratios, LTV, protocol fees
    39	    uint256 internal constant _PRECISION_DECIMALS = 1e18;
    40	    uint256 internal constant _INFINITY = type(uint256).max;
    41	
    42	    /// @notice Returns current user LTV and second LTV chosen in params
    43	    /// @dev This function is optimized for protocol use. In some cases there is no need to keep the calculation
    44	    /// going and predefined results can be returned.
    45	    /// @param _params `Solvency.SolvencyParams` struct with needed params for calculation
    46	    /// @param _secondLtvType type of LTV to be returned as second value
    47	    /// @return currentUserLTV Loan-to-Value ratio represents current user's proportion of debt to collateral
    48	    /// @return secondLTV second type of LTV which depends on _secondLtvType, zero is returned if the value of the loan
    49	    /// or the collateral are zero
    50	    function calculateLTVs(SolvencyParams memory _params, TypeofLTV _secondLtvType)
    51	        internal
    52	        view
    53	        returns (uint256 currentUserLTV, uint256 secondLTV)
    54	    {
    55	        uint256[] memory totalBorrowAmounts = getBorrowAmounts(_params);
    56	
    57	        // this return avoids eg. additional checks on withdraw, when user did not borrow any asset
    58	        if (EasyMath.sum(totalBorrowAmounts) == 0) return (0, 0);
    59	
    60	        IPriceProvidersRepository priceProvidersRepository = _params.siloRepository.priceProvidersRepository();
    61	
    62	        uint256[] memory borrowValues = convertAmountsToValues(
    63	            priceProvidersRepository,
    64	            _params.assets,
    65	            totalBorrowAmounts
    66	        );
    67	
    68	        // value of user's total debt
    69	        uint256 borrowTotalValue = EasyMath.sum(borrowValues);
    70	
    71	        if (borrowTotalValue == 0) return (0, 0);
    72	
    73	        uint256[] memory collateralValues = getUserCollateralValues(priceProvidersRepository, _params);
    74	
    75	        // value of user's collateral
    76	        uint256 collateralTotalValue = EasyMath.sum(collateralValues);
    77	
    78	        if (collateralTotalValue == 0) return (_INFINITY, 0);
