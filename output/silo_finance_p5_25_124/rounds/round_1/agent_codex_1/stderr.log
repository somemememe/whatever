   719	    /// @dev gets interest rates model object
   720	    /// @param _asset asset for which to calculate interest rate
   721	    /// @return IInterestRateModel interest rates model object
   722	    function _getModel(address _asset) internal view returns (IInterestRateModel) {
   723	        return IInterestRateModel(siloRepository.getInterestRateModel(address(this), _asset));
   724	    }
