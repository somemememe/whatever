   308	    /// @return collateralShare `_depositor` collateral shares based on deposited amount
   309	    function _deposit(
   310	        address _asset,
   311	        address _from,
   312	        address _depositor,
   313	        uint256 _amount,
   314	        bool _collateralOnly
   315	    )
   316	        internal
   317	        nonReentrant
   318	        validateMaxDepositsAfter(_asset)
   319	        returns (uint256 collateralAmount, uint256 collateralShare)
   320	    {
   321	        // MUST BE CALLED AS FIRST METHOD!
   322	        _accrueInterest(_asset);
   323	
   324	        if (!depositPossible(_asset, _depositor)) revert DepositNotPossible();
   325	
   326	        AssetStorage storage _state = _assetStorage[_asset];
   327	
   328	        collateralAmount = _amount;
   329	
   330	        uint256 totalDepositsCached = _collateralOnly ? _state.collateralOnlyDeposits : _state.totalDeposits;
   331	
   332	        if (_collateralOnly) {
   333	            collateralShare = _amount.toShare(totalDepositsCached, _state.collateralOnlyToken.totalSupply());
   334	            _state.collateralOnlyDeposits = totalDepositsCached + _amount;
   335	            _state.collateralOnlyToken.mint(_depositor, collateralShare);
   336	        } else {
   337	            collateralShare = _amount.toShare(totalDepositsCached, _state.collateralToken.totalSupply());
   338	            _state.totalDeposits = totalDepositsCached + _amount;
   339	            _state.collateralToken.mint(_depositor, collateralShare);
   340	        }
   341	
   342	        ERC20(_asset).safeTransferFrom(_from, address(this), _amount);
   343	
   344	        emit Deposit(_asset, _depositor, _amount, _collateralOnly);
   345	    }
   346	
   347	    /// @dev Main withdraw function that handles all withdraw logic and validation
   348	    /// @param _asset asset address that is being withdrawn
   349	    /// @param _depositor wallet address that is an owner of the deposited tokens
   350	    /// @param _receiver wallet address that will receive withdrawn tokens. It's possible that Router
   351	    /// contract is the owner of deposited tokens but we want user to get these tokens directly.
   352	    /// @param _amount amount to withdraw. If amount is equal to maximum value stored by uint256 type
   353	    /// (type(uint256).max), it will be assumed that user wants to withdraw all tokens and final account
   354	    /// will be dynamically calculated including interest.
   355	    /// @param _collateralOnly true if collateral only tokens are to be withdrawn. Otherwise false.
   356	    /// User can deposit the same asset as collateral only and as regular deposit. During withdraw,
   357	    /// it must be specified which tokens are to be withdrawn.
   358	    /// @return withdrawnAmount withdrawn amount that was transferred to user
   359	    /// @return withdrawnShare burned share based on `withdrawnAmount`
   360	    function _withdraw(address _asset, address _depositor, address _receiver, uint256 _amount, bool _collateralOnly)
   361	        internal
   362	        nonReentrant // because we transferring tokens
   363	        onlyExistingAsset(_asset)
   364	        returns (uint256 withdrawnAmount, uint256 withdrawnShare)
   365	    {
   366	        // MUST BE CALLED AS FIRST METHOD!
   367	        _accrueInterest(_asset);
   368	
   369	        (withdrawnAmount, withdrawnShare) = _withdrawAsset(
   370	            _asset,
   371	            _amount,
   372	            _depositor,
   373	            _receiver,
   374	            _collateralOnly,
   375	            0 // do not apply any fees on regular withdraw
   376	        );
   377	
   378	        if (withdrawnAmount == 0) revert UnexpectedEmptyReturn();
   379	
   380	        if (!isSolvent(_depositor)) revert NotSolvent();
   381	
   382	        emit Withdraw(_asset, _depositor, _receiver, withdrawnAmount, _collateralOnly);
   383	    }
   384	
   385	    /// @dev Main borrow function that handles all borrow logic and validation
   386	    /// @param _asset asset address that is being borrowed
   387	    /// @param _borrower wallet address that will own debt
   388	    /// @param _receiver wallet address that will receive borrowed tokens. It's possible that Router
   389	    /// contract is executing borrowing for user and should be the one receiving tokens, however,
   390	    /// the owner of the debt should be user himself.
   391	    /// @param _amount amount of asset to borrow
   392	    /// @return debtAmount borrowed amount
   393	    /// @return debtShare user debt share based on borrowed amount
   394	    function _borrow(address _asset, address _borrower, address _receiver, uint256 _amount)
   395	        internal
   396	        nonReentrant
   397	        returns (uint256 debtAmount, uint256 debtShare)
   398	    {
   399	        // MUST BE CALLED AS FIRST METHOD!
   400	        _accrueInterest(_asset);
   401	
   402	        if (!borrowPossible(_asset, _borrower)) revert BorrowNotPossible();
   403	
   404	        if (liquidity(_asset) < _amount) revert NotEnoughLiquidity();
   405	
   406	        AssetStorage storage _state = _assetStorage[_asset];
   407	
   408	        uint256 totalBorrowAmount = _state.totalBorrowAmount;
   409	        uint256 entryFee = siloRepository.entryFee();
   410	        uint256 fee = entryFee == 0 ? 0 : _amount * entryFee / Solvency._PRECISION_DECIMALS;
   411	        debtShare = (_amount + fee).toShareRoundUp(totalBorrowAmount, _state.debtToken.totalSupply());
   412	        debtAmount = _amount;
   413	
   414	        _state.totalBorrowAmount = totalBorrowAmount + _amount + fee;
   415	        _interestData[_asset].protocolFees += fee;
   416	
   417	        _state.debtToken.mint(_borrower, debtShare);
   418	
   419	        emit Borrow(_asset, _borrower, _amount);
   420	        ERC20(_asset).safeTransfer(_receiver, _amount);
   421	
   422	        // IMPORTANT - keep `validateBorrowAfter` at the end
   423	        _validateBorrowAfter(_borrower);
   424	    }
   425	
   426	    /// @dev Main repay function that handles all repay logic and validation
   427	    /// @param _asset asset address that is being repaid
   428	    /// @param _borrower wallet address for which debt is being repaid
   429	    /// @param _repayer wallet address that will pay the debt. It's possible that Router
   430	    /// contract is executing repay for user and should be the one paying the debt.
   431	    /// @param _amount amount of asset to repay
   432	    /// @return repaidAmount amount repaid
   433	    /// @return repaidShare burned debt share
   434	    function _repay(address _asset, address _borrower, address _repayer, uint256 _amount)
   435	        internal
   436	        onlyExistingAsset(_asset)
   437	        nonReentrant
   438	        returns (uint256 repaidAmount, uint256 repaidShare)
   439	    {
   440	        // MUST BE CALLED AS FIRST METHOD!
   441	        _accrueInterest(_asset);
   442	
   443	        AssetStorage storage _state = _assetStorage[_asset];
   444	        (repaidAmount, repaidShare) = _calculateDebtAmountAndShare(_state, _borrower, _amount);
   445	
   446	        if (repaidShare == 0) revert UnexpectedEmptyReturn();
   447	
   448	        emit Repay(_asset, _borrower, repaidAmount);
   449	
   450	        ERC20(_asset).safeTransferFrom(_repayer, address(this), repaidAmount);
   451	
   452	        // change debt state before, because share token state is changes the same way (notification is after burn)
   453	        _state.totalBorrowAmount -= repaidAmount;
   454	        _state.debtToken.burn(_borrower, repaidShare);
   455	    }
   456	
   457	    /// @param _assets all current assets, this is an optimization, so we don't have to read it from storage few times
   458	    /// @param _user user to liquidate
   459	    /// @param _flashReceiver address which will get all collaterals and will be notified once collaterals will be send
   460	    /// @param _flashReceiverData custom data to forward to receiver
   461	    /// @return receivedCollaterals amounts of collaterals transferred to `_flashReceiver`
   462	    /// @return shareAmountsToRepay expected amounts to repay
   463	    function _userLiquidation(
   464	        address[] memory _assets,
   465	        address _user,
   466	        IFlashLiquidationReceiver _flashReceiver,
   467	        bytes memory _flashReceiverData
   468	    )
   469	        internal
   470	        // we can not use `nonReentrant` because we are using it in `_repay`,
   471	        // and `_repay` needs to be reentered as part of a liquidation
   472	        liquidationNonReentrant
   473	        returns (uint256[] memory receivedCollaterals, uint256[] memory shareAmountsToRepay)
   474	    {
   475	        // gracefully fail if _user is solvent
   476	        if (isSolvent(_user)) {
   477	            uint256[] memory empty = new uint256[](_assets.length);
   478	            return (empty, empty);
   479	        }
   480	
   481	        (receivedCollaterals, shareAmountsToRepay) = _flashUserLiquidation(_assets, _user, address(_flashReceiver));
   482	
   483	        // _flashReceiver needs to repayFor user
   484	        _flashReceiver.siloLiquidationCallback(
   485	            _user,
   486	            _assets,
   487	            receivedCollaterals,
   488	            shareAmountsToRepay,
   489	            _flashReceiverData
   490	        );
   491	
   492	        for (uint256 i = 0; i < _assets.length; i++) {
   493	            if (receivedCollaterals[i] != 0 || shareAmountsToRepay[i] != 0) {
   494	                emit Liquidate(_assets[i], _user, shareAmountsToRepay[i], receivedCollaterals[i]);
   495	            }
   496	        }
   497	
   498	        if (!isSolvent(_user)) revert NotSolvent();
   499	    }
   500	
   501	    function _flashUserLiquidation(address[] memory _assets, address _borrower, address _liquidator)
   502	        internal
   503	        returns (uint256[] memory receivedCollaterals, uint256[] memory amountsToRepay)
   504	    {
   505	        uint256 assetsLength = _assets.length;
   506	        receivedCollaterals = new uint256[](assetsLength);
   507	        amountsToRepay = new uint256[](assetsLength);
   508	
   509	        uint256 protocolLiquidationFee = siloRepository.protocolLiquidationFee();
   510	
   511	        for (uint256 i = 0; i < assetsLength; i++) {
   512	            _accrueInterest(_assets[i]);
   513	
   514	            AssetStorage storage _state = _assetStorage[_assets[i]];
   515	
   516	            // we do not allow for partial repayment on liquidation, that's why max
   517	            (amountsToRepay[i],) = _calculateDebtAmountAndShare(_state, _borrower, type(uint256).max);
   518	
   519	            (uint256 withdrawnOnlyAmount,) = _withdrawAsset(
   520	                _assets[i],
   521	                type(uint256).max,
   522	                _borrower,
   523	                _liquidator,
   524	                true, // collateral only
   525	                protocolLiquidationFee
   526	            );
   527	
   528	            (uint256 withdrawnAmount,) = _withdrawAsset(
   529	                _assets[i],
   530	                type(uint256).max,
   531	                _borrower,
   532	                _liquidator,
   533	                false, // collateral only
   534	                protocolLiquidationFee
   535	            );
   536	
   537	            receivedCollaterals[i] = withdrawnOnlyAmount + withdrawnAmount;
   538	        }
   539	    }
