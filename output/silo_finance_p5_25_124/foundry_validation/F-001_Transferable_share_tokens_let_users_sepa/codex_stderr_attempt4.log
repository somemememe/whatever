            address(_priceRepo()),
            abi.encodeWithSelector(IPriceProvidersRepositoryLike.getPrice.selector, collateralAsset)
        );
        if (!okPrice || price == 0) return 0;

        (bool okDecimals, uint256 decimalsValue) = _staticUint(
