-        uint256 debtValue = collateralValue * maxLtv / ONE;
-        debtValue = debtValue * BORROW_SAFETY_BPS / BPS;
-        if (debtValue == 0) return 0;
-
-        uint256 entryFee = _entryFee();
-        if (entryFee == type(uint256).max) return 0;
