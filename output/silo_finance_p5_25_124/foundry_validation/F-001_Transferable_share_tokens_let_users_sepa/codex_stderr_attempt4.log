-    function _quoteBorrowAmount(address collateralAsset, address borrowAsset, uint256 collateralAmount)
-        internal
-        view
-        returns (uint256)
-    {
-        if (collateralAmount == 0) return 0;
-
-        uint256 maxLtv = _maximumLtv(collateralAsset);
