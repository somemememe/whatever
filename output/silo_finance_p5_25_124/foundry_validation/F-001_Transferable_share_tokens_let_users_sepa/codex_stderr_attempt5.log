-
-    function _quotePairAmountIn(address pair, address tokenIn, address tokenOut, uint256 amountOut)
-        internal
-        view
-        returns (uint256)
-    {
-        if (pair == address(0) || amountOut == 0) return 0;
-
-        IUniswapV2PairLike v2Pair = IUniswapV2PairLike(pair);
