/bin/bash -lc 'forge fmt --check src/FlawVerifier.sol' in /Users/zhanglongqin/AuditHoundV2/cases/silo_finance/src
diff --git a/src/FlawVerifier.sol b/src/FlawVerifier.sol
new file mode 100644
index 0000000000000000000000000000000000000000..18e10defffbb003a8fb7f0558fcc616e78171d58
