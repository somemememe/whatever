+        (bool okDecimals, uint256 assetDecimals) =
+            _staticUint(asset, abi.encodeWithSelector(IERC20Like.decimals.selector));
+        if (!okDecimals) return 0;
+        uint256 amount = targetValue * (10 ** assetDecimals) / price;
+        if (amount == 0) amount = 1;
+        return amount;
+    }
