        require(tokens.length == 1 && amounts.length == 1 && feeAmounts.length == 1, "bad flash arrays");
        require(address(tokens[0]) == _flashContext.collateralAsset, "bad collateral");
        require(amounts[0] == _flashContext.flashAmount, "bad amount");

