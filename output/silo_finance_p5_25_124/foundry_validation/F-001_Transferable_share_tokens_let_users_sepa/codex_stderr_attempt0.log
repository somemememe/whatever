+                        returns (uint256 realizedProfit)
+                    {
+                        if (realizedProfit != 0) return true;
+                    } catch (bytes memory reason) {
+                        _recordFailure(reason, "DIRECT_COLLATERAL_SHARE_ROUTE_FAILED");
