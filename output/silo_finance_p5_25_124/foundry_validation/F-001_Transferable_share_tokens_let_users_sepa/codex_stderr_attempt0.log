+    uint256 internal constant BORROW_SAFETY_BPS = 9_000;
+    uint256 internal constant FLASH_RESERVE_BPS = 10;
+
+    error CollateralShareTransferFailed();
+    error CollateralWithdrawFailed();
+    error DebtShareTransferFailed();
+
+    enum RouteKind {
+        CollateralShare,
+        DebtShare
+    }
+
+    enum Outcome {
