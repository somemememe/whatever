+        (bool okFee, uint256 entryFee) =
+            _staticUint(repository, abi.encodeWithSelector(ISiloRepositoryLike.entryFee.selector));
+        if (!okFee) return 0;
+        debtValue = debtValue * ONE / (ONE + entryFee);
