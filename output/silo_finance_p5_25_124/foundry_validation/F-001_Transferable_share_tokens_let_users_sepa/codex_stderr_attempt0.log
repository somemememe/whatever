+        amounts[1] = _min(cap, _amountForValue(asset, 100 ether));
+        amounts[2] = _min(cap, _amountForValue(asset, 1_000 ether));
+        amounts[3] = _min(cap, _amountForValue(asset, 10_000 ether));
+        amounts[4] = cap / 2;
+        amounts[5] = cap;
+    }
