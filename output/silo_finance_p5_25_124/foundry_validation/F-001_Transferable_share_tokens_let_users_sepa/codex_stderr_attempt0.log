+                        returns (bool success)
+                    {
+                        if (success) return true;
+                    } catch (bytes memory reason) {
+                        _recordFailure(reason, "FLASH_DEBT_SHARE_ROUTE_FAILED");
+                    }
+                }
+            }
+        }
