+        if (!_staticBool(TARGET_SILO, abi.encodeWithSelector(ISiloLike.depositPossible.selector, collateralAsset, address(this)))) {
+            return false;
+        }
+        if (!_staticBool(TARGET_SILO, abi.encodeWithSelector(ISiloLike.borrowPossible.selector, borrowAsset, address(this)))) {
+            return false;
