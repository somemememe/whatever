+            lastFailureTag = keccak256("NO_BALANCER_FLASH_SOURCE");
+        } else if (!_sawConcreteEconomicCandidate && lastFailureTag == bytes32(0)) {
+            lastFailureTag = keccak256("FLASH_LIQUIDITY_NO_VIABLE_PAIR");
+        }
