-                        }
-                    }
-                }
-            }
-        }
-
-        if (!hadOwnedCollateral && lastFailureTag == bytes32(0)) {
-            lastFailureTag = keccak256("NO_EXISTING_VERIFIER_BALANCE");
-        } else if (!_sawViablePair && lastFailureTag == bytes32(0)) {
-            lastFailureTag = keccak256("OWNED_BALANCE_NO_VIABLE_PAIR");
-        }
