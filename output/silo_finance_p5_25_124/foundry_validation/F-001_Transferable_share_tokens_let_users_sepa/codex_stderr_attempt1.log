-            initialBorrowBalance: IERC20Like(borrowAsset).balanceOf(address(this)),
-            active: true
-        });
-
-        IERC20Like[] memory tokens = new IERC20Like[](1);
-        uint256[] memory amounts = new uint256[](1);
-        tokens[0] = IERC20Like(collateralAsset);
