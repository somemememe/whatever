   159	    function mint(uint256 i) external {
   160	        uint256 id = max - balances[address(this)];                    // id is the next assigned id
   161	        require(id < max, "minting finished");
   162	        require (i > 0 && i <= 100, "must be between 1 and 100");
   163	        if (i + id > max) {                                            // if it goes over the max supply
   164	            i = max -  id;                                             // cap it
   165	        }
   166	        if (theDAO.transferFrom(msg.sender, address(this), oneDao*i)) { // take the DAO fee
   167	            while (i > 0) {
   168	                _transfer(address(this), msg.sender, id);
   169	                emit Mint(msg.sender, id);
   170	                i--;
   171	                id++;
   172	            }
   173	        }
   174	    }
