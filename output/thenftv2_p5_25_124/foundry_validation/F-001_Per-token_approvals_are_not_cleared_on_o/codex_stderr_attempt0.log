   20	investigation in to TheDAO. The report concluded that TheDAO tokens are securities.
   21	
   22	The following project converts each page in to an image, then shreds the images into strips. These strips can be then
   23	minted into NFTs
   24	
   25	RULES
   26	
   27	1. Each NFT requires 1 DAO token to be minted
   28	2. The DAO token will be wrapped inside the NFT
   29	3. The DAO token can be unwrapped
   30	4. When unwrapped, the NFT gets transferred to the "Dead Address"
   31	5. The NFT can be restored from the "Dead Address" with 4 DAO restoration fee
   32	6. the restoration fee goes to the Curator
   33	
   34	### Digital Assets
   35	
   36	The images are prepared with the help of a script, see script.php for the source.
   37	The input for the script is TheDAO-SEC-34-81207.pdf with the sha256-hash of:
   38	6c9ae041b9b9603da01d0aa4d912586c8d85b9fe1932c57f988d8bd0f9da3bc7
   39	
   40	After the script completes creating all the tiles, the following sha256-hash will be printed:
   41	final hash: 3ed52e4afc9030f69004f163017c3ffba0b837d90061437328af87330dee9575
   42	
   43	### Minting
   44	
   45	Minting is done sequentially from 0 to 1799
   46	Up to 100 NFTs can be minted per transaction at a time (if gas allows)
   47	
   48	At the beginning, all tokens are owned by 0x0
   49	balanceOf(address(this)) is used to track how many tokens are yet to be minted
   50	
   51	* Tokens cannot be sent to address(this)
   52	* Tokens cannot be sent to 0x0
   53	
   54	### Version 2
   55	
   56	This upgrade fixes a bug with approvals, which was found & disclosed by @alphasoups
   57	
   58	An upgrade method is provided
   59	When minting, we will still use the old contract to mint,
   60	As soon as it's minted, the NFT gets upgraded.
   61	
   62	*/
   63	
   64	import "./TheNFT.sol";
   65	//import "./safemath.sol"; // we don't need it
   66	//import "hardhat/console.sol";
   67	
   68	contract TheNFTV2 {
   69	    ITheNFTv1 v1;                                              // points to v1 of TheNFT
   70	    /**
   71	    * @dev PNG_SHA_256_HASH is a sha256 hash-sum of all 1800 bitmap tiles saved in the PNG format
   72	    * (the final hash)
   73	    */
   74	    string public constant PNG_SHA_256_HASH = "3ed52e4afc9030f69004f163017c3ffba0b837d90061437328af87330dee9575";
   75	    /**
   76	    * @dev PDF_SHA_256_HASH is a sha256 hash-sum of the pdf file TheDAO-SEC-34-81207.pdf
   77	    */
   78	    string public constant PDF_SHA_256_HASH = "6c9ae041b9b9603da01d0aa4d912586c8d85b9fe1932c57f988d8bd0f9da3bc7";
   79	    address private constant DEAD_ADDRESS = address(0x74eda0); // unwrapped NFTs go here
   80	    address public curator;                                    // the curator receives restoration fees
   81	    string private assetURL;
   82	    string private baseURI;
   83	    uint256 private immutable max;                             // total supply (1800)
   84	    uint256 private constant fee = 4;                          // fee is the amount of DAO needed to restore
   85	
   86	    // TheDAO stuff
   87	    IERC20 private immutable theDAO;                           // the contract of TheDAO, the greatest DAO of all time
   88	    uint256 private constant oneDao = 1e16;                    // 1 DAO = 16^10 wei or 0.01 ETH
   89	
   90	    mapping(address => uint256) private balances;              // counts of ownership
   91	    mapping(uint256  => address) private ownership;
   92	    mapping(uint256  => address) private approval;
   93	    mapping(address => mapping(address => bool)) private approvalAll; // operator approvals
   94	
   95	    /**
   96	     * Mint is fired when a new token is minted
   97	     */
   98	    event Mint(address owner, uint256 tokenId);
   99	    /**
  100	     * @dev Burn is fired when a token is burned
  101	     */
  102	    event Burn(address owner, uint256 tokenId);
  103	    /**
  104	     * @dev Restore is fired when a token is restored from the burn
  105	     */
  106	    event Restore(address owner, uint256 tokenId);
  107	    /**
  108	     * @dev Upgrade is fired when a token is upgraded
  109	     */
  110	    event Upgrade(address owner, uint256 tokenId);
  111	    /**
  112	     * @dev OwnershipTransferred is fired when a curator is changed
  113	     */
  114	    event OwnershipTransferred(address previousOwner, address newOwner);
  115	    /**
  116	     * @dev BaseURI is fired when the baseURI changed (set by the Curator)
  117	     */
  118	    event BaseURI(string);
  119	    /**
  120	    * @dev TheNFT constructor
  121	    * @param _theDAO address of TheDAO contract
  122	    * @param _max max supply of the NFT collection
  123	    * @param _v1 address of old version
  124	    */
  125	    constructor(
  126	        address _theDAO,
  127	        uint256 _max,
  128	        address _v1
  129	    ) {
  130	        curator = msg.sender;
  131	        theDAO = IERC20(_theDAO);
  132	        v1 = ITheNFTv1(_v1);
  133	        max = _max;
  134	        /* We will use v1 to mint */
  135	        balances[address(this)] = max;          // track how many haven't been upgraded
  136	        theDAO.approve(_v1, type(uint256).max); // allow v1 to spend our DAO
  137	    }
  138	
  139	    modifier onlyCurator {
  140	        require(
  141	            msg.sender == curator,
  142	            "only curator can call this"
  143	        );
  144	        _;
  145	    }
  146	
  147	    /**
  148	    * @dev regulators are not needed - smart contracts regulate themselves
  149	    */
  150	    modifier regulated(address _to) {
  151	        require(
  152	            _to != DEAD_ADDRESS,
  153	            "cannot send to dead address"
  154	        );
  155	        require(
  156	            _to != address(this),
  157	            "cannot send to self"
  158	        );
  159	        require(
  160	            _to != address(0),
  161	            "cannot send to 0x"
  162	        );
  163	        _;
  164	    }
  165	
  166	    /**
  167	    * @dev getStats helps to fetch some stats for the UI in a single web3 call
  168	    * @param _user the address to return the report for
  169	    * @return uint256[10] the stats
  170	    */
  171	    function getStats(address _user) external view returns(uint256[] memory) {
  172	        uint[] memory ret = new uint[](10);
  173	        ret[0] = theDAO.balanceOf(_user);                  // amount of TheDAO tokens owned by _user
  174	        ret[1] = theDAO.allowance(_user, address(this));   // amount of DAO this contract is approved to spend
  175	        ret[2] = v1.balanceOf(address(v1));                // how many NFTs to be minted
  176	        ret[3] = v1.balanceOf(DEAD_ADDRESS);               // how many NFTs are burned (v1)
  177	        ret[4] = theDAO.balanceOf(address(this));          // amount of DAO held by this contract
  178	        ret[5] = balanceOf(_user);                         // how many _user has
  179	        ret[6] = theDAO.balanceOf(address(v1));            // amount of DAO held by v1
  180	        ret[7] = balanceOf(address(this));                 // how many NFTs to be upgraded
  181	        ret[8] = balanceOf(DEAD_ADDRESS);                  // how many v2 nfts burned
  182	        if (v1.isApprovedForAll(_user, address(this))) {
  183	            ret[9] = 1;                                    // approved for upgrade?
  184	        }
  185	        return ret;
  186	    }
  187	
  188	    function upgrade(uint256[] calldata _ids) external {
  189	        for (uint256 i; i < _ids.length; i++) {
  190	            /*
  191	             * The owner must be caller, and the NFT id must not exist in this contract
  192	             * (the only way for NFTs to exist in this contract is to go through an upgrade, minting from 0x0 address)
  193	             */
  194	            require ((v1.ownerOf(_ids[i]) == msg.sender && ownership[_ids[i]] == address(0)), "not upgradable id");
  195	            v1.transferFrom(msg.sender, address(this), _ids[i]); // transfer to here
  196	            _upgrade(_ids[i]);                                   // burn * issue new nft
  197	        }
  198	    }
  199	
  200	    function _upgrade(uint256 id) internal {
  201	        v1.burn(id);                                    // take DAO token out
  202	        _transfer(address(this), msg.sender, id);       // issue new nft
  203	        emit Mint(msg.sender, id);
  204	    }
  205	
  206	    /**
  207	    * @dev mint mints a token. Requires 1 DAO per NFT to mint
  208	    */
  209	    function mint(uint256 i) external {
  210	        uint256 id = max - v1.balanceOf(address(v1));                    // id is the next assigned id
  211	        require(id < max, "minting finished");
  212	        require (i > 0 && i <= 100, "must be between 1 and 100");
  213	        if (i + id > max) {                                            // if it goes over the max supply
  214	            i = max -  id;                                             // cap it
  215	        }
  216	        require(
  217	            theDAO.transferFrom(msg.sender, address(this), oneDao*i) == true,
  218	            "DAO tokens required"
  219	        );
  220	        v1.mint(i);

