    function executeOnOpportunity() external {
        if (executed) {
            return;
        }
        executed = true;

        pathStage1RequiresExistingUndercollateralizedBorrower = false;
        pathStage2RedeemCollateralRemovesRealAssets = false;
        pathStage3CheckpointUsesCalcRewardIntegral = false;
