            swapper = value;
        } catch {}
    }

    function _isApprovedSwapper(IResupplyPairMinimal pair, address swapper) internal view returns (bool approved) {
        if (swapper == address(0)) {
            return false;
        }
        try pair.swappers(swapper) returns (bool value) {
            approved = value;
        } catch {}
    }

