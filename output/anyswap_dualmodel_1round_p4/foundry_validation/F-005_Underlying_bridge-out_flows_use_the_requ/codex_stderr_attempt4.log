+    function _raiseWNativeForRepayment(address sellToken, address wNative, address pair, uint256 targetWNative) internal {
+        uint256 remainingTarget = targetWNative;
+        uint256 rounds;
+
+        while (remainingTarget > 0 && rounds < 3) {
+            rounds++;
+
+            uint256 sellBalance = IERC20(sellToken).balanceOf(address(this));
+            require(sellBalance > 0, "no-sell-balance");
+
+            (uint256 reserveSell, uint256 reserveWNative) = _pairTwoTokenReserves(pair, sellToken, wNative);
+            uint256 sellAmount = _getAmountIn(remainingTarget, reserveSell, reserveWNative);
+            sellAmount = (sellAmount * SELL_BUFFER_BPS) / BPS_DENOMINATOR + 1;
+            if (sellAmount > sellBalance) {
+                sellAmount = sellBalance;
+            }
+
+            uint256 beforeWNative = IERC20(wNative).balanceOf(address(this));
+            _sellTokenForWNative(sellToken, wNative, pair, sellAmount);
+            uint256 gainedWNative = _positiveDelta(IERC20(wNative).balanceOf(address(this)), beforeWNative);
+            require(gainedWNative > 0, "sale-no-output");
+
+            if (gainedWNative >= remainingTarget) {
+                return;
+            }
+            remainingTarget -= gainedWNative;
+        }
+    }
