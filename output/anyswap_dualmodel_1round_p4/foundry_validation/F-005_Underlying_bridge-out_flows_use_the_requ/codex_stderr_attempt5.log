        );
        if (success) {
            actualReceivedOnTokensPath = actualReceived;
            return actualReceived < probe;
        }
        if (bytes(revertReason).length != 0 && bytes(lastRouterRevert).length == 0) {
            lastRouterRevert = revertReason;
        }
    }

    function _validateNativeUnderlyingPath(
        address anyToken,
