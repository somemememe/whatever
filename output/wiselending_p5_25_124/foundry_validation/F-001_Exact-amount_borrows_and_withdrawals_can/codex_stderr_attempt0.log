+                    return true;
+                }
+            } catch {
+                continue;
+            }
+        }
+
+        return false;
+    }
+
+    function _attemptFlashLoanBootstrap(address[] memory candidates) internal returns (bool) {
+        for (uint256 i = 0; i < candidates.length; ++i) {
