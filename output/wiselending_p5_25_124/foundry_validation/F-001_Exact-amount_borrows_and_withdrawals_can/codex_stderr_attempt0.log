+            return (false, 0, 0, 0);
+        }
+
+        if (WISE.getTotalPool(token) < borrowAmount + withdrawAmount) {
+            return (false, 0, 0, 0);
+        }
+
+        if (collateralFactor == 0) {
+            return (false, 0, 0, 0);
+        }
