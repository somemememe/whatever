+    }
+
+    function requestFlashLoanAttack(
+        address token,
+        uint256 bootstrapAmount,
+        uint256 borrowAmount,
+        uint256 withdrawAmount,
+        uint256 startingBalance
+    )
+        external
+        onlySelf
+        returns (uint256)
+    {
+        IERC20Minimal[] memory tokens = new IERC20Minimal[](1);
