[{"id": "F-048", "severity": "Medium", "confidence": "medium", "title": "Protocol seizure rewards accumulate without withdrawal mechanism", "locations": ["LayerZero/LendStorage.sol:89", "LayerZero/CoreRouter.sol:300", "LayerZero/CrossChainRouter.sol:322"], "claim": "The protocolReward mapping is updated during liquidation (both same-chain and cross-chain) but there is no function in the LayerZero contracts to withdraw or claim these accumulated rewards", "impact": "Seized tokens from liquidations become permanently locked in the protocol with no way to recover them", "paths": ["Liquidator seizes collateral -> protocolReward updated -> no withdraw function exists"]}, {"id": "F-049", "severity": "Medium", "confidence": "medium", "title": "Cross-chain liquidation success uses incorrect srcEid for borrow lookup", "locations": ["LayerZero/CrossChainRouter.sol:460"], "claim": "_handleLiquidationSuccess uses currentEid as srcEid when calling findCrossChainCollateral, but the actual srcEid from the original borrow position may differ from currentEid", "impact": "Repayment message may be sent to wrong chain or fail to find the correct borrow position, causing repayment to not be recorded", "paths": ["Cross-chain liquidation -> _handleLiquidationSuccess uses currentEid instead of actual srcEid"]}, {"id": "F-050", "severity": "Medium", "confidence": "medium", "title": "LEND distribution uses mixed borrow indices causing calculation inconsistency", "locations": ["LayerZero/LendStorage.sol:365-368"], "claim": "distributeBorrowerLend calculates borrower amount by combining borrowWithInterest (cross-chain) and borrowWithInterestSame (same-chain), but applies the local chain's borrowIndex uniformly to both", "impact": "Cross-chain borrowers may receive incorrect LEND reward calculations due to mismatched borrow indices between chains", "paths": ["User has cross-chain borrow -> distributeBorrowerLend called -> mixed index calculation"]}, {"id": "F-051", "severity": "Medium", "confidence": "medium", "title": "Cross-chain liquidation uses seize amount as synthetic borrow in health check", "locations": ["LayerZero/CrossChainRouter.sol:431-436"], "claim": "_checkLiquidationValid treats payload.amount (seizeTokens) as the borrowAmount parameter in getHypotheticalAccountLiquidityCollateral, effectively checking if the borrower becomes underwater by losing seizeTokens of collateral", "impact": "Liquidation may proceed incorrectly - the check compares collateral after seizure rather than verifying the actual debt position", "paths": ["Liquidator calls liquidateCrossChain -> _checkLiquidationValid uses seizeTokens as borrowAmount"]}, {"id": "F-052", "severity": "Medium", "confidence": "medium", "title": "Liquidation failure handler transfers tokens without balance verification", "locations": ["LayerZero/CrossChainRouter.sol:478-484"], "claim": "_handleLiquidationFailure transfers payload.amount tokens to the liquidator without checking if the contract has sufficient balance of the underlying token", "impact": "If insufficient balance, the transfer will fail silently or revert without proper error handling, leaving the liquidation in an inconsistent state", "paths": ["Liquidation execution fails -> _handleLiquidationFailure -> safeTransfer without balance check"]}, {"id": "F-053", "severity": "Low", "confidence": "medium", "title": "Cross-chain borrow request allows borrowing without entering destination market", "locations": ["LayerZero/CrossChainRouter.sol:625"], "claim": "borrowForCrossChain is called but the destination market is never entered via enterMarkets() on the destination chain", "impact": "User may not be properly tracked in the destination chain's markets, potentially affecting future operations or rewards", "paths": ["User borrows cross-chain -> borrowForCrossChain executes -> market not entered"]}, {"id": "F-054", "severity": "Low", "confidence": "low", "title": "Supply function uses pre-mint exchange rate after token transfer", "locations": ["LayerZero/CoreRouter.sol:74-80"], "claim": "supply() captures exchangeRateBefore after transferring tokens from user, then uses it to calculate minted lTokens - if mint() internally accrues and changes rate, the calculation uses stale pre-transfer rate", "impact": "User may receive fewer lTokens than expected if exchange rate changes between transfer and mint", "paths": ["User supplies tokens -> transferFrom -> exchangeRateBefore captured -> mint executes -> mintTokens calculated with stale rate"]}]
