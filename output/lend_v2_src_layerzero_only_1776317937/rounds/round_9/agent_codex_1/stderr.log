// SPDX-License-Identifier: UNLICENSED
pragma solidity 0.8.23;
import \"forge-std/Test.sol\";

contract C {
    struct S { uint x; }
    function a() external pure returns (uint) {
        S memory s = S(0);
        b(s);
        return s.x;
    }
    function b(S memory s) internal pure {
        s.x = 7;
    }
}

contract T is Test {
    function testMem() public {
        C c = new C();
        assertEq(c.a(), 7);
