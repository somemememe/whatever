+            ok = true;
+            router = SUSHISWAP_ROUTER;
+            viaWeth = true;
+            amountIn = in4;
+        }
+    }
+
+    function _quoteAmountsIn(
+        address router,
+        address tokenIn,
+        address tokenOut,
+        uint256 amountOut,
