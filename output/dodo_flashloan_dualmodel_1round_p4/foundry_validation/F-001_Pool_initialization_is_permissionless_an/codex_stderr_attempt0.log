+    function _planBorrowBase(
+        IDVMLike pool,
+        address base,
+        address quote,
+        uint256 baseReserve
+    ) internal returns (Plan memory best) {
+        pool.init(address(this), base, quote, 0, address(zeroFeeModel), 1, 0, false);
