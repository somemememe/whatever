+        //   effect, but it is not used as the profit path here because the harness requires a profit attempt.
+        if (originalBase == address(0) || originalQuote == address(0)) {
+            return;
+        }
+        if (baseReserve == 0 || quoteReserve == 0) {
+            return;
+        }
+
+        Plan memory basePlan = _planBorrowBase(pool, originalBase, originalQuote, baseReserve);
+        Plan memory quotePlan = _planBorrowQuote(pool, originalBase, originalQuote, quoteReserve);
+        Plan memory chosen = basePlan.estimatedProfit >= quotePlan.estimatedProfit ? basePlan : quotePlan;
+        if (chosen.kind == RouteKind.None || chosen.estimatedProfit == 0) {
+            return;
+        }
+
+        if (chosen.kind == RouteKind.BorrowBase) {
+            pool.init(address(this), originalBase, originalQuote, 0, address(zeroFeeModel), 1, 0, false);
+            uint256 beforeBalance = IERC20Like(originalBase).balanceOf(address(this));
+            pool.flashLoan(
+                chosen.borrowAmount,
+                0,
+                address(this),
+                abi.encode(chosen.kind, chosen.router, chosen.viaWeth, chosen.exactRepayOpposite, chosen.maxBorrowTokenToSell)
+            );
+            realizedProfitToken = originalBase;
+            realizedProfitAmount = IERC20Like(originalBase).balanceOf(address(this)) - beforeBalance;
+            return;
+        }
+
+        pool.init(address(this), originalBase, originalQuote, 0, address(zeroFeeModel), MAX_I, 0, false);
+        uint256 beforeBalanceQuote = IERC20Like(originalQuote).balanceOf(address(this));
+        pool.flashLoan(
+            0,
+            chosen.borrowAmount,
+            address(this),
+            abi.encode(chosen.kind, chosen.router, chosen.viaWeth, chosen.exactRepayOpposite, chosen.maxBorrowTokenToSell)
+        );
+        realizedProfitToken = originalQuote;
+        realizedProfitAmount = IERC20Like(originalQuote).balanceOf(address(this)) - beforeBalanceQuote;
+    }
