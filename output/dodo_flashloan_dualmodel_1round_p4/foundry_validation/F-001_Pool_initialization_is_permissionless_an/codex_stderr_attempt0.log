+        }
+
+        (bool ok1, uint256 in1) = _quoteAmountsIn(UNISWAP_V2_ROUTER, tokenIn, tokenOut, amountOut, false);
+        if (ok1) {
+            ok = true;
+            router = UNISWAP_V2_ROUTER;
+            viaWeth = false;
+            amountIn = in1;
+        }
+
+        (bool ok2, uint256 in2) = _quoteAmountsIn(UNISWAP_V2_ROUTER, tokenIn, tokenOut, amountOut, true);
+        if (ok2 && (!ok || in2 < amountIn)) {
+            ok = true;
+            router = UNISWAP_V2_ROUTER;
+            viaWeth = true;
+            amountIn = in2;
+        }
+
+        (bool ok3, uint256 in3) = _quoteAmountsIn(SUSHISWAP_ROUTER, tokenIn, tokenOut, amountOut, false);
+        if (ok3 && (!ok || in3 < amountIn)) {
+            ok = true;
+            router = SUSHISWAP_ROUTER;
+            viaWeth = false;
+            amountIn = in3;
+        }
+
+        (bool ok4, uint256 in4) = _quoteAmountsIn(SUSHISWAP_ROUTER, tokenIn, tokenOut, amountOut, true);
+        if (ok4 && (!ok || in4 < amountIn)) {
+            ok = true;
+            router = SUSHISWAP_ROUTER;
+            viaWeth = true;
+            amountIn = in4;
+        }
+    }
+
+    function _quoteAmountsIn(
+        address router,
+        address tokenIn,
+        address tokenOut,
