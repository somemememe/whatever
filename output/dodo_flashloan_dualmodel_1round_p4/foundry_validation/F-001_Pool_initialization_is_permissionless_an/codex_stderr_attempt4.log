        address originalQuote = pool._QUOTE_TOKEN_();

        address[5] memory profitCandidates = [originalBase, originalQuote, WETH, USDC, DAI];
        uint256[5] memory startingBalances;
        for (uint256 i = 0; i < profitCandidates.length; ++i) {
