            }

            (bool ok, address router, bool viaWeth, uint256 amountOut) = _bestSwapOutput(tokenIn, tokenOut, amountIn);
            if (!ok || amountOut <= bestOut) {
                continue;
            }

            bestOut = amountOut;
            best = ExitPlan(router, tokenOut, (amountOut * 95) / 100, viaWeth);
        }
