+    uint256 internal constant ZERO_DEPOSIT = 0;
+    uint256 internal constant UNIT_QUANTITY = 1;
+    uint256 internal constant DOUBLE_QUANTITY = 2;
+
+    enum Mode {
+        Idle,
+        AddressLockCreateLock,
+        MintReceiver,
+        SplitReceiver,
+        DepositAdditionalReceiver
