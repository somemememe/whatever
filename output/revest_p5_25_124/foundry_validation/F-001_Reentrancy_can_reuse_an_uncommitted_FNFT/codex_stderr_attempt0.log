+    function executeOnOpportunity() external {
+        startBalance = _wethBalance();
+        realizedProfit = 0;
+        collisionObserved = false;
+        callbackId = type(uint256).max;
+        reenteredId = type(uint256).max;
+        observedSupply = 0;
+        observedBalance = 0;
+        usedPath = "";
+        lastFailure = "";
