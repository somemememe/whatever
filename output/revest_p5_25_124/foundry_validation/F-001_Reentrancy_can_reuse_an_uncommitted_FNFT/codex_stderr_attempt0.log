+
+        if (inReentry || mode != Mode.AddressLockCreateLock) {
+            return false;
+        }
+
+        inReentry = true;
+        reenteredId = _tryMintAddressLock(ZERO_DEPOSIT, UNIT_QUANTITY, false, 0);
+        inReentry = false;
+    }
+
+    function updateLock(uint256, uint256, bytes calldata) external view {
