+        collisionObserved = false;
+        callbackId = type(uint256).max;
+        reenteredId = type(uint256).max;
+        observedSupply = 0;
+        observedBalance = 0;
+        usedPath = "";
+        lastFailure = "";
+        mode = Mode.Idle;
+        inReentry = false;
+
+        _ensureApprovals();
+
+        _attemptCreateLockReentry();
+        _attemptReceiverReentry();
+        _attemptSplitReentry();
+        _attemptDepositAdditionalReentry();
