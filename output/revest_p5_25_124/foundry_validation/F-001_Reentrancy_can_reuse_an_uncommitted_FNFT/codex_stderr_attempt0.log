        // outer call reaches `doMint()`. This preserves the exact finding causality for the trigger-based path.
        uint256 outerId = _tryMintAddressLock(ZERO_DEPOSIT, UNIT_QUANTITY, false, 0);
        mode = Mode.Idle;

