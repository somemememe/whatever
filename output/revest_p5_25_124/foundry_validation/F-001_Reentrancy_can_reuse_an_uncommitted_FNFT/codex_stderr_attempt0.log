+            return 0;
+        }
+        return IFNFTHandlerLike(_fnftHandlerAddress()).getSupply(fnftId);
+    }
+
+    function _wethBalance() internal view returns (uint256) {
+        return IERC20Like(WETH).balanceOf(address(this));
+    }
+}

