+        _recordCollision(expectedId, activeMode);
+        return collisionObserved;
+    }
+
+    function _recordCollision(uint256 expectedId, Mode activeMode) internal {
+        if (reenteredId != expectedId || expectedId == type(uint256).max) {
+            if (bytes(lastFailure).length == 0) {
