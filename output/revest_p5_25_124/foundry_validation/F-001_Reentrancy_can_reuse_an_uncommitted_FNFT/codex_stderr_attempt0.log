+            newSeriesId = id;
+        } catch {
+            mode = Mode.Idle;
+            _noteFailure("PATH4_DEPOSIT_CALL_REVERTED");
+            return false;
+        }
+
+        mode = Mode.Idle;
+
+        if (_finalizeCollision(newSeriesId, Mode.DepositAdditionalReceiver)) {
+            return true;
+        }
+
+        _noteFailure("PATH4_DEPOSIT_NO_COLLISION");
+        return false;
+    }
