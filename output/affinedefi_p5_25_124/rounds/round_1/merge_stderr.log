   348	    function harvest(Strategy[] calldata strategyList) external virtual onlyRole(HARVESTER) {
   349	        // Profit must not be unlocking
   350	        require(block.timestamp >= lastHarvest + LOCK_INTERVAL, "BV: profit unlocking");
