   439	    function _liquidate(uint256 amount) internal returns (uint256) {
   440	        uint256 amountLiquidated;
   441	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   442	            Strategy strategy = withdrawalQueue[i];
   443	            if (address(strategy) == address(0)) {
   444	                break;
   445	            }
   446	
   447	            uint256 balance = _asset.balanceOf(address(this));
   448	            if (balance >= amount) {
   449	                break;
   450	            }
   451	
   452	            uint256 amountNeeded = amount - balance;
   453	            amountNeeded = Math.min(amountNeeded, strategies[strategy].balance);
   454	
   455	            // Force withdraw of token from strategy
   456	            uint256 withdrawn = _withdrawFromStrategy(strategy, amountNeeded);
