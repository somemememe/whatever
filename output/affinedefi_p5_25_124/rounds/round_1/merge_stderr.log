   475	    /// @notice  Rebalance strategies according to given tvl bps
   476	    function rebalance() external onlyRole(HARVESTER) {
   477	        uint256 tvl = vaultTVL();
   478	
   479	        // Loop through all strategies. Divesting from those whose tvl is too high,
   480	        // Invest in those whose tvl is too low
   481	
   482	        // MAX_STRATEGIES is always equal to withdrawalQueue.length
   483	        uint256[MAX_STRATEGIES] memory amountsToInvest;
   484	
   485	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   486	            Strategy strategy = withdrawalQueue[i];
   487	            if (address(strategy) == address(0)) {
   488	                break;
   489	            }
   490	
   491	            uint256 idealStrategyTVL = (tvl * strategies[strategy].tvlBps) / MAX_BPS;
   492	            uint256 currStrategyTVL = strategy.totalLockedValue();
   493	            if (idealStrategyTVL < currStrategyTVL) {
   494	                _withdrawFromStrategy(strategy, currStrategyTVL - idealStrategyTVL);
   495	            }
   496	            if (idealStrategyTVL > currStrategyTVL) {
   497	                amountsToInvest[i] = idealStrategyTVL - currStrategyTVL;
   498	            }
   499	        }
   500	
   501	        // Loop through the strategies to invest in, and invest in them
   502	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   503	            uint256 amountToInvest = amountsToInvest[i];
   504	            if (amountToInvest == 0) {
