   354	
   355	        // Used to store the new total strategy holdings after harvesting.
   356	        uint256 newTotalStrategyHoldings = oldTotalStrategyHoldings;
   357	
   358	        // Used to store the total profit accrued by the strategies.
   359	        uint256 totalProfitAccrued;
   360	
   361	        for (uint256 i = 0; i < strategyList.length; i = uncheckedInc(i)) {
   362	            // Get the strategy at the current index.
