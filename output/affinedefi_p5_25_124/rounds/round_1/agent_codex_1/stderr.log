   151	    function _organizeWithdrawalQueue() internal {
   152	        // number or empty values we've seen iterating from left to right
   153	        uint256 offset;
   154	
   155	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   156	            Strategy strategy = withdrawalQueue[i];
   157	            if (address(strategy) == address(0)) {
   158	                offset += 1;
   159	            } else if (offset > 0) {
   160	                // index of first empty value seen takes on value of `strategy`
   161	                withdrawalQueue[i - offset] = strategy;
   162	                withdrawalQueue[i] = Strategy(address(0));
   163	            }
   164	        }
   165	    }
   166	
   167	    /**
   168	     * @notice Remove a strategy from the withdrawal queue. Fully divest from the strategy.
   169	     * @param strategy The strategy to remove
   170	     * @dev  removeStrategy MUST be called with harvest via multicall. This helps get the most accurate tvl numbers
   171	     * and allows us to add any realized profits to our lockedProfit
   172	     */
   173	    function removeStrategy(Strategy strategy) external onlyGovernance {
   174	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   175	            if (strategy != withdrawalQueue[i]) {
   176	                continue;
   177	            }
   178	
   179	            strategies[strategy].isActive = false;
   180	
   181	            // The vault can re-allocate bps to a new strategy
   182	            totalBps -= strategies[strategy].tvlBps;
   183	            strategies[strategy].tvlBps = 0;
   184	
   185	            // Remove strategy from withdrawal queue
   186	            withdrawalQueue[i] = Strategy(address(0));
   187	            emit StrategyRemoved(strategy);
   188	            _organizeWithdrawalQueue();
   189	
   190	            // Take all money out of strategy.
   191	            _withdrawFromStrategy(strategy, strategy.totalLockedValue());
   192	            break;
   193	        }
   194	    }
   195	
   196	    /**
   197	     * @notice Update tvl bps assigned to the given list of strategies
   198	     * @param strategyList The list of strategies
   199	     * @param strategyBps The new bps
   200	     */
   201	    function updateStrategyAllocations(Strategy[] calldata strategyList, uint16[] calldata strategyBps)
   202	        external
   203	        onlyRole(HARVESTER)
   204	    {
   205	        for (uint256 i = 0; i < strategyList.length; i = uncheckedInc(i)) {
   206	            // Get the strategy at the current index.
   207	            Strategy strategy = strategyList[i];
   208	
   209	            // Ignore inactive (removed) strategies
   210	            if (!strategies[strategy].isActive) continue;
   211	
   212	            // update tvl bps
   213	            totalBps -= strategies[strategy].tvlBps;
   214	            _increaseTVLBps(strategyBps[i]);
   215	            strategies[strategy].tvlBps = strategyBps[i];
   216	        }
   217	        emit StrategyAllocsUpdated(strategyList, strategyBps);
   218	    }
   219	
   220	    /**
   221	     * @notice Emitted when we update tvl bps for a list of strategies.
   222	     * @param strategyList The list of strategies.
   223	     * @param strategyBps The new tvl bps for the strategies
   224	     */
   225	    event StrategyAllocsUpdated(Strategy[] strategyList, uint16[] strategyBps);
   226	
   227	    /*//////////////////////////////////////////////////////////////
   228	                      STRATEGY DEPOSIT/WITHDRAWAL
   229	    //////////////////////////////////////////////////////////////*/
   230	
   231	    /**
   232	     * @notice Emitted after the Vault deposits into a strategy contract.
   233	     * @param strategy The strategy that was deposited into.
   234	     * @param assets The amount of assets deposited.
   235	     */
   236	    event StrategyDeposit(Strategy indexed strategy, uint256 assets);
   237	
   238	    /**
   239	     * @notice Emitted after the Vault withdraws funds from a strategy contract.
   240	     * @param strategy The strategy that was withdrawn from.
   241	     * @param assetsRequested The amount of assets we tried to divest from the strategy.
   242	     * @param assetsReceived The amount of assets actually withdrawn.
   243	     */
   244	    event StrategyWithdrawal(Strategy indexed strategy, uint256 assetsRequested, uint256 assetsReceived);
   245	
   246	    function depositIntoStrategy(Strategy strategy, uint256 assets) external virtual onlyRole(HARVESTER) {
   247	        _depositIntoStrategy(strategy, assets);
   248	    }
   249	
   250	    /// @notice Deposit `assetAmount` amount of `asset` into strategies according to each strategy's `tvlBps`.
   251	    function _depositIntoStrategies(uint256 assetAmount) internal {
   252	        // All non-zero strategies are active
   253	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   254	            Strategy strategy = withdrawalQueue[i];
   255	            if (address(strategy) == address(0)) {
   256	                break;
   257	            }
   258	            _depositIntoStrategy(strategy, (assetAmount * strategies[strategy].tvlBps) / MAX_BPS);
   259	        }
   260	    }

