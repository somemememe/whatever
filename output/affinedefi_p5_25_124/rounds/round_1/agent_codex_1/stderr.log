   301	        uint256 oldStratTVL = strategies[strategy].balance;
   302	        uint256 newStratTvl = strategy.totalLockedValue();
   303	        strategies[strategy].balance = uint232(newStratTvl);
   304	
   305	        // Decrease totalStrategyHoldings to account for the withdrawal.
   306	        // If we haven't harvested in a long time, newStratTvl could be bigger than oldStratTvl
   307	        totalStrategyHoldings -= oldStratTVL > newStratTvl ? oldStratTVL - newStratTvl : 0;
   308	        emit StrategyWithdrawal({strategy: strategy, assetsRequested: assets, assetsReceived: amountWithdrawn});
   309	        return amountWithdrawn;
   310	    }
   311	
   312	    /// @dev A small wrapper around divest(). We try-catch to make sure that a bad strategy does not pause withdrawals.
   313	    function _divest(Strategy strategy, uint256 assets) internal returns (uint256) {
   314	        try strategy.divest(assets) returns (uint256 amountDivested) {
   315	            return amountDivested;
   316	        } catch {
   317	            return 0;
   318	        }
   319	    }
   320	
   321	    /*//////////////////////////////////////////////////////////////
   322	                               HARVESTING
   323	    //////////////////////////////////////////////////////////////*/
   324	
   325	    /**
   326	     * @notice A timestamp representing when the most recent harvest occurred.
   327	     * @dev Since the time since the last harvest is used to calculate management fees, this is set
   328	     * to `block.timestamp` (instead of 0) during initialization.
   329	     */
   330	    uint128 public lastHarvest;
   331	    /// @notice The amount of profit *originally* locked after harvesting from a strategy
   332	    uint128 public maxLockedProfit;
   333	    /// @notice Amount of time in seconds that profit takes to fully unlock. See lockedProfit().
   334	    uint256 public constant LOCK_INTERVAL = 24 hours;
   335	
   336	    /**
   337	     * @notice Emitted after a successful harvest.
   338	     * @param user The authorized user who triggered the harvest.
   339	     * @param strategies The trusted strategies that were harvested.
   340	     */
   341	    event Harvest(address indexed user, Strategy[] strategies);
   342	
   343	    /**
   344	     * @notice Harvest a set of trusted strategies.
   345	     * @param strategyList The trusted strategies to harvest.
   346	     * @dev Will always revert if profit from last harvest has not finished unlocking.
   347	     */
   348	    function harvest(Strategy[] calldata strategyList) external virtual onlyRole(HARVESTER) {
   349	        // Profit must not be unlocking
   350	        require(block.timestamp >= lastHarvest + LOCK_INTERVAL, "BV: profit unlocking");
   351	
   352	        // Get the Vault's current total strategy holdings.
   353	        uint256 oldTotalStrategyHoldings = totalStrategyHoldings;
   354	
   355	        // Used to store the new total strategy holdings after harvesting.
   356	        uint256 newTotalStrategyHoldings = oldTotalStrategyHoldings;
   357	
   358	        // Used to store the total profit accrued by the strategies.
   359	        uint256 totalProfitAccrued;
   360	
   361	        for (uint256 i = 0; i < strategyList.length; i = uncheckedInc(i)) {
   362	            // Get the strategy at the current index.
   363	            Strategy strategy = strategyList[i];
   364	
   365	            // Ignore inactive (removed) strategies
   366	            if (!strategies[strategy].isActive) {
   367	                continue;
   368	            }
   369	
   370	            // Get the strategy's previous and current balance.
   371	            uint232 balanceLastHarvest = strategies[strategy].balance;
   372	            uint256 balanceThisHarvest = strategy.totalLockedValue();
   373	
   374	            // Update the strategy's stored balance.
   375	            strategies[strategy].balance = uint232(balanceThisHarvest);
   376	
   377	            // Increase/decrease newTotalStrategyHoldings based on the profit/loss registered.
   378	            // We cannot wrap the subtraction in parenthesis as it would underflow if the strategy had a loss.
   379	            newTotalStrategyHoldings = newTotalStrategyHoldings + balanceThisHarvest - balanceLastHarvest;
   380	
   381	            unchecked {
   382	                // Update the total profit accrued while counting losses as zero profit.
   383	                // Cannot overflow as we already increased total holdings without reverting.
   384	                totalProfitAccrued += balanceThisHarvest > balanceLastHarvest
   385	                    ? balanceThisHarvest - balanceLastHarvest // Profits since last harvest.
   386	                    : 0; // If the strategy registered a net loss we don't have any new profit.
   387	            }
   388	        }
   389	
   390	        // Update max unlocked profit based on any remaining locked profit plus new profit.
   391	        maxLockedProfit = uint128(lockedProfit() + totalProfitAccrued);
   392	
   393	        // Set strategy holdings to our new total.
   394	        totalStrategyHoldings = newTotalStrategyHoldings;
   395	
   396	        // Assess fees (using old lastHarvest) and update the last harvest timestamp.
   397	        _assessFees();
   398	        lastHarvest = uint128(block.timestamp);
   399	
   400	        emit Harvest(msg.sender, strategyList);
   401	    }
   402	
   403	    /**
   404	     * @notice Current locked profit amount.
   405	     * @dev Profit unlocks uniformly over `LOCK_INTERVAL` seconds after the last harvest
   406	     */
   407	    function lockedProfit() public view virtual returns (uint256) {
   408	        if (block.timestamp >= lastHarvest + LOCK_INTERVAL) {
   409	            return 0;
   410	        }
   411	
   412	        uint256 unlockedProfit = (maxLockedProfit * (block.timestamp - lastHarvest)) / LOCK_INTERVAL;
   413	        return maxLockedProfit - unlockedProfit;
   414	    }
   415	
   416	    /*//////////////////////////////////////////////////////////////
   417	                        LIQUIDATION/REBALANCING
   418	    //////////////////////////////////////////////////////////////*/
   419	
   420	    /// @notice The total amount of the underlying asset the vault has.
   421	    function vaultTVL() public view returns (uint256) {
   422	        return _asset.balanceOf(address(this)) + totalStrategyHoldings;
   423	    }
   424	
   425	    /**
   426	     * @notice Emitted when the vault must make a certain amount of assets available
   427	     * @dev We liquidate during cross chain rebalancing or withdrawals.
   428	     * @param assetsRequested The amount we wanted to make available for withdrawal.
   429	     * @param assetsLiquidated The amount we actually liquidated.
   430	     */
   431	    event Liquidation(uint256 assetsRequested, uint256 assetsLiquidated);
   432	
   433	    /**
   434	     * @notice Withdraw `amount` of underlying asset from strategies.
   435	     * @dev Always check the return value when using this function, we might not liquidate anything!
   436	     * @param amount The amount we want to liquidate
   437	     * @return The amount we actually liquidated
   438	     */
   439	    function _liquidate(uint256 amount) internal returns (uint256) {
   440	        uint256 amountLiquidated;
   441	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   442	            Strategy strategy = withdrawalQueue[i];
   443	            if (address(strategy) == address(0)) {
   444	                break;
   445	            }
   446	
   447	            uint256 balance = _asset.balanceOf(address(this));
   448	            if (balance >= amount) {
   449	                break;
   450	            }
   451	
   452	            uint256 amountNeeded = amount - balance;
   453	            amountNeeded = Math.min(amountNeeded, strategies[strategy].balance);
   454	
   455	            // Force withdraw of token from strategy
   456	            uint256 withdrawn = _withdrawFromStrategy(strategy, amountNeeded);
   457	            amountLiquidated += withdrawn;
   458	        }
   459	        emit Liquidation({assetsRequested: amount, assetsLiquidated: amountLiquidated});
   460	        return amountLiquidated;
   461	    }
   462	
   463	    /**
   464	     * @notice Assess fees.
   465	     * @dev This is called during harvest() to assess management fees.
   466	     */
   467	    function _assessFees() internal virtual {}
   468	
   469	    /**
   470	     * @notice Emitted when we do a strategy rebalance, i.e. when we make the strategy tvls match their tvl bps
   471	     * @param caller The caller
   472	     */
   473	    event Rebalance(address indexed caller);
   474	
   475	    /// @notice  Rebalance strategies according to given tvl bps
   476	    function rebalance() external onlyRole(HARVESTER) {
   477	        uint256 tvl = vaultTVL();
   478	
   479	        // Loop through all strategies. Divesting from those whose tvl is too high,
   480	        // Invest in those whose tvl is too low
   481	
   482	        // MAX_STRATEGIES is always equal to withdrawalQueue.length
   483	        uint256[MAX_STRATEGIES] memory amountsToInvest;
   484	
   485	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   486	            Strategy strategy = withdrawalQueue[i];
   487	            if (address(strategy) == address(0)) {
   488	                break;
   489	            }
   490	
   491	            uint256 idealStrategyTVL = (tvl * strategies[strategy].tvlBps) / MAX_BPS;
   492	            uint256 currStrategyTVL = strategy.totalLockedValue();
   493	            if (idealStrategyTVL < currStrategyTVL) {
   494	                _withdrawFromStrategy(strategy, currStrategyTVL - idealStrategyTVL);
   495	            }
   496	            if (idealStrategyTVL > currStrategyTVL) {
   497	                amountsToInvest[i] = idealStrategyTVL - currStrategyTVL;
   498	            }
   499	        }
   500	
   501	        // Loop through the strategies to invest in, and invest in them
   502	        for (uint256 i = 0; i < MAX_STRATEGIES; i = uncheckedInc(i)) {
   503	            uint256 amountToInvest = amountsToInvest[i];
   504	            if (amountToInvest == 0) {
   505	                continue;
   506	            }
   507	
   508	            // We aren't guaranteed that the vault has `amountToInvest` since there can be slippage
   509	            // when divesting from strategies
   510	            // NOTE: Strategies closer to the start of the queue are more likely to get the exact
   511	            // amount of money needed
   512	            amountToInvest = Math.min(amountToInvest, _asset.balanceOf(address(this)));
   513	            if (amountToInvest == 0) {
   514	                break;
   515	            }
   516	            // Deposit into strategy, making sure to not count this investment as a profit
   517	            _depositIntoStrategy(withdrawalQueue[i], amountToInvest);
   518	        }
   519	
   520	        emit Rebalance(msg.sender);
   521	    }
   522	}

