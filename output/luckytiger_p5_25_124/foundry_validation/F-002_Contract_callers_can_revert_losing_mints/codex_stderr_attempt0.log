+        return ((amount * FLASH_BPS_DENOMINATOR) / FLASH_BPS_NUMERATOR) + 1;
+    }
+
+    function _wrapAllEth() internal {
+        uint256 ethBalance = address(this).balance;
+        if (ethBalance > 0) {
+            WETH.deposit{value: ethBalance}();
+        }
+    }
