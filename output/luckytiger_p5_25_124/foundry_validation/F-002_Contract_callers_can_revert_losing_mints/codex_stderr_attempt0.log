+        if (address(this).balance >= mintPrice) {
+            _attemptDirect(mintPrice);
+        } else {
+            _attemptWithFlashSwap(mintPrice);
+        }
+
+        _wrapAllEth();
+
+        uint256 endingValue = WETH.balanceOf(address(this));
+        if (endingValue <= startingValue) revert NoNetProfit();
