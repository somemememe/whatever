            hypothesisRefuted = true;
            return;
        } catch (bytes memory reason) {
            redemptionRevertData = reason;
            redemptionUnsupportedObserved = _matchesSelector(reason, Unsupported.selector);
        }

        if (!redemptionUnsupportedObserved) {
