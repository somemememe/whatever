    address public USDT_ADDRESS;

    function setAddressesCurve(address TriPool_, address ADDRESSPROVIDER_, address USDC_ADDRESS_, address USDT_ADDRESS_) internal {
//        TriPool = 0xbEbc44782C7dB0a1A60Cb6fe97d0b483032FF1C7;
