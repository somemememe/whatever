    }   

    /*
     * Withdraws USDT from Compound V2 to this contract
     */
    function withdrawUSDTfromCmp(uint amount) internal {
        ICompoundV2(compoundV2cUSDTAddress).redeemUnderlying(amount);
    }    
}

