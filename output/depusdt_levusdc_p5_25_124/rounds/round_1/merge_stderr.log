   550	    /**
   551	     * @notice User supplies assets into the market and receives DepTokens in exchange
   552	     * @dev Assumes interest has already been accrued up to the current block
   553	     * @param minter The address of the account which is supplying the assets
   554	     * @param mintAmount The amount of the underlying asset to supply
   555	     */
   556	    function mintFresh(address minter, uint mintAmount) internal {
   557	        /* Fail if mint not allowed */
   558	        // console.log("mint fresh this deptoken addr ", address(this));
   559	        uint allowed = matrixpricer.mintAllowed(address(this), minter);
   560	        if (allowed != 0) {
   561	            revert MintMatrixpricerRejection(allowed);
   562	        }
   563	
   564	        /* after the updates in accrualInterest(), these should match */
   565	        if (accrualBlockNumber != getBlockNumber()) {
   566	            revert MintFreshnessCheck();
   567	        }
   568	
   569	        Exp memory exchangeRate = Exp({mantissa: exchangeRateStoredInternal()});
   570	        //console.log("mintFresh - exchangeRate is: ", exchangeRate.mantissa);
   571	        // start executing transfers according to the completed calculations
   572	
   573	        /*
   574	         *  We call `doTransferIn` for the minter and the mintAmount.
   575	         *  Note: The DepToken can only handle USDT!
   576	         *  `doTransferIn` reverts if anything goes wrong, since we can't be sure if side-effects occurred. 
   577	         *  The function returns the amount actually transferred, after gas. 
   578	         *  On success, the DepToken holds an additional `actualMintAmount` of cash.
   579	         */
   580	        uint actualMintAmount = doTransferIn(minter, mintAmount);
   581	        //console.log("mintFresh - actualMintAmount is: ",  actualMintAmount);
   582	        /*
   583	         * We get the current exchange rate and calculate the number of DepTokens to be minted:
   584	         *  mintTokens = actualMintAmount / exchangeRate
   585	         */
   586	
   587	        uint mintTokens = div_(actualMintAmount, exchangeRate);
   588	//        console.log("deptoken actual mint amount=", actualMintAmount);
   589	//        console.log("deptoken Mint Token amount=", mintTokens);
   590	        /*
   591	         * We calculate the new total supply of DepTokens and minter token balance, checking for overflow:
   592	         *  totalSupplyNew = totalSupply + mintTokens
   593	         *  accountTokensNew = accountTokens[minter] + mintTokens
   594	         * And write them into storage
   595	         */
   596	        totalSupply = totalSupply + mintTokens;
   597	        accountTokens[minter] = accountTokens[minter] + mintTokens;
   598	
   599	        // deposit mintAmount to compound V2
   600	        uint currUSDTBalance = getCashExReserves();  // usdt in this contract, 1e6
   601	        if(checkCompound(currUSDTBalance)){
   602	            supplyUSDT2Cmp(currUSDTBalance - thresholdUSDT);
   603	        }
   604	
   605	        /* We emit a Mint event, and a Transfer event */
   606	        emit Mint(minter, actualMintAmount, mintTokens, supplyRatePerBlock());
   607	        emit Transfer(address(this), minter, mintTokens);
   608	    }
