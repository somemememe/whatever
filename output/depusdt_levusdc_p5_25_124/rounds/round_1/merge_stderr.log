   537	    /**
   538	     * @notice check if sufficient USDT to push to compound
   539	     * @dev
   540	     * @return if true, then transfer
   541	     */
   542	    function checkCompound(uint currUSDTBalance) internal pure returns (bool) {
   543	        if(currUSDTBalance > minTransferAmtUSDT+thresholdUSDT){
   544	            return true;
   545	        }else{
