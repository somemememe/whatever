   610	    /**
   611	     * @notice Sender redeems DepTokens in exchange for the underlying asset
   612	     * @dev Accrues interest whether or not the operation succeeds, unless reverted
   613	     * @param redeemTokensIn The number of DepTokens to redeem into underlying
   614	     * @param redeemAmountIn The amount of underlying to receive from redeeming DepTokens
   615	     */
   715	         *  doTransferOut reverts if anything goes wrong, since we can't be sure if side effects occurred.
   716	         */
   717	        // deptoken and levtoken pay for the gases of all the transactions. msg.sender pay for the final transfer 
   718	        doTransferOut(redeemer, redeemAmount);
   719	
   720	        /* We emit a Transfer event, and a Redeem event */
   721	        emit Transfer(redeemer, address(this), redeemTokens);
   722	        emit Redeem(redeemer, redeemAmount, redeemTokens, supplyRatePerBlock());
   723	    }
