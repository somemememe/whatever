   914	    /**
   915	      * @notice Begins transfer of admin rights. The newPendingAdmin must call `_acceptAdmin` to finalize the transfer.
   916	      * @dev Admin function to begin change of admin. The newPendingAdmin must call `_acceptAdmin` to finalize the transfer.
   917	      * @param newPendingAdmin New pending admin.
   918	      * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   919	      */
   920	    function _setPendingAdmin(address payable newPendingAdmin) override external returns (uint) {
   921	        // Check caller = admin
   922	        if (msg.sender != admin) {
   923	            revert SetPendingAdminOwnerCheck();
   924	        }
   925	
   926	        // Save current value, if any, for inclusion in log
   927	        address oldPendingAdmin = pendingAdmin;
   928	
   929	        // Store pendingAdmin with value newPendingAdmin
   930	        pendingAdmin = newPendingAdmin;
   931	
   932	        // Emit NewPendingAdmin(oldPendingAdmin, newPendingAdmin)
   933	        emit NewPendingAdmin(oldPendingAdmin, newPendingAdmin);
   934	
   935	        return NO_ERROR;
   936	    }
   937	
   938	    /**
   939	      * @notice Accepts transfer of admin rights. msg.sender must be pendingAdmin
   940	      * @dev Admin function for pending admin to accept role and update admin
   941	      * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   942	      */
   943	    function _acceptAdmin() override external returns (uint) {
   944	        // Check caller is pendingAdmin and pendingAdmin ≠ address(0)
   945	        if (msg.sender != pendingAdmin || msg.sender == address(0)) {
   946	            revert AcceptAdminPendingAdminCheck();
   947	        }
   948	
   949	        // Save current values for inclusion in log
   950	        address oldAdmin = admin;
   951	        address oldPendingAdmin = pendingAdmin;
   952	
   953	        // Store admin with value pendingAdmin
   954	        admin = pendingAdmin;
   955	
   956	        // Clear the pending value
   957	        pendingAdmin = payable(address(0));
   958	
   959	        emit NewAdmin(oldAdmin, admin);
   960	        emit NewPendingAdmin(oldPendingAdmin, pendingAdmin);
   961	
   962	        return NO_ERROR;
   963	    }
