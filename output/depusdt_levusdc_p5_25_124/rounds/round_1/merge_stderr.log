   725	    /**
   726	      * @notice Sender borrows assets from the protocol to their own address
   727	      * @param origBorrowAmount The amount of the underlying asset to borrow
   728	      */
   729	    function borrowInternal(uint origBorrowAmount) internal nonReentrant returns (uint) {
   730	        accrueInterest();
   731	        // borrowFresh emits borrow-specific logs on errors, so we don't need to
   732	        // note that borrower is only the initiator, all borrowed amounts get transferred to the LEV contract
   733	        /* Fail if borrow not allowed */
   734	        address borrower = msg.sender;
   735	        uint allowed = matrixpricer.borrowAllowed(address(this), borrower);
   736	        if (allowed != 0) {
   737	            revert BorrowMatrixpricerRejection(allowed);
   738	        }
   739	
   740	        /* Verify market's block number equals current block number */
   741	        if (accrualBlockNumber != getBlockNumber()) {
   742	            revert BorrowFreshnessCheck();
   743	        }
   744	
   745	        uint currUSDTBalance = getCashExReserves();
   746	        uint compoundBalance = getCmpBalanceInternal();
   747	        uint borrowAmount = origBorrowAmount;
   748	        uint256 totalUndUnborrowed = currUSDTBalance + compoundBalance;
   749	        if (totalUndUnborrowed == 0) {
   750	            revert BorrowCashNotAvailable();    // Fail gracefully if protocol has no underlying cash
   751	        }else if(totalUndUnborrowed < borrowAmount){
   752	            borrowAmount = totalUndUnborrowed;  // lend out as much as possible
   753	        }
   754	        if(borrowAmount > currUSDTBalance){ // need to get funds from compound
   755	            uint amtNeeded = borrowAmount-currUSDTBalance;
   756	            if(compoundBalance > (amtNeeded + extraUSDT)){
   757	                withdrawUSDTfromCmp(amtNeeded + extraUSDT);
   758	            }else{
   759	                withdrawUSDTfromCmp(compoundBalance);  // taking out all we have
   760	            }
   761	        }
   762	
   763	        /*
   764	         * We calculate the new borrow and total borrow balances, failing on overflow:
   765	         *  accountBorrowNew = accountBorrow + borrowAmount
   766	         *  totalBorrowsNew = totalBorrows + borrowAmount
   767	         */
   768	        address payable levErc20Addr = payable(address(levErc20));
   769	        uint accountBorrowsPrev = borrowBalanceStoredInternal(levErc20Addr);
   770	        uint accountBorrowsNew = accountBorrowsPrev + borrowAmount;
   771	        uint totalBorrowsNew = totalBorrows + borrowAmount;
   772	
   773	        // ACT
   774	
   775	        /*
   776	         * We write the previously calculated values into storage.
   777	         *  Note: Avoid token reentrancy attacks by writing increased borrow before external transfer.
   778	        `*/
   779	        accountBorrows[levErc20Addr].principal = accountBorrowsNew;
   780	        accountBorrows[levErc20Addr].interestIndex = borrowIndex;
   781	        totalBorrows = totalBorrowsNew;
   782	
   783	//        console.log("depToken borrow, currUSDTBalance=", currUSDTBalance);
   784	//        console.log("depToken borrow, compoundBalance=", compoundBalance);
   785	//        console.log("depToken borrow, origBorrowAmount=", origBorrowAmount);
   786	//        console.log("depToken borrow, accountBorrowsPrev=", accountBorrowsPrev);
   787	//        console.log("depToken borrow, accountBorrowsNew=", accountBorrowsNew);
   788	//        console.log("depToken borrow, totalBorrowsNew=", totalBorrowsNew);
   789	        /*
   790	         * We invoke doTransferOut for the address(levErc20) and the borrowAmount.
   791	         *  Note: The DepToken must handle variations between ERC-20 and ETH underlying.
   792	         *  On success, the DepToken borrowAmount less of cash.
   793	         *  doTransferOut reverts if anything goes wrong, since we can't be sure if side effects occurred.
   794	         */
   795	        // dont do transfer out, use curve to change USDT to USDC and push to levToken directly
   796	        uint _usdcRec = changeUSDT2USDC(borrowAmount, 0, levErc20Addr);
   797	        uint transFx = _usdcRec * expScale / borrowAmount;
   798	        console.log("changed %d usdt into %d usdc",borrowAmount, _usdcRec);
   799	        //doTransferOut(levErc20Addr, borrowAmount);
   800	
   801	        /* We emit a Borrow event */
   802	        emit Borrow(levErc20Addr, borrowAmount, accountBorrowsNew, totalBorrowsNew);
   803	        return transFx;
   804	    }
