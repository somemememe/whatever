   882	    /**
   883	     * @notice Calculates the ideal utilization rate of the market: `idealborrows / (cash + borrows - reserves)`
   884	     * @return The utilization rate as a mantissa between [0, MANTISSA]
   885	     */
   886	    function idealUtilizationRate() public view returns (uint) {
   887	        // Utilization rate is 0 when there are no borrows
   888	        if (totalBorrows == 0) {
   889	            return 0;
   890	        }
   891	
   892	        uint unborrowedCash = getCashExReserves() + getCmpBalanceInternal();
   893	//        console.log("deptoken unborrowed cash=", unborrowedCash);
   894	//        console.log("deptoken totalBorrows=", totalBorrows);
   895	        uint idealBorrow;
   896	        if (unborrowedCash > 0) {    // the balance left in depositor
   897	            idealBorrow = totalBorrows;
   898	        } else {
   899	            uint extraborrowdemand = levErc20.getExtraBorrowDemand();
   900	            uint extraborrowsupply = levErc20.getExtraBorrowSupply();
   901	//            console.log("deptoken extraborrowdemand=", extraborrowdemand);
   902	//            console.log("deptoken extraborrowsupply=", extraborrowsupply);
   903	            if(totalBorrows + extraborrowdemand > extraborrowsupply){
   904	                idealBorrow = totalBorrows + extraborrowdemand - extraborrowsupply;
   905	            }else{
   906	                idealBorrow = 0;
   907	            }
   908	        }
   909	        return idealBorrow * expScale / (unborrowedCash + totalBorrows);
   910	    }
