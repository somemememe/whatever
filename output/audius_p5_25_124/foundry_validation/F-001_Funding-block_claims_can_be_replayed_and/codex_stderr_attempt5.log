pragma solidity ^0.8.20;

import "../src/FlawVerifier.sol";

interface Vm {
    function envString(string calldata) external returns (string memory);
    function createSelectFork(string calldata,uint256) external returns (uint256);
}

contract DebugTest {
    Vm constant vm = Vm(address(uint160(uint256(keccak256('hevm cheat code')))));

    event LogAddr(string key, address val);
    event LogUint(string key, uint256 val);
    event LogBytes32(string key, bytes32 val);
    event LogBool(string key, bool val);

    function testDebug() public {
        string memory url = vm.envString("AUDITHOUND_RPC_URL");
        vm.createSelectFork(url, 15201793);
        FlawVerifier fv = new FlawVerifier();
        fv.executeOnOpportunity();
        emit LogAddr("profitToken", fv.profitToken());
        emit LogUint("profitAmount", fv.profitAmount());
        emit LogBool("duplicate", fv.duplicatePathValidated());
        emit LogBool("ordering", fv.orderingPathValidated());
        emit LogBool("usedExistingRoundFunding", fv.usedExistingRoundFunding());
        emit LogBool("usedExistingProviderFallback", fv.usedExistingProviderFallback());
        emit LogAddr("primary", fv.primaryProvider());
        emit LogAddr("secondary", fv.secondaryProvider());
        emit LogUint("fundedBlock", fv.fundedBlock());
        emit LogUint("fundingAmount", fv.fundingAmount());
        emit LogUint("firstClaimIncrease", fv.firstClaimIncrease());
        emit LogUint("secondClaimIncrease", fv.secondClaimIncrease());
        emit LogUint("secondaryExpectedBefore", fv.secondaryExpectedBefore());
        emit LogUint("secondaryExpectedAfter", fv.secondaryExpectedAfter());
        emit LogUint("secondaryActualIncrease", fv.secondaryActualIncrease());
        emit LogUint("snapshotTotalBefore", fv.snapshotTotalBefore());
        emit LogUint("snapshotTotalAfterFirst", fv.snapshotTotalAfterFirst());
        emit LogUint("snapshotTotalAfterSecond", fv.snapshotTotalAfterSecond());
        emit LogBytes32("failure", fv.failure());
        emit LogBytes32("orderingFailure", fv.orderingFailure());
    }
}
