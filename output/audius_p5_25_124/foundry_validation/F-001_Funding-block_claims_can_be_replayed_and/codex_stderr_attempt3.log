+    function _claimCandidateState(
+        address serviceProvider,
+        IServiceProviderFactory spFactory,
+        address stakingAddr,
+        address delegateManagerAddr,
+        address claimsManagerAddr
+    ) internal view returns (bool candidateOk, bool pending, bool replayable, uint256 expectedReward) {
+        if (!_isClaimCandidate(serviceProvider, spFactory, stakingAddr, delegateManagerAddr)) {
+            return (false, false, false, 0);
+        }
+
+        uint256 totalAtFundBlock = _safeTotalStakedAt(stakingAddr, fundedBlock);
+        if (totalAtFundBlock == 0) {
+            return (false, false, false, 0);
+        }
+
+        uint256 activeStake = _activeStakeAt(serviceProvider, stakingAddr, delegateManagerAddr);
+        if (activeStake == 0) {
+            return (false, false, false, 0);
+        }
+
+        uint256 lastClaimed = _safeLastClaimedFor(stakingAddr, serviceProvider);
+        pending = lastClaimed < fundedBlock;
+        replayable = lastClaimed == fundedBlock;
+
+        if (!pending && !replayable) {
+            return (false, false, false, 0);
+        }
+
