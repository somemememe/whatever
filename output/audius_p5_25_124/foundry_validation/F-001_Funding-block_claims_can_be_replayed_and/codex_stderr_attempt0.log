            liquidProfitAchieved = finalLiquidBalanceEmpty > initialLiquidBalance;
            return;
        }

        if (usedExistingProviderFallback) {
            finalEconomicBalance = _safeTotalStakedFor(stakingAddr, exploitedSp);
            _profitAmount = _positiveDelta(finalEconomicBalance, initialEconomicBalance);
            liquidProfitAchieved = false;
