s=p.read_text()
old='''        try spFactory.register(chosenType, _endpoint(serviceProvider), minStake, address(0)) returns (uint256 registeredId) {
            registeredId;
            (bool registeredOk, bool validBoundsAfter, uint256 endpointsAfter) =
                _safeServiceProviderStatus(address(spFactory), serviceProvider);
            return registeredOk && validBoundsAfter && endpointsAfter > 0;
        } catch {
            return false;
        }
    }
'''
new='''        try spFactory.register(chosenType, _endpoint(serviceProvider), minStake, address(0)) returns (uint256 registeredId) {
            registeredId;
            return _isRegisteredProvider(address(spFactory), serviceProvider);
        } catch {
            return false;
        }
    }

    function _isRegisteredProvider(address spFactoryAddr, address serviceProvider) internal view returns (bool) {
        (bool registeredOk, bool validBoundsAfter, uint256 endpointsAfter) =
            _safeServiceProviderStatus(spFactoryAddr, serviceProvider);
        return registeredOk && validBoundsAfter && endpointsAfter > 0;
    }
'''
if old not in s:
    raise SystemExit('pattern not found')
p.write_text(s.replace(old,new))
