pragma solidity "'^0.8.20;
interface Vm { function envString(string calldata) external returns (string memory); function createSelectFork(string calldata, uint256) external returns (uint256); function writeFile(string calldata, string calldata) external; }
interface IGovernanceRoot { function getServiceProviderFactoryAddress() external view returns (address); function getDelegateManagerAddress() external view returns (address); function getStakingAddress() external view returns (address); }
interface IDelegateManager { function getClaimsManagerAddress() external view returns (address); function getTotalLockedDelegationForServiceProvider(address) external view returns (uint256); }
interface IClaimsManager { function getLastFundedBlock() external view returns (uint256); function getFundsPerRound() external view returns (uint256); }
interface IStaking { function totalStakedForAt(address, uint256) external view returns (uint256); function totalStakedAt(uint256) external view returns (uint256); function lastClaimedFor(address) external view returns (uint256); }
interface IServiceProviderFactory { function getServiceTypeManagerAddress() external view returns (address); function getServiceProviderDetails(address) external view returns (uint256, uint256, bool, uint256, uint256, uint256); function getTotalServiceTypeProviders(bytes32) external view returns (uint256); function getServiceEndpointInfo(bytes32, uint256) external view returns (address, string memory, uint256, address); function getPendingDecreaseStakeRequest(address) external view returns (uint256, uint256); }
interface IServiceTypeManager { function getValidServiceTypes() external view returns (bytes32[] memory); }
contract ScanTest {
    Vm constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
    address constant TARGET = 0x4DEcA517D6817B6510798b7328F2314d3003AbAC;
    address dm; address staking; address spf; uint256 fundedBlock; uint256 fundingAmount; uint256 totalStakedAtFund; address bestReplay; uint256 bestReplayReward; uint256 replayableCount;
    function testScan() external {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 15201793);
        IGovernanceRoot root = IGovernanceRoot(TARGET); dm = root.getDelegateManagerAddress(); staking = root.getStakingAddress(); spf = root.getServiceProviderFactoryAddress();
        address cm = IDelegateManager(dm).getClaimsManagerAddress(); fundedBlock = IClaimsManager(cm).getLastFundedBlock(); fundingAmount = IClaimsManager(cm).getFundsPerRound(); totalStakedAtFund = IStaking(staking).totalStakedAt(fundedBlock);
        bytes32[] memory types = IServiceTypeManager(IServiceProviderFactory(spf).getServiceTypeManagerAddress()).getValidServiceTypes();
        for (uint256 i; i < types.length; i++) _scanType(types[i]);
        vm.writeFile("/tmp/audius_scan.txt", _a(bestReplay)); vm.writeFile("/tmp/audius_scan_reward.txt", _u(bestReplayReward)); vm.writeFile("/tmp/audius_scan_count.txt", _u(replayableCount));
    }
    function _scanType(bytes32 serviceType) internal {
        uint256 total = IServiceProviderFactory(spf).getTotalServiceTypeProviders(serviceType);
        for (uint256 id = 1; id <= total; id++) _consider(serviceType, id);
    }
    function _consider(bytes32 serviceType, uint256 id) internal {
        (address owner,,,) = IServiceProviderFactory(spf).getServiceEndpointInfo(serviceType, id); if (owner == address(0)) return;
        (,, bool validBounds,,,) = IServiceProviderFactory(spf).getServiceProviderDetails(owner); if (!validBounds) return;
        uint256 stakedAtFund = IStaking(staking).totalStakedForAt(owner, fundedBlock); if (stakedAtFund == 0) return;
        uint256 locked = IDelegateManager(dm).getTotalLockedDelegationForServiceProvider(owner); (uint256 pendingDecrease,) = IServiceProviderFactory(spf).getPendingDecreaseStakeRequest(owner); locked += pendingDecrease; if (stakedAtFund <= locked) return;
        uint256 reward = (stakedAtFund - locked) * fundingAmount / totalStakedAtFund; if (reward == 0) return;
        if (IStaking(staking).lastClaimedFor(owner) != fundedBlock) return; replayableCount++; if (reward > bestReplayReward) { bestReplayReward = reward; bestReplay = owner; }
    }
    function _u(uint256 v) internal pure returns (string memory) { if (v == 0) return "0"; uint256 j = v; uint256 len; while (j != 0) { len++; j /= 10; } bytes memory b = new bytes(len); while (v != 0) { len--; b[len] = bytes1(uint8(48 + v % 10)); v /= 10; } return string(b); }
    function _a(address x) internal pure returns (string memory) { bytes16 s = 0x30313233343536373839616263646566; bytes memory b = new bytes(42); b[0] = '"'0'; b[1] = 'x'; uint160 v = uint160(x); for (uint256 i = 0; i < 20; i++) { b[2 + i * 2] = bytes1(s[(v >> (8 * (19 - i) + 4)) & 0xf]); b[3 + i * 2] = bytes1(s[(v >> (8 * (19 - i))) & 0xf]); } return string(b); }
}
