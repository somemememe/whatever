interface IGovernanceRoot { function getServiceProviderFactoryAddress() external view returns (address); function getDelegateManagerAddress() external view returns (address); function getStakingAddress() external view returns (address); }
interface IDelegateManager { function getClaimsManagerAddress() external view returns (address); function getTotalLockedDelegationForServiceProvider(address serviceProvider) external view returns (uint256); }
interface IClaimsManager { function getLastFundedBlock() external view returns (uint256); function getFundsPerRound() external view returns (uint256); function claimPending(address serviceProvider) external view returns (bool); }
interface IStaking { function totalStakedFor(address account) external view returns (uint256); function totalStakedForAt(address account, uint256 blockNumber) external view returns (uint256); function totalStakedAt(uint256 blockNumber) external view returns (uint256); function lastClaimedFor(address account) external view returns (uint256); }
interface IServiceProviderFactory { function getServiceTypeManagerAddress() external view returns (address); function getServiceProviderDetails(address serviceProvider) external view returns (uint256, uint256, bool, uint256, uint256, uint256); function getTotalServiceTypeProviders(bytes32 serviceType) external view returns (uint256); function getServiceEndpointInfo(bytes32 serviceType, uint256 serviceId) external view returns (address owner, string memory endpoint, uint256 blockNumber, address delegateOwnerWallet); function getPendingDecreaseStakeRequest(address serviceProvider) external view returns (uint256 amount, uint256 lockupExpiryBlock); }
interface IServiceTypeManager { function getValidServiceTypes() external view returns (bytes32[] memory); }

contract Scan {
    Vm constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
    address constant TARGET = 0x4DEcA517D6817B6510798b7328F2314d3003AbAC;

    function run() external {
        string memory rpc = vm.envString("AUDITHOUND_RPC_URL");
        vm.createSelectFork(rpc, 15201793);

        IGovernanceRoot root = IGovernanceRoot(TARGET);
        address dm = root.getDelegateManagerAddress();
        address staking = root.getStakingAddress();
        address spf = root.getServiceProviderFactoryAddress();
        address cm = IDelegateManager(dm).getClaimsManagerAddress();
        uint256 fundedBlock = IClaimsManager(cm).getLastFundedBlock();
        uint256 fundingAmount = IClaimsManager(cm).getFundsPerRound();
        bytes32[] memory types = IServiceTypeManager(IServiceProviderFactory(spf).getServiceTypeManagerAddress()).getValidServiceTypes();

        address bestReplay;
        uint256 bestReplayReward;
        address bestPending;
        uint256 bestPendingReward;
        uint256 scanned;
        uint256 replayableCount;
        uint256 pendingCount;

        for (uint256 t; t < types.length; t++) {
            uint256 total = IServiceProviderFactory(spf).getTotalServiceTypeProviders(types[t]);
            for (uint256 id = 1; id <= total; id++) {
                (address owner,,,) = IServiceProviderFactory(spf).getServiceEndpointInfo(types[t], id);
                if (owner == address(0)) continue;
                scanned++;
                (,, bool validBounds,,,) = IServiceProviderFactory(spf).getServiceProviderDetails(owner);
                if (!validBounds) continue;
                uint256 totalAtFund = IStaking(staking).totalStakedForAt(owner, fundedBlock);
                if (totalAtFund == 0) continue;
                uint256 lockedDelegation = IDelegateManager(dm).getTotalLockedDelegationForServiceProvider(owner);
                (uint256 pendingDecrease,) = IServiceProviderFactory(spf).getPendingDecreaseStakeRequest(owner);
                uint256 active = totalAtFund > lockedDelegation + pendingDecrease ? totalAtFund - lockedDelegation - pendingDecrease : 0;
                if (active == 0) continue;
                uint256 totalStakedAtFund = IStaking(staking).totalStakedAt(fundedBlock);
                uint256 reward = active * fundingAmount / totalStakedAtFund;
                if (reward == 0) continue;
                uint256 lastClaimed = IStaking(staking).lastClaimedFor(owner);
                if (lastClaimed == fundedBlock) {
                    replayableCount++;
                    if (reward > bestReplayReward) {
                        bestReplayReward = reward;
                        bestReplay = owner;
                    }
                }
                if (lastClaimed < fundedBlock) {
                    pendingCount++;
                    if (reward > bestPendingReward) {
                        bestPendingReward = reward;
                        bestPending = owner;
                    }
                }
            }
        }

        string memory out = string.concat(
            "fundedBlock=", _u(fundedBlock), "'"\\n\",
            \"fundingAmount=\", _u(fundingAmount), \"\\n\",
            \"scanned=\", _u(scanned), \"\\n\",
            \"replayableCount=\", _u(replayableCount), \"\\n\",
            \"bestReplay=\", _a(bestReplay), \"\\n\",
            \"bestReplayReward=\", _u(bestReplayReward), \"\\n\",
            \"pendingCount=\", _u(pendingCount), \"\\n\",
            \"bestPending=\", _a(bestPending), \"\\n\",
            \"bestPendingReward=\", _u(bestPendingReward), \"\\n\"
        );
        vm.writeFile(\"/tmp/audius_scan.txt\", out);
    }

    function _u(uint256 v) internal pure returns (string memory) {
        if (v == 0) return \"0\";
        uint256 j = v; uint256 len;
        while (j "'!= 0) { len++; j /= 10; }
        bytes memory b = new bytes(len);
        while (v != 0) { len--; b[len] = bytes1(uint8(48 + v % 10)); v /= 10; }
        return string(b);
    }

    function _a(address x) internal pure returns (string memory) {
        bytes16 s = 0x30313233343536373839616263646566;
        bytes memory b = new bytes(42);
        b[0] = '"'0'; b[1] = 'x';
        uint160 v = uint160(x);
        for (uint256 i = 0; i < 20; i++) {
            b[2 + i * 2] = bytes1(s[(v >> (8 * (19 - i) + 4)) & 0xf]);
            b[3 + i * 2] = bytes1(s[(v >> (8 * (19 - i))) & 0xf]);
        }
        return string(b);
    }
}
