Nice, the local Etherscan cache has source for several router addresses. I’m extracting their names and likely entrypoints.
exec
/bin/bash -lc "python - <<'PY'
import json, os, re
addrs=['0x663dc15d3c1ac63ff12e45ab68fea3f0a883c251','0x362fa9d0bca5d19f743db50738345ce2b40ec99f','0xb9e13785127bffcc3dc970a55f6c7bf0844a3c15','0x1111111254eeb25477b68fb85ed929f73a960582','0x1231deb6f5749ef6ce6943a275a1d3e7486f4eae','0x765277eebeca2e31912c9946eae1021199b39c61','0x5427fefa711eff984124bfbb1ab6fbf5e3da1820','0xe592427a0aece92de3edee1f18e0157c05861564','0x68b3465833fb72a70ecdf485e0e4c7bd8665fc45']
for a in addrs:
    p=os.path.expanduser(f'~/.foundry/cache/etherscan/mainnet/sources/{a}.json')
    print('\\nADDR',a)
    if not os.path.exists(p):
        print('missing'); continue
    d=json.load(open(p))['data'][0]
    sc=d['SourceCode']
    if isinstance(sc,str):
        print('SourceCode string len',len(sc))
        m=re.search(r'contract\\s+(\\w+)', sc)
        print('first contract', m.group(1) if m else 'n/a')
        funcs=re.findall(r'function\\s+(\\w+)\\s*\\(', sc)
        print('func sample', funcs[:25])
    else:
        print('sources', list(sc['sources'])[:8])
        text='\\n'.join(v['content'] for v in sc['sources'].values())
        m=re.search(r'contract\\s+(\\w+)', text)
        print('first contract', m.group(1) if m else 'n/a')
        funcs=re.findall(r'function\\s+(\\w+)\\s*\\(', text)
        uniq=[]
        for f in funcs:
            if f not in uniq:
                uniq.append(f)
        print('func sample', uniq[:40])
