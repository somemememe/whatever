`MetaRouter` is close but its gateway can’t be reused later. I’m checking routers with more flexible pull semantics.
exec
/bin/bash -lc "python - <<'PY'
import json, os, re
for a in ['0x1111111254eeb25477b68fb85ed929f73a960582','0x765277eebeca2e31912c9946eae1021199b39c61','0x5427fefa711eff984124bfbb1ab6fbf5e3da1820']:
    p=os.path.expanduser(f'~/.foundry/cache/etherscan/mainnet/sources/{a}.json')
    d=json.load(open(p))['data'][0]['SourceCode']
    if not isinstance(d,str):
        d='\\n'.join(v['content'] for v in d['sources'].values())
    print('\\nADDR',a)
    for pat in [r'function\\s+swap\\s*\\(', r'function\\s+externalCall\\s*\\(', r'function\\s+claimTokens\\s*\\(', r'transferFrom\\(', r'safeTransferFrom\\(', r'srcReceiver', r'srcToken', r'caller', r'msg\\.sender', r'onlyOwner', r'onlyMeta', r'only\\w+', r'function\\s+.*execute.*\\(']:
        if re.search(pat,d):
            print('matches',pat)
    # print snippets around srcReceiver and swap desc in 1inch
    if a.startswith('0x1111'):
        for key in ['struct SwapDescription','srcReceiver','dstReceiver','function swap','function unoswap','function clipperSwap','function uniswapV3Swap']:
            m=re.search(key, d)
            if m:
                s=max(0,m.start()-500); e=min(len(d),m.start()+2500)
                print('\\nSNIP',key)
                print(d[s:e])
                print('\\n---')
