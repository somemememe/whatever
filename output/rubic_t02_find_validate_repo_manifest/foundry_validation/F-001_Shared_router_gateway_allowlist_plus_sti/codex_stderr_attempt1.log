codex
One more cleanup: Solidity wants those integer literals prefixed to avoid address-literal parsing.
exec
/bin/bash -lc "python - <<'PY'
from pathlib import Path
import re
p=Path('src/FlawVerifier.sol')
text=p.read_text()

def fix(m):
    h=m.group(1)
    if len(h) < 42:
        h = h.rjust(42, '0')
    return f'address(uint160(0x{h}))'
text=re.sub(r'address\\(uint160\\(0x([0-9a-fA-F]+)\\)\\)', fix, text)
p.write_text(text)
