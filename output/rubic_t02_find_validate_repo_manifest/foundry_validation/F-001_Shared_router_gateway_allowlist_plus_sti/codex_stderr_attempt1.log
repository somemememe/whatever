import json, os, re
p=os.path.expanduser('~/.foundry/cache/rpc/mainnet/16260580')
acc=json.load(open(p))['accounts']
for a in ['0x3b7551eb0162c838a10c2437b60d1f5455b9554','0x935bbf5c69225e3eda7c3aa542a7baa5c5c30094','0x8eb8a3b98659cce290402893d0123abb75e3ab28','0xe3eb2eab0e524b69c79e24910f4318db46baa9c','0xf9fb1c508ff49f78b60d3a96dea99fa5d7f3a8a6','0x92e929d8b2c8430bcaf4cd87654789578bb2b786']:
    acct=acc.get(a)
    print('\\nADDR',a)
    if not acct:
        print('missing in cache'); continue
    code=acct['code']['LegacyAnalyzed']['bytecode']
    sels=[]
    for m in re.finditer(r'63([0-9a-fA-F]{8})', code):
        s='0x'+m.group(1).lower()
        if s not in sels:
            sels.append(s)
    print('selectors', sels[:80])
    strings=re.findall(r'7f([0-9a-fA-F]{64})', code)
    decoded=[]
    for h in strings:
        try:
            b=bytes.fromhex(h)
            if sum(32 <= c < 127 for c in b) >= 10:
                decoded.append(b.rstrip(b'\\x00').decode('ascii','ignore'))
        except: pass
    print('ascii', decoded[:10])
