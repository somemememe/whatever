/bin/bash -lc "python3 - <<'PY'
import re, json, requests
from pathlib import Path
RPC='https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk'
text=Path('src/FlawVerifier.sol').read_text()
TARGET='0x3335A88bb18fD3b6824b59Af62b50CE494143333'
# normalize all address literals seen in file to 20-byte addresses
raws=re.findall(r'0x([0-9A-Fa-f]{40,42})', text)
addrs=[]
seen=set()
for raw in raws:
    norm='0x'+raw[-40:]
    if norm.lower() not in seen:
        seen.add(norm.lower()); addrs.append(norm)
# split rough candidates: known token list from _candidateTokens common array + WETH/USDC etc are in addrs
# helper RPC
s=requests.Session(); rid=0

def rpc(method, params):
    global rid
    rid += 1
    r=s.post(RPC, json={'jsonrpc':'2.0','id':rid,'method':method,'params':params}, timeout=30)
    r.raise_for_status(); j=r.json()
    if 'error' in j: return {'error': j['error']}
    return j['result']

def pad(addr):
    return addr.lower().replace('0x','').rjust(64,'0')

def eth_call(to, data):
    return rpc('eth_call', [{'to':to,'data':data}, 'latest'])

def dec_hex(h):
    if isinstance(h, dict): return None
    return int(h,16)

# query live routers list from contract
routers_hex = eth_call(TARGET, '0x3a68ff83')
print('getAvailableRouters raw ok', isinstance(routers_hex,str), 'len', len(routers_hex) if isinstance(routers_hex,str) else routers_hex)
# decode address[]
def decode_address_array(data):
    if not isinstance(data,str) or not data.startswith('0x'): return []
    body=data[2:]
    if len(body) < 128: return []
