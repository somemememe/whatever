        } catch {
            return (false, 0, 0);
        }
    }

    function _discoverRouterAndPair() internal view returns (address router, address weth, address pair) {
        (router, weth, pair) = _probeRouter(UNI_V2_ROUTER);
        if (pair != address(0)) {
