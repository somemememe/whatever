        pair = IUniswapV2FactoryLike(factory).getPair(weth, USDC);
        if (pair != address(0)) {
            return pair;
        }

        pair = IUniswapV2FactoryLike(factory).getPair(weth, USDT);
        if (pair != address(0)) {
            return pair;
        }

        pair = IUniswapV2FactoryLike(factory).getPair(weth, DAI);
    }

