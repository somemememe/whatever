            _profitToken = address(0);
            _profitAmount = 0;
            return;
        }

        uint256 endingWeth = IERC20Minimal(weth).balanceOf(address(this));
        _profitToken = weth;
        if (endingWeth > startingWeth) {
            _profitAmount = endingWeth - startingWeth;
        }
    }
