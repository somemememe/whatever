+        uint256 stakingStart = STAKING.stakingStartTime();
+        if (stakingStart == 0) {
+            revert StakingNotStarted(stakingStart);
+        }
+
+        uint256 stakingEnd = STAKING.stakingEndTime();
+        if (stakingEnd <= block.timestamp) {
+            revert StakingClosed(stakingEnd, block.timestamp);
+        }
