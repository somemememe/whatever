+        uint256 stakeWeeks = ((bonusBudget * 100) / (expectedPending * 9)) + 1;
+        if (stakeWeeks < 2) {
+            stakeWeeks = 2;
+        }
+        if (stakeWeeks > MAX_STAKE_WEEKS) {
+            stakeWeeks = MAX_STAKE_WEEKS;
+        }
+        return stakeWeeks;
+    }
+}

