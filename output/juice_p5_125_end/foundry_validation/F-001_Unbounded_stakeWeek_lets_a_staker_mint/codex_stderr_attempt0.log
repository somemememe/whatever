+        (
+            uint256 stakedAmount,
+            ,
+            uint256 endTime,
+            ,
+            ,
+            uint256 unstakeStatus
+        ) = STAKING.mapStakingInfo(address(this), trackedStakeIndex);
+
+        if (stakedAmount == 0 || unstakeStatus != 0) {
+            revert StakeAlreadyExited();
+        }
