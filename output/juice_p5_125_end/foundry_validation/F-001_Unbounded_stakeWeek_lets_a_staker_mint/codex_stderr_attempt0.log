+        uint256 amount = _chooseStakeAmount(available, currentStaked, rewardRate);
+        uint256 poolBalance = juice.balanceOf(address(STAKING));
+        chosenStakeWeeks = _chooseStakeWeeks(amount, currentStaked, rewardRate, poolBalance);
