+    address internal constant YUSDC = 0xd6aD7a6750A7593E092a9B218d66C0A814a3436e;
+
+    uint256 internal constant ONE_MILLION_DAI = 1_000_000e18;
+    uint256 internal constant TWENTY_MILLION_DAI = 20_000_000e18;
+
+    enum Mode {
+        Idle,
+        DepositFlash
+    }
+
