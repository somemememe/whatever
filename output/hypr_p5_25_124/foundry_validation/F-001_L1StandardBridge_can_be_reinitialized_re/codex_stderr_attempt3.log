    address internal constant OP_SNX = 0x8700daec35af8ff88c16bdf041006c17c5c68ba3;
    address internal constant OP_UNI = 0x6fd9d7ad17242c41f7131d257212c54a0e816691;
    address internal constant OP_LUSD = 0xc40f949f8a4e094d1b49a23ea9241d289b7b2819;
