        pairs[17] = TokenPair({ l1Token: RPL, l2Token: address(0) });
        pairs[18] = TokenPair({ l1Token: CBETH, l2Token: address(0) });
        pairs[19] = TokenPair({ l1Token: STETH, l2Token: address(0) });
        pairs[20] = TokenPair({ l1Token: RETH, l2Token: address(0) });
