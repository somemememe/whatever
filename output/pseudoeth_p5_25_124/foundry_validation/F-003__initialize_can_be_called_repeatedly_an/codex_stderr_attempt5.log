I’ve isolated the main issue: the current fallback only arbitrages one direction, converts everything to native immediately, and takes a single stale reserve snapshot per venue. That’s brittle for a wrapper token that can likely be wrapped and unwrapped 1:1; I’m going to patch the verifier to evaluate both wrapper/WETH directions and iterate against live reserves until the profit threshold is actually reached or no public arb remains.
exec
/bin/bash -lc "rg -n \"pseudoeth|initialize can be called repeatedly|reinitialize|token addresses\" -S /Users/zhanglongqin/AuditHoundV2/README.md /Users/zhanglongqin/AuditHoundV2/benchmark.csv /Users/zhanglongqin/AuditHoundV2/output 2>/dev/null | sed -n '1,120p'" in /Users/zhanglongqin/AuditHoundV2/cases/pseudoeth/src
exec
/bin/bash -lc "node - <<'NODE'
const reserveWrapper = 1491284115468245230n;
const reserveWeth = 1505623594015964360n;
function getAmountIn(amountOut,reserveIn,reserveOut){
  if (amountOut >= reserveOut) return null;
  return (reserveIn*amountOut*1000n)/((reserveOut-amountOut)*997n) + 1n;
}
function best(resIn,resOut){
  let bestP=-1n,bestB=0n,bestIn=0n;
  for(let i=1n;i<100000n;i++){
    const b=(resOut*i)/100000n;
    const amtIn=getAmountIn(b,resIn,resOut);
    const p=b-amtIn;
    if(p>bestP){bestP=p;bestB=b;bestIn=amtIn;}
  }
  console.log({bestB:String(bestB),bestIn:String(bestIn),bestP:String(bestP)});
}
