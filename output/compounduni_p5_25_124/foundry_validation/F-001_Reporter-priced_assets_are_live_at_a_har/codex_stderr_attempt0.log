    constructor() {}

    function attempt(
        address target,
        address token0_,
        address token1_,
        address interestRate_,
        uint8 ltv_,
        uint8 lb_,
        uint8 rf_
    ) external returns (bool success, bytes memory revertData) {
        (success, revertData) = target.call(
