+            symbolHash;
+            baseUnit;
+            priceSource;
+            fixedPrice;
+            uniswapMarket;
+            reporter;
+            reporterMultiplier;
+            isUniswapReversed;
+
+            if (underlying != address(0)) {
+                continue;
+            }
+            if (!_isListedOnTargetOracle(cToken)) {
