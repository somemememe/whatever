+
+    function _unwindCEtherCollateralAndRepay() internal {
+        uint256 cEtherBal = IERC20Like(plan.cCollateral).balanceOf(address(this));
+        if (cEtherBal != 0) {
+            ICEtherLike(plan.cCollateral).redeem(cEtherBal);
