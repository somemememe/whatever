+                oraclePrice: plan.debtPrice,
+                cash: 0,
+                viaReporterAtOne: plan.debtViaReporterAtOne,
+                viaFixedEthAtOne: plan.debtViaFixedEthAtOne,
+                salePair: plan.salePair,
+                saleReserveToken: 0,
+                saleReserveWeth: 0
