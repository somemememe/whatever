-        hypothesisValidated = false;
-        hypothesisRefuted = false;
-
-        path0_oracleListedBeforeValidate = false;
-        path1_borrowReporterBackedDebtPricedAtOne = false;
-        path2_fixedEthAssetsDependOnEthReporter = false;
