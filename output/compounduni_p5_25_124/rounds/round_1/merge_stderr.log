   337	        //  a. `getUniswapTwap(config)` handles "reversed" token pairs, so `twap` will always be Token/ETH TWAP.
   338	        //  b. conversionFactor = ETH price * 1e6
   339	        //      unscaledPriceMantissa = twap{token/ETH} * EXP_SCALE * conversionFactor
   340	        //      so ->
   341	        //      anchorPrice = (twap * tokenBaseUnit / ETH_BASE_UNIT) * ETH_price * 1e6
   342	        //                  = twap * conversionFactor * tokenBaseUnit / ETH_BASE_UNIT
   343	        //                  = unscaledPriceMantissa / EXP_SCALE * tokenBaseUnit / ETH_BASE_UNIT
   344	        uint256 anchorPrice = (unscaledPriceMantissa * config.baseUnit) /
   345	            ETH_BASE_UNIT /
   346	            EXP_SCALE;
   347	
   348	        return anchorPrice;
   349	    }
   350	
   351	    /**
   352	     * @notice Activate failover, and fall back to using failover directly.
   353	     * @dev Only the owner can call this function
   354	     */
   355	    function activateFailover(bytes32 symbolHash) external onlyOwner {
   356	        require(!prices[symbolHash].failoverActive, "Already active");
   357	        TokenConfig memory config = getTokenConfigBySymbolHash(symbolHash);
   358	        require(config.priceSource == PriceSource.REPORTER, "Not reporter");
   359	        prices[symbolHash].failoverActive = true;
   360	        emit FailoverActivated(symbolHash);
   361	        pokeFailedOverPrice(symbolHash);
   362	    }
   363	
   364	    /**
   365	     * @notice Deactivate a previously activated failover
   366	     * @dev Only the owner can call this function
   367	     */
   368	    function deactivateFailover(bytes32 symbolHash) external onlyOwner {
   369	        require(prices[symbolHash].failoverActive, "Not active");
   370	        prices[symbolHash].failoverActive = false;
   371	        emit FailoverDeactivated(symbolHash);
   372	    }
   373	}

