    28	
    29	    function proposeUpgrade(address _logic, bytes calldata upgradeInit) public onlyAdmin {
    30	        ProxyStorage.ProxyData storage pd = ProxyStorage.load();
    31	        require(_logic != address(0), "Invalid logic");
