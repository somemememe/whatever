   203	                        abi.encodePacked(
   204	                            _concatUintString("Insufficient output to pay bps fees. Required: ", total),
   205	                            _concatUintString(" Output amount: ", meta.outAmount)
   206	                        )
   207	                    )
   208	                );
   209	            }
   210	            meta.outToTrader = meta.outAmount - total;
   211	        } else {
   212	            //input debits are handled later so we keep track of what's due so far in bps fees
   213	            meta.inputAmountDue = total;
   214	        }
   215	    }
   216	
   217	    /**
   218	     * Final step to compute gas consumption for trader and pay the vault, protocol, affiliate, and trader 
   219	     * their portions.
   220	     */
   221	    function payProtocolAndTrader(SwapTypes.SwapRequest memory request,
   222	                            SwapMeta memory meta) internal {
   223	        
   224	        DexibleStorage.DexibleData storage dd = DexibleStorage.load();
   225	
   226	        if(!meta.isSelfSwap) {
   227	            //If this was a relay-based swap, we need to pay treasury an estimated gas fee
   228	            
   229	            //we leave unguarded for gas savings since we know start gas is always higher 
   230	            //than used and will never rollover without costing an extremely large amount of $$
   231	            unchecked { 
   232	                //console.log("Start gas", meta.startGas, "Left", gasleft());
   233	
   234	                //the total gas used thus far plus some post-op buffer for transfers and events
   235	                uint totalGas = (meta.startGas - gasleft());
   236	                if(address(dd.communityVault) != meta.preSwapVault && totalGas > 200_000) {
   237	                    totalGas -= 200_000; //give credit for estimated migration gas
   238	                }
   239	                
   240	                console.log("Estimated gas used for trader gas payment", totalGas);
   241	                meta.nativeGasAmount = LibFees.computeGasCost(totalGas, true); //(totalGas * tx.gasprice);
   242	            }
   243	            //use price oracle in vault to get native price in fee token
   244	            meta.gasAmount = dd.communityVault.convertGasToFeeToken(address(request.executionRequest.fee.feeToken), meta.nativeGasAmount);
   245	            //console.log("Gas paid by trader in fee token", meta.gasAmount);
   246	
   247	            //add gas payment to treasury portion
   248	            meta.toProtocol += meta.gasAmount;
   249	            //console.log("Payment to protocol", meta.toProtocol);
   250	
   251	            if(!meta.feeIsInput) {
   252	                //if output was fee, deduct gas payment from proceeds, revert if there isn't enough output
   253	                //for it (should have been caught offchain before submit). We make sure the trader gets 
   254	                //something out of the deal by ensuring output is more than gas.
   255	                if(meta.outToTrader <= meta.gasAmount) {
   256	                    revert(
   257	                        string(
   258	                            abi.encodePacked(
   259	                                _concatUintString("Insufficient output to pay gas fees. Required: ", meta.gasAmount),
   260	                                _concatUintString(" Trader output proceeds: ", meta.outToTrader)
   261	                            )
   262	                        )
   263	                    );
   264	                }
   265	                meta.outToTrader -= meta.gasAmount;
   266	            } else {
   267	                //other make sure it's account for as input debit
   268	                meta.inputAmountDue += meta.gasAmount;
   269	            }
   270	            //console.log("Proceeds to trader", payments.outToTrader);
   271	        }
   272	
   273	        //now distribute fees
   274	        IERC20 feeToken = request.executionRequest.fee.feeToken;
   275	        if(meta.feeIsInput) {
   276	            //make sure we didn't overspend on trading input amount and not have enough to cover
   277	            //fees
   278	            uint totalInputSpent = request.routes[0].routeAmount.amount + meta.inputAmountDue;
   279	            //console.log("Total input spent", totalInputSpent, "Expected input amount", request.tokenIn.amount);
   280	            if(totalInputSpent > request.tokenIn.amount) {
   281	                revert(
   282	                    string(
   283	                        abi.encodePacked(_concatUintString("Attempt to spend more input than anticipated. Total required: ", totalInputSpent),
   284	                                        _concatUintString(" Max input: ", request.tokenIn.amount))
   285	                    )
   286	                );
   287	            }
   288	            //pay protocol from input token
   289	            feeToken.safeTransferFrom(request.executionRequest.requester, dd.treasury, meta.toProtocol);
   290	
   291	            //pay vault from input token
   292	            feeToken.safeTransferFrom(request.executionRequest.requester, address(dd.communityVault), meta.toRevshare);
   293	            if(request.executionRequest.fee.affiliatePortion > 0) {
   294	                //pay affiliate their portion which was deducted from protocol's bps portion
   295	                feeToken.safeTransferFrom(request.executionRequest.requester, request.executionRequest.fee.affiliate, request.executionRequest.fee.affiliatePortion);
   296	                emit AffiliatePaid(request.executionRequest.fee.affiliate, address(feeToken), request.executionRequest.fee.affiliatePortion);
   297	            }
   298	        } else {
   299	            //otherwise, transfer directly from generated output
   300	            //console.log("Total output spent", (meta.toProtocol + meta.toRevshare + request.executionRequest.fee.affiliatePortion));
   301	            //console.log("Total output generated", meta.outAmount);
   302	            feeToken.safeTransfer(dd.treasury, meta.toProtocol);
   303	            feeToken.safeTransfer(address(dd.communityVault), meta.toRevshare);
   304	            if(request.executionRequest.fee.affiliatePortion > 0) {
   305	                //pay affiliate their portion
   306	                feeToken.safeTransfer(request.executionRequest.fee.affiliate, request.executionRequest.fee.affiliatePortion);
   307	                emit AffiliatePaid(request.executionRequest.fee.affiliate, address(feeToken), request.executionRequest.fee.affiliatePortion);
   308	            }
   309	        }
   310	        
   311	        //and send trader their proceeds
   312	        request.tokenOut.token.safeTransfer(request.executionRequest.requester, meta.outToTrader);
   313	        
   314	        emit SwapSuccess(request.executionRequest.requester,
   315	                    request.executionRequest.fee.affiliate,
   316	                    request.tokenOut.amount,
   317	                    meta.outToTrader, 
   318	                    address(request.executionRequest.fee.feeToken),
   319	                    meta.gasAmount,
   320	                    request.executionRequest.fee.affiliatePortion,
   321	                    meta.bpsAmount); 
   322	    }
   323	
   324	    function preCheck(SwapTypes.SwapRequest calldata request, SwapMeta memory meta) internal {
   325	        //make sure fee token is allowed
   326	        address fToken = address(request.executionRequest.fee.feeToken);
   327	        DexibleStorage.DexibleData storage dd = DexibleStorage.load();
   328	        require(
   329	            dd.communityVault.isFeeTokenAllowed(fToken), 
   330	            "Fee token is not allowed"
   331	        );
   332	
   333	        //and that it's one of the tokens swapped
   334	        require(fToken == address(request.tokenIn.token) ||
   335	                fToken == address(request.tokenOut.token), 
   336	                "Fee token must be input or output token");
   337	
   338	         //get the current DXBL balance at the start to apply discounts
   339	        meta.preDXBLBalance = dd.dxblToken.balanceOf(request.executionRequest.requester);
   340	        
   341	        //flag whether the input token is the fee token
   342	        meta.feeIsInput = address(request.tokenIn.token) == address(request.executionRequest.fee.feeToken);
   343	        
   344	        //transfer input tokens for router so it can perform swap
   345	        //console.log("Transfering input for trading:", request.routes[0].routeAmount.amount);
   346	        request.tokenIn.token.safeTransferFrom(request.executionRequest.requester, address(this), request.routes[0].routeAmount.amount);
   347	        //console.log("Expected output", request.tokenOut.amount);
   348	    }
   349	
   350	
   351	    /**
   352	     * Pay the relay with gas funds stored in this contract. The gas used provided 
   353	     * does not include arbitrum multiplier but may include additional amount for post-op
   354	     * gas estimates.
   355	     */
   356	    function payRelayGas(uint gasFee) internal {
   357	        if(gasFee == 0) {
   358	            return;
   359	        }
   360	        
   361	        //console.log("Relay Gas Reimbursement", gasFee);
   362	        //if there is ETH in the contract, reimburse the relay that called the fill function
   363	        if(address(this).balance < gasFee) {
   364	            //console.log("Cannot reimburse relay since do not have enough funds");
   365	            emit InsufficientGasFunds(msg.sender, gasFee);
   366	        } else {
   367	            //console.log("Transfering gas fee to relay");
   368	            payable(msg.sender).transfer(gasFee);
   369	            emit PaidGasFunds(msg.sender, gasFee);
   370	        }
   371	    }
   372	
   373	    /**
   374	     * Compute the bps to charge for the swap. This leverages the DXBL token to compute discounts
   375	     * based on trader balances and discount rates applied per DXBL token.
   376	     */
   377	    function computeBpsFee(SwapTypes.SwapRequest memory request, bool feeIsInput, uint preDXBL, uint outAmount) internal view returns (uint) {
   378	        //apply any discounts
   379	        DexibleStorage.DexibleData storage ds = DexibleStorage.load();
   380	        
   381	        return ds.dxblToken.computeDiscountedFee(
   382	            IDXBL.FeeRequest({
   383	                trader: request.executionRequest.requester,
   384	                amt: feeIsInput ? request.tokenIn.amount : outAmount,
   385	                referred: request.executionRequest.fee.affiliate != address(0),
   386	                dxblBalance: preDXBL,
   387	                stdBpsRate: ds.stdBpsRate,
   388	                minBpsRate: ds.minBpsRate
   389	            }));
   390	    }

