    47	        //execute the swap but catch any problem
    48	        try this.fill{
    49	            gas: gasleft() - 80_000
    50	        }(request, details) returns (SwapMeta memory sd) {
    51	            details = sd;
    52	            success = true;
    53	        } catch {
    54	            console.log("Swap failed");
    55	            success = false;
    56	        }
    57	
    58	        postFill(request, details, success);
    59	    }
    60	
    61	    function selfSwap(SwapTypes.SelfSwap calldata request) external notPaused {
    62	        //we create a swap request that has no affiliate attached and thus no
