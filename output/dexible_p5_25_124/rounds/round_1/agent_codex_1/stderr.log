    27	    function swap(SwapTypes.SwapRequest calldata request) external onlyRelay notPaused {
    28	        //compute how much gas we have at the outset, plus some gas for loading contract, etc.
    29	        uint startGas = gasleft();
    30	        SwapMeta memory details = SwapMeta({
