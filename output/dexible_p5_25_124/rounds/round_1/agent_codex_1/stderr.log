     4	import "./oracles/IOptimismGasOracle.sol";
     5	import "./DexibleStorage.sol";
     6	import "../common/LibConstants.sol";
     7	import "./oracles/IStandardGasAdjustments.sol";
     8	import "hardhat/console.sol";
     9	
    10	library LibFees {
    11	
    12	    //special handling for L2s that impose an L1 rollup fee
    13	    uint constant ARB = 42161;
    14	    uint constant OPT = 10;
    15	    IOptimismGasOracle constant optGasOracle = IOptimismGasOracle(0x420000000000000000000000000000000000000F);
    16	
    17	    function computeGasCost(uint gasUsed, bool success) internal view returns(uint) {
    18	        DexibleStorage.DexibleData storage ds = DexibleStorage.load();
    19	        uint add = ds.stdGasAdjustment.adjustment(success ? LibConstants.SWAP_SUCCESS : LibConstants.SWAP_FAILURE);
    20	        gasUsed += add;
    21	        //console.log("Gas used to compute cost in fee token", gasUsed, "after adding", add);
    22	        uint cid;
    23	        assembly {
    24	            cid := chainid()
    25	        }
    26	        if(cid == ARB) {
    27	            return ds.arbitrumGasOracle.calculateGasCost(msg.data.length, gasUsed);
    28	        }
    29	        if(cid == OPT) {
    30	            return (tx.gasprice * gasUsed) + optGasOracle.getL1Fee(msg.data);
    31	        }
    32	       // console.log("Gas fee", tx.gasprice * gasUsed);
    33	        return tx.gasprice * gasUsed;
    34	    }
    35	
    36	    function computeMinFeeUnits(address feeToken) internal view returns (uint) {
    37	        DexibleStorage.DexibleData storage rs = DexibleStorage.load();
    38	        if(rs.minFeeUSD == 0) {
    39	            return 0;
    40	        }
    41	
    42	        //fee token price is in 30-dec units.
    43	        uint usdPrice = rs.communityVault.feeTokenPriceUSD(feeToken);
    44	
    45	        uint8 ftDecs = IERC20Metadata(feeToken).decimals();
    46	
    47	        //fee USD configuration is expressed in 18-decimals. Have to convert to fee-token units and 
    48	        //account for price units
    49	        uint minFeeUSD = (rs.minFeeUSD * (ftDecs != 18 ? ((10**ftDecs) / 1e18) : 1)) * LibConstants.PRICE_PRECISION;
    50	
    51	        //then simply divide to get fee token units that equate to min fee USD
    52	        return  minFeeUSD / usdPrice;
    53	    }
    54	}
