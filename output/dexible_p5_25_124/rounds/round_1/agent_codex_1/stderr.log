    49	    //anyone can call or it will be called when next call is made to the contract after upgrade
    50	    //is allowed
    51	    function upgradeLogic() public {
    52	        require(canUpgrade(), "Cannot upgrade yet");
    53	        ProxyStorage.ProxyData storage pd = ProxyStorage.load();
    54	        pd.logic = pd.pendingUpgrade.newLogic;
    55	        if(pd.pendingUpgrade.initData.length > 0) {
    56	            (bool s, ) = pd.logic.delegatecall(pd.pendingUpgrade.initData);
    57	            if(!s) {
    58	                revert("Failed to initialize new implementation");
    59	            }
    60	        }
    61	        delete pd.pendingUpgrade;
    62	        emit UpgradedLogic(pd.logic);
    63	    }
    64	
    65	    //call impl using proxy's state data
    66	    fallback() external {
    67	        
    68	        //if an upgrade can happen, upgrade
    69	        if(canUpgrade()) {
    70	            upgradeLogic();
    71	        }
    72	
    73	        //get the logic from storage
    74	        address addr = ProxyStorage.load().logic;
    75	        assembly {
    76	            //and call it
    77	            calldatacopy(0x0, 0x0, calldatasize())
    78	            let success := delegatecall(sub(gas(), 10000), addr, 0x0, calldatasize(), 0, 0)
    79	            let retSz := returndatasize()
    80	            returndatacopy(0, 0, retSz)
    81	            switch success
    82	                case 0 {
    83	                    revert(0, retSz)
    84	                }
    85	                default {
    86	                    return(0, retSz)
    87	                }
    88	        }
    89	    }
    90	}
