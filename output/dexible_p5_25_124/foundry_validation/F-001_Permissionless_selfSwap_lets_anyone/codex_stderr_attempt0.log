+    function decimals() external view returns (uint8);
+}
+
+struct FeeDetails {
+    IERC20Like feeToken;
+    address affiliate;
+    uint256 affiliatePortion;
+}
+
+struct ExecutionRequest {
+    address requester;
+    FeeDetails fee;
+}
+
+struct TokenAmount {
+    uint112 amount;
+    IERC20Like token;
+}
+
+struct RouterRequest {
+    address router;
+    address spender;
+    TokenAmount routeAmount;
+    bytes routerData;
+}
+
+struct SelfSwapRequest {
+    IERC20Like feeToken;
+    TokenAmount tokenIn;
+    TokenAmount tokenOut;
