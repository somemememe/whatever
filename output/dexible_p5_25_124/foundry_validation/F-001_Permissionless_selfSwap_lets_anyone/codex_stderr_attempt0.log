+    address router;
+    address spender;
+    TokenAmount routeAmount;
+    bytes routerData;
+}
+
+struct SelfSwapRequest {
+    IERC20Like feeToken;
+    TokenAmount tokenIn;
+    TokenAmount tokenOut;
+    RouterRequest[] routes;
+}
+
