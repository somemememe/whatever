+}
+
+struct FeeDetails {
+    IERC20Like feeToken;
+    address affiliate;
+    uint256 affiliatePortion;
+}
+
+struct ExecutionRequest {
+    address requester;
+    FeeDetails fee;
+}
+
+struct TokenAmount {
+    uint112 amount;
