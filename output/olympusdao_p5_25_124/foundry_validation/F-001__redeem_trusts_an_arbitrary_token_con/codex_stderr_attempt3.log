        candidates[44] = 0x221657776846890989a759BA2973e427DfF5C9bB;
        candidates[45] = 0x92D6C1e31e14520e676a687F0a93788B716BEff5;
        candidates[46] = 0x3A283D9c08E8b55966afb64C515f5143cf907611;
        candidates[47] = 0x3472A5A71965499acd81997a54BBA8D852C6E53d;
        candidates[48] = 0x68749665FF8D2d112Fa859AA293F07A622782F38;
        candidates[49] = 0xD417144312DbF50465b1C641d016962017Ef6240;
        candidates[50] = 0x25F8087Ea8fa962956c8077C8DeBECe9c409e894;
        candidates[51] = 0x8762db106B2c2A0bccB3A80d1Ed41273552616E8;
        candidates[52] = 0x4d224452801ACEd8B2F0aebE155379bb5D594381;
    }

    function _safeBalanceOf(address token, address account)
        internal
        view
        returns (uint256 balance, bool ok)
    {
        (bool success, bytes memory data) = token.staticcall(
            abi.encodeWithSelector(IERC20Minimal.balanceOf.selector, account)
        );
        if (!success || data.length < 32) {
            return (0, false);
        }
        return (abi.decode(data, (uint256)), true);
    }
}
