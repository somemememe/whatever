    function _bestObservedNarrative() internal view returns (string memory) {
        if (((_coveredPaths >> 0) & 1) == 1 && ((_coveredPaths >> 1) & 1) == 1 && ((_coveredPaths >> 2) & 1) == 1 && ((_coveredPaths >> 3) & 1) == 1) {
