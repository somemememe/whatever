            amountIn,
            0,
            sellPath,
            address(this),
            block.timestamp
        );
        payloads[2] = abi.encodeWithSelector(
            bytes4(keccak256("swapExactTokensForTokens(uint256,uint256,address[],address,uint256)")),
            amountIn,
            0,
            sellPath,
            address(this),
            block.timestamp
        );
        payloads[3] = abi.encodeWithSelector(
