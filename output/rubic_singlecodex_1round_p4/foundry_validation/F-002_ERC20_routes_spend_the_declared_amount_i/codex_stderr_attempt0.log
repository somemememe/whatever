-
-        if (_freshApprovalObserved) {
-            uint256 proxyWethBalance = _balanceOf(WETH, TARGET);
-            if (proxyWethBalance != 0) {
-                _scanTokenApprovals(WETH, proxyWethBalance, spenders, liveRouters);
