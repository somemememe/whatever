+        require(borrowedWeth > minReserve, "borrow");
+
+        uint256 bought = _buyCandidateToken(ctx.pair, ctx.token, borrowedWeth - minReserve);
+        require(bought != 0, "buy");
+
+        uint256 grossAmount = bought;
