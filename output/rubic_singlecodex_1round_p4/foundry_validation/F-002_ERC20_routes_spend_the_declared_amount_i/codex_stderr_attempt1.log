            sawProxyBalance = true;

            address[] memory pairs = _pairsForToken(token);
            for (uint256 j = 0; j < pairs.length; j++) {
                address pair = pairs[j];
                if (pair == address(0) || !_pairHasLiquidity(pair)) {
