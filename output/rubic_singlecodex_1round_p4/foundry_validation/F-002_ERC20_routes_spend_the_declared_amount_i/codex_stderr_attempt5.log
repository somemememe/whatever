    function _scanSellPlans(
        address token,
        uint256 proxyBalance,
        address buyRouter,
        address[] memory buyPath,
        address[] memory fundingPairs,
        uint256[] memory borrowSizes,
        address[] memory sellRouters,
        address[5] memory quotes
    ) internal returns (bool) {
        for (uint256 sellVenue = 0; sellVenue < 3; sellVenue++) {
            address sellRouter = _venueRouter(sellVenue);
            address sellFactory = _venueFactory(sellVenue);
            if (!_hasCode(sellRouter) || !_hasCode(sellFactory) || !_routerInList(sellRouters, sellRouter)) {
                continue;
            }

            for (uint256 sq = 0; sq < quotes.length; sq++) {
                address sellQuote = quotes[sq];
                if (!_routeExists(token, sellFactory, sellQuote)) {
                    continue;
                }

                if (
                    _scanRoutePlan(
                        token,
                        buyRouter,
                        buyPath,
                        sellRouter,
                        sellQuote,
                        fundingPairs,
                        borrowSizes
                    )
                ) {
                    return true;
                }
            }
        }

        return false;
    }

    function _scanRoutePlan(
        address token,
        address buyRouter,
        address[] memory buyPath,
        address sellRouter,
        address sellQuote,
        address[] memory fundingPairs,
        uint256[] memory borrowSizes
    ) internal returns (bool) {
        address[] memory sellPath = _buildSellPath(token, sellQuote);

        for (uint256 f = 0; f < fundingPairs.length; f++) {
            address fundingPair = fundingPairs[f];
            if (fundingPair == address(0) || !_pairHasLiquidity(fundingPair)) {
                continue;
            }

            for (uint256 b = 0; b < borrowSizes.length; b++) {
                AttemptContext memory ctx = AttemptContext({
                    fundingPair: fundingPair,
                    token: token,
                    buyRouter: buyRouter,
                    sellRouter: sellRouter,
                    buyPath: buyPath,
                    sellPath: sellPath,
                    borrowWeth: borrowSizes[b]
                });

                if (_attemptFlashswap(ctx)) {
                    return true;
                }
            }
        }

        return false;
    }

    function _attemptFlashswap(AttemptContext memory ctx) internal returns (bool) {
        if (_balanceOf(ctx.token, TARGET) == 0 || !_fundingPairSupportsWeth(ctx.fundingPair, ctx.borrowWeth)) {
            return false;
        }

        bool wethIsToken0 = IUniswapV2PairLike(ctx.fundingPair).token0() == WETH;
        uint256 amount0Out = wethIsToken0 ? ctx.borrowWeth : 0;

