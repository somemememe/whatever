/bin/bash -lc "python3 - <<'PY'
import json,re,glob
for p in glob.glob('out/*/*.json'):
  if any(x in p for x in ['Probe.t.sol/ProbeTest.json','Scan.t.sol/ScanTest.json','CacheProbe.t.sol/CacheProbe.json']):
    j=json.load(open(p))
    obj=j['deployedBytecode']['object']
    bs=bytes.fromhex(obj[2:] if obj.startswith('0x') else obj)
    strings=set()
    cur=b''
    for b in bs:
      if 32 <= b < 127:
        cur += bytes([b])
      else:
        if len(cur) >= 4:
          strings.add(cur.decode())
        cur=b''
    if len(cur) >= 4:
      strings.add(cur.decode())
    print('FILE',p)
    for s in sorted(strings):
      print(s)
    print('---')
PY" in /Users/zhanglongqin/AuditHoundV2/cases/rubic/src
