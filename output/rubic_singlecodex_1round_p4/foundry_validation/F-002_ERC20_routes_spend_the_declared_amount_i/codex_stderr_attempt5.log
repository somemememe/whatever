+// SPDX-License-Identifier: MIT
+pragma solidity ^0.8.20;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+}
+
+interface IERC20Probe {
+    function balanceOf(address) external view returns (uint256);
+    function totalSupply() external view returns (uint256);
+}
+
+contract TempProbeTest {
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+    address internal constant TARGET = 0x3335A88bb18fD3b6824b59Af62b50CE494143333;
+
+    function setUp() public {
+        vm.createSelectFork("AUDITHOUND_RPC_URL", 16260580);
+    }
+
+    function testProbe() public view {
+        TARGET;
+    }
+}

