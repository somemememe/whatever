const BASE = 10n**18n;
function computeNewMultiplier(prevBalance, prevMultiplier, amount, currentMultiplier){
  const prevAmount = prevBalance*BigInt(prevMultiplier)/BASE;
  const addAmount = amount*BigInt(currentMultiplier)/BASE;
  return Number((prevAmount+addAmount)*BASE/(prevBalance+amount));
}
function getCheckpointBalance(c){return c.startBalance+c.newDeposits}
function getCheckpointEffectiveBalance(c){return getCheckpointBalance(c)*BigInt(c.multiplier)/BASE}
function getEpochUserBalance(checkpoints, epochId){
  if (checkpoints.length===0 || epochId < checkpoints[0].epochId) return 0n;
  let min=0,max=checkpoints.length-1;
  if (epochId >= checkpoints[max].epochId) return getCheckpointEffectiveBalance(checkpoints[max]);
  while(max>min){let mid=Math.floor((max+min+1)/2); if(checkpoints[mid].epochId<=epochId) min=mid; else max=mid-1;}
  return getCheckpointEffectiveBalance(checkpoints[min]);
}
function clone(x){return JSON.parse(JSON.stringify(x));}
function run(seq){
 let balances=0n; let cps=[]; let pool={};
