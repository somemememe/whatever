 function epochInit(e){return pool[e]?.set===true}
 function manual(e){ if(e===0){pool[e]={size:0n,set:true};} else { if("'!epochInit(e-1)) throw '"'prev uninit'; pool[e]={size:pool[e-1].size,set:true}; } }
 for (const step of seq){
  const {kind,e,amount,mul}=step; // mul is currentMultiplier bigint
  if(kind==='deposit'){
    balances += amount;
    if("'!epochInit(e)) manual(e);
    pool[e+1] = {size: balances, set:true};
    const balanceBefore = getEpochUserBalance(cps,e);
    if(cps.length===0){ cps.push({epochId:e,multiplier:Number(mul),startBalance:0n,newDeposits:amount}); cps.push({epochId:e+1,multiplier:Number(BASE),startBalance:amount,newDeposits:0n}); }
    else {
      let last=cps.length-1;
      if(cps[last].epochId < e){
        const m=computeNewMultiplier(getCheckpointBalance(cps[last]), Number(BASE), amount, Number(mul));
        cps.push({epochId:e,multiplier:m,startBalance:getCheckpointBalance(cps[last]),newDeposits:amount});
        cps.push({epochId:e+1,multiplier:Number(BASE),startBalance:balances,newDeposits:0n});
      } else if(cps[last].epochId == e){
        cps[last].multiplier = computeNewMultiplier(getCheckpointBalance(cps[last]), cps[last].multiplier, amount, Number(mul));
        cps[last].newDeposits += amount;
        cps.push({epochId:e+1,multiplier:Number(BASE),startBalance:balances,newDeposits:0n});
      } else {
