          cps[last-1].multiplier = computeNewMultiplier(getCheckpointBalance(cps[last-1]), cps[last-1].multiplier, amount, Number(mul));
          cps[last-1].newDeposits += amount;
        }
        cps[last].startBalance = balances;
      }
    }
