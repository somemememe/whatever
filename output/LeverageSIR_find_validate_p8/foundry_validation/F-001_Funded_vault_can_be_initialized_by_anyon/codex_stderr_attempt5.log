    }

    function _vaultHasAssets() internal view returns (bool) {
        return IERC20Like(USDC).balanceOf(VAULT) > 0
            || IERC20Like(WBTC).balanceOf(VAULT) > 0
            || IERC20Like(WETH).balanceOf(VAULT) > 0;
    }
}

