+    uint256 internal constant TOKEN_UNIT = 1e9;
+    uint256 internal constant TEAM_SWAP_THRESHOLD = 4_000 * TOKEN_UNIT;
+    uint256 internal constant TEAM_FEE_BPS = 1_000;
+    uint256 internal constant BPS_DENOM = 10_000;
