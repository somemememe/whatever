        _executed = true;

        uint256 startingUsdc = IERC20Minimal(USDC).balanceOf(address(this));
        if (startingUsdc >= TOTAL_CAPITAL) {
            _runExploitRounds();
            _updateProfit(startingUsdc);
            return;
