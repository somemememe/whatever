        uint256 repayAmount = amounts[0] + feeAmounts[0];
        require(IERC20Minimal(USDC).balanceOf(address(this)) >= repayAmount, "insufficient USDC for Balancer repay");
        IERC20Minimal(USDC).transfer(BALANCER_VAULT, repayAmount);
