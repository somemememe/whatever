            ICurveMIM(MIM_POOL).exchange(0, 1, mimFromRemove, 0);
            ICurve3Pool(THREE_POOL).remove_liquidity_one_coin(IERC20Minimal(THREE_POOL_LP).balanceOf(address(this)), 1, 0);

