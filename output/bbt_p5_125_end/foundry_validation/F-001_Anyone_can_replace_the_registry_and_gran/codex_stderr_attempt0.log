+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+}
+
+contract ExploitPOCTest {
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+    function testExploit() external {
+        vm.createSelectFork(
+            "https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240",
+            19417822
+        );
+
+        FlawVerifier verifier = new FlawVerifier();
