+
+        require(verifier.profitToken() == 0x3541499cda8CA51B24724Bb8e7Ce569727406E04, "wrong token");
+        require(verifier.profitAmount() == 1_000_000 ether, "no profit");
+        require(verifier.brickConfirmed(), "brick path not confirmed");
+    }
+}

