    function _buildFundingRequest() internal returns (IERC20[] memory tokens, uint256[] memory amounts) {
        uint256[FUNDING_SLOTS] memory desired = _targetFunding();

        for (uint256 i = 0; i < FUNDING_SLOTS; ++i) {
            _effectiveDesired[i] = 0;
