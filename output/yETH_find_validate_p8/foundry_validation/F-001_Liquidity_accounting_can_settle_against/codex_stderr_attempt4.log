        uint256[] memory indexes = new uint256[](1);
        indexes[0] = assetIndex;
        POOL.update_rates(indexes);
    }

    function _addLiquidity(uint256[8] memory fixedAmounts) internal {
        uint256[] memory amounts = new uint256[](NUM_ASSETS);
        bool hasNonZero;

