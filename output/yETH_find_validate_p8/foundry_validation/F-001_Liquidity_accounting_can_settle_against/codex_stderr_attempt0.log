        indexes[5] = 5;
        POOL.update_rates(indexes);
    }

    function _updateSingleRate(uint256 assetIndex) internal {
        uint256[] memory indexes = new uint256[](1);
        indexes[0] = assetIndex;
        POOL.update_rates(indexes);
    }

    function _addLiquidity(uint256[8] memory amountsFixed) internal {
