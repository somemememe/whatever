        finalPointBalance = bestPoints;
        finalReentryCount = bestReentries;

        if (bestPoints <= beforePoints + pending || bestReentries == 0) {
            failureReason = "reentry-did-not-duplicate-pending-mint";
            hypothesisRefuted = true;
            return;

