+    function _attemptUniswapV3MarketBuy(address token) internal returns (bool) {
+        if (token == WETH) {
+            if (address(this).balance > 0) {
+                IWETHLike(WETH).deposit{value: address(this).balance}();
+            }
+            return IERC20Like(WETH).balanceOf(address(this)) > 0;
+        }
+
+        if (address(this).balance > 0) {
+            IWETHLike(WETH).deposit{value: address(this).balance}();
+        }
+
+        if (_attemptUniswapV3FromBase(WETH, token)) {
+            return true;
+        }
+        if (_attemptUniswapV3FromBase(USDC, token)) {
+            return true;
+        }
+        if (_attemptUniswapV3FromBase(USDT, token)) {
+            return true;
+        }
+        if (_attemptUniswapV3FromBase(DAI, token)) {
+            return true;
+        }
+
+        return false;
+    }
+
+    function _attemptUniswapV3FromBase(address baseToken, address token) internal returns (bool) {
+        uint256 amountIn = IERC20Like(baseToken).balanceOf(address(this));
+        if (amountIn == 0 || baseToken == token) {
+            return false;
+        }
+
+        if (_attemptUniswapV3Single(baseToken, token, amountIn)) {
+            return true;
+        }
+
+        address[3] memory mids = [USDC, USDT, DAI];
+        for (uint256 i = 0; i < mids.length; ++i) {
+            address mid = mids[i];
+            if (mid == token || mid == baseToken) {
+                continue;
+            }
+            if (_attemptUniswapV3Multi(baseToken, mid, token, IERC20Like(baseToken).balanceOf(address(this)))) {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
+    function _attemptUniswapV3Single(address tokenIn, address tokenOut, uint256 amountIn) internal returns (bool) {
+        if (amountIn == 0) {
+            return false;
+        }
+
+        uint24[3] memory fees = [uint24(500), uint24(3000), uint24(10000)];
+        uint256 beforeBal = IERC20Like(tokenOut).balanceOf(address(this));
+
+        for (uint256 i = 0; i < fees.length; ++i) {
+            if (_v3Pool(tokenIn, tokenOut, fees[i]) == address(0)) {
+                continue;
+            }
+
+            _forceApprove(tokenIn, UNISWAP_V3_ROUTER, amountIn);
+            IUniswapV3RouterLike.ExactInputSingleParams memory params = IUniswapV3RouterLike.ExactInputSingleParams({
+                tokenIn: tokenIn,
+                tokenOut: tokenOut,
+                fee: fees[i],
+                recipient: address(this),
+                deadline: block.timestamp,
+                amountIn: amountIn,
+                amountOutMinimum: 1,
+                sqrtPriceLimitX96: 0
+            });
+
+            try IUniswapV3RouterLike(UNISWAP_V3_ROUTER).exactInputSingle(params) returns (uint256 amountOut) {
+                if (amountOut > 0 && IERC20Like(tokenOut).balanceOf(address(this)) > beforeBal) {
+                    return true;
+                }
+            } catch {}
+        }
+
+        return IERC20Like(tokenOut).balanceOf(address(this)) > beforeBal;
+    }
+
+    function _attemptUniswapV3Multi(address tokenIn, address mid, address tokenOut, uint256 amountIn)
