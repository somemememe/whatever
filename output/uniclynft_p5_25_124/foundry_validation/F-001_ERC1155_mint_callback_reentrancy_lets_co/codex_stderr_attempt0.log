+        if (uniReserve == 0 && sushiReserve == 0) {
+            return address(0);
+        }
+
+        return uniReserve >= sushiReserve ? UNISWAP_V2_ROUTER : SUSHISWAP_ROUTER;
+    }
+
+    function _wethReserveForFactory(address factory, address token) internal view returns (uint256) {
+        address pair;
