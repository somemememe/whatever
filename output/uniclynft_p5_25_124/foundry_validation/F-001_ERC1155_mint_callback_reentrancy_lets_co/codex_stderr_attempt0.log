+            if (ethToSpend == 0) {
+                break;
+            }
+
+            if (_attemptBuyToken(token, ethToSpend)) {
+                uint256 bought = IERC20Like(token).balanceOf(address(this));
+                if (bought > 0) {
+                    _seedPool(pid, token, bought);
+                    return;
+                }
