+        IERC20Like(token).approve(spender, amount);
+    }
+
+    function seedStake(uint256 pid_, address token, uint256 amount) external onlyController {
+        activePid = pid_;
+        IERC20Like(token).approve(address(FARM), amount);
+        FARM.deposit(pid_, amount);
+    }
+
