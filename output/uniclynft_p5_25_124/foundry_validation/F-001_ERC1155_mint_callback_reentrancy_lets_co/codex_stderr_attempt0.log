+            if (token == address(0) || token == WETH || token.code.length == 0) {
+                continue;
+            }
+
+            uint256 ethToSpend = address(this).balance / 4;
+            if (ethToSpend == 0) {
+                ethToSpend = address(this).balance;
+            }
+            if (ethToSpend == 0) {
+                break;
+            }
+
+            if (_attemptBuyToken(token, ethToSpend)) {
