   429	            uint256 targetAllocation_ = totalUnderlying_.mulDown(weight_);
   430	            if (allocatedUnderlying_ <= targetAllocation_) continue;
   431	            uint256 minBalance_ = targetAllocation_ - targetAllocation_.mulDown(_getMaxDeviation());
   432	            uint256 maxWithdrawalAmount_ = allocatedUnderlying_ - minBalance_;
   433	            if (maxWithdrawalAmount_ <= maxWithdrawalAmount) continue;
   434	            maxWithdrawalAmount = maxWithdrawalAmount_;
