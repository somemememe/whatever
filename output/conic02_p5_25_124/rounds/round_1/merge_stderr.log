   447	    function _minAmountOut(
   448	        address tokenIn_,
   449	        address tokenOut_,
   450	        uint256 amountIn_
   451	    ) internal view returns (uint256) {
   452	        IOracle oracle_ = controller.priceOracle();
   453	
   454	        if (tokenIn_ == tokenOut_) {
   455	            return amountIn_;
   456	        }
   457	
   458	        // If we don't have a price for either token, we can't calculate the min amount out
   459	        // This should only ever happen for very minor tokens, so we accept the risk of not having
   460	        // slippage protection in that case
   461	        if (!oracle_.isTokenSupported(tokenIn_) || !oracle_.isTokenSupported(tokenOut_)) {
   462	            return 0;
   463	        }
   464	
   465	        return
   466	            amountIn_
   467	                .mulDown(oracle_.getUSDPrice(tokenIn_))
   468	                .divDown(oracle_.getUSDPrice(tokenOut_))
   469	                .convertScale(
   470	                    IERC20Metadata(tokenIn_).decimals(),
   471	                    IERC20Metadata(tokenOut_).decimals()
   472	                )
   473	                .mulDown(SLIPPAGE_THRESHOLD);
   474	    }
   475	}

