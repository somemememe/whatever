    }

    function _balanceOf(address token, address account) internal view returns (uint256) {
        if (token == address(0) || account == address(0)) {
            return 0;
        }
        try IERC20Like(token).balanceOf(account) returns (uint256 balance) {
            return balance;
        } catch {
            return 0;
        }
    }
}
