/Users/zhanglongqin/AuditHoundV2/output/sushi_badger_digg_dualmodel_1round_p4/rounds/round_1/round_summary_stderr.log:732:[{"id":"F-001","severity":"Critical","confidence":"high","title":"Missing Parentheses in SushiMaker._swap Causes Incorrect Amount Calculation","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiMaker.sol:181","0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiMaker.sol:186"],"claim":"The _swap function in SushiMaker has missing parentheses in the amountOut calculation formula. At line 181: `amountIn.mul(997).mul(reserve1) / reserve0.mul(1000).add(amountInWithFee)` is computed as `amountIn * 997 * reserve1 / reserve0 * 1000 + amountIn * 997` instead of the correct `amountIn * 997 * reserve1 / (reserve0 * 1000 + amountIn * 997)`","impact":"Users receive significantly less output tokens than expected during swaps, causing permanent loss of funds. The protocol will lose tokens in every conversion operation.","paths":["Call SushiMaker.convert() or convertMultiple() with any token pair - the incorrect formula will cause the protocol to lose value on each swap"]},{"id":"F-002","severity":"High","confidence":"high","title":"Migrator Can Drain All LP Tokens from MasterChef","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/MasterChef.sol:137-146"],"claim":"The migrate() function can be called by anyone (not just owner) and gives the migrator full control over LP tokens. Once a migrator is set by the owner, anyone can trigger `migrator.migrate(lpToken)` which approves all LP tokens to the migrator contract.","impact":"A malicious or compromised migrator contract can drain all LP tokens from MasterChef, causing permanent loss of all staked funds.","paths":["1. Owner sets a malicious migrator via setMigrator()\n2. Anyone calls migrate() with any pool ID\n3. Migrator receives approval for all LP tokens and transfers them out"]},{"id":"F-003","severity":"High","confidence":"high","title":"Timelock Allows Arbitrary Contract Execution Without Validation","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/Timelock.sol:103-128"],"claim":"The executeTransaction() function executes arbitrary calls to any target address without validating that the target is a known safe contract. It also uses low-level .call() without specifying gas limits.","impact":"If the admin account is compromised, the attacker can execute arbitrary calls to any contract, potentially stealing funds from any contract the admin has access to. No protection against reentrancy or malicious targets.","paths":["1. Compromise admin account\n2. Queue and execute transaction to malicious target\n3. Target can call back into Timelock or other vulnerable contracts"]},{"id":"F-004","severity":"Medium","confidence":"medium","title":"SushiRoll Migration Lacks Slippage Protection for New Pools","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiRoll.sol:42-72"],"claim":"The migrate() function uses amountAMin and amountBMin only for the removeLiquidity call on the old router, but doesn't verify that the amount of new LP tokens received provides adequate value.","impact":"If the new SushiSwap pool has worse rates or if price moves significantly during the migration, users could receive significantly fewer tokens than expected with no protection.","paths":["1. User calls migrate() with small slippage parameters\n2. Price moves significantly between removeLiquidity and addLiquidity\n3. User receives less than expected tokens"]},{"id":"F-005","severity":"Medium","confidence":"high","title":"MasterChef Dev Fee Not Transparent","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/MasterChef.sol:196"],"claim":"The updatePool() function mints 10% of rewards to the dev address without any user disclosure or opt-out mechanism. The dev address can be changed by the current dev.","impact":"Users stake in the protocol without knowing that 10% of rewards are diverted to a developer address. The dev can also change the dev address to redirect fees.","paths":["1. User deposits into MasterChef\n2. Rewards are distributed with 10% going to devaddr\n3. Dev can change dev address to redirect fees"]},{"id":"F-006","severity":"Medium","confidence":"medium","title":"MasterChef SafeSushiTransfer May Distribute Incorrect Amounts","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/MasterChef.sol:251-258"],"claim":"The safeSushiTransfer function transfers the full balance if pending reward exceeds balance, rather than reverting. This can cause users to receive more than their pending reward when the pool is depleted.","impact":"When the contract doesn't have enough SUSHI to pay all pending rewards, early withdrawers may receive more than their fair share, leaving later withdrawers with nothing.","paths":["1. Large reward distribution occurs\n2. Multiple users withdraw simultaneously\n3. Early users get full balance, later users get nothing"]},{"id":"F-007","severity":"Low","confidence":"high","title":"MasterChef Pool Allocation Points Have No Upper Bound","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/MasterChef.sol:108-120"],"claim":"The add() function allows setting any allocPoint value without upper bound check. Total allocPoint can become extremely large.","impact":"Very large allocation points could cause precision issues in reward calculations due to integer division limitations.","paths":["Owner calls add() with extremely large allocation points"]},{"id":"F-008","severity":"Low","confidence":"medium","title":"SushiToken Uses Deprecated `now` Keyword","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiToken.sol:121"],"claim":"The delegateBySig function uses `now` for signature expiry check which is deprecated in favor of `block.timestamp`.","impact":"Code maintainability and future compatibility issues. `now` may be removed in future Solidity versions.","paths":["None - this is a code quality issue"]},{"id":"F-009","severity":"Informational","confidence":"high","title":"SushiBar Enter/Leave Functions Subject to Rounding Loss","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiBar.sol:23-50"],"claim":"The enter() and leave() functions use integer division which can result in users losing small amounts of tokens due to rounding.","impact":"Users may lose up to a few wei of tokens per transaction due to division truncation.","paths":["User repeatedly enters and leaves SushiBar - small amounts lost per transaction"]},{"id":"F-010","severity":"High","confidence":"medium","title":"SushiMaker onlyEOA Modifier Can Be Bypassed Via Smart Contract","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/SushiMaker.sol:73-77"],"claim":"The onlyEOA modifier checks msg.sender == tx.origin but can be bypassed by calling from a separately deployed contract that isn't a proxy. The SushiMakerExploitMock demonstrates this vulnerability.","impact":"Flash loan attacks could potentially be executed if the onlyEOA check can be bypassed, allowing manipulation of xSushi balances.","paths":["1. Deploy a contract that calls SushiMaker.convert()\n2. This contract has msg.sender != tx.origin (contract vs EOA)\n3. However, the check still passes since tx.origin is the original caller"]},{"id":"F-011","severity":"Medium","confidence":"medium","title":"Timelock Receive Function Allows Direct ETH Transfers","locations":["0xe11fc0b43ab98eb91e9836129d1ee7c3bc95df50/contracts/Timelock.sol:51"],"claim":"The receive() function accepts direct ETH transfers without any control or logging.","impact":"ETH can be sent directly to Timelock but can only be recovered via executeTransaction, creating potential for locked funds if admin is unavailable.","paths":["Any EOA sends ETH directly to Timelock contract"]}]
