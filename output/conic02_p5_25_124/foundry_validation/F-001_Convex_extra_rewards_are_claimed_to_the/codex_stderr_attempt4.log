        address convexHandler,
        address[] memory curvePools
    ) internal view returns (uint256) {
        try IConvexHandlerLike(convexHandler).getCrvEarnedBatch(pool, curvePools) returns (
            uint256 amount
        ) {
            return amount;
        } catch {
            return 0;
        }
    }

