   291	
   292	            if (latestRoundID == 0) {
   293	                sharePrice = MULTIPLIER;
   294	            } else {
   295	                uint256 currSharePrice = currentSharePrice();
   296	                uint256 latestSharePrice = roundPricePerShare[
   297	                    latestRoundID - 1
   298	                ];
   299	
   300	                sharePrice = latestSharePrice < currSharePrice
   301	                    ? latestSharePrice
   302	                    : currSharePrice;
   303	            }
   304	
   305	            uint256 ethAmount = VaultMath.sharesToAsset(_shares, sharePrice);
   306	
   307	            stoneMinter.burn(msg.sender, _shares);
   308	
   309	            if (ethAmount <= idleAmount) {
   310	                actualWithdrawn = actualWithdrawn + ethAmount;
   311	
   312	                emit Withdrawn(msg.sender, ethAmount, latestRoundID);
   313	            } else {
   314	                actualWithdrawn = actualWithdrawn + idleAmount;
   315	                ethAmount = ethAmount - idleAmount;
   316	
   317	                StrategyController controller = StrategyController(
   318	                    strategyController
   319	                );
   320	                uint256 actualAmount = controller.forceWithdraw(ethAmount);
   321	
   322	                actualWithdrawn = actualWithdrawn + actualAmount;
   323	
   324	                emit WithdrawnFromStrategy(
   325	                    msg.sender,
   326	                    ethAmount,
   327	                    actualAmount,
   328	                    latestRoundID
   329	                );
   330	            }
   331	        }
   332	
   333	        require(aVault.getBalance() >= actualWithdrawn, "still need wait");
   334	
   335	        uint256 withFee;
   336	        if (withdrawFeeRate != 0) {
   337	            withFee = (actualWithdrawn * withdrawFeeRate) / ONE_HUNDRED_PERCENT;
   338	            aVault.withdraw(feeRecipient, withFee);
   339	
   340	            emit FeeCharged(msg.sender, withFee);
   341	        }
   342	        aVault.withdraw(msg.sender, actualWithdrawn - withFee);
   343	    }
   344	
   345	    function rollToNextRound() external {
   346	        require(
   347	            block.timestamp > rebaseTime + rebaseTimeInterval,
   348	            "already rebased"
   349	        );
   350	
   351	        StrategyController controller = StrategyController(strategyController);
   352	        AssetsVault aVault = AssetsVault(assetsVault);
   353	        uint256 previewSharePrice = currentSharePrice();
   354	
   355	        uint256 vaultBalance = aVault.getBalance();
   356	        uint256 amountToWithdraw = VaultMath.sharesToAsset(
   357	            withdrawingSharesInRound,
   358	            previewSharePrice
   359	        );
   360	        uint256 amountVaultNeed = withdrawableAmountInPast + amountToWithdraw;
   361	        uint256 allPendingValue = controller.getAllStrategyPendingValue();
   362	
   363	        uint256 vaultIn;
   364	        uint256 vaultOut;
   365	
   366	        if (vaultBalance > amountVaultNeed) {
   367	            vaultIn = vaultBalance - amountVaultNeed;
   368	        } else if (vaultBalance + allPendingValue < amountVaultNeed) {
   369	            vaultOut = amountVaultNeed - vaultBalance - allPendingValue;
   370	        }
   371	
   372	        controller.rebaseStrategies(vaultIn, vaultOut);
   373	
   374	        uint256 newSharePrice = currentSharePrice();
   375	        roundPricePerShare[latestRoundID] = previewSharePrice < newSharePrice
   376	            ? previewSharePrice
   377	            : newSharePrice;
   378	
   379	        settlementTime[latestRoundID] = block.timestamp;
   380	        latestRoundID = latestRoundID + 1;
   381	
   382	        withdrawingSharesInPast =
   383	            withdrawingSharesInPast +
   384	            withdrawingSharesInRound;
   385	        withdrawableAmountInPast =
   386	            withdrawableAmountInPast +
   387	            VaultMath.sharesToAsset(withdrawingSharesInRound, newSharePrice);
   388	        withdrawingSharesInRound = 0;
   389	        rebaseTime = block.timestamp;
   390	
   391	        emit RollToNextRound(latestRoundID, vaultIn, vaultOut, newSharePrice);
   392	    }
