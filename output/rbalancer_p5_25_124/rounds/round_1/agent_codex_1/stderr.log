   431	        Minter(minter).setNewVault(_vault);
   432	        AssetsVault(assetsVault).setNewVault(_vault);
   433	        StrategyController(strategyController).setNewVault(_vault);
   434	    }
   435	
   436	    function currentSharePrice() public returns (uint256 price) {
   437	        Stone stoneToken = Stone(stone);
   438	        uint256 totalStone = stoneToken.totalSupply();
   439	        if (
   440	            latestRoundID == 0 ||
   441	            totalStone == 0 ||
   442	            totalStone == withdrawingSharesInPast
   443	        ) {
   444	            return MULTIPLIER;
   445	        }
   446	
   447	        uint256 etherAmount = AssetsVault(assetsVault).getBalance() +
   448	            StrategyController(strategyController).getAllStrategiesValue() -
   449	            withdrawableAmountInPast;
   450	        uint256 activeShare = totalStone - withdrawingSharesInPast;
   451	
   452	        return (etherAmount * MULTIPLIER) / activeShare;
   453	    }
   454	
   455	    function getVaultAvailableAmount()
   456	        public
   457	        returns (uint256 idleAmount, uint256 investedAmount)
   458	    {
   459	        AssetsVault vault = AssetsVault(assetsVault);
   460	
   461	        if (vault.getBalance() > withdrawableAmountInPast) {
   462	            idleAmount = vault.getBalance() - withdrawableAmountInPast;
   463	        }
   464	
   465	        investedAmount = StrategyController(strategyController)
   466	            .getAllStrategyValidValue();
   467	    }
   468	
