     3	pragma solidity ^0.8.0;
     4	
     5	import "./LzApp.sol";
     6	import "../util/ExcessivelySafeCall.sol";
     7	
     8	/*
     9	 * the default LayerZero messaging behaviour is blocking, i.e. any failed message will block the channel
    10	 * this abstract class try-catch all fail messages and store locally for future retry. hence, non-blocking
    11	 * NOTE: if the srcAddress is not configured properly, it will still block the message pathway from (srcChainId, srcAddress)
    12	 */
    13	abstract contract NonblockingLzApp is LzApp {
    14	    using ExcessivelySafeCall for address;
    15	
    16	    constructor(address _endpoint) LzApp(_endpoint) {}
    17	
    18	    mapping(uint16 => mapping(bytes => mapping(uint64 => bytes32))) public failedMessages;
    19	
    20	    event MessageFailed(uint16 _srcChainId, bytes _srcAddress, uint64 _nonce, bytes _payload, bytes _reason);
    21	    event RetryMessageSuccess(uint16 _srcChainId, bytes _srcAddress, uint64 _nonce, bytes32 _payloadHash);
    22	
    23	    // overriding the virtual function in LzReceiver
    24	    function _blockingLzReceive(uint16 _srcChainId, bytes memory _srcAddress, uint64 _nonce, bytes memory _payload) internal virtual override {
    25	        (bool success, bytes memory reason) = address(this).excessivelySafeCall(gasleft(), 150, abi.encodeWithSelector(this.nonblockingLzReceive.selector, _srcChainId, _srcAddress, _nonce, _payload));
    26	        // try-catch all errors/exceptions
    27	        if (!success) {
    28	            _storeFailedMessage(_srcChainId, _srcAddress, _nonce, _payload, reason);
    29	        }
    30	    }
    31	
    32	    function _storeFailedMessage(uint16 _srcChainId, bytes memory _srcAddress, uint64 _nonce, bytes memory _payload, bytes memory _reason) internal virtual {
    33	        failedMessages[_srcChainId][_srcAddress][_nonce] = keccak256(_payload);
    34	        emit MessageFailed(_srcChainId, _srcAddress, _nonce, _payload, _reason);
    35	    }
    36	
    37	    function nonblockingLzReceive(uint16 _srcChainId, bytes calldata _srcAddress, uint64 _nonce, bytes calldata _payload) public virtual {
    38	        // only internal transaction
    39	        require(_msgSender() == address(this), "NonblockingLzApp: caller must be LzApp");
    40	        _nonblockingLzReceive(_srcChainId, _srcAddress, _nonce, _payload);
    41	    }
    42	
    43	    //@notice override this function
    44	    function _nonblockingLzReceive(uint16 _srcChainId, bytes memory _srcAddress, uint64 _nonce, bytes memory _payload) internal virtual;
    45	
    46	    function retryMessage(uint16 _srcChainId, bytes calldata _srcAddress, uint64 _nonce, bytes calldata _payload) public payable virtual {
    47	        // assert there is message to retry
    48	        bytes32 payloadHash = failedMessages[_srcChainId][_srcAddress][_nonce];
    49	        require(payloadHash != bytes32(0), "NonblockingLzApp: no stored message");
    50	        require(keccak256(_payload) == payloadHash, "NonblockingLzApp: invalid payload");
    51	        // clear the stored message
    52	        failedMessages[_srcChainId][_srcAddress][_nonce] = bytes32(0);
    53	        // execute the message. revert if it fails again
    54	        _nonblockingLzReceive(_srcChainId, _srcAddress, _nonce, _payload);
    55	        emit RetryMessageSuccess(_srcChainId, _srcAddress, _nonce, payloadHash);
    56	    }
    57	}

