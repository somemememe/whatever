   409	        StrategyController controller = StrategyController(strategyController);
   410	
   411	        controller.clearStrategy(_strategy);
   412	        emit StragetyCleared(_strategy);
   413	    }
   414	
   415	    function updatePortfolioConfig(
   416	        address[] memory _strategies,
   417	        uint256[] memory _ratios
   418	    ) external onlyProposal {
   419	        StrategyController controller = StrategyController(strategyController);
   420	
   421	        controller.setStrategies(_strategies, _ratios);
   422	
   423	        emit PortfolioConfigUpdated(_strategies, _ratios);
   424	    }
   425	
