   103	            total = 0;
   104	        } else {
   105	            total = total + _in - _out;
   106	        }
   107	
   108	        uint256 length = strategies.length();
   109	        StrategyDiff[] memory diffs = new StrategyDiff[](length);
   110	        uint256 head;
   111	        uint256 tail = length - 1;
   112	        for (uint i; i < length; i++) {
   113	            address strategy = strategies.at(i);
   114	            if (ratios[strategy] == 0) {
   115	                _clearStrategy(strategy, true);
   116	                continue;
   117	            }
   118	            uint256 newPosition = (total * ratios[strategy]) /
   119	                ONE_HUNDRED_PERCENT;
   120	            uint256 position = getStrategyValidValue(strategy);
   121	
   122	            if (newPosition < position) {
   123	                diffs[head] = StrategyDiff(
   124	                    strategy,
   125	                    false,
   126	                    position - newPosition
   127	                );
   128	                head++;
   129	            } else if (newPosition > position) {
   130	                diffs[tail] = StrategyDiff(
   131	                    strategy,
   132	                    true,
   133	                    newPosition - position
   134	                );
   135	                if (tail != 0) {
   136	                    tail--;
   137	                }
   138	            }
   139	        }
   140	
   141	        length = diffs.length;
   142	        for (uint256 i; i < length; i++) {
   143	            StrategyDiff memory diff = diffs[i];
   144	
   145	            if (diff.amount == 0) {
   146	                continue;
   147	            }
   148	
   149	            if (diff.isDeposit) {
   150	                if (address(this).balance < diff.amount) {
   151	                    diff.amount = address(this).balance;
   152	                }
   153	                _depositToStrategy(diff.strategy, diff.amount);
   154	            } else {
   155	                _withdrawFromStrategy(diff.strategy, diff.amount);
   156	            }
   157	        }
   158	
   159	        _repayToVault();
   160	    }
   161	
   162	    function _repayToVault() internal {
   163	        if (address(this).balance != 0) {
   164	            TransferHelper.safeTransferETH(assetsVault, address(this).balance);
   165	        }
   166	    }
   167	
   168	    function _depositToStrategy(address _strategy, uint256 _amount) internal {
   169	        Strategy(_strategy).deposit{value: _amount}();
   170	    }
   171	
   172	    function _withdrawFromStrategy(
   173	        address _strategy,
   174	        uint256 _amount
   175	    ) internal {
   176	        Strategy(_strategy).withdraw(_amount);
   177	    }
   178	
   179	    function _forceWithdraw(
   180	        uint256 _amount
   181	    ) internal returns (uint256 actualAmount) {
   182	        uint256 length = strategies.length();
   183	        for (uint i; i < length; i++) {
   184	            address strategy = strategies.at(i);
   185	
   186	            uint256 withAmount = (_amount * ratios[strategy]) /
   187	                ONE_HUNDRED_PERCENT;
   188	
   189	            if (withAmount != 0) {
   190	                actualAmount =
   191	                    Strategy(strategy).instantWithdraw(withAmount) +
   192	                    actualAmount;
   193	            }
   194	        }
   195	
   196	        _repayToVault();
   197	    }
