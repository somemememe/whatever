   315	    function _couldDestroyStrategy(
   316	        address _strategy
   317	    ) internal returns (bool status) {
   318	        return
   319	            ratios[_strategy] == 0 && Strategy(_strategy).getAllValue() < 1e4;
   320	    }
   321	
   322	    function setNewVault(address _vault) external onlyVault {
   323	        stoneVault = _vault;
   324	    }
   325	
   326	    receive() external payable {}
   327	}

