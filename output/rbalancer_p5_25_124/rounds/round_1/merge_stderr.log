   218	        uint256 length = strategies.length();
   219	        for (uint i; i < length; i++) {
   220	            _value = _value + getStrategyValue(strategies.at(i));
   221	        }
   222	    }
   223	
   224	    function getAllStrategyValidValue() public returns (uint256 _value) {
   225	        uint256 length = strategies.length();
   226	        for (uint i; i < length; i++) {
   227	            _value = _value + getStrategyValidValue(strategies.at(i));
   228	        }
   229	    }
   230	
   231	    function getAllStrategyPendingValue() public returns (uint256 _value) {
   232	        uint256 length = strategies.length();
   233	        for (uint i; i < length; i++) {
   234	            _value = _value + getStrategyPendingValue(strategies.at(i));
   235	        }
   236	    }
   237	
   238	    function getStrategies()
   239	        public
   240	        view
   241	        returns (address[] memory addrs, uint256[] memory portions)
   242	    {
   243	        uint256 length = strategies.length();
   244	
   245	        addrs = new address[](length);
   246	        portions = new uint256[](length);
   247	
   248	        for (uint256 i; i < length; i++) {
   249	            address addr = strategies.at(i);
   250	            addrs[i] = addr;
   251	            portions[i] = ratios[addr];
   252	        }
   253	    }
   254	
   255	    function _initStrategies(
   256	        address[] memory _strategies,
   257	        uint256[] memory _ratios
   258	    ) internal {
   259	        require(_strategies.length == _ratios.length, "invalid length");
   260	
   261	        uint256 totalRatio;
   262	        uint256 length = _strategies.length;
   263	        for (uint i; i < length; i++) {
   264	            strategies.add(_strategies[i]);
   265	            ratios[_strategies[i]] = _ratios[i];
   266	            totalRatio = totalRatio + _ratios[i];
   267	        }
   268	        require(totalRatio <= ONE_HUNDRED_PERCENT, "exceed 100%");
   269	    }
   270	
   271	    function _setStrategies(
   272	        address[] memory _strategies,
   273	        uint256[] memory _ratios
   274	    ) internal {
   275	        uint256 length = _strategies.length;
   276	        require(length == _ratios.length, "invalid length");
   277	
   278	        uint256 oldLength = strategies.length();
   279	        for (uint i; i < oldLength; i++) {
   280	            ratios[strategies.at(i)] = 0;
   281	        }
   282	        uint256 totalRatio;
   283	        for (uint i; i < length; i++) {
   284	            require(
   285	                Strategy(_strategies[i]).controller() == address(this),
   286	                "controller mismatch"
   287	            );
   288	            strategies.add(_strategies[i]);
   289	            ratios[_strategies[i]] = _ratios[i];
   290	            totalRatio = totalRatio + _ratios[i];
   291	        }
   292	        require(totalRatio <= ONE_HUNDRED_PERCENT, "exceed 100%");
   293	    }
