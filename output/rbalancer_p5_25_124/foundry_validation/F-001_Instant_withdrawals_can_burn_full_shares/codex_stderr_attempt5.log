    function _candidateFromPool(
        address pool,
        uint24 feeTier,
        address stone,
        SearchParams memory params,
        StrategyState memory state
    ) internal returns (Candidate memory best) {
        uint256[10] memory probes;
        probes[0] = params.minControllerShares;
        probes[1] = params.minControllerShares * 2;
        probes[2] = params.minControllerShares * 4;
        probes[3] = params.minControllerShares * 8;
        probes[4] = params.minControllerShares * 16;
        probes[5] = params.maxProbeShares / 64;
        probes[6] = params.maxProbeShares / 32;
        probes[7] = params.maxProbeShares / 16;
        probes[8] = params.maxProbeShares / 8;
        probes[9] = params.maxProbeShares / 4;

        for (uint256 j = 0; j < probes.length; ++j) {
            Candidate memory probe = _candidateFromProbe(
                pool,
                feeTier,
                stone,
                probes[j],
                params,
                state
            );
            if (_isBetterCandidate(probe, best)) {
                best = probe;
            }
        }
    }

    function _candidateFromProbe(
        address pool,
        uint24 feeTier,
        address stone,
        uint256 probedBorrowAmount,
        SearchParams memory params,
        StrategyState memory state
    ) internal returns (Candidate memory candidate) {
        uint256 borrowAmount = probedBorrowAmount;
        if (borrowAmount < params.minControllerShares) {
            borrowAmount = params.minControllerShares;
        }
        if (borrowAmount == 0 || borrowAmount > params.maxProbeShares) {
            return candidate;
        }

        uint256 expectedPayout = _sharesToAsset(borrowAmount, params.sharePrice);
        if (expectedPayout <= params.idleAmount + params.controllerCash) {
            return candidate;
        }

        uint256 estimatedGrossActual = _estimateGrossActual(
            expectedPayout,
            params.idleAmount,
            params.controllerCash,
            state.ratios,
            state.liveValues
        );
        if (expectedPayout <= estimatedGrossActual) {
            return candidate;
        }

        uint256 estimatedNetActual = _applyFee(estimatedGrossActual, params.feeRate);
        uint256 quotedWethIn = _quoteWethForStone(stone, feeTier, borrowAmount);
        if (quotedWethIn == 0) {
            return candidate;
        }

        uint256 premium = (quotedWethIn * params.flashloanPremiumRate + (AAVE_BPS - 1)) / AAVE_BPS;
        uint256 repayWeth = quotedWethIn + premium;
        if (estimatedNetActual <= repayWeth + MIN_BUFFER) {
            return candidate;
        }

        candidate = Candidate({
            pool: pool,
            feeTier: feeTier,
            borrowAmount: borrowAmount,
            quotedWethIn: quotedWethIn,
            repayWeth: repayWeth,
            expectedPayout: expectedPayout,
            estimatedGrossActual: estimatedGrossActual,
            estimatedNetActual: estimatedNetActual,
            controllerCash: params.controllerCash
        });
    }

    function _isBetterCandidate(Candidate memory lhs, Candidate memory rhs) internal pure returns (bool) {
        if (lhs.pool == address(0)) {
            return false;
        }
        if (rhs.pool == address(0)) {
            return true;
        }

        uint256 lhsNetMargin = lhs.estimatedNetActual - lhs.repayWeth;
        uint256 rhsNetMargin = rhs.estimatedNetActual - rhs.repayWeth;
        if (lhsNetMargin != rhsNetMargin) {
            return lhsNetMargin > rhsNetMargin;
        }

        uint256 lhsShortfall = lhs.expectedPayout - lhs.estimatedGrossActual;
        uint256 rhsShortfall = rhs.expectedPayout - rhs.estimatedGrossActual;
        return lhsShortfall > rhsShortfall;
    }

    function _estimateGrossActual(
