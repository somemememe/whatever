\"\"\",\"\"\"contract FlawVerifier is IFlashLoanRecipient {
    struct SellSnapshot {
        uint256 reserveTokenBefore;
        uint256 reserveWethBefore;
        uint256 pairTokenBalanceBefore;
        bool wethIsToken0;
    }

