// SPDX-License-Identifier: UNLICENSED
pragma solidity "'^0.8.20;
import "forge-std/Test.sol";

interface IRubicProxyProbe {
    function getAvailableRouters() external view returns (address[] memory);
    function fixedCryptoFee() external view returns (uint256);
    function RubicPlatformFee() external view returns (uint256);
    function minTokenAmount(address) external view returns (uint256);
    function maxTokenAmount(address) external view returns (uint256);
}

interface IERC20Probe {
    function balanceOf(address) external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function symbol() external view returns (string memory);
}

interface IFactoryProbe { function getPair(address,address) external view returns (address); }

contract ProbeTest is Test {
    address constant PROXY = 0x3335A88bb18fD3b6824b59Af62b50CE494143333;
    address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address constant UNI_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;

    function setUp() public {
        vm.createSelectFork(vm.envString("RPC"), 16260580);
    }

    function testProbe() public {
        address[] memory routers = IRubicProxyProbe(PROXY).getAvailableRouters();
        emit log_named_uint("routerCount", routers.length);
        emit log_named_uint("fixedFee", IRubicProxyProbe(PROXY).fixedCryptoFee());
        emit log_named_uint("platformFee", IRubicProxyProbe(PROXY).RubicPlatformFee());
        for (uint256 i; i < routers.length; ++i) {
            address a = routers[i];
            emit log_named_address("router", a);
            try IERC20Probe(a).balanceOf(PROXY) returns (uint256 bal) {
                emit log_named_uint("bal", bal);
            } catch {
                emit log_string("bal revert");
            }
            try IERC20Probe(a).symbol() returns (string memory s) {
                emit log_string(s);
            } catch {
                emit log_string("symbol revert");
            }
            try IRubicProxyProbe(PROXY).minTokenAmount(a) returns (uint256 mn) {
                uint256 mx = IRubicProxyProbe(PROXY).maxTokenAmount(a);
                emit log_named_uint("min", mn);
                emit log_named_uint("max", mx);
            } catch {}
            address p1 = IFactoryProbe(UNI_FACTORY).getPair(a, WETH);
            address p2 = IFactoryProbe(SUSHI_FACTORY).getPair(a, WETH);
            emit log_named_address("uniPair", p1);
            emit log_named_address("sushiPair", p2);
        }
    }
}
