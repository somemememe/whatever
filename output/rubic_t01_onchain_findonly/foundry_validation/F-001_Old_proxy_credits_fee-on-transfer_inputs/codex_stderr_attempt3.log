import os, json, requests
RPC=os.environ['RPC']

def rpc(method, params):
    r=requests.post(RPC, json={'jsonrpc':'2.0','id':1,'method':method,'params':params}, timeout=30)
    r.raise_for_status()
    j=r.json()
    if 'error' in j:
        raise SystemExit(j)
    return j['result']

def eth_call(to, data):
    return rpc('eth_call', [{'to':to,'data':data}, '0xf82150'])

proxy='0x3335A88bb18fD3b6824b59Af62b50CE494143333'
