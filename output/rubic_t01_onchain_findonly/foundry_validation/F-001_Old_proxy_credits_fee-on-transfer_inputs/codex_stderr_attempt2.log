        tokens.push(0x43f11c02439e2736800433b4594994Bd43Cd066D);
        tokens.push(0x52b492a33E447Cdb854c7FC19F1e57E8BfA1777D);
        tokens.push(0xaccC63f2a6C0F30755C320950565F4c4E88A5272);
        tokens.push(0x29b0Da86e484E1C0029B56e817912d778aC0EC69);
    }

    function testProbe() public {
        address[] memory routers = IRubicProxy(TARGET_PROXY).getAvailableRouters();
        emit log_named_uint("router count", routers.length);
        for (uint256 i; i < routers.length; ++i) {
            emit log_named_address("router", routers[i]);
        }
        emit log_named_uint("fee ppm", IRubicProxy(TARGET_PROXY).RubicPlatformFee());
        emit log_named_uint("fixed fee", IRubicProxy(TARGET_PROXY).fixedCryptoFee());
        for (uint256 i; i < tokens.length; ++i) {
            uint256 bal = IERC20(tokens[i]).balanceOf(TARGET_PROXY);
            if (bal > 0) {
                emit log_named_address("token", tokens[i]);
                emit log_named_uint("bal", bal);
            }
        }
    }
}
