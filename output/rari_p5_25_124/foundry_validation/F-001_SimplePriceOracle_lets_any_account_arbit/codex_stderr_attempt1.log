    function _flashBorrow(address pair, address debtToken, uint256 amount) internal {
        address token0 = IUniV2Pair(pair).token0();
        address token1 = IUniV2Pair(pair).token1();
        bytes memory data = abi.encode(uint256(1));

        if (token0 == debtToken) {
            IUniV2Pair(pair).swap(amount, 0, address(this), data);
            return;
        }

        require(token1 == debtToken, "pair-mismatch");
        IUniV2Pair(pair).swap(0, amount, address(this), data);
    }

    function _findDexRoute(address debtToken, address collateralToken)
        internal
        view
        returns (address pair, address router, address routeMid)
    {
        (pair,) = _findFlashPairOnFactory(UNISWAP_FACTORY, debtToken);
        if (pair != address(0) && _hasSwapPath(UNISWAP_FACTORY, collateralToken, debtToken)) {
            routeMid = _pickRouteMid(UNISWAP_FACTORY, collateralToken, debtToken);
            return (pair, UNISWAP_ROUTER, routeMid);
        }

        (pair,) = _findFlashPairOnFactory(SUSHI_FACTORY, debtToken);
        if (pair != address(0) && _hasSwapPath(SUSHI_FACTORY, collateralToken, debtToken)) {
            routeMid = _pickRouteMid(SUSHI_FACTORY, collateralToken, debtToken);
            return (pair, SUSHI_ROUTER, routeMid);
        }

        return (address(0), address(0), address(0));
