+            (cToken == CUSDT && underlying == USDT) ||
+            (cToken == CWBTC && underlying == WBTC) ||
+            (cToken == CSAI && underlying == SAI) ||
+            (cToken == CREP && underlying == REP) ||
+            (cToken == CZRX && underlying == ZRX) ||
+            (cToken == CUNI && underlying == UNI) ||
+            (cToken == CCOMP && underlying == COMP) ||
+            (cToken == CLINK && underlying == LINK) ||
+            (cToken == CTUSD && underlying == TUSD) ||
+            (cToken == CAAVE && underlying == AAVE) ||
+            (cToken == CMKR && underlying == MKR) ||
+            (cToken == CSUSHI && underlying == SUSHI) ||
+            (cToken == CYFI && underlying == YFI) ||
+            (cToken == CWBTC2 && underlying == WBTC) ||
+            (cToken == CFEI && underlying == FEI);
+    }
