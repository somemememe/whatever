  1149	     * @param borrowSpeed New borrow-side COMP speed for market
  1150	     */
  1151	    function setCompSpeedInternal(CToken cToken, uint supplySpeed, uint borrowSpeed) internal {
  1152	        Market storage market = markets[address(cToken)];
  1153	        require(market.isListed, "comp market is not listed");
  1154	
  1155	        if (compSupplySpeeds[address(cToken)] != supplySpeed) {
  1156	            // Supply speed updated so let's update supply state to ensure that
  1157	            //  1. COMP accrued properly for the old speed, and
  1158	            //  2. COMP accrued at the new speed starts after this block.
  1159	            updateCompSupplyIndex(address(cToken));
  1160	
  1161	            // Update speed and emit event
  1162	            compSupplySpeeds[address(cToken)] = supplySpeed;
  1163	            emit CompSupplySpeedUpdated(cToken, supplySpeed);
  1164	        }
  1165	
  1166	        if (compBorrowSpeeds[address(cToken)] != borrowSpeed) {
  1167	            // Borrow speed updated so let's update borrow state to ensure that
  1168	            //  1. COMP accrued properly for the old speed, and
  1169	            //  2. COMP accrued at the new speed starts after this block.
  1170	            Exp memory borrowIndex = Exp({mantissa: cToken.borrowIndex()});
  1171	            updateCompBorrowIndex(address(cToken), borrowIndex);
  1172	
  1173	            // Update speed and emit event
  1174	            compBorrowSpeeds[address(cToken)] = borrowSpeed;
  1175	            emit CompBorrowSpeedUpdated(cToken, borrowSpeed);
  1176	        }
  1177	    }
