  1337	     * @param cTokens The list of markets to claim COMP in
  1338	     * @param borrowers Whether or not to claim COMP earned by borrowing
  1339	     * @param suppliers Whether or not to claim COMP earned by supplying
  1340	     */
  1341	    function claimComp(address[] memory holders, CToken[] memory cTokens, bool borrowers, bool suppliers) public {
  1342	        for (uint i = 0; i < cTokens.length; i++) {
  1343	            CToken cToken = cTokens[i];
  1344	            require(markets[address(cToken)].isListed, "market must be listed");
  1345	            if (borrowers == true) {
  1346	                Exp memory borrowIndex = Exp({mantissa: cToken.borrowIndex()});
  1347	                updateCompBorrowIndex(address(cToken), borrowIndex);
  1348	                for (uint j = 0; j < holders.length; j++) {
  1349	                    distributeBorrowerComp(address(cToken), holders[j], borrowIndex);
  1350	                }
  1351	            }
  1352	            if (suppliers == true) {
  1353	                updateCompSupplyIndex(address(cToken));
  1354	                for (uint j = 0; j < holders.length; j++) {
  1355	                    distributeSupplierComp(address(cToken), holders[j]);
  1356	                }
  1357	            }
  1358	        }
  1359	        for (uint j = 0; j < holders.length; j++) {
  1360	            compAccrued[holders[j]] = grantCompInternal(holders[j], compAccrued[holders[j]]);
  1361	        }
  1362	    }
