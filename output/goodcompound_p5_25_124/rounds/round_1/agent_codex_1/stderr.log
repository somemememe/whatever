  1221	    /**
  1222	     * @notice Calculate COMP accrued by a supplier and possibly transfer it to them
  1223	     * @param cToken The market in which the supplier is interacting
  1224	     * @param supplier The address of the supplier to distribute COMP to
  1225	     */
  1226	    function distributeSupplierComp(address cToken, address supplier) internal {
  1227	        // TODO: Don't distribute supplier COMP if the user is not in the supplier market.
  1228	        // This check should be as gas efficient as possible as distributeSupplierComp is called in many places.
  1229	        // - We really don't want to call an external contract as that's quite expensive.
  1230	
  1231	        CompMarketState storage supplyState = compSupplyState[cToken];
  1232	        uint supplyIndex = supplyState.index;
  1233	        uint supplierIndex = compSupplierIndex[cToken][supplier];
  1234	
  1235	        // Update supplier's index to the current index since we are distributing accrued COMP
  1236	        compSupplierIndex[cToken][supplier] = supplyIndex;
  1237	
  1238	        if (supplierIndex == 0 && supplyIndex >= compInitialIndex) {
  1239	            // Covers the case where users supplied tokens before the market's supply state index was set.
  1240	            // Rewards the user with COMP accrued from the start of when supplier rewards were first
  1241	            // set for the market.
  1242	            supplierIndex = compInitialIndex;
  1243	        }
  1244	
  1245	        // Calculate change in the cumulative sum of the COMP per cToken accrued
  1246	        Double memory deltaIndex = Double({mantissa: sub_(supplyIndex, supplierIndex)});
  1247	
  1248	        uint supplierTokens = CToken(cToken).balanceOf(supplier);
  1249	
  1250	        // Calculate COMP accrued: cTokenAmount * accruedPerCToken
  1251	        uint supplierDelta = mul_(supplierTokens, deltaIndex);
  1252	
  1253	        uint supplierAccrued = add_(compAccrued[supplier], supplierDelta);
  1254	        compAccrued[supplier] = supplierAccrued;
  1255	
  1256	        emit DistributedSupplierComp(CToken(cToken), supplier, supplierDelta, supplyIndex);
  1257	    }
  1258	
  1259	    /**
  1260	     * @notice Calculate COMP accrued by a borrower and possibly transfer it to them
  1261	     * @dev Borrowers will not begin to accrue until after the first interaction with the protocol.
  1262	     * @param cToken The market in which the borrower is interacting
  1263	     * @param borrower The address of the borrower to distribute COMP to
  1264	     */
  1265	    function distributeBorrowerComp(address cToken, address borrower, Exp memory marketBorrowIndex) internal {
  1266	        // TODO: Don't distribute supplier COMP if the user is not in the borrower market.
  1267	        // This check should be as gas efficient as possible as distributeBorrowerComp is called in many places.
  1268	        // - We really don't want to call an external contract as that's quite expensive.
  1269	
  1270	        CompMarketState storage borrowState = compBorrowState[cToken];
  1271	        uint borrowIndex = borrowState.index;
  1272	        uint borrowerIndex = compBorrowerIndex[cToken][borrower];
  1273	
  1274	        // Update borrowers's index to the current index since we are distributing accrued COMP
  1275	        compBorrowerIndex[cToken][borrower] = borrowIndex;
  1276	
  1277	        if (borrowerIndex == 0 && borrowIndex >= compInitialIndex) {
  1278	            // Covers the case where users borrowed tokens before the market's borrow state index was set.
  1279	            // Rewards the user with COMP accrued from the start of when borrower rewards were first
  1280	            // set for the market.
  1281	            borrowerIndex = compInitialIndex;
  1282	        }
  1283	
  1284	        // Calculate change in the cumulative sum of the COMP per borrowed unit accrued
  1285	        Double memory deltaIndex = Double({mantissa: sub_(borrowIndex, borrowerIndex)});
  1286	
  1287	        uint borrowerAmount = div_(CToken(cToken).borrowBalanceStored(borrower), marketBorrowIndex);
  1288	        
  1289	        // Calculate COMP accrued: cTokenAmount * accruedPerBorrowedUnit
  1290	        uint borrowerDelta = mul_(borrowerAmount, deltaIndex);
  1291	
  1292	        uint borrowerAccrued = add_(compAccrued[borrower], borrowerDelta);
  1293	        compAccrued[borrower] = borrowerAccrued;
  1294	
  1295	        emit DistributedBorrowerComp(CToken(cToken), borrower, borrowerDelta, borrowIndex);
  1296	    }
