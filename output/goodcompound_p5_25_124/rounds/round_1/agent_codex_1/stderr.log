   610	     * @param redeemTokensIn The number of cTokens to redeem into underlying (only one of redeemTokensIn or redeemAmountIn may be non-zero)
   611	     * @param redeemAmountIn The number of underlying tokens to receive from redeeming cTokens (only one of redeemTokensIn or redeemAmountIn may be non-zero)
   612	     * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   613	     */
   614	    function redeemFresh(address payable redeemer, uint redeemTokensIn, uint redeemAmountIn) internal returns (uint) {
   615	        require(redeemTokensIn == 0 || redeemAmountIn == 0, "one of redeemTokensIn or redeemAmountIn must be zero");
   616	
   617	        RedeemLocalVars memory vars;
   618	
   619	        /* exchangeRate = invoke Exchange Rate Stored() */
   620	        (vars.mathErr, vars.exchangeRateMantissa) = exchangeRateStoredInternal();
   621	        if (vars.mathErr != MathError.NO_ERROR) {
   622	            return failOpaque(Error.MATH_ERROR, FailureInfo.REDEEM_EXCHANGE_RATE_READ_FAILED, uint(vars.mathErr));
   623	        }
   624	
   625	        /* If redeemTokensIn > 0: */
   626	        if (redeemTokensIn > 0) {
   627	            /*
   628	             * We calculate the exchange rate and the amount of underlying to be redeemed:
   629	             *  redeemTokens = redeemTokensIn
   630	             *  redeemAmount = redeemTokensIn x exchangeRateCurrent
   631	             */
   632	            vars.redeemTokens = redeemTokensIn;
   633	
   634	            (vars.mathErr, vars.redeemAmount) = mulScalarTruncate(Exp({mantissa: vars.exchangeRateMantissa}), redeemTokensIn);
   635	            if (vars.mathErr != MathError.NO_ERROR) {
   636	                return failOpaque(Error.MATH_ERROR, FailureInfo.REDEEM_EXCHANGE_TOKENS_CALCULATION_FAILED, uint(vars.mathErr));
   637	            }
   638	        } else {
   639	            /*
   640	             * We get the current exchange rate and calculate the amount to be redeemed:
   641	             *  redeemTokens = redeemAmountIn / exchangeRate
   642	             *  redeemAmount = redeemAmountIn
   643	             */
   644	
   645	            (vars.mathErr, vars.redeemTokens) = divScalarByExpTruncate(redeemAmountIn, Exp({mantissa: vars.exchangeRateMantissa}));
   646	            if (vars.mathErr != MathError.NO_ERROR) {
   647	                return failOpaque(Error.MATH_ERROR, FailureInfo.REDEEM_EXCHANGE_AMOUNT_CALCULATION_FAILED, uint(vars.mathErr));
   648	            }
   649	
   650	            vars.redeemAmount = redeemAmountIn;
   651	        }
   652	
   653	        /* Fail if redeem not allowed */
   654	        uint allowed = comptroller.redeemAllowed(address(this), redeemer, vars.redeemTokens);
   655	        if (allowed != 0) {
   656	            return failOpaque(Error.COMPTROLLER_REJECTION, FailureInfo.REDEEM_COMPTROLLER_REJECTION, allowed);
   657	        }
   658	
   659	        /* Verify market's block number equals current block number */
   660	        if (accrualBlockNumber != getBlockNumber()) {
   661	            return fail(Error.MARKET_NOT_FRESH, FailureInfo.REDEEM_FRESHNESS_CHECK);
   662	        }
   663	
   664	        /*
   665	         * We calculate the new total supply and redeemer balance, checking for underflow:
   666	         *  totalSupplyNew = totalSupply - redeemTokens
   667	         *  accountTokensNew = accountTokens[redeemer] - redeemTokens
   668	         */
   669	        (vars.mathErr, vars.totalSupplyNew) = subUInt(totalSupply, vars.redeemTokens);
   670	        if (vars.mathErr != MathError.NO_ERROR) {
   671	            return failOpaque(Error.MATH_ERROR, FailureInfo.REDEEM_NEW_TOTAL_SUPPLY_CALCULATION_FAILED, uint(vars.mathErr));
   672	        }
   673	
   674	        (vars.mathErr, vars.accountTokensNew) = subUInt(accountTokens[redeemer], vars.redeemTokens);
   675	        if (vars.mathErr != MathError.NO_ERROR) {
   676	            return failOpaque(Error.MATH_ERROR, FailureInfo.REDEEM_NEW_ACCOUNT_BALANCE_CALCULATION_FAILED, uint(vars.mathErr));
   677	        }
   678	
   679	        /* Fail gracefully if protocol has insufficient cash */
   680	        if (getCashPrior() < vars.redeemAmount) {
   681	            return fail(Error.TOKEN_INSUFFICIENT_CASH, FailureInfo.REDEEM_TRANSFER_OUT_NOT_POSSIBLE);
   682	        }
   683	
   684	        /////////////////////////
   685	        // EFFECTS & INTERACTIONS
   686	        // (No safe failures beyond this point)
   687	
   688	        /*
   689	         * We invoke doTransferOut for the redeemer and the redeemAmount.
   690	         *  Note: The cToken must handle variations between ERC-20 and ETH underlying.
   691	         *  On success, the cToken has redeemAmount less of cash.
   692	         *  doTransferOut reverts if anything goes wrong, since we can't be sure if side effects occurred.
   693	         */
   694	        doTransferOut(redeemer, vars.redeemAmount);
   695	
   696	        /* We write previously calculated values into storage */
   697	        totalSupply = vars.totalSupplyNew;
   698	        accountTokens[redeemer] = vars.accountTokensNew;
   699	
   700	        /* We emit a Transfer event, and a Redeem event */
   701	        emit Transfer(redeemer, address(this), vars.redeemTokens);
   702	        emit Redeem(redeemer, vars.redeemAmount, vars.redeemTokens);
   703	
   704	        /* We call the defense hook */
   705	        comptroller.redeemVerify(address(this), redeemer, vars.redeemAmount, vars.redeemTokens);
   706	
   707	        return uint(Error.NO_ERROR);
   708	    }
   709	
   710	    /**
   711	      * @notice Sender borrows assets from the protocol to their own address
   712	      * @param borrowAmount The amount of the underlying asset to borrow
   713	      * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   714	      */
   715	    function borrowInternal(uint borrowAmount) internal nonReentrant returns (uint) {
   716	        uint error = accrueInterest();
   717	        if (error != uint(Error.NO_ERROR)) {
   718	            // accrueInterest emits logs on errors, but we still want to log the fact that an attempted borrow failed
   719	            return fail(Error(error), FailureInfo.BORROW_ACCRUE_INTEREST_FAILED);
   720	        }
   721	        // borrowFresh emits borrow-specific logs on errors, so we don't need to
   722	        return borrowFresh(msg.sender, borrowAmount);
   723	    }
   724	
   725	    struct BorrowLocalVars {
   726	        MathError mathErr;
   727	        uint accountBorrows;
   728	        uint accountBorrowsNew;
   729	        uint totalBorrowsNew;
   730	    }
   731	
   732	    /**
   733	      * @notice Users borrow assets from the protocol to their own address
   734	      * @param borrowAmount The amount of the underlying asset to borrow
   735	      * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   736	      */
   737	    function borrowFresh(address payable borrower, uint borrowAmount) internal returns (uint) {
   738	        /* Fail if borrow not allowed */
   739	        uint allowed = comptroller.borrowAllowed(address(this), borrower, borrowAmount);
   740	        if (allowed != 0) {
   741	            return failOpaque(Error.COMPTROLLER_REJECTION, FailureInfo.BORROW_COMPTROLLER_REJECTION, allowed);
   742	        }
   743	
   744	        /* Verify market's block number equals current block number */
   745	        if (accrualBlockNumber != getBlockNumber()) {
   746	            return fail(Error.MARKET_NOT_FRESH, FailureInfo.BORROW_FRESHNESS_CHECK);
   747	        }
   748	
   749	        /* Fail gracefully if protocol has insufficient underlying cash */
   750	        if (getCashPrior() < borrowAmount) {
   751	            return fail(Error.TOKEN_INSUFFICIENT_CASH, FailureInfo.BORROW_CASH_NOT_AVAILABLE);
   752	        }
   753	
   754	        BorrowLocalVars memory vars;
   755	
   756	        /*
   757	         * We calculate the new borrower and total borrow balances, failing on overflow:
   758	         *  accountBorrowsNew = accountBorrows + borrowAmount
   759	         *  totalBorrowsNew = totalBorrows + borrowAmount
   760	         */
   761	        (vars.mathErr, vars.accountBorrows) = borrowBalanceStoredInternal(borrower);
   762	        if (vars.mathErr != MathError.NO_ERROR) {
   763	            return failOpaque(Error.MATH_ERROR, FailureInfo.BORROW_ACCUMULATED_BALANCE_CALCULATION_FAILED, uint(vars.mathErr));
   764	        }
   765	
   766	        (vars.mathErr, vars.accountBorrowsNew) = addUInt(vars.accountBorrows, borrowAmount);
   767	        if (vars.mathErr != MathError.NO_ERROR) {
   768	            return failOpaque(Error.MATH_ERROR, FailureInfo.BORROW_NEW_ACCOUNT_BORROW_BALANCE_CALCULATION_FAILED, uint(vars.mathErr));
   769	        }
   770	
   771	        (vars.mathErr, vars.totalBorrowsNew) = addUInt(totalBorrows, borrowAmount);
   772	        if (vars.mathErr != MathError.NO_ERROR) {
   773	            return failOpaque(Error.MATH_ERROR, FailureInfo.BORROW_NEW_TOTAL_BALANCE_CALCULATION_FAILED, uint(vars.mathErr));
   774	        }
   775	
   776	        /////////////////////////
   777	        // EFFECTS & INTERACTIONS
   778	        // (No safe failures beyond this point)
   779	
   780	        /*
   781	         * We invoke doTransferOut for the borrower and the borrowAmount.
   782	         *  Note: The cToken must handle variations between ERC-20 and ETH underlying.
   783	         *  On success, the cToken borrowAmount less of cash.
   784	         *  doTransferOut reverts if anything goes wrong, since we can't be sure if side effects occurred.
   785	         */
   786	        doTransferOut(borrower, borrowAmount);
   787	
   788	        /* We write the previously calculated values into storage */
   789	        accountBorrows[borrower].principal = vars.accountBorrowsNew;
   790	        accountBorrows[borrower].interestIndex = borrowIndex;
   791	        totalBorrows = vars.totalBorrowsNew;
   792	
   793	        /* We emit a Borrow event */
   794	        emit Borrow(borrower, borrowAmount, vars.accountBorrowsNew, vars.totalBorrowsNew);
   795	
   796	        /* We call the defense hook */
   797	        // unused function
   798	        // comptroller.borrowVerify(address(this), borrower, borrowAmount);
   799	
   800	        return uint(Error.NO_ERROR);
   801	    }
   802	
   803	    /**
   804	     * @notice Sender repays their own borrow
   805	     * @param repayAmount The amount to repay
   806	     * @return (uint, uint) An error code (0=success, otherwise a failure, see ErrorReporter.sol), and the actual repayment amount.
   807	     */
   808	    function repayBorrowInternal(uint repayAmount) internal nonReentrant returns (uint, uint) {
   809	        uint error = accrueInterest();
   810	        if (error != uint(Error.NO_ERROR)) {
   811	            // accrueInterest emits logs on errors, but we still want to log the fact that an attempted borrow failed
   812	            return (fail(Error(error), FailureInfo.REPAY_BORROW_ACCRUE_INTEREST_FAILED), 0);
   813	        }
   814	        // repayBorrowFresh emits repay-borrow-specific logs on errors, so we don't need to
   815	        return repayBorrowFresh(msg.sender, msg.sender, repayAmount);
   816	    }
   817	
   818	    /**
   819	     * @notice Sender repays a borrow belonging to borrower
   820	     * @param borrower the account with the debt being payed off
   821	     * @param repayAmount The amount to repay
   822	     * @return (uint, uint) An error code (0=success, otherwise a failure, see ErrorReporter.sol), and the actual repayment amount.
   823	     */
   824	    function repayBorrowBehalfInternal(address borrower, uint repayAmount) internal nonReentrant returns (uint, uint) {
   825	        uint error = accrueInterest();
   826	        if (error != uint(Error.NO_ERROR)) {
   827	            // accrueInterest emits logs on errors, but we still want to log the fact that an attempted borrow failed
   828	            return (fail(Error(error), FailureInfo.REPAY_BEHALF_ACCRUE_INTEREST_FAILED), 0);
   829	        }
   830	        // repayBorrowFresh emits repay-borrow-specific logs on errors, so we don't need to
   831	        return repayBorrowFresh(msg.sender, borrower, repayAmount);
   832	    }
   833	
   834	    struct RepayBorrowLocalVars {
   835	        Error err;
   836	        MathError mathErr;
   837	        uint repayAmount;
   838	        uint borrowerIndex;
   839	        uint accountBorrows;
   840	        uint accountBorrowsNew;
   841	        uint totalBorrowsNew;
   842	        uint actualRepayAmount;
   843	    }
   844	
   845	    /**
   846	     * @notice Borrows are repaid by another user (possibly the borrower).
   847	     * @param payer the account paying off the borrow
   848	     * @param borrower the account with the debt being payed off
   849	     * @param repayAmount the amount of undelrying tokens being returned
   850	     * @return (uint, uint) An error code (0=success, otherwise a failure, see ErrorReporter.sol), and the actual repayment amount.
   851	     */
   852	    function repayBorrowFresh(address payer, address borrower, uint repayAmount) internal returns (uint, uint) {
   853	        /* Fail if repayBorrow not allowed */
   854	        uint allowed = comptroller.repayBorrowAllowed(address(this), payer, borrower, repayAmount);
   855	        if (allowed != 0) {
   856	            return (failOpaque(Error.COMPTROLLER_REJECTION, FailureInfo.REPAY_BORROW_COMPTROLLER_REJECTION, allowed), 0);
   857	        }
   858	
   859	        /* Verify market's block number equals current block number */
   860	        if (accrualBlockNumber != getBlockNumber()) {
   861	            return (fail(Error.MARKET_NOT_FRESH, FailureInfo.REPAY_BORROW_FRESHNESS_CHECK), 0);
   862	        }
   863	
   864	        RepayBorrowLocalVars memory vars;
   865	
   866	        /* We remember the original borrowerIndex for verification purposes */
   867	        vars.borrowerIndex = accountBorrows[borrower].interestIndex;
   868	
   869	        /* We fetch the amount the borrower owes, with accumulated interest */
   870	        (vars.mathErr, vars.accountBorrows) = borrowBalanceStoredInternal(borrower);
   871	        if (vars.mathErr != MathError.NO_ERROR) {
   872	            return (failOpaque(Error.MATH_ERROR, FailureInfo.REPAY_BORROW_ACCUMULATED_BALANCE_CALCULATION_FAILED, uint(vars.mathErr)), 0);
   873	        }
   874	
   875	        /* If repayAmount == -1, repayAmount = accountBorrows */
   876	        if (repayAmount == uint(-1)) {
   877	            vars.repayAmount = vars.accountBorrows;
   878	        } else {
   879	            vars.repayAmount = repayAmount;
   880	        }
   881	
   882	        /////////////////////////
   883	        // EFFECTS & INTERACTIONS
   884	        // (No safe failures beyond this point)
   885	
   886	        /*
   887	         * We call doTransferIn for the payer and the repayAmount
   888	         *  Note: The cToken must handle variations between ERC-20 and ETH underlying.
   889	         *  On success, the cToken holds an additional repayAmount of cash.
   890	         *  doTransferIn reverts if anything goes wrong, since we can't be sure if side effects occurred.
   891	         *   it returns the amount actually transferred, in case of a fee.
   892	         */
   893	        vars.actualRepayAmount = doTransferIn(payer, vars.repayAmount);
   894	
   895	        /*
   896	         * We calculate the new borrower and total borrow balances, failing on underflow:
   897	         *  accountBorrowsNew = accountBorrows - actualRepayAmount
   898	         *  totalBorrowsNew = totalBorrows - actualRepayAmount
   899	         */
   900	        (vars.mathErr, vars.accountBorrowsNew) = subUInt(vars.accountBorrows, vars.actualRepayAmount);
   901	        require(vars.mathErr == MathError.NO_ERROR, "REPAY_BORROW_NEW_ACCOUNT_BORROW_BALANCE_CALCULATION_FAILED");
   902	
   903	        (vars.mathErr, vars.totalBorrowsNew) = subUInt(totalBorrows, vars.actualRepayAmount);
   904	        require(vars.mathErr == MathError.NO_ERROR, "REPAY_BORROW_NEW_TOTAL_BALANCE_CALCULATION_FAILED");
   905	
   906	        /* We write the previously calculated values into storage */
   907	        accountBorrows[borrower].principal = vars.accountBorrowsNew;
   908	        accountBorrows[borrower].interestIndex = borrowIndex;
   909	        totalBorrows = vars.totalBorrowsNew;
   910	
   911	        /* We emit a RepayBorrow event */
   912	        emit RepayBorrow(payer, borrower, vars.actualRepayAmount, vars.accountBorrowsNew, vars.totalBorrowsNew);
   913	
   914	        /* We call the defense hook */
   915	        // unused function
   916	        // comptroller.repayBorrowVerify(address(this), payer, borrower, vars.actualRepayAmount, vars.borrowerIndex);
   917	
   918	        return (uint(Error.NO_ERROR), vars.actualRepayAmount);
   919	    }
   920	
   921	    /**
   922	     * @notice The sender liquidates the borrowers collateral.
   923	     *  The collateral seized is transferred to the liquidator.
   924	     * @param borrower The borrower of this cToken to be liquidated
   925	     * @param cTokenCollateral The market in which to seize collateral from the borrower
   926	     * @param repayAmount The amount of the underlying borrowed asset to repay
   927	     * @return (uint, uint) An error code (0=success, otherwise a failure, see ErrorReporter.sol), and the actual repayment amount.
   928	     */
   929	    function liquidateBorrowInternal(address borrower, uint repayAmount, CTokenInterface cTokenCollateral) internal nonReentrant returns (uint, uint) {
   930	        uint error = accrueInterest();
   931	        if (error != uint(Error.NO_ERROR)) {
   932	            // accrueInterest emits logs on errors, but we still want to log the fact that an attempted liquidation failed
   933	            return (fail(Error(error), FailureInfo.LIQUIDATE_ACCRUE_BORROW_INTEREST_FAILED), 0);
   934	        }
   935	
   936	        error = cTokenCollateral.accrueInterest();
   937	        if (error != uint(Error.NO_ERROR)) {
   938	            // accrueInterest emits logs on errors, but we still want to log the fact that an attempted liquidation failed
   939	            return (fail(Error(error), FailureInfo.LIQUIDATE_ACCRUE_COLLATERAL_INTEREST_FAILED), 0);
   940	        }
   941	
   942	        // liquidateBorrowFresh emits borrow-specific logs on errors, so we don't need to
   943	        return liquidateBorrowFresh(msg.sender, borrower, repayAmount, cTokenCollateral);
   944	    }
   945	
   946	    /**
   947	     * @notice The liquidator liquidates the borrowers collateral.
   948	     *  The collateral seized is transferred to the liquidator.
   949	     * @param borrower The borrower of this cToken to be liquidated
   950	     * @param liquidator The address repaying the borrow and seizing collateral
   951	     * @param cTokenCollateral The market in which to seize collateral from the borrower
   952	     * @param repayAmount The amount of the underlying borrowed asset to repay
   953	     * @return (uint, uint) An error code (0=success, otherwise a failure, see ErrorReporter.sol), and the actual repayment amount.
   954	     */
   955	    function liquidateBorrowFresh(address liquidator, address borrower, uint repayAmount, CTokenInterface cTokenCollateral) internal returns (uint, uint) {
   956	        /* Fail if liquidate not allowed */
   957	        uint allowed = comptroller.liquidateBorrowAllowed(address(this), address(cTokenCollateral), liquidator, borrower, repayAmount);
   958	        if (allowed != 0) {
   959	            return (failOpaque(Error.COMPTROLLER_REJECTION, FailureInfo.LIQUIDATE_COMPTROLLER_REJECTION, allowed), 0);
   960	        }
   961	
   962	        /* Verify market's block number equals current block number */
   963	        if (accrualBlockNumber != getBlockNumber()) {
   964	            return (fail(Error.MARKET_NOT_FRESH, FailureInfo.LIQUIDATE_FRESHNESS_CHECK), 0);
   965	        }
   966	
   967	        /* Verify cTokenCollateral market's block number equals current block number */
   968	        if (cTokenCollateral.accrualBlockNumber() != getBlockNumber()) {
   969	            return (fail(Error.MARKET_NOT_FRESH, FailureInfo.LIQUIDATE_COLLATERAL_FRESHNESS_CHECK), 0);
   970	        }
   971	
   972	        /* Fail if borrower = liquidator */
   973	        if (borrower == liquidator) {
   974	            return (fail(Error.INVALID_ACCOUNT_PAIR, FailureInfo.LIQUIDATE_LIQUIDATOR_IS_BORROWER), 0);
   975	        }
   976	
   977	        /* Fail if repayAmount = 0 */
   978	        if (repayAmount == 0) {
   979	            return (fail(Error.INVALID_CLOSE_AMOUNT_REQUESTED, FailureInfo.LIQUIDATE_CLOSE_AMOUNT_IS_ZERO), 0);
   980	        }
   981	
   982	        /* Fail if repayAmount = -1 */
   983	        if (repayAmount == uint(-1)) {
   984	            return (fail(Error.INVALID_CLOSE_AMOUNT_REQUESTED, FailureInfo.LIQUIDATE_CLOSE_AMOUNT_IS_UINT_MAX), 0);
   985	        }
   986	
   987	
   988	        /* Fail if repayBorrow fails */
   989	        (uint repayBorrowError, uint actualRepayAmount) = repayBorrowFresh(liquidator, borrower, repayAmount);
   990	        if (repayBorrowError != uint(Error.NO_ERROR)) {
   991	            return (fail(Error(repayBorrowError), FailureInfo.LIQUIDATE_REPAY_BORROW_FRESH_FAILED), 0);
   992	        }
   993	
   994	        /////////////////////////
   995	        // EFFECTS & INTERACTIONS
   996	        // (No safe failures beyond this point)
   997	
   998	        /* We calculate the number of collateral tokens that will be seized */
   999	        (uint amountSeizeError, uint seizeTokens) = comptroller.liquidateCalculateSeizeTokens(address(this), address(cTokenCollateral), actualRepayAmount);
  1000	        require(amountSeizeError == uint(Error.NO_ERROR), "LIQUIDATE_COMPTROLLER_CALCULATE_AMOUNT_SEIZE_FAILED");
  1001	
  1002	        /* Revert if borrower collateral token balance < seizeTokens */
  1003	        require(cTokenCollateral.balanceOf(borrower) >= seizeTokens, "LIQUIDATE_SEIZE_TOO_MUCH");
  1004	
  1005	        // If this is also the collateral, run seizeInternal to avoid re-entrancy, otherwise make an external call
  1006	        uint seizeError;
  1007	        if (address(cTokenCollateral) == address(this)) {
  1008	            seizeError = seizeInternal(address(this), liquidator, borrower, seizeTokens);
  1009	        } else {
  1010	            seizeError = cTokenCollateral.seize(liquidator, borrower, seizeTokens);
  1011	        }
  1012	
  1013	        /* Revert if seize tokens fails (since we cannot be sure of side effects) */
  1014	        require(seizeError == uint(Error.NO_ERROR), "token seizure failed");
  1015	
  1016	        /* We emit a LiquidateBorrow event */
  1017	        emit LiquidateBorrow(liquidator, borrower, actualRepayAmount, address(cTokenCollateral), seizeTokens);
  1018	
  1019	        /* We call the defense hook */
  1020	        // unused function
  1021	        // comptroller.liquidateBorrowVerify(address(this), address(cTokenCollateral), liquidator, borrower, actualRepayAmount, seizeTokens);
  1022	
  1023	        return (uint(Error.NO_ERROR), actualRepayAmount);
  1024	    }
  1025	
  1026	    /**
  1027	     * @notice Transfers collateral tokens (this market) to the liquidator.
  1028	     * @dev Will fail unless called by another cToken during the process of liquidation.
  1029	     *  Its absolutely critical to use msg.sender as the borrowed cToken and not a parameter.
  1030	     * @param liquidator The account receiving seized collateral
  1031	     * @param borrower The account having collateral seized
  1032	     * @param seizeTokens The number of cTokens to seize
  1033	     * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
  1034	     */
  1035	    function seize(address liquidator, address borrower, uint seizeTokens) external nonReentrant returns (uint) {
  1036	        return seizeInternal(msg.sender, liquidator, borrower, seizeTokens);
  1037	    }
  1038	
  1039	    struct SeizeInternalLocalVars {
  1040	        MathError mathErr;
  1041	        uint borrowerTokensNew;
  1042	        uint liquidatorTokensNew;
  1043	        uint liquidatorSeizeTokens;
  1044	        uint protocolSeizeTokens;
  1045	        uint protocolSeizeAmount;
  1046	        uint exchangeRateMantissa;
  1047	        uint totalReservesNew;
  1048	        uint totalSupplyNew;
  1049	    }
  1050	
  1051	    /**
  1052	     * @notice Transfers collateral tokens (this market) to the liquidator.
  1053	     * @dev Called only during an in-kind liquidation, or by liquidateBorrow during the liquidation of another CToken.
  1054	     *  Its absolutely critical to use msg.sender as the seizer cToken and not a parameter.
  1055	     * @param seizerToken The contract seizing the collateral (i.e. borrowed cToken)
  1056	     * @param liquidator The account receiving seized collateral
  1057	     * @param borrower The account having collateral seized
  1058	     * @param seizeTokens The number of cTokens to seize
