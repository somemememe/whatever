   480	
   481	        if (!markets[cTokenBorrowed].isListed || !markets[cTokenCollateral].isListed) {
   482	            return uint(Error.MARKET_NOT_LISTED);
   483	        }
   484	
   485	        uint borrowBalance = CToken(cTokenBorrowed).borrowBalanceStored(borrower);
   486	
   487	        /* allow accounts to be liquidated if the market is deprecated */
   488	        if (isDeprecated(CToken(cTokenBorrowed))) {
   489	            require(borrowBalance >= repayAmount, "Can not repay more than the total borrow");
   490	        } else {
   491	            /* The borrower must have shortfall in order to be liquidatable */
   492	            (Error err, , uint shortfall) = getAccountLiquidityInternal(borrower);
   493	            if (err != Error.NO_ERROR) {
   494	                return uint(err);
   495	            }
   496	
   497	            if (shortfall == 0) {
   498	                return uint(Error.INSUFFICIENT_SHORTFALL);
   499	            }
   500	
   501	            /* The liquidator may not repay more than what is allowed by the closeFactor */
   502	            uint maxClose = mul_ScalarTruncate(Exp({mantissa: closeFactorMantissa}), borrowBalance);
   503	            if (repayAmount > maxClose) {
   504	                return uint(Error.TOO_MUCH_REPAY);
   505	            }
   506	        }
   507	        return uint(Error.NO_ERROR);
   508	    }
