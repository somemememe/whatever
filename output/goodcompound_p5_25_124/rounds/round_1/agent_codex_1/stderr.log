  1302	    function updateContributorRewards(address contributor) public {
  1303	        uint compSpeed = compContributorSpeeds[contributor];
  1304	        uint blockNumber = getBlockNumber();
  1305	        uint deltaBlocks = sub_(blockNumber, lastContributorBlock[contributor]);
  1306	        if (deltaBlocks > 0 && compSpeed > 0) {
  1307	            uint newAccrued = mul_(deltaBlocks, compSpeed);
  1308	            uint contributorAccrued = add_(compAccrued[contributor], newAccrued);
  1309	
  1310	            compAccrued[contributor] = contributorAccrued;
  1311	            lastContributorBlock[contributor] = blockNumber;
  1312	        }
  1313	    }
