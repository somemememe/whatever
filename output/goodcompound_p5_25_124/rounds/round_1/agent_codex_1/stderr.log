  1088	    /// @notice Delete this function after proposal 65 is executed
  1089	    function fixBadAccruals(address[] calldata affectedUsers, uint[] calldata amounts) external {
  1090	        require(msg.sender == admin, "Only admin can call this function"); // Only the timelock can call this function
  1091	        require(!proposal65FixExecuted, "Already executed this one-off function"); // Require that this function is only called once
  1092	        require(affectedUsers.length == amounts.length, "Invalid input");
  1093	
  1094	        // Loop variables
  1095	        address user;
  1096	        uint currentAccrual;
  1097	        uint amountToSubtract;
  1098	        uint newAccrual;
  1099	
  1100	        // Iterate through all affected users
  1101	        for (uint i = 0; i < affectedUsers.length; ++i) {
  1102	            user = affectedUsers[i];
  1103	            currentAccrual = compAccrued[user];
  1104	
  1105	            amountToSubtract = amounts[i];
  1106	
  1107	            // The case where the user has claimed and received an incorrect amount of COMP.
  1108	            // The user has less currently accrued than the amount they incorrectly received.
  1109	            if (amountToSubtract > currentAccrual) {
  1110	                // Amount of COMP the user owes the protocol
  1111	                uint accountReceivable = amountToSubtract - currentAccrual; // Underflow safe since amountToSubtract > currentAccrual
  1112	
  1113	                uint oldReceivable = compReceivable[user];
  1114	                uint newReceivable = add_(oldReceivable, accountReceivable);
  1115	
  1116	                // Accounting: record the COMP debt for the user
  1117	                compReceivable[user] = newReceivable;
  1118	
  1119	                emit CompReceivableUpdated(user, oldReceivable, newReceivable);
  1120	
  1121	                amountToSubtract = currentAccrual;
  1122	            }
  1123	            
  1124	            if (amountToSubtract > 0) {
  1125	                // Subtract the bad accrual amount from what they have accrued.
  1126	                // Users will keep whatever they have correctly accrued.
  1127	                compAccrued[user] = newAccrual = sub_(currentAccrual, amountToSubtract);
  1128	
  1129	                emit CompAccruedAdjusted(user, currentAccrual, newAccrual);
  1130	            }
  1131	        }
  1132	
  1133	        proposal65FixExecuted = true; // Makes it so that this function cannot be called again
  1134	    }
