   986	    /**
   987	      * @notice Set the given borrow caps for the given cToken markets. Borrowing that brings total borrows to or above borrow cap will revert.
   988	      * @dev Admin or borrowCapGuardian function to set the borrow caps. A borrow cap of 0 corresponds to unlimited borrowing.
   989	      * @param cTokens The addresses of the markets (tokens) to change the borrow caps for
   990	      * @param newBorrowCaps The new borrow cap values in underlying to be set. A value of 0 corresponds to unlimited borrowing.
   991	      */
   992	    function _setMarketBorrowCaps(CToken[] calldata cTokens, uint[] calldata newBorrowCaps) external {
   993	    	require(msg.sender == admin || msg.sender == borrowCapGuardian, "only admin or borrow cap guardian can set borrow caps"); 
   994	
   995	        uint numMarkets = cTokens.length;
   996	        uint numBorrowCaps = newBorrowCaps.length;
   997	
   998	        require(numMarkets != 0 && numMarkets == numBorrowCaps, "invalid input");
   999	
  1000	        for(uint i = 0; i < numMarkets; i++) {
  1001	            borrowCaps[address(cTokens[i])] = newBorrowCaps[i];
  1002	            emit NewBorrowCap(cTokens[i], newBorrowCaps[i]);
  1003	        }
  1004	    }
  1005	
