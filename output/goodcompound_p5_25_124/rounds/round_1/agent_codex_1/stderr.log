  1179	    /**
  1180	     * @notice Accrue COMP to the market by updating the supply index
  1181	     * @param cToken The market whose supply index to update
  1182	     * @dev Index is a cumulative sum of the COMP per cToken accrued.
  1183	     */
  1184	    function updateCompSupplyIndex(address cToken) internal {
  1185	        CompMarketState storage supplyState = compSupplyState[cToken];
  1186	        uint supplySpeed = compSupplySpeeds[cToken];
  1187	        uint32 blockNumber = safe32(getBlockNumber(), "block number exceeds 32 bits");
  1188	        uint deltaBlocks = sub_(uint(blockNumber), uint(supplyState.block));
  1189	        if (deltaBlocks > 0 && supplySpeed > 0) {
  1190	            uint supplyTokens = CToken(cToken).totalSupply();
  1191	            uint compAccrued = mul_(deltaBlocks, supplySpeed);
  1192	            Double memory ratio = supplyTokens > 0 ? fraction(compAccrued, supplyTokens) : Double({mantissa: 0});
  1193	            supplyState.index = safe224(add_(Double({mantissa: supplyState.index}), ratio).mantissa, "new index exceeds 224 bits");
  1194	            supplyState.block = blockNumber;
  1195	        } else if (deltaBlocks > 0) {
  1196	            supplyState.block = blockNumber;
  1197	        }
  1198	    }
  1199	
  1200	    /**
  1201	     * @notice Accrue COMP to the market by updating the borrow index
  1202	     * @param cToken The market whose borrow index to update
  1203	     * @dev Index is a cumulative sum of the COMP per cToken accrued.
  1204	     */
  1205	    function updateCompBorrowIndex(address cToken, Exp memory marketBorrowIndex) internal {
  1206	        CompMarketState storage borrowState = compBorrowState[cToken];
  1207	        uint borrowSpeed = compBorrowSpeeds[cToken];
  1208	        uint32 blockNumber = safe32(getBlockNumber(), "block number exceeds 32 bits");
  1209	        uint deltaBlocks = sub_(uint(blockNumber), uint(borrowState.block));
  1210	        if (deltaBlocks > 0 && borrowSpeed > 0) {
  1211	            uint borrowAmount = div_(CToken(cToken).totalBorrows(), marketBorrowIndex);
  1212	            uint compAccrued = mul_(deltaBlocks, borrowSpeed);
  1213	            Double memory ratio = borrowAmount > 0 ? fraction(compAccrued, borrowAmount) : Double({mantissa: 0});
  1214	            borrowState.index = safe224(add_(Double({mantissa: borrowState.index}), ratio).mantissa, "new index exceeds 224 bits");
  1215	            borrowState.block = blockNumber;
  1216	        } else if (deltaBlocks > 0) {
  1217	            borrowState.block = blockNumber;
  1218	        }
  1219	    }
