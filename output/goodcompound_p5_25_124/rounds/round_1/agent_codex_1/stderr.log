   649	    /*** Liquidity/Liquidation Calculations ***/
   650	
   651	    /**
   652	     * @dev Local vars for avoiding stack-depth limits in calculating account liquidity.
   653	     *  Note that `cTokenBalance` is the number of cTokens the account owns in the market,
   654	     *  whereas `borrowBalance` is the amount of underlying that the account has borrowed.
   655	     */
   656	    struct AccountLiquidityLocalVars {
   657	        uint sumCollateral;
   658	        uint sumBorrowPlusEffects;
   659	        uint cTokenBalance;
   660	        uint borrowBalance;
   661	        uint exchangeRateMantissa;
   662	        uint oraclePriceMantissa;
   663	        Exp collateralFactor;
   664	        Exp exchangeRate;
   665	        Exp oraclePrice;
   666	        Exp tokensToDenom;
   667	    }
   668	
   669	    /**
   670	     * @notice Determine the current account liquidity wrt collateral requirements
   671	     * @return (possible error code (semi-opaque),
   672	                account liquidity in excess of collateral requirements,
   673	     *          account shortfall below collateral requirements)
   674	     */
   675	    function getAccountLiquidity(address account) public view returns (uint, uint, uint) {
   676	        (Error err, uint liquidity, uint shortfall) = getHypotheticalAccountLiquidityInternal(account, CToken(0), 0, 0);
   677	
   678	        return (uint(err), liquidity, shortfall);
   679	    }
   680	
   681	    /**
   682	     * @notice Determine the current account liquidity wrt collateral requirements
   683	     * @return (possible error code,
   684	                account liquidity in excess of collateral requirements,
   685	     *          account shortfall below collateral requirements)
   686	     */
   687	    function getAccountLiquidityInternal(address account) internal view returns (Error, uint, uint) {
   688	        return getHypotheticalAccountLiquidityInternal(account, CToken(0), 0, 0);
   689	    }
   690	
   691	    /**
   692	     * @notice Determine what the account liquidity would be if the given amounts were redeemed/borrowed
   693	     * @param cTokenModify The market to hypothetically redeem/borrow in
   694	     * @param account The account to determine liquidity for
   695	     * @param redeemTokens The number of tokens to hypothetically redeem
   696	     * @param borrowAmount The amount of underlying to hypothetically borrow
   697	     * @return (possible error code (semi-opaque),
   698	                hypothetical account liquidity in excess of collateral requirements,
   699	     *          hypothetical account shortfall below collateral requirements)
   700	     */
   701	    function getHypotheticalAccountLiquidity(
   702	        address account,
   703	        address cTokenModify,
   704	        uint redeemTokens,
   705	        uint borrowAmount) public view returns (uint, uint, uint) {
   706	        (Error err, uint liquidity, uint shortfall) = getHypotheticalAccountLiquidityInternal(account, CToken(cTokenModify), redeemTokens, borrowAmount);
   707	        return (uint(err), liquidity, shortfall);
   708	    }
   709	
   710	    /**
   711	     * @notice Determine what the account liquidity would be if the given amounts were redeemed/borrowed
   712	     * @param cTokenModify The market to hypothetically redeem/borrow in
   713	     * @param account The account to determine liquidity for
   714	     * @param redeemTokens The number of tokens to hypothetically redeem
   715	     * @param borrowAmount The amount of underlying to hypothetically borrow
   716	     * @dev Note that we calculate the exchangeRateStored for each collateral cToken using stored data,
   717	     *  without calculating accumulated interest.
   718	     * @return (possible error code,
   719	                hypothetical account liquidity in excess of collateral requirements,
   720	     *          hypothetical account shortfall below collateral requirements)
   721	     */
   722	    function getHypotheticalAccountLiquidityInternal(
   723	        address account,
   724	        CToken cTokenModify,
   725	        uint redeemTokens,
   726	        uint borrowAmount) internal view returns (Error, uint, uint) {
   727	
   728	        AccountLiquidityLocalVars memory vars; // Holds all our calculation results
   729	        uint oErr;
   730	
   731	        // For each asset the account is in
   732	        CToken[] memory assets = accountAssets[account];
   733	        for (uint i = 0; i < assets.length; i++) {
   734	            CToken asset = assets[i];
   735	
   736	            // Read the balances and exchange rate from the cToken
   737	            (oErr, vars.cTokenBalance, vars.borrowBalance, vars.exchangeRateMantissa) = asset.getAccountSnapshot(account);
   738	            if (oErr != 0) { // semi-opaque error code, we assume NO_ERROR == 0 is invariant between upgrades
   739	                return (Error.SNAPSHOT_ERROR, 0, 0);
   740	            }
   741	            vars.collateralFactor = Exp({mantissa: markets[address(asset)].collateralFactorMantissa});
   742	            vars.exchangeRate = Exp({mantissa: vars.exchangeRateMantissa});
   743	
   744	            // Get the normalized price of the asset
   745	            vars.oraclePriceMantissa = oracle.getUnderlyingPrice(asset);
   746	            if (vars.oraclePriceMantissa == 0) {
   747	                return (Error.PRICE_ERROR, 0, 0);
   748	            }
   749	            vars.oraclePrice = Exp({mantissa: vars.oraclePriceMantissa});
   750	
   751	            // Pre-compute a conversion factor from tokens -> ether (normalized price value)
   752	            vars.tokensToDenom = mul_(mul_(vars.collateralFactor, vars.exchangeRate), vars.oraclePrice);
   753	
   754	            // sumCollateral += tokensToDenom * cTokenBalance
   755	            vars.sumCollateral = mul_ScalarTruncateAddUInt(vars.tokensToDenom, vars.cTokenBalance, vars.sumCollateral);
   756	
   757	            // sumBorrowPlusEffects += oraclePrice * borrowBalance
   758	            vars.sumBorrowPlusEffects = mul_ScalarTruncateAddUInt(vars.oraclePrice, vars.borrowBalance, vars.sumBorrowPlusEffects);
   759	
   760	            // Calculate effects of interacting with cTokenModify
   761	            if (asset == cTokenModify) {
   762	                // redeem effect
   763	                // sumBorrowPlusEffects += tokensToDenom * redeemTokens
   764	                vars.sumBorrowPlusEffects = mul_ScalarTruncateAddUInt(vars.tokensToDenom, redeemTokens, vars.sumBorrowPlusEffects);
   765	
   766	                // borrow effect
   767	                // sumBorrowPlusEffects += oraclePrice * borrowAmount
   768	                vars.sumBorrowPlusEffects = mul_ScalarTruncateAddUInt(vars.oraclePrice, borrowAmount, vars.sumBorrowPlusEffects);
   769	            }
   770	        }
   771	
   772	        // These are safe, as the underflow condition is checked first
   773	        if (vars.sumCollateral > vars.sumBorrowPlusEffects) {
   774	            return (Error.NO_ERROR, vars.sumCollateral - vars.sumBorrowPlusEffects, 0);
   775	        } else {
   776	            return (Error.NO_ERROR, 0, vars.sumBorrowPlusEffects - vars.sumCollateral);
   777	        }
   778	    }
   779	
   780	    /**
   781	     * @notice Calculate number of tokens of collateral asset to seize given an underlying amount
   782	     * @dev Used in liquidation (called in cToken.liquidateBorrowFresh)
   783	     * @param cTokenBorrowed The address of the borrowed cToken
   784	     * @param cTokenCollateral The address of the collateral cToken
   785	     * @param actualRepayAmount The amount of cTokenBorrowed underlying to convert into cTokenCollateral tokens
   786	     * @return (errorCode, number of cTokenCollateral tokens to be seized in a liquidation)
   787	     */
   788	    function liquidateCalculateSeizeTokens(address cTokenBorrowed, address cTokenCollateral, uint actualRepayAmount) external view returns (uint, uint) {
   789	        /* Read oracle prices for borrowed and collateral markets */
   790	        uint priceBorrowedMantissa = oracle.getUnderlyingPrice(CToken(cTokenBorrowed));
   791	        uint priceCollateralMantissa = oracle.getUnderlyingPrice(CToken(cTokenCollateral));
   792	        if (priceBorrowedMantissa == 0 || priceCollateralMantissa == 0) {
   793	            return (uint(Error.PRICE_ERROR), 0);
   794	        }
   795	
   796	        /*
   797	         * Get the exchange rate and calculate the number of collateral tokens to seize:
   798	         *  seizeAmount = actualRepayAmount * liquidationIncentive * priceBorrowed / priceCollateral
   799	         *  seizeTokens = seizeAmount / exchangeRate
   800	         *   = actualRepayAmount * (liquidationIncentive * priceBorrowed) / (priceCollateral * exchangeRate)
   801	         */
   802	        uint exchangeRateMantissa = CToken(cTokenCollateral).exchangeRateStored(); // Note: reverts on error
   803	        uint seizeTokens;
   804	        Exp memory numerator;
   805	        Exp memory denominator;
   806	        Exp memory ratio;
   807	
   808	        numerator = mul_(Exp({mantissa: liquidationIncentiveMantissa}), Exp({mantissa: priceBorrowedMantissa}));
   809	        denominator = mul_(Exp({mantissa: priceCollateralMantissa}), Exp({mantissa: exchangeRateMantissa}));
   810	        ratio = div_(numerator, denominator);
   811	
   812	        seizeTokens = mul_ScalarTruncate(ratio, actualRepayAmount);
   813	
   814	        return (uint(Error.NO_ERROR), seizeTokens);
   815	    }
   816	
   817	    /*** Admin Functions ***/
   818	
   819	    /**
   820	      * @notice Sets a new price oracle for the comptroller
   821	      * @dev Admin function to set a new price oracle
   822	      * @return uint 0=success, otherwise a failure (see ErrorReporter.sol for details)
   823	      */
   824	    function _setPriceOracle(PriceOracle newOracle) public returns (uint) {
   825	        // Check caller is admin
   826	        if (msg.sender != admin) {
   827	            return fail(Error.UNAUTHORIZED, FailureInfo.SET_PRICE_ORACLE_OWNER_CHECK);
   828	        }
   829	
   830	        // Track the old oracle for the comptroller
   831	        PriceOracle oldOracle = oracle;
   832	
   833	        // Set comptroller's oracle to newOracle
   834	        oracle = newOracle;
   835	
   836	        // Emit NewPriceOracle(oldOracle, newOracle)
   837	        emit NewPriceOracle(oldOracle, newOracle);
   838	
   839	        return uint(Error.NO_ERROR);
   840	    }
   841	
   842	    /**
   843	      * @notice Sets the closeFactor used when liquidating borrows
   844	      * @dev Admin function to set closeFactor
   845	      * @param newCloseFactorMantissa New close factor, scaled by 1e18
   846	      * @return uint 0=success, otherwise a failure
   847	      */
   848	    function _setCloseFactor(uint newCloseFactorMantissa) external returns (uint) {
   849	        // Check caller is admin
   850	    	require(msg.sender == admin, "only admin can set close factor");
   851	
   852	        uint oldCloseFactorMantissa = closeFactorMantissa;
   853	        closeFactorMantissa = newCloseFactorMantissa;
   854	        emit NewCloseFactor(oldCloseFactorMantissa, closeFactorMantissa);
   855	
   856	        return uint(Error.NO_ERROR);
   857	    }
   858	
   859	    /**
   860	      * @notice Sets the collateralFactor for a market
   861	      * @dev Admin function to set per-market collateralFactor
   862	      * @param cToken The market to set the factor on
   863	      * @param newCollateralFactorMantissa The new collateral factor, scaled by 1e18
   864	      * @return uint 0=success, otherwise a failure. (See ErrorReporter for details)
   865	      */
   866	    function _setCollateralFactor(CToken cToken, uint newCollateralFactorMantissa) external returns (uint) {
   867	        // Check caller is admin
   868	        if (msg.sender != admin) {
   869	            return fail(Error.UNAUTHORIZED, FailureInfo.SET_COLLATERAL_FACTOR_OWNER_CHECK);
   870	        }
   871	
   872	        // Verify market is listed
   873	        Market storage market = markets[address(cToken)];
   874	        if (!market.isListed) {
   875	            return fail(Error.MARKET_NOT_LISTED, FailureInfo.SET_COLLATERAL_FACTOR_NO_EXISTS);
   876	        }
   877	
   878	        Exp memory newCollateralFactorExp = Exp({mantissa: newCollateralFactorMantissa});
   879	
   880	        // Check collateral factor <= 0.9
   881	        Exp memory highLimit = Exp({mantissa: collateralFactorMaxMantissa});
   882	        if (lessThanExp(highLimit, newCollateralFactorExp)) {
   883	            return fail(Error.INVALID_COLLATERAL_FACTOR, FailureInfo.SET_COLLATERAL_FACTOR_VALIDATION);
   884	        }
   885	
   886	        // If collateral factor != 0, fail if price == 0
   887	        if (newCollateralFactorMantissa != 0 && oracle.getUnderlyingPrice(cToken) == 0) {
   888	            return fail(Error.PRICE_ERROR, FailureInfo.SET_COLLATERAL_FACTOR_WITHOUT_PRICE);
   889	        }
   890	
   891	        // Set market's collateral factor to new collateral factor, remember old value
   892	        uint oldCollateralFactorMantissa = market.collateralFactorMantissa;
   893	        market.collateralFactorMantissa = newCollateralFactorMantissa;
   894	
   895	        // Emit event with asset, old collateral factor, and new collateral factor
   896	        emit NewCollateralFactor(cToken, oldCollateralFactorMantissa, newCollateralFactorMantissa);
   897	
   898	        return uint(Error.NO_ERROR);
   899	    }
   900	
   901	    /**
   902	      * @notice Sets liquidationIncentive
   903	      * @dev Admin function to set liquidationIncentive
   904	      * @param newLiquidationIncentiveMantissa New liquidationIncentive scaled by 1e18
   905	      * @return uint 0=success, otherwise a failure. (See ErrorReporter for details)
   906	      */
   907	    function _setLiquidationIncentive(uint newLiquidationIncentiveMantissa) external returns (uint) {
   908	        // Check caller is admin
   909	        if (msg.sender != admin) {
   910	            return fail(Error.UNAUTHORIZED, FailureInfo.SET_LIQUIDATION_INCENTIVE_OWNER_CHECK);
   911	        }
   912	
   913	        // Save current value for use in log
   914	        uint oldLiquidationIncentiveMantissa = liquidationIncentiveMantissa;
   915	
   916	        // Set liquidation incentive to new incentive
   917	        liquidationIncentiveMantissa = newLiquidationIncentiveMantissa;
   918	
   919	        // Emit event with old incentive, new incentive
   920	        emit NewLiquidationIncentive(oldLiquidationIncentiveMantissa, newLiquidationIncentiveMantissa);
   921	
   922	        return uint(Error.NO_ERROR);
   923	    }
   924	
   925	    /**
   926	      * @notice Add the market to the markets mapping and set it as listed
   927	      * @dev Admin function to set isListed and add support for the market
   928	      * @param cToken The address of the market (token) to list
   929	      * @return uint 0=success, otherwise a failure. (See enum Error for details)
   930	      */
   931	    function _supportMarket(CToken cToken) external returns (uint) {
   932	        if (msg.sender != admin) {
   933	            return fail(Error.UNAUTHORIZED, FailureInfo.SUPPORT_MARKET_OWNER_CHECK);
   934	        }
   935	
   936	        if (markets[address(cToken)].isListed) {
   937	            return fail(Error.MARKET_ALREADY_LISTED, FailureInfo.SUPPORT_MARKET_EXISTS);
   938	        }
   939	
   940	        cToken.isCToken(); // Sanity check to make sure its really a CToken
   941	
   942	        // Note that isComped is not in active use anymore
   943	        markets[address(cToken)] = Market({isListed: true, isComped: false, collateralFactorMantissa: 0});
   944	
   945	        _addMarketInternal(address(cToken));
   946	        _initializeMarket(address(cToken));
   947	
   948	        emit MarketListed(cToken);
   949	
   950	        return uint(Error.NO_ERROR);
   951	    }
   952	
   953	    function _addMarketInternal(address cToken) internal {
   954	        for (uint i = 0; i < allMarkets.length; i ++) {
   955	            require(allMarkets[i] != CToken(cToken), "market already added");
   956	        }
   957	        allMarkets.push(CToken(cToken));
   958	    }
   959	
   960	    function _initializeMarket(address cToken) internal {
   961	        uint32 blockNumber = safe32(getBlockNumber(), "block number exceeds 32 bits");
   962	
   963	        CompMarketState storage supplyState = compSupplyState[cToken];
   964	        CompMarketState storage borrowState = compBorrowState[cToken];
   965	
   966	        /*
   967	         * Update market state indices
   968	         */
   969	        if (supplyState.index == 0) {
   970	            // Initialize supply state index with default value
   971	            supplyState.index = compInitialIndex;
   972	        }
   973	
   974	        if (borrowState.index == 0) {
   975	            // Initialize borrow state index with default value
   976	            borrowState.index = compInitialIndex;
   977	        }
   978	
   979	        /*
   980	         * Update market state block numbers
   981	         */
   982	         supplyState.block = borrowState.block = blockNumber;
   983	    }
