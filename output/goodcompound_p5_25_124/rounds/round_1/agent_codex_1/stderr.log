   139	    function addToMarketInternal(CToken cToken, address borrower) internal returns (Error) {
   140	        Market storage marketToJoin = markets[address(cToken)];
   141	
   142	        if (!marketToJoin.isListed) {
   143	            // market is not listed, cannot join
   144	            return Error.MARKET_NOT_LISTED;
   145	        }
   146	
   147	        if (marketToJoin.accountMembership[borrower] == true) {
   148	            // already joined
   149	            return Error.NO_ERROR;
   150	        }
   151	
   152	        // survived the gauntlet, add to list
   153	        // NOTE: we store these somewhat redundantly as a significant optimization
   154	        //  this avoids having to iterate through the list for the most common use cases
   155	        //  that is, only when we need to perform liquidity checks
   156	        //  and not whenever we want to check if an account is in a particular market
   157	        marketToJoin.accountMembership[borrower] = true;
   158	        accountAssets[borrower].push(cToken);
