  1364	    /**
  1365	     * @notice Transfer COMP to the user
  1366	     * @dev Note: If there is not enough COMP, we do not perform the transfer all.
  1367	     * @param user The address of the user to transfer COMP to
  1368	     * @param amount The amount of COMP to (possibly) transfer
  1369	     * @return The amount of COMP which was NOT transferred to the user
  1370	     */
  1371	    function grantCompInternal(address user, uint amount) internal returns (uint) {
  1372	        Comp comp = Comp(getCompAddress());
  1373	        uint compRemaining = comp.balanceOf(address(this));
  1374	        if (amount > 0 && amount <= compRemaining) {
  1375	            comp.transfer(user, amount);
  1376	            return 0;
  1377	        }
  1378	        return amount;
  1379	    }
