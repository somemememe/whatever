function maxOut(R0,R1,x){
  let best=-1;
  for(let y=0;y<R1;y++){
    const refFee=Math.floor(x*3/1994);
    const bal0=R0+x-refFee;
    const bal1=R1-y;
    const lhs=(bal0*10000 - x*15)*(bal1*10000);
    const rhs=R0*R1*(1000**2);
    if(lhs>=rhs) best=y;
  }
  return best;
}
for (const x of [1,2,5,10,100]) console.log('x',x,'maxOut',maxOut(1000,1000,x));
