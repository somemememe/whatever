+    function _pairState(address pair)
+        internal
+        view
+        returns (uint256 tokenReserve, uint256 wethReserve, uint256 tokenBalanceOnPair, uint256 wethBalanceOnPair)
+    {
+        IUniswapV2PairMinimal uniPair = IUniswapV2PairMinimal(pair);
