    "title": "FeeManager updateState front-run vulnerability",
    "locations": ["managers/FeeManager.sol:116-128", "modules/ShareModule.sol:281-293"],
    "claim": "FeeManager.updateState is permissionless and can be front-run by anyone with the vault address to lock price updates.",
    "impact": "An attacker can call updateState immediately after a legitimate report is submitted, causing the vault to use stale prices for subsequent fee calculations and handleReport to skip updating minPriceD18, effectively censoring price updates.",
    "paths": ["1. Attacker monitors mempool for updateState calls", "2. Attacker front-runs with updateState using same asset to lock timestamp", "3. Subsequent handleReport calls may behave unexpectedly"]
  },
