     7	library SlotLibrary {
     8	    /// @notice Computes a unique storage slot based on the module's identifiers
     9	    /// @param contractName Logical contract/module name (e.g., "ShareModule")
    10	    /// @param name Human-readable instance name (e.g., "Mellow")
