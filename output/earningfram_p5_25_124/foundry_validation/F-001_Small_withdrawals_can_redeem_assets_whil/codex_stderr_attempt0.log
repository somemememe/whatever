+        require(msg.sender == address(BALANCER), "unauthorized");
+        require(tokens.length == 1 && amounts.length == 1 && feeAmounts.length == 1, "invalid flashloan");
+        require(address(tokens[0]) == address(WETH), "unexpected token");
