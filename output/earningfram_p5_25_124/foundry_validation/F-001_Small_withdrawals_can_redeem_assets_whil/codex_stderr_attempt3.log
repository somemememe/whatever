+        emit LogAddress("owner", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("controller()"));
+        emit LogUint("controllerOk", ok ? 1 : 0);
+        emit LogAddress("controller", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("asset()"));
+        emit LogUint("assetOk", ok ? 1 : 0);
+        emit LogAddress("asset", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("subStrategy()"));
+        emit LogUint("subStrategyOk", ok ? 1 : 0);
+        emit LogAddress("subStrategy", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("maxDeposit()"));
+        emit LogUint("maxDepositOk", ok ? 1 : 0);
+        emit LogUint("maxDeposit", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("maxWithdraw()"));
+        emit LogUint("maxWithdrawOk", ok ? 1 : 0);
+        emit LogUint("maxWithdraw", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("paused()"));
+        emit LogUint("pausedOk", ok ? 1 : 0);
+        emit LogUint("paused", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("totalSupply()"));
+        emit LogUint("totalSupplyOk", ok ? 1 : 0);
+        emit LogUint("totalSupply", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("name()"));
