+// SPDX-License-Identifier: MIT
+pragma solidity ^0.8.20;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+    function envString(string calldata name) external returns (string memory);
+}
+
+address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));
+
+contract InspectPOCTest {
+    Vm constant vm = Vm(HEVM_ADDRESS);
+
+    address constant TARGET = 0x863e572B215Fd67C855d973F870266cF827AEa5e;
+
+    event LogAddress(string key, address value);
+    event LogUint(string key, uint256 value);
+    event LogBytes(string key, bytes value);
+
+    function _call(bytes memory data) internal view returns (bool ok, bytes memory ret) {
+        (ok, ret) = TARGET.staticcall(data);
+    }
+
+    function _decodeAddress(bytes memory ret) internal pure returns (address value) {
+        if (ret.length >= 32) value = abi.decode(ret, (address));
+    }
+
+    function _decodeUint(bytes memory ret) internal pure returns (uint256 value) {
+        if (ret.length >= 32) value = abi.decode(ret, (uint256));
+    }
+
+    function testInspect() public {
+        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 17875885);
+
+        emit LogUint("codeSize", TARGET.code.length);
+        emit LogUint("nativeBalance", TARGET.balance);
+
+        (bool ok, bytes memory ret) = _call(abi.encodeWithSignature("owner()"));
+        emit LogUint("ownerOk", ok ? 1 : 0);
+        emit LogAddress("owner", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("controller()"));
+        emit LogUint("controllerOk", ok ? 1 : 0);
+        emit LogAddress("controller", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("asset()"));
+        emit LogUint("assetOk", ok ? 1 : 0);
+        emit LogAddress("asset", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("subStrategy()"));
+        emit LogUint("subStrategyOk", ok ? 1 : 0);
+        emit LogAddress("subStrategy", _decodeAddress(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("maxDeposit()"));
+        emit LogUint("maxDepositOk", ok ? 1 : 0);
+        emit LogUint("maxDeposit", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("maxWithdraw()"));
+        emit LogUint("maxWithdrawOk", ok ? 1 : 0);
+        emit LogUint("maxWithdraw", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("paused()"));
+        emit LogUint("pausedOk", ok ? 1 : 0);
+        emit LogUint("paused", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("totalSupply()"));
+        emit LogUint("totalSupplyOk", ok ? 1 : 0);
+        emit LogUint("totalSupply", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("name()"));
+        emit LogUint("nameOk", ok ? 1 : 0);
+        emit LogBytes("nameRet", ret);
+
+        (ok, ret) = _call(abi.encodeWithSignature("symbol()"));
+        emit LogUint("symbolOk", ok ? 1 : 0);
