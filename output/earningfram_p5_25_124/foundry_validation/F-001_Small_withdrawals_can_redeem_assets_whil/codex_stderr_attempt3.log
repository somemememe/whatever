+        emit LogUint("totalSupply", _decodeUint(ret));
+
+        (ok, ret) = _call(abi.encodeWithSignature("name()"));
+        emit LogUint("nameOk", ok ? 1 : 0);
+        emit LogBytes("nameRet", ret);
+
+        (ok, ret) = _call(abi.encodeWithSignature("symbol()"));
