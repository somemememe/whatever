+        uint256 wethBuffer = borrowedWeth / 2;
+        uint256 wethToUse = borrowedWeth - wethBuffer;
+        wethSpent = wethToUse;
+
+        if (wethToUse > 0) {
+            tokenBought = _swapExactInput(token0, token1, wethToUse);
+        }
+
+        _induceStalePositiveBalanceAndSkim();
