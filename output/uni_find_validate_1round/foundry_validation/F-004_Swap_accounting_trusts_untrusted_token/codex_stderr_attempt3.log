s=s.replace('        if (attackerHonestAfter > attackerHonestBefore) {\\n            _profitToken = honestToken;\\n            _profitAmount = attackerHonestAfter - attackerHonestBefore;\\n', '        if (attackerHonestAfter > routeInitialHonestBalance) {\\n            _profitToken = honestToken;\\n            _profitAmount = attackerHonestAfter - routeInitialHonestBalance;\\n')
s=s.replace('        attackerHonestBefore = _balanceOf(honestToken, address(this));\\n        attackerHonestAfter = attackerHonestBefore;\\n', '        routeInitialHonestBalance = _balanceOf(honestToken, address(this));\\n        attackerHonestBefore = routeInitialHonestBalance;\\n        attackerHonestAfter = routeInitialHonestBalance;\\n')
s=s.replace('\\n            successfulRounds += 1;\\n            attackerHonestBefore = _balanceOf(honestToken, address(this));\\n', '\\n            successfulRounds += 1;\\n')
s=s.replace('        attackerHonestBefore = 0;\\n        attackerHonestAfter = 0;\\n', '        attackerHonestBefore = 0;\\n        attackerHonestAfter = 0;\\n        routeInitialHonestBalance = 0;\\n')
