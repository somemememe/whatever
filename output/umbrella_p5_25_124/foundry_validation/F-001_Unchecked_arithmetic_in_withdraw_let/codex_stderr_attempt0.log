import json, urllib.request
RPC='https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk'
BLOCK=hex(14421983)
TARGET='0xB3FB1D01B07A706736Ca175f827e4F56021b85dE'
BALANCE_OF='70a08231'

def rpc(method, params):
    payload={\"jsonrpc\":\"2.0\",\"id\":1,\"method\":method,\"params\":params}
    req=urllib.request.Request(RPC, data=json.dumps(payload).encode(), headers={'Content-Type':'application/json'})
    with urllib.request.urlopen(req, timeout=20) as r:
        return json.load(r)

def eth_call(to, data):
    res=rpc('eth_call', [{\"to\":to,\"data\":data}, BLOCK])
    if 'error' in res:
        raise SystemExit(res)
    return res['result']

def pad_addr(a):
    return a.lower().replace('0x','').rjust(64,'0')

staking='0x'+eth_call(TARGET,'0x72f702f3')[-40:]
rewards='0x'+eth_call(TARGET,'0xd1af0c7d')[-40:]
total=int(eth_call(TARGET,'0x18160ddd'),16)
bal=int(eth_call(staking,'0x'+BALANCE_OF+pad_addr(TARGET)),16)
print('staking', staking)
print('rewards', rewards)
print('totalSupply', total)
print('farmTokenBalance', bal)
