import json, urllib.request
try:
    from Crypto.Hash import keccak
except Exception as e:
    print('NOCRYPTO', e)
    raise
RPC='https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk'
TARGET='0xB3FB1D01B07A706736Ca175f827e4F56021b85dE'
BLOCK=hex(14421983)

def selector(sig):
    k=keccak.new(digest_bits=256)
    k.update(sig.encode())
    return '0x'+k.digest()[:4].hex()

def rpc(method, params):
    payload={\"jsonrpc\":\"2.0\",\"id\":1,\"method\":method,\"params\":params}
    req=urllib.request.Request(RPC, data=json.dumps(payload).encode(), headers={'Content-Type':'application/json'})
    with urllib.request.urlopen(req, timeout=20) as r:
        return json.load(r)

def call(sig):
    res=rpc('eth_call', [{\"to\":TARGET,\"data\":selector(sig)}, BLOCK])
    return res['result']

def addr(raw):
    return '0x'+raw[-40:]

print('stakingToken', addr(call('stakingToken()')))
print('rewardsToken', addr(call('rewardsToken()')))
