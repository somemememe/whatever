            return;
        }

        address pair = IUniswapV2FactoryLike(UNISWAP_V2_FACTORY).getPair(USDT, WETH);
        if (pair == address(0)) {
            return;
        }

        uint256 deficit = MIN_MAKER_USDT - _safeBalanceOf(USDT, address(this));
        uint256 amountToBorrow = deficit + ONE_USDT;
        if (amountToBorrow < ONE_USDT) {
            amountToBorrow = ONE_USDT;
        }
        if (amountToBorrow > FLASH_SEED_USDT) {
            amountToBorrow = FLASH_SEED_USDT;
        }

