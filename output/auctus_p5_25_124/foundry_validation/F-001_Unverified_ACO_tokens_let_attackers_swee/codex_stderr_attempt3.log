-            return;
-        }
-        _entered = true;
-
-        if (!_baselineCaptured) {
-            _captureBaseline();
-        }
-
-        if (!_writerHasCandidateBalance()) {
-            status = STATUS_NO_WRITER_BALANCE;
-            _entered = false;
-            return;
