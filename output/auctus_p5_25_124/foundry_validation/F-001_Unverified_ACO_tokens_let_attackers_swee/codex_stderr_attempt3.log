        address sushiPair = IUniswapV2Factory(SUSHISWAP_FACTORY).getPair(tokenIn, tokenOut);

        if (uniPair != address(0) && uniPair.code.length > 0) {
            uint256 uniOut = _quoteOut(uniPair, tokenIn, tokenOut, amountIn);
