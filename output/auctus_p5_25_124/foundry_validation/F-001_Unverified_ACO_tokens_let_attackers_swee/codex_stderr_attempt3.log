        if (!flashOk) {
            flashOk = _tryFlashswapSeed(SUSHISWAP_WETH_USDC_PAIR);
        }
        if (!flashOk && status == STATUS_UNSET) {
            status = STATUS_FLASH_FAILED;
        }

        _entered = false;
    }

    function profitToken() external view returns (address) {
        (address token,) = _currentProfit();
        return token;
