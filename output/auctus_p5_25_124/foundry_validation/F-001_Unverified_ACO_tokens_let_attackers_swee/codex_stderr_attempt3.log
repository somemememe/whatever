    function _tryFlashswapSeed(address pair) internal returns (bool ok) {
        if (pair.code.length == 0) {
            return false;
        }

        address token0 = IUniswapV2Pair(pair).token0();
        address token1 = IUniswapV2Pair(pair).token1();
        if (token0 != WETH && token1 != WETH) {
            return false;
