+
+    constructor() {
+        fakeCollateral = new MaliciousCollateralToken();
+        fakeAcoToken = new MaliciousACOToken(address(fakeCollateral));
+    }
+
+    receive() external payable {}
+
+    function executeOnOpportunity() external payable {
+        if (_entered) {
+            return;
+        }
+        _entered = true;
+
+        if (!_baselineCaptured) {
+            _captureBaseline();
+        }
+
+        if (_writerHasCandidateBalance()) {
