+        if (bestPair != address(0) && bestOut > 0) {
+            _swapExactOnPair(bestPair, tokenIn, amountIn, bestOut);
+        }
+    }
+
+    function _swapTwoHopIfPossible(address tokenIn, address bridge, address tokenOut, uint256 amountIn) internal {
