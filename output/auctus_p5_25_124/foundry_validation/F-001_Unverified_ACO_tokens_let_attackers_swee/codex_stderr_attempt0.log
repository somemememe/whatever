+                    status = STATUS_DIRECT_SUCCESS;
+                    hypothesisValidated = true;
+                }
+            } else if (_tryFlashswapSeed(UNISWAP_V2_WETH_USDC_PAIR) || _tryFlashswapSeed(SUSHISWAP_WETH_USDC_PAIR)) {
+                if (successfulSweeps > 0) {
+                    status = STATUS_FLASH_SUCCESS;
+                    hypothesisValidated = true;
+                }
+            } else {
+                status = STATUS_FLASH_FAILED;
+            }
+        } else {
+            // Economic infeasibility on this fork: the path still exists, but there is no
+            // writer-held balance among the candidate on-chain tokens to sweep for profit.
+            status = STATUS_NO_WRITER_BALANCE;
+        }
+
+        _entered = false;
+    }
+
+    function profitToken() external view returns (address) {
+        (address token,) = _currentProfit();
