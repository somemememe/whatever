+            uint256 sushiOut = _quoteOut(sushiPair, tokenIn, tokenOut, amountIn);
+            if (sushiOut > bestOut) {
+                bestOut = sushiOut;
+                bestPair = sushiPair;
+            }
+        }
+    }
+
+    function _swapExactOnPair(address pair, address tokenIn, uint256 amountIn, uint256 amountOut) internal {
+        _safeTransfer(tokenIn, pair, amountIn);
