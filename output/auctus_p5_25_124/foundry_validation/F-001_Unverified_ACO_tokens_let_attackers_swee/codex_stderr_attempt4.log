+contract MaliciousACOToken is IERC20Minimal {
+    address public immutable collateralToken;
+    address public strikeToken;
+
+    mapping(address => uint256) internal _forgedBalance;
+
+    constructor(address collateralToken_) {
+        collateralToken = collateralToken_;
+    }
+
+    function configureStrike(address strikeToken_) external {
+        strikeToken = strikeToken_;
+    }
+
+    function collateral() external view returns (address) {
