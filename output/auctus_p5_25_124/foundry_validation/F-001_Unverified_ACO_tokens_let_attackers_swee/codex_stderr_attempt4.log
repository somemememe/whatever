    function _attemptSweep(address token) internal {
        if (token == address(0) || token.code.length == 0 || _attemptedToken[token]) {
            return;
        }
        _attemptedToken[token] = true;

        uint256 writerBalance = _balanceOfIfPossible(token, TARGET);
        if (writerBalance == 0) {
