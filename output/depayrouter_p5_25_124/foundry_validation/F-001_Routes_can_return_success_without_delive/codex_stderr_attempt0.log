        }
    }

    function _callUniswapOnlyETHToUSDC(uint256 amountIn) internal returns (bool ok) {
        address[] memory path = new address[](2);
        path[0] = ETH_SENTINEL;
        path[1] = USDC;

        uint256[] memory amounts = new uint256[](3);
        amounts[0] = amountIn;
