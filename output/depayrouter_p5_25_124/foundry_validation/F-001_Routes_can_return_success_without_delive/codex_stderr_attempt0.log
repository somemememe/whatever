+
+        uint256[] memory amounts = new uint256[](3);
+        amounts[0] = amountIn;
+        amounts[1] = 1;
+        amounts[2] = block.timestamp + 1 days;
+
+        address[] memory addresses_ = new address[](1);
+        addresses_[0] = address(this);
+
+        address[] memory plugins = new address[](1);
