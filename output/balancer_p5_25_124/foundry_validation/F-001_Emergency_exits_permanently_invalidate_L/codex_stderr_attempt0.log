+        uint256 approximateVirtualSupply;
+        uint256 realVirtualSupply;
+        uint256 reportedRate;
+        uint256 trueRate;
+        uint256 lowerTarget;
+        uint256 upperTarget;
+        uint256 swapFeePercentage;
+        uint256 wrappedTokenRate;
+        uint256 mainBalance;
+        uint256 wrappedBalance;
+        address mainToken;
+        address wrappedToken;
+        address vault;
+    }
