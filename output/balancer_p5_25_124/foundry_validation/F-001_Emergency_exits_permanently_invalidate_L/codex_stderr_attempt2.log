            uint256 burnedSupply,
            uint256 approximateVirtualSupply,
            uint256 realVirtualSupply,
            uint256 reportedRate,
            uint256 trueRate,
            address mainToken,
            address wrappedToken,
            address vault
        )
    {
        Snapshot memory snap = _snapshot;
        return (
