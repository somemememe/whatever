        try IGenericBalancerPoolLike(pool).getPoolId() returns (bytes32 poolId) {
            (address[] memory tokens,,) = IVaultLike(VAULT).getPoolTokens(poolId);
            for (uint256 i = 0; i < tokens.length; ++i) {
                if (tokens[i] == TARGET) {
