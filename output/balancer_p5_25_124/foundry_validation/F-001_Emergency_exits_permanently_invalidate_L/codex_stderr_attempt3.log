    constructor() {}

    function executeOnOpportunity() external {
        require(!_attempted, "already-attempted");
        _attempted = true;

        Snapshot memory snap = _captureSnapshot();
        _snapshot = snap;
        _profitToken = USDC;
        _profitAmount = 0;
