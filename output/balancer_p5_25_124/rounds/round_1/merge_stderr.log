   371	    function _swapGivenWrappedOut(
   372	        SwapRequest memory request,
   373	        uint256[] memory balances,
   374	        LinearMath.Params memory params
   375	    ) internal view returns (uint256) {
   376	        _require(request.tokenIn == _mainToken || request.tokenIn == this, Errors.INVALID_TOKEN);
   377	        return
   378	            request.tokenIn == this
