   500	    function _getMaxTokens() internal pure override returns (uint256) {
   501	        return _TOTAL_TOKENS;
   502	    }
   503	
   504	    function _getMinimumBpt() internal pure override returns (uint256) {
   505	        // Linear Pools don't lock any BPT, as the total supply will already be forever non-zero due to the preminting
   506	        // mechanism, ensuring initialization only occurs once.
   507	        return 0;
   508	    }
