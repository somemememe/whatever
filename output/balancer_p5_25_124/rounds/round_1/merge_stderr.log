   388	
   389	    function _onInitializePool(
   390	        bytes32,
   391	        address sender,
   392	        address recipient,
   393	        uint256[] memory,
   394	        bytes memory
   395	    ) internal view override whenNotPaused returns (uint256, uint256[] memory) {
   396	        // Linear Pools can only be initialized by the Pool performing the initial join via the `initialize` function.
   397	        _require(sender == address(this), Errors.INVALID_INITIALIZATION);
   398	        _require(recipient == address(this), Errors.INVALID_INITIALIZATION);
   399	
   400	        // The full BPT supply will be minted and deposited in the Pool. Note that there is no need to approve the Vault
   401	        // as it already has infinite BPT allowance.
   402	        uint256 bptAmountOut = _INITIAL_BPT_SUPPLY;
   403	
   404	        uint256[] memory amountsIn = new uint256[](_TOTAL_TOKENS);
   405	        amountsIn[_bptIndex] = _INITIAL_BPT_SUPPLY;
