   575	    function getTargets() public view returns (uint256 lowerTarget, uint256 upperTarget) {
   576	        bytes32 miscData = _getMiscData();
   577	        lowerTarget = miscData.decodeUint96(_LOWER_TARGET_OFFSET);
   578	        upperTarget = miscData.decodeUint96(_UPPER_TARGET_OFFSET);
   579	    }
   580	
   581	    function _setTargets(
   582	        IERC20 mainToken,
   583	        uint256 lowerTarget,
   584	        uint256 upperTarget
   585	    ) private {
   586	        _require(lowerTarget <= upperTarget, Errors.LOWER_GREATER_THAN_UPPER_TARGET);
   587	        _require(upperTarget <= _MAX_UPPER_TARGET, Errors.UPPER_TARGET_TOO_HIGH);
   588	
   589	        // Pack targets as two uint96 values into a single storage slot. This results in targets being capped to 96
   590	        // bits, but that should be more than enough.
   591	        _setMiscData(
   592	            WordCodec.encodeUint(lowerTarget, _LOWER_TARGET_OFFSET) |
   593	                WordCodec.encodeUint(upperTarget, _UPPER_TARGET_OFFSET)
   594	        );
   595	
   596	        emit TargetsSet(mainToken, lowerTarget, upperTarget);
   597	    }
   598	
   599	    function setTargets(uint256 newLowerTarget, uint256 newUpperTarget) external authenticate {
   600	        // For a new target range to be valid:
   601	        //  - the pool must currently be between the current targets (meaning no fees are currently pending)
   602	        //  - the pool must currently be between the new targets (meaning setting them does not cause for fees to be
   603	        //    pending)
   604	        //
   605	        // The first requirement could be relaxed, as the LPs actually benefit from the pending fees not being paid out,
   606	        // but being stricter makes analysis easier at little expense.
   607	
   608	        (uint256 currentLowerTarget, uint256 currentUpperTarget) = getTargets();
   609	        _require(_isMainBalanceWithinTargets(currentLowerTarget, currentUpperTarget), Errors.OUT_OF_TARGET_RANGE);
   610	        _require(_isMainBalanceWithinTargets(newLowerTarget, newUpperTarget), Errors.OUT_OF_NEW_TARGET_RANGE);
   611	
   612	        _setTargets(_mainToken, newLowerTarget, newUpperTarget);
   613	    }
   614	
   615	    function setSwapFeePercentage(uint256 swapFeePercentage) public override {
   616	        // For the swap fee percentage to be changeable:
   617	        //  - the pool must currently be between the current targets (meaning no fees are currently pending)
   618	        //
   619	        // As the amount of accrued fees is not explicitly stored but rather derived from the main token balance and the
   620	        // current swap fee percentage, requiring for no fees to be pending prevents the fee setter from changing the
   621	        // amount of pending fees, which they could use to e.g. drain Pool funds in the form of inflated fees.
   622	
   623	        (uint256 lowerTarget, uint256 upperTarget) = getTargets();
   624	        _require(_isMainBalanceWithinTargets(lowerTarget, upperTarget), Errors.OUT_OF_TARGET_RANGE);
   625	
   626	        super.setSwapFeePercentage(swapFeePercentage);
   627	    }
   628	
   629	    function _isMainBalanceWithinTargets(uint256 lowerTarget, uint256 upperTarget) private view returns (bool) {
   630	        bytes32 poolId = getPoolId();
   631	        (, uint256[] memory balances, ) = getVault().getPoolTokens(poolId);
   632	        uint256 mainTokenBalance = _upscale(balances[_mainIndex], _scalingFactor(_mainToken));
   633	
   634	        return mainTokenBalance >= lowerTarget && mainTokenBalance <= upperTarget;
   635	    }
   636	
   637	    function _isOwnerOnlyAction(bytes32 actionId) internal view virtual override returns (bool) {
