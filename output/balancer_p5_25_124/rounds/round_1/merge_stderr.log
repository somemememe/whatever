   645	     * remains constant, whereas `virtualSupply` increases as users join the pool and decreases as they exit it.
   646	     */
   647	    function getVirtualSupply() external view returns (uint256) {
   648	        (, uint256[] memory balances, ) = getVault().getPoolTokens(getPoolId());
   649	        // We technically don't need to upscale the BPT balance as its scaling factor is equal to one (since BPT has
   650	        // 18 decimals), but we do it for completeness.
   651	        uint256 bptBalance = _upscale(balances[_bptIndex], _scalingFactor(this));
   652	
   653	        return _getVirtualSupply(bptBalance);
   654	    }
   655	
   656	    function _getVirtualSupply(uint256 bptBalance) internal view returns (uint256) {
   657	        return totalSupply().sub(bptBalance);
   658	    }
   659	
   660	    /**
   661	     * @dev Computes an approximation of virtual supply, which costs less gas than `_getVirtualSupply` and returns the
   662	     * same value in all cases except when the emergency pause has been enabled and BPT burned as part of the emergency
   663	     * exit process.
