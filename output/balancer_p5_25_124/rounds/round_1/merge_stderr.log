   432	    function _onExitPool(
   433	        bytes32,
   434	        address,
   435	        address,
   436	        uint256[] memory balances,
   437	        uint256,
   438	        uint256,
   439	        uint256[] memory,
   440	        bytes memory userData
   441	    )
   442	        internal
   443	        view
   444	        override
   445	        returns (
   446	            uint256 bptAmountIn,
   447	            uint256[] memory amountsOut,
   448	            uint256[] memory dueProtocolFeeAmounts
   449	        )
   450	    {
   451	        // Exits typically revert, except for the proportional exit when the emergency pause mechanism has been
   452	        // triggered. This allows for a simple and safe way to exit the Pool.
   453	
   454	        // Note that the rate cache will not be automatically updated in such a scenario (though this can be still done
   455	        // manually). This however should not lead to any issues as the rate is not important during the emergency exit.
   456	        // On the contrary, decoupling the rate provider from the emergency exit might be useful under these
   457	        // circumstances.
   458	
   459	        LinearPoolUserData.ExitKind kind = userData.exitKind();
   460	        if (kind != LinearPoolUserData.ExitKind.EMERGENCY_EXACT_BPT_IN_FOR_TOKENS_OUT) {
   461	            _revert(Errors.UNHANDLED_BY_LINEAR_POOL);
   462	        } else {
   463	            _ensurePaused();
   464	            // Note that this will cause the user's BPT to be burned, which is not something that happens during
   465	            // regular operation of this Pool, and may lead to accounting errors. Because of this, it is highly
   466	            // advisable to stop using a Pool after it is paused and the pause window expires.
   467	
   468	            (bptAmountIn, amountsOut) = _emergencyProportionalExit(balances, userData);
   469	
   470	            // Due protocol fees are set to zero as this Pool accrues no fees and pays no protocol fees.
   471	            dueProtocolFeeAmounts = new uint256[](_getTotalTokens());
   472	        }
   473	    }
   474	
   475	    function _emergencyProportionalExit(uint256[] memory balances, bytes memory userData)
   476	        private
   477	        view
   478	        returns (uint256, uint256[] memory)
   479	    {
   480	        // This proportional exit function is only enabled if the contract is paused, to provide users a way to
   481	        // retrieve their tokens in case of an emergency.
   482	        //
   483	        // This particular exit function is the only one available because it is the simplest, and therefore least
   484	        // likely to be incorrect, or revert and lock funds.
   485	
   486	        uint256 bptAmountIn = userData.exactBptInForTokensOut();
   487	        // Note that there is no minimum amountOut parameter: this is handled by `IVault.exitPool`.
   488	
   489	        // This process burns BPT, rendering `_getApproximateVirtualSupply` inaccurate, so we use the real method here
   490	        uint256[] memory amountsOut = LinearMath._calcTokensOutGivenExactBptIn(
   491	            balances,
   492	            bptAmountIn,
   493	            _getVirtualSupply(balances[_bptIndex]),
   494	            _bptIndex
   495	        );
   496	
   497	        return (bptAmountIn, amountsOut);
   498	    }
