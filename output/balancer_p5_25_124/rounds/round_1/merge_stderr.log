   510	    function _getTotalTokens() internal view virtual override returns (uint256) {
   511	        return _TOTAL_TOKENS;
   512	    }
   513	
   514	    function _scalingFactor(IERC20 token) internal view virtual override returns (uint256) {
   515	        if (token == _mainToken) {
   516	            return _scalingFactorMainToken;
   517	        } else if (token == _wrappedToken) {
   518	            // The wrapped token's scaling factor is not constant, but increases over time as the wrapped token
   519	            // increases in value.
   520	            return _scalingFactorWrappedToken.mulDown(_getWrappedTokenRate());
   521	        } else if (token == this) {
   522	            return FixedPoint.ONE;
   523	        } else {
   524	            _revert(Errors.INVALID_TOKEN);
   525	        }
   526	    }
   527	
   528	    function _scalingFactors() internal view virtual override returns (uint256[] memory) {
   529	        uint256[] memory scalingFactors = new uint256[](_TOTAL_TOKENS);
   530	
   531	        // The wrapped token's scaling factor is not constant, but increases over time as the wrapped token increases in
   532	        // value.
   533	        scalingFactors[_mainIndex] = _scalingFactorMainToken;
   534	        scalingFactors[_wrappedIndex] = _scalingFactorWrappedToken.mulDown(_getWrappedTokenRate());
   535	        scalingFactors[_bptIndex] = FixedPoint.ONE;
   536	
   537	        return scalingFactors;
   538	    }
   539	
   540	    // Price rates
   541	
   542	    /**
   543	     * @dev For a Linear Pool, the rate represents the appreciation of BPT with respect to the underlying tokens. This
   544	     * rate increases slowly as the wrapped token appreciates in value.
   545	     */
   546	    function getRate() external view override returns (uint256) {
   547	        bytes32 poolId = getPoolId();
   548	        (, uint256[] memory balances, ) = getVault().getPoolTokens(poolId);
   549	        _upscaleArray(balances, _scalingFactors());
   550	
   551	        (uint256 lowerTarget, uint256 upperTarget) = getTargets();
   552	        LinearMath.Params memory params = LinearMath.Params({
   553	            fee: getSwapFeePercentage(),
   554	            lowerTarget: lowerTarget,
   555	            upperTarget: upperTarget
   556	        });
   557	
   558	        uint256 totalBalance = LinearMath._calcInvariant(
   559	            LinearMath._toNominal(balances[_mainIndex], params),
   560	            balances[_wrappedIndex]
   561	        );
   562	
   563	        // Note that we're dividing by the virtual supply, which may be zero (causing this call to revert). However, the
   564	        // only way for that to happen would be for all LPs to exit the Pool, and nothing prevents new LPs from
   565	        // joining it later on.
   566	        return totalBalance.divUp(_getApproximateVirtualSupply(balances[_bptIndex]));
   567	    }
   568	
   569	    function getWrappedTokenRate() external view returns (uint256) {
   570	        return _getWrappedTokenRate();
   571	    }
