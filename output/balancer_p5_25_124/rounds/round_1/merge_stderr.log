   417	        uint256[] memory,
   418	        bytes memory
   419	    )
   420	        internal
   421	        pure
   422	        override
   423	        returns (
   424	            uint256,
   425	            uint256[] memory,
   426	            uint256[] memory
   427	        )
   428	    {
   429	        _revert(Errors.UNHANDLED_BY_LINEAR_POOL);
