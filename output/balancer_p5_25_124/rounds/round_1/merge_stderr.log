   665	    function _getApproximateVirtualSupply(uint256 bptBalance) internal pure returns (uint256) {
   666	        // No need for checked arithmetic as _INITIAL_BPT_SUPPLY is always greater than any valid Vault BPT balance.
   667	        return _INITIAL_BPT_SUPPLY - bptBalance;
   668	    }
