    46	        sorted[0] = token;
    47	        return sorted;
    48	    }
    49	
    50	    uint256 i;
    51	    for (i = tokens.length; i > 0 && tokens[i - 1] > token; i--) sorted[i] = tokens[i - 1];
    52	    for (uint256 j = 0; j < i; j++) sorted[j] = tokens[j];
