    31	/**
    32	 * @dev Linear Pools are designed to hold two assets: "main" and "wrapped" tokens that have an equal value underlying
    33	 * token (e.g., DAI and waDAI). There must be an external feed available to provide an exact, non-manipulable exchange
    34	 * rate between the tokens. In particular, any reversible manipulation (e.g. causing the rate to increase and then
    35	 * decrease) can lead to severe issues and loss of funds.
    36	 *
    37	 * The Pool will register three tokens in the Vault however: the two assets and the BPT itself,
    38	 * so that BPT can be exchanged (effectively joining and exiting) via swaps.
    39	 *
    40	 * Despite inheriting from BasePool, much of the basic behavior changes. This Pool does not support regular joins and
    41	 * exits, as the entire BPT supply is 'preminted' during initialization.
    42	 *
    43	 * Unlike most other Pools, this one does not attempt to create revenue by charging fees: value is derived by holding
    44	 * the wrapped, yield-bearing asset. However, the 'swap fee percentage' value is still used, albeit with a different
    45	 * meaning. This Pool attempts to hold a certain amount of "main" tokens, between a lower and upper target value.
    46	 * The pool charges fees on trades that move the balance outside that range, which are then paid back as incentives to
    47	 * traders whose swaps return the balance to the desired region.
    48	 * The net revenue via fees is expected to be zero: all collected fees are used to pay for this 'rebalancing'.
    49	 */
    50	abstract contract LinearPool is BasePool, IGeneralPool, IRateProvider {
    51	    using WordCodec for bytes32;
    52	    using FixedPoint for uint256;
    53	    using PriceRateCache for bytes32;
    54	    using LinearPoolUserData for bytes;
    55	
    56	    uint256 private constant _TOTAL_TOKENS = 3; // Main token, wrapped token, BPT
    57	
    58	    // This is the maximum token amount the Vault can hold. In regular operation, the total BPT supply remains constant
    59	    // and equal to _INITIAL_BPT_SUPPLY, but most of it remains in the Pool, waiting to be exchanged for tokens. The
    60	    // actual amount of BPT in circulation is the total supply minus the amount held by the Pool, and is known as the
    61	    // 'virtual supply'.
    62	    // The total supply can only change if the emergency pause is activated by governance, enabling an
    63	    // alternative proportional exit that burns BPT. As this is not expected to happen, we optimize for
    64	    // success by using _INITIAL_BPT_SUPPLY instead of totalSupply(), saving a storage read. This optimization is only
    65	    // valid if the Pool is never paused: in case of an emergency that leads to burned tokens, the Pool should not
    66	    // be used after the buffer period expires and it automatically 'unpauses'.
    67	    uint256 private constant _INITIAL_BPT_SUPPLY = 2**(112) - 1;
    68	
    69	    IERC20 private immutable _mainToken;
    70	    IERC20 private immutable _wrappedToken;
    71	
    72	    // The indices of each token when registered, which can then be used to access the balances array.
    73	    uint256 private immutable _bptIndex;
    74	    uint256 private immutable _mainIndex;
    75	    uint256 private immutable _wrappedIndex;
    76	
    77	    // Both BPT and the main token have a regular, constant scaling factor (equal to FixedPoint.ONE for BPT, and
    78	    // dependent on the number of decimals for the main token). However, the wrapped token's scaling factor has two
    79	    // components: the usual token decimal scaling factor, and an externally provided rate used to convert wrapped
    80	    // tokens to an equivalent main token amount. This external rate is expected to be ever increasing, reflecting the
    81	    // fact that the wrapped token appreciates in value over time (e.g. because it is accruing interest).
    82	    uint256 private immutable _scalingFactorMainToken;
    83	    uint256 private immutable _scalingFactorWrappedToken;
    84	
    85	    // The lower and upper target are in BasePool's misc data field, which has 192 bits available (as it shares the same
    86	    // storage slot as the swap fee percentage, which is 64 bits). These are already scaled by the main token's scaling
    87	    // factor, which means that the maximum upper target is ~80 billion in the main token units if the token were to
