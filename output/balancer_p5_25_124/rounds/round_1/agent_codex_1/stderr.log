    90	    // [       reserved       | upper target |  lower target ]
    91	    // [  base pool swap fee  |         misc data            ]
    92	    // [ MSB                                             LSB ]
    93	
    94	    uint256 private constant _LOWER_TARGET_OFFSET = 0;
    95	    uint256 private constant _UPPER_TARGET_OFFSET = 96;
    96	
    97	    uint256 private constant _MAX_UPPER_TARGET = 2**(96) - 1;
