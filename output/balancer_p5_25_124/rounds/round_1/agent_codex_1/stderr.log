   279	    function _toNominal(uint256 real, Params memory params) internal pure returns (uint256) {
   280	        // Fees are always rounded down: either direction would work but we need to be consistent, and rounding down
   281	        // uses less gas.
   282	
   283	        if (real < params.lowerTarget) {
   284	            uint256 fees = (params.lowerTarget - real).mulDown(params.fee);
   285	            return real.sub(fees);
   286	        } else if (real <= params.upperTarget) {
   287	            return real;
   288	        } else {
   289	            uint256 fees = (real - params.upperTarget).mulDown(params.fee);
   290	            return real.sub(fees);
   291	        }
   292	    }
   293	
   294	    function _fromNominal(uint256 nominal, Params memory params) internal pure returns (uint256) {
   295	        // Since real = nominal + fees, rounding down fees is equivalent to rounding down real.
   296	
   297	        if (nominal < params.lowerTarget) {
   298	            return (nominal.add(params.fee.mulDown(params.lowerTarget))).divDown(FixedPoint.ONE.add(params.fee));
   299	        } else if (nominal <= params.upperTarget) {
   300	            return nominal;
   301	        } else {
   302	            return (nominal.sub(params.fee.mulDown(params.upperTarget)).divDown(FixedPoint.ONE.sub(params.fee)));
   303	        }
   304	    }
