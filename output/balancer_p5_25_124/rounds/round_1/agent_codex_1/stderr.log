from decimal import Decimal, getcontext
getcontext().prec=80
ONE=10**18

def to_nom(real, fee, lower, upper):
    if real < lower:
        fees=(lower-real)*fee//ONE
        return real-fees
    elif real <= upper:
        return real
    else:
        fees=(real-upper)*fee//ONE
        return real-fees

def from_nom(nom, fee, lower, upper):
    if nom < lower:
        return (nom + fee*lower//ONE) * ONE // (ONE+fee)
    elif nom <= upper:
        return nom
    else:
        return (nom - fee*upper//ONE) * ONE // (ONE-fee)

def bpt_out_main_in(mainIn, M, W, S, fee, lower, upper):
    if S == 0:
        return to_nom(mainIn, fee, lower, upper)
    pn=to_nom(M, fee, lower, upper)
    an=to_nom(M+mainIn, fee, lower, upper)
    d=an-pn
    inv=pn+W
    return S*d//inv

def wrapped_out_bpt_in(bptIn, M, W, S, fee, lower, upper):
    pn=to_nom(M, fee, lower, upper)
    prev=pn+W
    newB=S-bptIn
    newW=((newB*prev + S -1)//S)-pn # divUp
    return W-newW

def wrapped_out_main_in(mainIn, M, fee, lower, upper):
    pn=to_nom(M, fee, lower, upper)
    an=to_nom(M+mainIn, fee, lower, upper)
    return an-pn

