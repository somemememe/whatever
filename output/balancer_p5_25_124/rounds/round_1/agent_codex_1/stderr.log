   306	    function _calcTokensOutGivenExactBptIn(
   307	        uint256[] memory balances,
   308	        uint256 bptAmountIn,
   309	        uint256 bptTotalSupply,
   310	        uint256 bptIndex
   311	    ) internal pure returns (uint256[] memory) {
   312	        /**********************************************************************************************
   313	        // exactBPTInForTokensOut                                                                    //
   314	        // (per token)                                                                               //
   315	        // aO = tokenAmountOut             /        bptIn         \                                  //
   316	        // b = tokenBalance      a0 = b * | ---------------------  |                                 //
   317	        // bptIn = bptAmountIn             \     bptTotalSupply    /                                 //
   318	        // bpt = bptTotalSupply                                                                      //
   319	        **********************************************************************************************/
   320	
   321	        // Since we're computing an amount out, we round down overall. This means rounding down on both the
   322	        // multiplication and division.
   323	
   324	        uint256 bptRatio = bptAmountIn.divDown(bptTotalSupply);
   325	
   326	        uint256[] memory amountsOut = new uint256[](balances.length);
   327	        for (uint256 i = 0; i < balances.length; i++) {
   328	            // BPT is skipped as those tokens are not the LPs, but rather the preminted and undistributed amount.
   329	            if (i != bptIndex) {
   330	                amountsOut[i] = balances[i].mulDown(bptRatio);
   331	            }
   332	        }
   333	
   334	        return amountsOut;
   335	    }
   336	}

