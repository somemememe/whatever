    20	/**
    21	 * Price rate caches are used to avoid querying the price rate for a token every time we need to work with it. It is
    22	 * useful for slow changing rates, such as those that arise from interest-bearing tokens (e.g. waDAI into DAI).
    23	 *
    24	 * The cache data is packed into a single bytes32 value with the following structure:
    25	 * [   expires   | duration | price rate value ]
    26	 * [   uint64    |  uint64  |      uint128     ]
    27	 * [ MSB                                   LSB ]
    28	 *
    29	 *
    30	 * 'rate' is an 18 decimal fixed point number, supporting rates of up to ~3e20. 'expires' is a Unix timestamp, and
    31	 * 'duration' is expressed in seconds.
    32	 */
    33	library PriceRateCache {
    34	    using WordCodec for bytes32;
    35	
    36	    uint256 private constant _PRICE_RATE_CACHE_VALUE_OFFSET = 0;
    37	    uint256 private constant _PRICE_RATE_CACHE_DURATION_OFFSET = 128;
    38	    uint256 private constant _PRICE_RATE_CACHE_EXPIRES_OFFSET = 128 + 64;
    39	
    40	    /**
    41	     * @dev Returns the rate of a price rate cache.
    42	     */
    43	    function getRate(bytes32 cache) internal pure returns (uint256) {
    44	        return cache.decodeUint128(_PRICE_RATE_CACHE_VALUE_OFFSET);
    45	    }
    46	
    47	    /**
    48	     * @dev Returns the duration of a price rate cache.
    49	     */
    50	    function getDuration(bytes32 cache) internal pure returns (uint256) {
    51	        return cache.decodeUint64(_PRICE_RATE_CACHE_DURATION_OFFSET);
    52	    }
    53	
    54	    /**
    55	     * @dev Returns the duration and expiration time of a price rate cache.
    56	     */
    57	    function getTimestamps(bytes32 cache) internal pure returns (uint256 duration, uint256 expires) {
    58	        duration = getDuration(cache);
    59	        expires = cache.decodeUint64(_PRICE_RATE_CACHE_EXPIRES_OFFSET);
    60	    }
    61	
    62	    /**
    63	     * @dev Encodes rate and duration into a price rate cache. The expiration time is computed automatically, counting
    64	     * from the current time.
    65	     */
    66	    function encode(uint256 rate, uint256 duration) internal view returns (bytes32) {
    67	        _require(rate < 2**128, Errors.PRICE_RATE_OVERFLOW);
    68	
    69	        // solhint-disable not-rely-on-time
    70	        return
    71	            WordCodec.encodeUint(uint128(rate), _PRICE_RATE_CACHE_VALUE_OFFSET) |
    72	            WordCodec.encodeUint(uint64(duration), _PRICE_RATE_CACHE_DURATION_OFFSET) |
    73	            WordCodec.encodeUint(uint64(block.timestamp + duration), _PRICE_RATE_CACHE_EXPIRES_OFFSET);
    74	    }
    75	
