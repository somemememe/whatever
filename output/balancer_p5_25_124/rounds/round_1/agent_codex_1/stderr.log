from itertools import product
ONE=10**18
f=int(0.1*ONE); l=100; u=200
class Revert(Exception): pass

def to_nom(real):
    if real < l:
        fees=(l-real)*f//ONE
        if fees>real: raise Revert('to_nom underflow')
        return real-fees
    elif real <= u:
        return real
    else:
        fees=(real-u)*f//ONE
        if fees>real: raise Revert
        return real-fees

def from_nom(nom):
    if nom < l:
        return (nom + f*l//ONE) * ONE // (ONE+f)
    elif nom <= u:
        return nom
    else:
        return (nom - f*u//ONE) * ONE // (ONE-f)

def bpt_out_main_in(x,M,W,S):
    if S==0: return to_nom(x)
    pn=to_nom(M); an=to_nom(M+x); d=an-pn; inv=pn+W
    return S*d//inv

def main_out_bpt_in(x,M,W,S):
    pn=to_nom(M); inv=pn+W; d=inv*x//S
    if d>pn: raise Revert('nom underflow')
    an=pn-d; newM=from_nom(an)
    if newM>M: raise Revert
    return M-newM

def bpt_out_wrapped_in(x,M,W,S):
    if S==0: return x
    n=to_nom(M); prev=n+W; newInv=n+W+x; newB=S*newInv//prev
    return newB-S

def wrapped_out_bpt_in(x,M,W,S):
    n=to_nom(M); prev=n+W
    if x>S: raise Revert
    newB=S-x
    newW=((newB*prev + S -1)//S)-n
    if newW>W: raise Revert
    return W-newW

def wrapped_out_main_in(x,M):
    pn=to_nom(M); an=to_nom(M+x); return an-pn

def main_out_wrapped_in(x,M):
    pn=to_nom(M)
    if x>pn: raise Revert
    an=pn-x; newM=from_nom(an)
    if newM>M: raise Revert
    return M-newM

def step(state, action, amt):
    M,W,S=state
    if action=='m2w':
        y=wrapped_out_main_in(amt,M); 
        if y>W: raise Revert
        return y,(M+amt,W-y,S)
    if action=='w2m':
        y=main_out_wrapped_in(amt,M); 
        if y>M: raise Revert
        return y,(M-y,W+amt,S)
    if action=='m2b':
        y=bpt_out_main_in(amt,M,W,S); return y,(M+amt,W,S+y)
    if action=='b2m':
        y=main_out_bpt_in(amt,M,W,S); return y,(M-y,W,S-amt)
    if action=='w2b':
        y=bpt_out_wrapped_in(amt,M,W,S); return y,(M,W+amt,S+y)
    if action=='b2w':
        y=wrapped_out_bpt_in(amt,M,W,S); return y,(M,W-y,S-amt)
    raise

acts=['m2w','w2m','m2b','b2m','w2b','b2w']
for state in [(0,1000,10000),(10,1000,10000),(50,1000,10000),(100,1000,10000),(150,1000,10000),(300,1000,10000)]:
    print('state',state)
    found=[]
    for length in [2,3]:
        for seq in product(acts, repeat=length):
            start=seq[0][0]; end=seq[-1][-1]
            if start"'!=end: continue
            ok=True
            for i in range(length-1):
                if seq[i][-1]!=seq[i+1][0]: ok=False; break
            if not ok: continue
            for amt in [1,2,5,10,20,50,100]:
                s=state; a=amt
                try:
