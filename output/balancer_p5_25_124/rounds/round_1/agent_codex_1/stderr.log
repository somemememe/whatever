    20	/**
    21	 * @title Highly opinionated token implementation
    22	 * @author Balancer Labs
    23	 * @dev
    24	 * - Includes functions to increase and decrease allowance as a workaround
    25	 *   for the well-known issue with `approve`:
    26	 *   https://github.com/ethereum/EIPs/issues/20#issuecomment-263524729
    27	 * - Allows for 'infinite allowance', where an allowance of 0xff..ff is not
    28	 *   decreased by calls to transferFrom
    29	 * - Lets a token holder use `transferFrom` to send their own tokens,
    30	 *   without first setting allowance
    31	 * - Emits 'Approval' events whenever allowance is changed by `transferFrom`
    32	 * - Assigns infinite allowance for all token holders to the Vault
    33	 */
    34	contract BalancerPoolToken is ERC20Permit {
    35	    IVault private immutable _vault;
    36	
    37	    constructor(
    38	        string memory tokenName,
    39	        string memory tokenSymbol,
    40	        IVault vault
    41	    ) ERC20(tokenName, tokenSymbol) ERC20Permit(tokenName) {
    42	        _vault = vault;
    43	    }
    44	
    45	    function getVault() public view returns (IVault) {
    46	        return _vault;
    47	    }
    48	
    49	    // Overrides
    50	
    51	    /**
    52	     * @dev Override to grant the Vault infinite allowance, causing for Pool Tokens to not require approval.
    53	     *
    54	     * This is sound as the Vault already provides authorization mechanisms when initiation token transfers, which this
    55	     * contract inherits.
    56	     */
    57	    function allowance(address owner, address spender) public view override returns (uint256) {
    58	        if (spender == address(getVault())) {
    59	            return uint256(-1);
    60	        } else {
    61	            return super.allowance(owner, spender);
    62	        }
    63	    }
    64	
    65	    /**
    66	     * @dev Override to allow for 'infinite allowance' and let the token owner use `transferFrom` with no self-allowance
    67	     */
    68	    function transferFrom(
    69	        address sender,
    70	        address recipient,
    71	        uint256 amount
    72	    ) public override returns (bool) {
    73	        uint256 currentAllowance = allowance(sender, msg.sender);
    74	        _require(msg.sender == sender || currentAllowance >= amount, Errors.ERC20_TRANSFER_EXCEEDS_ALLOWANCE);
    75	
    76	        _transfer(sender, recipient, amount);
    77	
    78	        if (msg.sender != sender && currentAllowance != uint256(-1)) {
    79	            // Because of the previous require, we know that if msg.sender != sender then currentAllowance >= amount
    80	            _approve(sender, msg.sender, currentAllowance - amount);
    81	        }
    82	
    83	        return true;
    84	    }
    85	
    86	    /**
    87	     * @dev Override to allow decreasing allowance by more than the current amount (setting it to zero)
    88	     */
    89	    function decreaseAllowance(address spender, uint256 amount) public override returns (bool) {
    90	        uint256 currentAllowance = allowance(msg.sender, spender);
    91	
    92	        if (amount >= currentAllowance) {
    93	            _approve(msg.sender, spender, 0);
    94	        } else {
    95	            // No risk of underflow due to if condition
    96	            _approve(msg.sender, spender, currentAllowance - amount);
    97	        }
    98	
    99	        return true;
   100	    }
   101	
   102	    // Internal functions
   103	
   104	    function _mintPoolTokens(address recipient, uint256 amount) internal {
   105	        _mint(recipient, amount);
   106	    }
   107	
   108	    function _burnPoolTokens(address sender, uint256 amount) internal {
   109	        _burn(sender, amount);
   110	    }
   111	}

