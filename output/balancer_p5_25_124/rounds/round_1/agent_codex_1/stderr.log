ONE=10**18
f=int(0.1*ONE); l=100*ONE; u=200*ONE
class Revert(Exception): pass

def add(a,b): c=a+b; assert c>=a; return c

def sub(a,b):
    if b>a: raise Revert
    return a-b

def mul(a,b): c=a*b; assert a==0 or c//a==b; return c

def divDown(a,b):
    if b==0: raise Revert
    return a//b

def divUp(a,b):
    if b==0: raise Revert
    return 0 if a==0 else 1+(a-1)//b

def mulDown(a,b): return mul(a,b)//ONE

def divDownFP(a,b): return 0 if a==0 else mul(a,ONE)//b

def divUpFP(a,b): return 0 if a==0 else ((mul(a,ONE)-1)//b)+1

def to_nom(real):
    if real < l: return sub(real,mulDown(l-real,f))
    elif real <= u: return real
    else: return sub(real,mulDown(real-u,f))

def from_nom(nom):
    if nom < l: return divDownFP(add(nom,mulDown(f,l)), add(ONE,f))
    elif nom <= u: return nom
    else: return divDownFP(sub(nom,mulDown(f,u)), sub(ONE,f))

def bpt_out_main_in(x,M,W,S):
    if S==0:return to_nom(x)
    prev=to_nom(M); after=to_nom(add(M,x)); d=sub(after,prev); inv=add(prev,W); return divDown(mul(S,d),inv)

def main_out_bpt_in(x,M,W,S):
    prev=to_nom(M); inv=add(prev,W); d=divDown(mul(inv,x),S); after=sub(prev,d); newM=from_nom(after); return sub(M,newM)

def bpt_out_wrapped_in(x,M,W,S):
    if S==0:return x
    n=to_nom(M); prev=add(n,W); newW=add(W,x); newInv=add(n,newW); newB=divDown(mul(S,newInv),prev); return sub(newB,S)

def wrapped_out_bpt_in(x,M,W,S):
    n=to_nom(M); prev=add(n,W); newB=sub(S,x); newW=sub(divUp(mul(newB,prev),S),n); return sub(W,newW)

for state in [(100*ONE,1000*ONE,10000*ONE),(50*ONE,1000*ONE,10000*ONE),(300*ONE,1000*ONE,10000*ONE)]:
    M,W,S=state
    print('state',tuple(v//ONE for v in state))
    for fn1,fn2,name in [
        (bpt_out_main_in, main_out_bpt_in, 'm-b-m'),
        (main_out_bpt_in, bpt_out_main_in, 'b-m-b'),
        (bpt_out_wrapped_in, wrapped_out_bpt_in, 'w-b-w'),
        (wrapped_out_bpt_in, bpt_out_wrapped_in, 'b-w-b')]:
        best=None
        for amt in [i*10**16 for i in range(1,1000)]:  # 0.01 to 9.99
            try:
                if name=='m-b-m':
                    inter=fn1(amt,M,W,S); out=fn2(inter,M+amt,W,S+inter); profit=out-amt
                elif name=='b-m-b':
                    inter=fn1(amt,M,W,S); out=fn2(inter,M-inter,W,S-amt); profit=out-amt
                elif name=='w-b-w':
                    inter=fn1(amt,M,W,S); out=fn2(inter,M,W+amt,S+inter); profit=out-amt
                else:
                    inter=fn1(amt,M,W,S); out=fn2(inter,M,W-inter,S-amt); profit=out-amt
                if best is None or profit>best[0]:
                    best=(profit,amt,inter,out)
            except: pass
        print(name,'best profit',best[0] if best else None,'amt',best[1]/ONE if best else None)
    print()
