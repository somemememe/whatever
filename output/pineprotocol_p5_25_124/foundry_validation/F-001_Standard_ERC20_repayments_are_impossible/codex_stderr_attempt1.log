pragma solidity ^0.8.20;

import {FlawVerifier} from "../src/FlawVerifier.sol";

interface Vm {
    function createSelectFork(string calldata rpcUrl, uint256 blockNumber) external returns (uint256);
}

contract ExploitPOCTest {
    Vm private constant VM = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));

    function testExecute() external {
        VM.createSelectFork("https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240", 18835344);

        FlawVerifier verifier = new FlawVerifier();
        verifier.executeOnOpportunity();

        verifier.profitToken();
        verifier.profitAmount();
        verifier.hypothesisValidated();
        verifier.hypothesisRefuted();
        verifier.lastFailureCode();
        verifier.lastRevertData();
        verifier.selfTransferFromWithoutAllowanceWorks();
    }
}

