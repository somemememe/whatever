-        }
-
-        bytes memory sliced = new bytes(revertData.length - 4);
-        for (uint256 i = 4; i < revertData.length; i++) {
-            sliced[i - 4] = revertData[i];
-        }
-
-        return abi.decode(sliced, (string));
-    }
