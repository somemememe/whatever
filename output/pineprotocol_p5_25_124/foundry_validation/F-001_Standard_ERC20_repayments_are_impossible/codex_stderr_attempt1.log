-        }
-
-        return
-            "repay(nftID, repayAmount, pineWallet) -> transferFrom(msg.sender, address(this), repayAmount) -> transferFrom(address(this), _fundSource, ...) -> transferFrom(address(this), _controlPlane, ...)";
-    }
