    81	// File: contracts/PineLendingLibrary.sol
    82	
    83	
    84	pragma solidity 0.8.3;
    85	
    86	library PineLendingLibrary {
    87	  struct LoanTerms {
    88	    uint256 loanStartBlock;
    89	    uint256 loanExpireTimestamp;
    90	    uint32 interestBPS1000000XBlock;
    91	    uint32 maxLTVBPS;
    92	    uint256 borrowedWei;
    93	    uint256 returnedWei;
    94	    uint256 accuredInterestWei;
    95	    uint256 repaidInterestWei;
    96	    address borrower;
    97	    }
    98	
    99	  function outstanding(LoanTerms calldata loanTerms, uint txSpeedBlocks) public view returns (uint256) {
   100	    // do not lump the interest
   101	    if (loanTerms.borrowedWei <= loanTerms.returnedWei) return 0;
   102	    uint256 newAccuredInterestWei = ((block.number + txSpeedBlocks -
   103	        loanTerms.loanStartBlock) *
   104	        (loanTerms.borrowedWei - loanTerms.returnedWei) *
   105	        loanTerms.interestBPS1000000XBlock) / 10000000000;
   106	    return
   107	        (loanTerms.borrowedWei - loanTerms.returnedWei) +
   108	        (loanTerms.accuredInterestWei -
   109	            loanTerms.repaidInterestWei) +
   110	        newAccuredInterestWei;
   111	  }
   112	
   113	  function outstanding(LoanTerms calldata loanTerms) public view returns (uint256) {
   114	    return outstanding(loanTerms, 0);
   115	  }
   116	
   117	  function nftHasLoan(LoanTerms memory loanTerms) public pure returns (bool) {
   118	      return loanTerms.borrowedWei > loanTerms.returnedWei;
   119	  }
   120	
   121	
   122	  function isUnHealthyLoan(LoanTerms calldata loanTerms)
   123	      public
   124	      view
   125	      returns (bool, uint32)
   126	  {
   127	      require(nftHasLoan(loanTerms), "nft does not have active loan");
   128	      bool isExpired = block.timestamp > loanTerms.loanExpireTimestamp &&
   129	          outstanding(loanTerms) > 0;
   130	      return (isExpired, 0);
   131	  }
   132	
   133	  event LoanInitiated(
   134	      address indexed user,
   135	      address indexed erc721,
   136	      uint256 indexed nftID,
   137	      LoanTerms loan
   138	  );
   139	  event LoanTermsChanged(
   140	      address indexed user,
   141	      address indexed erc721,
   142	      uint256 indexed nftID,
   143	      LoanTerms oldTerms,
   144	      LoanTerms newTerms
   145	  );
   146	  event Liquidation(
   147	      address indexed user,
   148	      address indexed erc721,
   149	      uint256 indexed nftID,
   150	      uint256 liquidated_at,
   151	      address liquidator
   152	  );
   153	}
