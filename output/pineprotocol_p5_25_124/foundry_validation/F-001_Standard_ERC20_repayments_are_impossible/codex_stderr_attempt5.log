/bin/bash -lc "python3 - <<'PY'
import json, urllib.request
url='https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240'
addr='0x2405913d54fC46eEAF3Fb092BfB099F46803872f'
for name, data in [
 ('supported','0xfd9147ae'),
 ('fund','0x781cc8e5'),
 ('control','0xca45f773'),
 ('paused','0x5c975abb')]:
    payload={\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"eth_call\",\"params\":[{\"to\":addr,\"data\":data},\"0x11f6d90\"]}
    req=urllib.request.Request(url,data=json.dumps(payload).encode(),headers={'Content-Type':'application/json'})
    with urllib.request.urlopen(req, timeout=20) as r:
        out=json.load(r)['result']
    print(name, out)
