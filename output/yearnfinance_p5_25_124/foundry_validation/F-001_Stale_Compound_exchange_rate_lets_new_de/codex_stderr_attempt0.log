+            if (_profitAmount > 0) {
+                status = Status.Success;
+                hypothesisValidated = true;
+                return;
+            }
+        }
+
+        uint256 deltaUnderlying = (cBalance * (currentRate - staleRate)) / WAD;
+        uint256 optimalFlash = _optimalFlashAmount(stalePool, deltaUnderlying);
+        if (optimalFlash == 0) {
+            status = directCapital == 0 ? Status.FlashLoanEconomicallyInfeasible : Status.NoDirectCapital;
+            hypothesisValidated = false;
+            return;
+        }
