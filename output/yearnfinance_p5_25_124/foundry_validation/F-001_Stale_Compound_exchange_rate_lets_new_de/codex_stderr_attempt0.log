codex
`cast` is crashing on this machine before the RPC call is even sent, so I’m bypassing it and querying Alchemy with raw JSON-RPC. That lets me inspect the exact fork-block state without changing the exploit path or depending on any external PoC material.
exec
/bin/bash -lc "python3 - <<'PY'
import json, urllib.request
url='https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk'
block=hex(17036774)
reqs=[
('eth_call',[{'to':'0x83f798e925BcD4017Eb265844FDDAbb448f1707D','data':'0xfc0c546a'}, block], 'token'),
('eth_call',[{'to':'0x83f798e925BcD4017Eb265844FDDAbb448f1707D','data':'0x02c14db0'}, block], 'compound'),
('eth_call',[{'to':'0x83f798e925BcD4017Eb265844FDDAbb448f1707D','data':'0x4f4b8a2a'}, block], 'provider'),
('eth_call',[{'to':'0x83f798e925BcD4017Eb265844FDDAbb448f1707D','data':'0x18160ddd'}, block], 'totalSupply'),
('eth_call',[{'to':'0x83f798e925BcD4017Eb265844FDDAbb448f1707D','data':'0x8b876347'}, block], 'calcPoolValueInToken')
]
for i,(method,params,label) in enumerate(reqs,1):
    payload={'jsonrpc':'2.0','id':i,'method':method,'params':params}
    data=json.dumps(payload).encode()
    req=urllib.request.Request(url,data=data,headers={'Content-Type':'application/json'})
    with urllib.request.urlopen(req, timeout=30) as resp:
        print(label, resp.read().decode())
