                phase = Phase.Infeasible;
                hypothesisRefuted = true;
                lastStatus = "Execution returned but no profit asset reached the verifier";
            }
        } catch {
            phase = Phase.Infeasible;
            hypothesisRefuted = true;
            lastStatus = "executeProposalWithIndex reverted under current fork-state conditions";
        }
