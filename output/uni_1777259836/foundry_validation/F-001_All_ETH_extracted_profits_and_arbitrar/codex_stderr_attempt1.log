        _reset();

        targetEthBefore = TARGET.balance;
        targetWethBefore = IERC20Like(WETH).balanceOf(TARGET);
        targetUsdcBefore = IERC20Like(USDC).balanceOf(TARGET);

        uint256 available = address(this).balance;

