        uint256 directWeth = IERC20Minimal(WETH).balanceOf(address(this));
        if (directWeth >= requiredWeth && requiredWeth != 0) {
            _executeRoute(plan, 0);
            _updateProfitAfterExecution(target.grapesToken());
