        (RoutePlan memory plan, uint256 borrowedWeth) = abi.decode(data, (RoutePlan, uint256));
        require(amount0 == borrowedWeth || amount1 == borrowedWeth, "unexpected borrow");

        _executeRoute(plan, borrowedWeth);
