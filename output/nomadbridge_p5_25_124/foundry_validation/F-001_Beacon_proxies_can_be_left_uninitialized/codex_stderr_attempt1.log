        ownerAfter = _readAddress(TARGET, abi.encodeWithSignature("owner()"));
        updaterAfter = _readAddress(TARGET, abi.encodeWithSignature("updater()"));
        stateAfter = _readUint8(TARGET, abi.encodeWithSignature("state()"));
        remoteDomainAfter = _readUint32(TARGET, abi.encodeWithSignature("remoteDomain()"));
        optimisticSecondsAfter = _readUint256(TARGET, abi.encodeWithSignature("optimisticSeconds()"));
        committedRootAfter = _readBytes32(TARGET, abi.encodeWithSignature("committedRoot()"));

        attackerControlsReplica =
            ownerAfter == address(this) &&
            updaterAfter == address(this) &&
            stateAfter == 1 &&
            remoteDomainAfter == ATTACKER_REMOTE_DOMAIN &&
            committedRootAfter == chosenRoot &&
            optimisticSecondsAfter == 1;

        if (!attackerControlsReplica) {
