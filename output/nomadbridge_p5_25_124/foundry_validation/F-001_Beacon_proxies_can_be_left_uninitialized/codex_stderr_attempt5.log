-        bytes32 remoteRouter = _readBytes32(
-            BRIDGE_ROUTER,
-            abi.encodeWithSignature("remotes(uint32)", BEAM_DOMAIN)
-        );
-        if (remoteRouter == bytes32(0)) {
-            remoteRouter = KNOWN_BEAM_ROUTER;
-        }
-
-        if (remoteRouter == bytes32(0)) {
-            if (bytes(failureReason).length == 0) {
-                failureReason = "bridge router remote not discoverable";
-            }
-            return;
