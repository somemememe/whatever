-        uint256 tranche = _standardTranche(token, bridgeBalance);
-        if (tranche > 0 && tranche != bridgeBalance && tranche != half) {
-            if (_tryTransferLayouts(remoteRouter, token, tranche, zeroDetailsHash, metadataDetailsHash, beforeBalance)) {
-                return true;
-            }
-        }
-
-        return false;
-    }
