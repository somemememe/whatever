-    function _realizeOnChainProfit() internal {
-        liveReplica = LIVE_REPLICA;
-        liveLocalDomain = _readUint32(liveReplica, abi.encodeWithSignature("localDomain()"));
-        if (liveLocalDomain == 0) {
-            liveLocalDomain = ETH_DOMAIN;
-        }
-
-        if (!_initializeLiveReplica()) {
-            return;
-        }
