-        if (_tryBridgeTransfer(remoteRouter, token, amount, zeroDetailsHash, 1, beforeBalance)) return true;
-        if (_tryBridgeTransfer(remoteRouter, token, amount, metadataDetailsHash, 1, beforeBalance)) return true;
-        if (_tryBridgeTransfer(remoteRouter, token, amount, zeroDetailsHash, 2, beforeBalance)) return true;
