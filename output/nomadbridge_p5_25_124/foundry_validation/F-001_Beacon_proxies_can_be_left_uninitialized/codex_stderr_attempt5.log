-
-    function _bridgeBody(
-        uint8 layout,
-        uint32 tokenDomain,
-        address token,
-        address recipient,
-        uint256 amount,
-        bytes32 detailsHash
-    ) internal pure returns (bytes memory) {
-        bytes32 tokenId = _addressToBytes32(token);
-        bytes32 recipientBytes = _addressToBytes32(recipient);
