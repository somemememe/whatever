-        address[] memory path = new address[](2);
-        path[0] = token;
-        path[1] = WETH;
-
-        try IUniswapV2RouterLike(UNISWAP_V2_ROUTER_02).swapExactTokensForTokens(
-            amount,
-            1,
-            path,
-            address(this),
-            block.timestamp
