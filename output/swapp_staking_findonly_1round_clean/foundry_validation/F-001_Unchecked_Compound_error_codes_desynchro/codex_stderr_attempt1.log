/bin/bash -lc "python - <<'PY'
import json,re
obj=json.load(open('onchain_auto/0x245a551ee0f55005e510b239c917fa34b41b3461/Contract.sol'))
for k,v in obj.items():
    if 'Staking' in k:
        s=v['content']
        for name in ['claimReward','claimRewards','reward','Reward','epochDuration','tokensPerEpoch','swapp']:
            if name in s:
                print('FOUND',name)
        pats=[r'function [A-Za-z0-9_]*claim[A-Za-z0-9_]*\\b.*?\\n\\}',r'function [A-Za-z0-9_]*reward[A-Za-z0-9_]*\\b.*?\\n\\}',r'emit .*Reward',r'swapp',r'tokensPerEpoch']
        for pat in pats:
            for m in re.finditer(pat,s,re.S|re.I):
