 238:     // **** Stateful functions ****
 239: 
 240:     function zapToBMI(
 241:         address _from,
 242:         uint256 _amount,
 243:         address _fromUnderlying,
 244:         uint256 _fromUnderlyingAmount,
 245:         uint256 _minBMIRecv,
 246:         address[] memory _bmiConstituents,
 247:         uint256[] memory _bmiConstituentsWeightings,
 248:         address _aggregator,
 249:         bytes memory _aggregatorData,
 250:         bool refundDust
 251:     ) public returns (uint256) {
 252:         uint256 sum = 0;
 253:         for (uint256 i = 0; i < _bmiConstituentsWeightings.length; i++) {
 254:             sum = sum.add(_bmiConstituentsWeightings[i]);
 255:         }
 256: 
 257:         // Sum should be between 0.999 and 1.000
 258:         assert(sum <= 1e18);
 259:         assert(sum >= 999e15);
 260: 
 261:         // Transfer to contract
 262:         IERC20(_from).safeTransferFrom(msg.sender, address(this), _amount);
 263: 
 264:         // Primitive
 265:         if (_isBare(_from)) {
 266:             _primitiveToBMI(_from, _amount, _bmiConstituents, _bmiConstituentsWeightings, _aggregator, _aggregatorData);
 267:         }
 268:         // Yearn (primitive)
 269:         else if (_isYearn(_from)) {
 270:             IYearn(_from).withdraw();
 271:             _primitiveToBMI(
 272:                 _fromUnderlying,
 273:                 _fromUnderlyingAmount,
 274:                 _bmiConstituents,
 275:                 _bmiConstituentsWeightings,
 276:                 _aggregator,
 277:                 _aggregatorData
 278:             );
 279:         }
 280:         // Yearn (primitive)
 281:         else if (_isYearnCRV(_from)) {
 282:             IYearn(_from).withdraw();
 283:             address crvToken = IYearn(_from).token();
 284:             _crvToPrimitive(crvToken, IERC20(crvToken).balanceOf(address(this)));
 285:             _primitiveToBMI(
 286:                 USDC,
 287:                 IERC20(USDC).balanceOf(address(this)),
 288:                 _bmiConstituents,
 289:                 _bmiConstituentsWeightings,
 290:                 address(0),
 291:                 ""
 292:             );
 293:         }
 294:         // Compound
 295:         else if (_isCompound(_from)) {
 296:             require(ICToken(_from).redeem(_amount) == 0, "!ctoken-redeem");
 297:             _primitiveToBMI(
 298:                 _fromUnderlying,
 299:                 _fromUnderlyingAmount,
 300:                 _bmiConstituents,
 301:                 _bmiConstituentsWeightings,
 302:                 _aggregator,
 303:                 _aggregatorData
 304:             );
 305:         }
 306:         // Aave
 307:         else if (_isAave(_from)) {
 308:             IERC20(_from).safeApprove(AAVE_LENDING_POOL_V2, 0);
 309:             IERC20(_from).safeApprove(AAVE_LENDING_POOL_V2, _amount);
 310:             ILendingPoolV2(AAVE_LENDING_POOL_V2).withdraw(_fromUnderlying, type(uint256).max, address(this));
 311: 
 312:             _primitiveToBMI(
 313:                 _fromUnderlying,
 314:                 _fromUnderlyingAmount,
 315:                 _bmiConstituents,
 316:                 _bmiConstituentsWeightings,
 317:                 _aggregator,
 318:                 _aggregatorData
 319:             );
 320:         }
 321:         // Curve
 322:         else {
 323:             _crvToPrimitive(_from, _amount);
 324:             _primitiveToBMI(
 325:                 USDC,
 326:                 IERC20(USDC).balanceOf(address(this)),
 327:                 _bmiConstituents,
 328:                 _bmiConstituentsWeightings,
 329:                 address(0),
 330:                 ""
 331:             );
 332:         }
 333: 
 334:         // Checks
 335:         uint256 _bmiBal = IERC20(BMI).balanceOf(address(this));
 336:         require(_bmiBal >= _minBMIRecv, "!min-mint");
 337:         IERC20(BMI).safeTransfer(msg.sender, _bmiBal);
 338: 
 339:         // Convert back dust to USDC and refund remaining USDC to usd
 340:         if (refundDust) {
 341:             for (uint256 i = 0; i < _bmiConstituents.length; i++) {
 342:                 _fromBMIConstituentToUSDC(_bmiConstituents[i], IERC20(_bmiConstituents[i]).balanceOf(address(this)));
 343:             }
 344:             IERC20(USDC).safeTransfer(msg.sender, IERC20(USDC).balanceOf(address(this)));
 345:         }
 346: 
 347:         return _bmiBal;
 348:     }
