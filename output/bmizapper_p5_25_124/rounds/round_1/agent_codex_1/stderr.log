 350:     // **** Internal helpers ****
 351: 
 352:     function _crvToPrimitive(address _from, uint256 _amount) internal {
 353:         // Remove via zap to USDC
 354:         if (_from == crvY || _from == crvSUSD || _from == crvYBUSD) {
 355:             address zap = crvYZap;
 356: 
 357:             if (_from == crvSUSD) {
 358:                 zap = crvSUSDZap;
 359:             } else if (_from == crvYBUSD) {
 360:                 zap = crvYBUSDZap;
 361:             }
 362: 
 363:             IERC20(_from).safeApprove(zap, 0);
 364:             IERC20(_from).safeApprove(zap, _amount);
 365:             ICurveZapSimple(zap).remove_liquidity_one_coin(_amount, 1, 0, false);
 366:         } else if (_from == crvUSDP || _from == crvUSDN || _from == crvDUSD || _from == crvMUSD || _from == crvUST) {
 367:             address zap = crvUSDNZap;
 368: 
 369:             if (_from == crvUSDP) {
 370:                 zap = crvUSDPZap;
 371:             } else if (_from == crvDUSD) {
 372:                 zap = crvDUSDZap;
 373:             } else if (_from == crvMUSD) {
 374:                 zap = crvMUSDZap;
 375:             } else if (_from == crvUST) {
 376:                 zap = crvUSTZap;
 377:             }
 378: 
 379:             IERC20(_from).safeApprove(zap, 0);
 380:             IERC20(_from).safeApprove(zap, _amount);
 381:             ICurveZapSimple(zap).remove_liquidity_one_coin(_amount, 2, 0);
 382:         } else if (_from == crvIB) {
 383:             IERC20(_from).safeApprove(crvIBPool, 0);
 384:             IERC20(_from).safeApprove(crvIBPool, _amount);
 385:             ICurveZapSimple(crvIBPool).remove_liquidity_one_coin(_amount, 1, 0, true);
 386:         } else if (_from == crvThree) {
 387:             address zap = crvThreePool;
 388: 
 389:             IERC20(_from).safeApprove(zap, 0);
 390:             IERC20(_from).safeApprove(zap, _amount);
 391:             ICurveZapSimple(zap).remove_liquidity_one_coin(_amount, 1, 0);
 392:         } else {
 393:             // Meta pools, USDC is 2nd index
 394:             IERC20(_from).safeApprove(crvMetaZapper, 0);
 395:             IERC20(_from).safeApprove(crvMetaZapper, _amount);
 396:             ICurveZapSimple(crvMetaZapper).remove_liquidity_one_coin(_from, _amount, 2, 0, address(this));
 397:         }
 398:     }
 399: 
 400:     function _primitiveToBMI(
 401:         address _token,
 402:         uint256 _amount,
 403:         address[] memory _bmiConstituents,
 404:         uint256[] memory _bmiConstituentsWeightings,
 405:         address _aggregator,
 406:         bytes memory _aggregatorData
 407:     ) internal {
 408:         // Offset, DAI = 0, USDC = 1, USDT = 2
 409:         uint256 offset = 0;
 410: 
 411:         // Primitive to USDC (if not already USDC)
 412:         if (_token != DAI && _token != USDC && _token != USDT) {
 413:             IERC20(_token).safeApprove(_aggregator, 0);
 414:             IERC20(_token).safeApprove(_aggregator, _amount);
 415: 
 416:             (bool success, ) = _aggregator.call(_aggregatorData);
 417:             require(success, "!swap");
 418: 
 419:             // Always goes to USDC
 420:             // If we swapping
 421:             _token = USDC;
 422:         }
 423: 
 424:         if (_token == USDC) {
 425:             offset = 1;
 426:         } else if (_token == USDT) {
 427:             offset = 2;
 428:         }
 429: 
 430:         // Amount to mint
 431:         uint256 amountToMint;
 432:         uint256 bmiSupply = IERC20(BMI).totalSupply();
 433: 
 434:         uint256 tokenBal = IERC20(_token).balanceOf(address(this));
 435:         uint256 tokenAmount;
 436:         for (uint256 i = 0; i < _bmiConstituents.length; i++) {
 437:             // Weighting of the token for BMI constituient
 438:             tokenAmount = tokenBal.mul(_bmiConstituentsWeightings[i]).div(1e18);
 439:             _toBMIConstituent(_token, _bmiConstituents[i], tokenAmount, offset);
 440: 
 441:             // Get amount to Mint
 442:             amountToMint = _approveBMIAndGetMintableAmount(bmiSupply, _bmiConstituents[i], amountToMint);
 443:         }
 444: 
 445:         // Mint BASK
 446:         IBasket(BMI).mint(amountToMint);
 447:     }
 448: 
 449:     function _approveBMIAndGetMintableAmount(
 450:         uint256 _bmiTotalSupply,
 451:         address _bmiConstituient,
 452:         uint256 _curMintAmount
 453:     ) internal returns (uint256) {
 454:         uint256 bal = IERC20(_bmiConstituient).balanceOf(address(this));
 455:         uint256 bmiBal = IERC20(_bmiConstituient).balanceOf(BMI);
 456: 
 457:         IERC20(_bmiConstituient).safeApprove(BMI, 0);
 458:         IERC20(_bmiConstituient).safeApprove(BMI, bal);
 459: 
 460:         // Calculate how much BMI we can mint at max
 461:         // Formula: min(e for e in bmiSupply * tokenWeHave[e] / tokenInBMI[e])
 462:         if (_curMintAmount == 0) {
 463:             return _bmiTotalSupply.mul(bal).div(bmiBal);
 464:         }
 465: 
 466:         uint256 temp = _bmiTotalSupply.mul(bal).div(bmiBal);
 467:         if (temp < _curMintAmount) {
 468:             return temp;
 469:         }
 470: 
 471:         return _curMintAmount;
 472:     }
 473: 
 474:     function _toBMIConstituent(
 475:         address _fromToken,
 476:         address _toToken,
 477:         uint256 _amount,
 478:         uint256 _curveOffset
 479:     ) internal {
 480:         uint256 bal;
 481:         uint256[4] memory depositAmounts4 = [uint256(0), uint256(0), uint256(0), uint256(0)];
 482: 
 483:         if (_toToken == ySUSD) {
 484:             IERC20(_fromToken).safeApprove(crvSUSDPool, 0);
 485:             IERC20(_fromToken).safeApprove(crvSUSDPool, _amount);
 486: 
 487:             ICurvePool(crvSUSDPool).exchange(int128(_curveOffset), 3, _amount, 0);
 488: 
 489:             bal = IERC20(SUSD).balanceOf(address(this));
 490:             IERC20(SUSD).safeApprove(ySUSD, 0);
 491:             IERC20(SUSD).safeApprove(ySUSD, bal);
 492:         }
 493:         // Gen 1 pools
 494:         else if (
 495:             _toToken == yCRV ||
 496:             _toToken == ycrvSUSD ||
 497:             _toToken == ycrvYBUSD ||
 498:             _toToken == ycrvUSDN ||
 499:             _toToken == ycrvUSDP ||
 500:             _toToken == ycrvDUSD ||
 501:             _toToken == ycrvMUSD ||
 502:             _toToken == ycrvUST
 503:         ) {
 504:             address crvToken = IYearn(_toToken).token();
 505: 
 506:             address zap = crvYZap;
 507:             if (_toToken == ycrvSUSD) {
 508:                 zap = crvSUSDZap;
 509:             } else if (_toToken == ycrvYBUSD) {
 510:                 zap = crvYBUSDZap;
 511:             } else if (_toToken == ycrvUSDN) {
 512:                 zap = crvUSDNZap;
 513:                 _curveOffset += 1;
 514:             } else if (_toToken == ycrvUSDP) {
 515:                 zap = crvUSDPZap;
 516:                 _curveOffset += 1;
 517:             } else if (_toToken == ycrvDUSD) {
 518:                 zap = crvDUSDZap;
 519:                 _curveOffset += 1;
 520:             } else if (_toToken == ycrvMUSD) {
 521:                 zap = crvMUSDZap;
 522:                 _curveOffset += 1;
 523:             } else if (_toToken == ycrvUST) {
 524:                 zap = crvUSTZap;
 525:                 _curveOffset += 1;
 526:             }
 527: 
 528:             depositAmounts4[_curveOffset] = _amount;
 529:             IERC20(_fromToken).safeApprove(zap, 0);
 530:             IERC20(_fromToken).safeApprove(zap, _amount);
 531:             ICurveZapSimple(zap).add_liquidity(depositAmounts4, 0);
 532: 
 533:             bal = IERC20(crvToken).balanceOf(address(this));
 534:             IERC20(crvToken).safeApprove(_toToken, 0);
 535:             IERC20(crvToken).safeApprove(_toToken, bal);
 536:         } else if (_toToken == ycrvThree || _toToken == ycrvIB) {
 537:             address crvToken = IYearn(_toToken).token();
 538: 
 539:             uint256[3] memory depositAmounts3 = [uint256(0), uint256(0), uint256(0)];
 540:             depositAmounts3[_curveOffset] = _amount;
 541: 
 542:             address zap = crvThreePool;
 543:             if (_toToken == ycrvIB) {
 544:                 zap = crvIBPool;
 545:             }
 546: 
 547:             IERC20(_fromToken).safeApprove(zap, 0);
 548:             IERC20(_fromToken).safeApprove(zap, _amount);
 549: 
 550:             if (_toToken == ycrvThree) {
 551:                 ICurveZapSimple(zap).add_liquidity(depositAmounts3, 0);
 552:             } else {
 553:                 ICurveZapSimple(zap).add_liquidity(depositAmounts3, 0, true);
 554:             }
 555: 
 556:             bal = IERC20(crvToken).balanceOf(address(this));
 557:             IERC20(crvToken).safeApprove(_toToken, 0);
 558:             IERC20(crvToken).safeApprove(_toToken, bal);
 559:         }
 560:         // Meta pools
 561:         else if (_toToken == ycrvBUSD || _toToken == ycrvFRAX || _toToken == ycrvALUSD || _toToken == ycrvLUSD) {
 562:             // CRV Token = CRV Pool
 563:             address crvToken = IYearn(_toToken).token();
 564: 
 565:             depositAmounts4[_curveOffset + 1] = _amount;
 566:             IERC20(_fromToken).safeApprove(crvMetaZapper, 0);
 567:             IERC20(_fromToken).safeApprove(crvMetaZapper, _amount);
 568: 
 569:             ICurveZapSimple(crvMetaZapper).add_liquidity(crvToken, depositAmounts4, 0);
 570: 
 571:             bal = IERC20(crvToken).balanceOf(address(this));
 572:             IERC20(crvToken).safeApprove(_toToken, 0);
 573:             IERC20(crvToken).safeApprove(_toToken, bal);
 574:         }
 575: 
 576:         IYearn(_toToken).deposit();
 577:     }
