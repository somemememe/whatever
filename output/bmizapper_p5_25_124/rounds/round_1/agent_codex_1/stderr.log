 151:     // Estimates USDC equilavent for yearn crv and crv pools
 152:     function calcUSDCEquilavent(address _from, uint256 _amount) public view returns (uint256) {
 153:         if (_isYearnCRV(_from)) {
 154:             _amount = _amount.mul(IYearn(_from).pricePerShare()).div(1e18);
 155:             _from = IYearn(_from).token();
 156:         }
 157: 
 158:         if (_from == crvY || _from == crvSUSD || _from == crvThree || _from == crvYBUSD) {
 159:             address zap = crvYZap;
 160: 
 161:             if (_from == crvSUSD) {
 162:                 zap = crvSUSDZap;
 163:             } else if (_from == crvThree) {
 164:                 zap = crvThreePool;
 165:             } else if (_from == crvYBUSD) {
 166:                 zap = crvYBUSDZap;
 167:             }
 168: 
 169:             return ICurveZapSimple(zap).calc_withdraw_one_coin(_amount, 1);
 170:         } else if (_from == crvUSDN || _from == crvUSDP || _from == crvDUSD || _from == crvMUSD || _from == crvUST) {
 171:             address zap = crvUSDNZap;
 172: 
 173:             if (_from == crvUSDP) {
 174:                 zap = crvUSDPZap;
 175:             } else if (_from == crvDUSD) {
 176:                 zap = crvDUSDZap;
 177:             } else if (_from == crvMUSD) {
 178:                 zap = crvMUSDZap;
 179:             } else if (_from == crvUST) {
 180:                 zap = crvUSTZap;
 181:             }
 182: 
 183:             return ICurveZapSimple(zap).calc_withdraw_one_coin(_amount, 2);
 184:         } else if (_from == crvIB) {
 185:             return ICurveZapSimple(crvIBPool).calc_withdraw_one_coin(_amount, 1, true);
 186:         } else {
 187:             // Meta pools, USDC is 2nd index
 188:             return ICurveZapSimple(crvMetaZapper).calc_withdraw_one_coin(_from, _amount, 2);
 189:         }
 190:     }
 191: 
 192:     function getUnderlyingAmount(address _derivative, uint256 _amount) public view returns (address, uint256) {
 193:         if (_isAave(_derivative)) {
 194:             return (IATokenV2(_derivative).UNDERLYING_ASSET_ADDRESS(), _amount);
 195:         }
 196: 
 197:         if (_isCompound(_derivative)) {
 198:             uint256 rate = ICToken(_derivative).exchangeRateStored();
 199:             address underlying = ICToken(_derivative).underlying();
 200:             uint256 underlyingDecimals = ERC20(underlying).decimals();
 201:             uint256 mantissa = 18 + underlyingDecimals - 8;
 202:             uint256 oneCTokenInUnderlying = rate.mul(1e18).div(10**mantissa);
 203:             return (underlying, _amount.mul(oneCTokenInUnderlying).div(1e8));
 204:         }
 205: 
 206:         // YearnCRV just or CRV return USDC
 207:         if (_isCRV(_derivative) || _isYearnCRV(_derivative)) {
 208:             return (USDC, calcUSDCEquilavent(_derivative, _amount));
 209:         }
 210: 
 211:         if (_isYearn(_derivative)) {
 212:             _amount = _amount.mul(IYearn(_derivative).pricePerShare()).div(1e18);
 213: 
 214:             if (_derivative == yDAI) {
 215:                 return (DAI, _amount);
 216:             }
 217: 
 218:             if (_derivative == yUSDC) {
 219:                 return (USDC, _amount);
 220:             }
 221: 
 222:             if (_derivative == yUSDT) {
 223:                 return (USDT, _amount);
 224:             }
 225: 
 226:             if (_derivative == yTUSD) {
 227:                 return (TUSD, _amount);
 228:             }
 229: 
 230:             if (_derivative == ySUSD) {
 231:                 return (SUSD, _amount);
 232:             }
 233:         }
 234: 
 235:         return (_derivative, _amount);
 236:     }
