+    function stake(uint256 stakingId, uint256 amount) external;
+    function claimEarned(uint256 stakingId, uint256 burnRate) external;
+    function plans(uint256 stakingId)
+        external
+        view
+        returns (
+            uint256 overallStaked,
+            uint256 stakesCount,
+            uint256 apr,
+            uint256 stakeDuration,
+            bool conclude
+        );
