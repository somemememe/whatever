+            }
+        }
+        return (false, 0, 0);
+    }
+
+    function _minClaimsForPathAndRepayment(uint256 aprBps, bool needsRepayment) internal pure returns (uint256) {
+        uint256 netPerClaimBps = (aprBps * (100 - MIN_BURN_RATE)) / 100;
