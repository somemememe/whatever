+        uint256 borrowed = amount0 > 0 ? amount0 : amount1;
+        uint256 repayment = _flashRepayment(borrowed);
+        uint256 borrowedBalance = IERC20Like(token).balanceOf(address(this));
+        require(borrowedBalance > 0, "no borrowed tokens");
