}

interface IMockCallee {
    function NimbusCall(address sender, uint256 amount0, uint256 amount1, bytes calldata data) external;
}

contract MockFactory {
    address public referral;
    constructor(address r) { referral = r; }
    function nimbusReferralProgram() external view returns (address) { return referral; }
}

contract MockReferral {
    function recordFee(address, address, uint256) external {}
}

contract MockPair {
    address public immutable token0;
    address public immutable token1;
    address public immutable factory;
    uint112 private reserve0;
    uint112 private reserve1;
    uint32 private ts;
    uint256 private unlocked = 1;

    constructor(address t0, address t1) {
        token0 = t0;
        token1 = t1;
        MockReferral ref = new MockReferral();
        factory = address(new MockFactory(address(ref)));
    }

    modifier lock() {
        require(unlocked == 1, "locked");
        unlocked = 0;
        _;
        unlocked = 1;
    }

    function seed(uint112 r0, uint112 r1) external {
        reserve0 = r0;
        reserve1 = r1;
        ts = uint32(block.timestamp);
        MockERC20(token0).mint(address(this), r0);
        MockERC20(token1).mint(address(this), r1);
    }

    function getReserves() external view returns (uint112, uint112, uint32) {
        return (reserve0, reserve1, ts);
    }

    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external lock {
        require(amount0Out > 0 || amount1Out > 0, "insufficient-output");
        uint112 _reserve0 = reserve0;
        uint112 _reserve1 = reserve1;
        require(amount0Out < _reserve0 && amount1Out < _reserve1, "liquidity");

        if (amount0Out > 0) MockERC20(token0).transfer(to, amount0Out);
        if (amount1Out > 0) MockERC20(token1).transfer(to, amount1Out);
        if (data.length > 0) IMockCallee(to).NimbusCall(msg.sender, amount0Out, amount1Out, data);

        uint256 balance0 = MockERC20(token0).balanceOf(address(this));
        uint256 balance1 = MockERC20(token1).balanceOf(address(this));
        uint256 amount0In = balance0 > _reserve0 - amount0Out ? balance0 - (_reserve0 - amount0Out) : 0;
        uint256 amount1In = balance1 > _reserve1 - amount1Out ? balance1 - (_reserve1 - amount1Out) : 0;
        require(amount0In > 0 || amount1In > 0, "insufficient-input");

        uint256 balance0Adjusted = balance0 * 10000 - amount0In * 15;
        uint256 balance1Adjusted = balance1 * 10000 - amount1In * 15;
        require(balance0Adjusted * balance1Adjusted >= uint256(_reserve0) * uint256(_reserve1) * (1000 ** 2), "K");

        reserve0 = uint112(balance0);
        reserve1 = uint112(balance1);
        ts = uint32(block.timestamp);
    }
}

contract FlawVerifierHarness is FlawVerifier {
    address public mockTarget;

    constructor(address target_) {
        mockTarget = target_;
    }
}

