-            return;
-        }
-
-        baselineCaptured = true;
-        baselineEquityInFloor = _currentEquityInFloor();
-    }
-
-    function _bootstrapFloorBalance() internal {
-        if (_floor().balanceOf(address(this)) != 0) {
-            return;
-        }
-
-        _redeemVerifierSFloor();
