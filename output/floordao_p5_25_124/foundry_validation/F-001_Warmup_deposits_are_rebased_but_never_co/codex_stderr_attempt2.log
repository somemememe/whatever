-    function rebase() external returns (uint256);
-}
-
-contract FlawVerifier {
-    struct Claim {
-        uint256 deposit;
-        uint256 gons;
-        uint256 expiry;
-        bool lock;
-    }
-
-    IStakingLike internal constant STAKING =
