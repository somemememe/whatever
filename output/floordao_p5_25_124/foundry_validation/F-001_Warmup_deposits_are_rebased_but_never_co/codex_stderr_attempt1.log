        uint256 reserves = _floor().balanceOf(address(STAKING));
        if (reserves == 0) {
            return;
        }

        uint256 maxGByReserves = _gFloor().balanceTo(reserves);
        uint256 amount = gBalance < maxGByReserves ? gBalance : maxGByReserves;
        if (amount == 0) {
