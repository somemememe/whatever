        if (gons != 0) {
            equity += _sFloor().balanceForGons(gons);
        }
    }

    function _remainingImmediateRebases() internal view returns (uint256) {
        (uint256 length,, uint256 end,) = STAKING.epoch();
        if (end > block.timestamp) {
            return 0;
        }
        if (length == 0) {
            return 0;
        }
        return ((block.timestamp - end) / length) + 1;
    }

