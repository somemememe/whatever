-      return UNISWAP_V2_FACTORY;
-    }
-    if (index == 1) {
-      return SUSHISWAP_FACTORY;
-    }
-    return address(0);
-  }
-
-  function _bridgeAssetAt(uint256 index) internal pure returns (address) {
-    if (index == 0) {
