   324	        abi.encodeWithSelector(IPoolMinimal.supply.selector, asset, bal, address(this), uint16(0))
   325	      );
   326	      if (!ok) {
   327	        continue;
   328	      }
   329	
   330	      categoryMask |= (uint256(1) << cfg.eModeCategory);
   331	    }
   332	  }
   333	
   334	  function _findBestPlan(
   335	    address[] memory reserves,
   336	    uint256 suppliedCategoryMask,
   337	    uint256 normalAvailableBorrowsBase
   338	  ) internal returns (Plan memory best) {
   339	    for (uint8 category = 1; category < type(uint8).max; ++category) {
   340	      if ((suppliedCategoryMask & (uint256(1) << category)) == 0) {
   341	        continue;
   342	      }
   343	
   344	      (uint256 emodeAvailableBorrowsBase, bool modeSet) = _setModeAndReadAccountData(category);
   345	      if (!modeSet) {
   346	        continue;
   347	      }
   348	      if (emodeAvailableBorrowsBase <= normalAvailableBorrowsBase) {
   349	        continue;
   350	      }
   351	
   352	      for (uint256 i = 0; i < reserves.length; ++i) {
   353	        address borrowAsset = reserves[i];
   354	        if (borrowAsset == address(0)) {
   355	          continue;
   356	        }
   357	
   358	        AssetConfig memory borrowCfg = _readAssetConfig(borrowAsset);
   359	        if (
   360	          borrowCfg.eModeCategory != category ||
   361	          !borrowCfg.borrowingEnabled ||
   362	          !borrowCfg.active ||
   363	          borrowCfg.paused
   364	        ) {
   365	          continue;
   366	        }
   367	
   368	        IPoolMinimal.ReserveData memory reserveData = POOL.getReserveData(borrowAsset);
   369	        uint256 liquidity = IERC20Minimal(borrowAsset).balanceOf(reserveData.aTokenAddress);
   370	        if (liquidity == 0) {
   371	          continue;
   372	        }
   373	
   374	        uint256 price = IPriceOracleGetterMinimal(ADDRESSES_PROVIDER.getPriceOracle()).getAssetPrice(
   375	          borrowAsset
   376	        );
   377	        if (price == 0) {
   378	          continue;
   379	        }
   380	
   381	        uint256 unit = 10 ** borrowCfg.decimals;
   382	        uint256 normalTokenMax = (normalAvailableBorrowsBase * unit) / price;
   383	        uint256 emodeTokenMax = (emodeAvailableBorrowsBase * unit) / price;
   384	        uint256 maxBorrowable = emodeTokenMax < liquidity ? emodeTokenMax : liquidity;
   385	        if (maxBorrowable <= normalTokenMax) {
   386	          continue;
   387	        }
   388	
   389	        uint256 gap = maxBorrowable - normalTokenMax;
   390	        uint256 candidateAmount = normalTokenMax + (gap * 3) / 4;
   391	        if (candidateAmount <= normalTokenMax) {
   392	          candidateAmount = normalTokenMax + 1;
   393	        }
   394	        if (candidateAmount > maxBorrowable) {
   395	          candidateAmount = maxBorrowable;
   396	        }
   397	        if (candidateAmount <= normalTokenMax || candidateAmount == 0) {
   398	          continue;
   399	        }
   400	
   401	        uint256 candidateBase = (candidateAmount * price) / unit;
   402	        if (candidateBase <= best.borrowAmountBase) {
   403	          continue;
   404	        }
   405	
   406	        best.found = true;
   407	        best.collateralAsset = _pickCollateralAssetForCategory(reserves, category);
   408	        best.borrowAsset = borrowAsset;
   409	        best.collateralAmount = 0;
   410	        best.borrowAmount = candidateAmount;
   411	        best.borrowAmountBase = candidateBase;
   412	        best.normalAvailableBorrowsBase = normalAvailableBorrowsBase;
   413	        best.eModeAvailableBorrowsBase = emodeAvailableBorrowsBase;
   414	        best.category = category;
   415	      }
   416	    }
   417	
   418	    _setUserEMode(0);
   419	  }
   420	
