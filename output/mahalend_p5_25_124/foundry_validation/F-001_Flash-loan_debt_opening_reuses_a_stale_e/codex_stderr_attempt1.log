  function _findBestPlan(
    address[] memory reserves,
    uint256 suppliedCategoryMask,
    uint256 normalAvailableBorrowsBase
  ) internal returns (Plan memory best) {
    for (uint8 category = 1; category < type(uint8).max; ++category) {
      if ((suppliedCategoryMask & (uint256(1) << category)) == 0) {
        continue;
      }

      (uint256 emodeAvailableBorrowsBase, bool modeSet) = _setModeAndReadAccountData(category);
      if (!modeSet) {
        continue;
      }
      if (emodeAvailableBorrowsBase <= normalAvailableBorrowsBase) {
        continue;
      }

      for (uint256 i = 0; i < reserves.length; ++i) {
        address borrowAsset = reserves[i];
        if (borrowAsset == address(0)) {
          continue;
        }

        (uint256 candidateAmount, uint256 candidateBase) = _quoteBorrowCandidate(
          borrowAsset,
          category,
          normalAvailableBorrowsBase,
          emodeAvailableBorrowsBase
        );
        if (candidateBase <= best.borrowAmountBase) {
          continue;
        }

        best.found = true;
        (best.collateralAsset, best.collateralAmount) = _pickCollateralAssetForCategory(
          reserves,
          category
        );
        best.borrowAsset = borrowAsset;
        best.borrowAmount = candidateAmount;
        best.borrowAmountBase = candidateBase;
        best.normalAvailableBorrowsBase = normalAvailableBorrowsBase;
        best.eModeAvailableBorrowsBase = emodeAvailableBorrowsBase;
        best.category = category;
      }
    }

    _setUserEMode(0);
  }

  function _quoteBorrowCandidate(
    address borrowAsset,
    uint8 category,
    uint256 normalAvailableBorrowsBase,
    uint256 emodeAvailableBorrowsBase
  ) internal view returns (uint256 candidateAmount, uint256 candidateBase) {
    AssetConfig memory borrowCfg = _readAssetConfig(borrowAsset);
    if (
      borrowCfg.eModeCategory != category ||
      !borrowCfg.borrowingEnabled ||
      !borrowCfg.active ||
      borrowCfg.paused
    ) {
      return (0, 0);
    }

    IPoolMinimal.ReserveData memory reserveData = POOL.getReserveData(borrowAsset);
    uint256 liquidity = IERC20Minimal(borrowAsset).balanceOf(reserveData.aTokenAddress);
    if (liquidity == 0) {
      return (0, 0);
    }

    uint256 price = IPriceOracleGetterMinimal(ADDRESSES_PROVIDER.getPriceOracle()).getAssetPrice(
      borrowAsset
    );
    if (price == 0) {
      return (0, 0);
    }

    uint256 unit = 10 ** borrowCfg.decimals;
    uint256 normalTokenMax = (normalAvailableBorrowsBase * unit) / price;
    uint256 emodeTokenMax = (emodeAvailableBorrowsBase * unit) / price;
    uint256 maxBorrowable = emodeTokenMax < liquidity ? emodeTokenMax : liquidity;
    if (maxBorrowable <= normalTokenMax) {
      return (0, 0);
    }

    uint256 gap = maxBorrowable - normalTokenMax;
    candidateAmount = normalTokenMax + (gap * 3) / 4;
    if (candidateAmount <= normalTokenMax) {
      candidateAmount = normalTokenMax + 1;
    }
    if (candidateAmount > maxBorrowable) {
      candidateAmount = maxBorrowable;
    }
    if (candidateAmount <= normalTokenMax || candidateAmount == 0) {
      return (0, 0);
    }

    candidateBase = (candidateAmount * price) / unit;
  }

  function _pickCollateralAssetForCategory(
    address[] memory reserves,
    uint8 category
  ) internal view returns (address picked, uint256 pickedAmount) {
    uint256 bestATokenBalance;
    for (uint256 i = 0; i < reserves.length; ++i) {
      address asset = reserves[i];
      if (asset == address(0)) {
        continue;
      }
      AssetConfig memory cfg = _readAssetConfig(asset);
      if (cfg.eModeCategory != category || cfg.ltv == 0 || cfg.debtCeiling != 0) {
        continue;
      }
      address aToken = POOL.getReserveData(asset).aTokenAddress;
      uint256 bal = IERC20Minimal(aToken).balanceOf(address(this));
      if (bal > bestATokenBalance) {
        bestATokenBalance = bal;
        picked = asset;
        pickedAmount = bal;
      }
    }
  }

  function _setModeAndReadAccountData(
    uint8 category
  ) internal returns (uint256 availableBorrowsBase, bool ok) {
    if (!_setUserEMode(category)) {
      return (0, false);
    }
    (, , availableBorrowsBase, , , ) = POOL.getUserAccountData(address(this));
    return (availableBorrowsBase, true);
  }

  function _setUserEMode(uint8 category) internal returns (bool) {
    (bool ok, ) = address(POOL).call(
      abi.encodeWithSelector(IPoolMinimal.setUserEMode.selector, category)
    );
    return ok;
  }

  function _approveIfNeeded(address token, address spender, uint256 amount) internal returns (bool) {
    uint256 current = IERC20Minimal(token).allowance(address(this), spender);
    if (current >= amount) {
      return true;
    }

    if (current != 0 && !_safeApprove(token, spender, 0)) {
      return false;
    }

    return _safeApprove(token, spender, type(uint256).max);
  }

  function _safeApprove(address token, address spender, uint256 amount) internal returns (bool) {
    (bool ok, bytes memory ret) = token.call(
      abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, amount)
    );
    return ok && (ret.length == 0 || abi.decode(ret, (bool)));
  }

  function _readAssetConfig(address asset) internal view returns (AssetConfig memory cfg) {
    cfg.raw = POOL.getConfiguration(asset).data;
    cfg.ltv = cfg.raw & ~LTV_MASK;
    cfg.decimals = (cfg.raw & ~DECIMALS_MASK) >> 48;
    cfg.active = (cfg.raw & ~ACTIVE_MASK) != 0;
    cfg.borrowingEnabled = (cfg.raw & ~BORROWING_MASK) != 0;
    cfg.paused = (cfg.raw & ~PAUSED_MASK) != 0;
    cfg.eModeCategory = (cfg.raw & ~EMODE_CATEGORY_MASK) >> 168;
    cfg.debtCeiling = (cfg.raw & ~DEBT_CEILING_MASK) >> 212;
  }
}

