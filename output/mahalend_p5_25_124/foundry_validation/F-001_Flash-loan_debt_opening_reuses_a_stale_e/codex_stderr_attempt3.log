   555	    if (minBorrow < minProfitableBorrow) {
   556	      minBorrow = minProfitableBorrow;
   557	    }
   558	
   559	    if (emodeTokenMax <= minBorrow || collateralAmount == 0) {
   560	      return 0;
   561	    }
   562	
   563	    uint256 headroom = emodeTokenMax - minBorrow;
   564	    return minBorrow + ((headroom * 19) / 20);
   565	  }
   566	
   567	  function _pairReservesFor(
   568	    address pair,
   569	    address collateralAsset,
   570	    address borrowAsset
   571	  ) internal view returns (uint256 reserveCollateral, uint256 reserveBorrow) {
   572	    IUniswapV2PairMinimal v2Pair = IUniswapV2PairMinimal(pair);
   573	    (uint112 reserve0, uint112 reserve1, ) = v2Pair.getReserves();
   574	    address token0 = v2Pair.token0();
   575	    address token1 = v2Pair.token1();
   576	
   577	    if (token0 == collateralAsset && token1 == borrowAsset) {
   578	      return (uint256(reserve0), uint256(reserve1));
   579	    }
   580	    if (token0 == borrowAsset && token1 == collateralAsset) {
   581	      return (uint256(reserve1), uint256(reserve0));
   582	    }
   583	    return (0, 0);
   584	  }
   585	
   586	  function _quotePairRepayment(
   587	    address pair,
   588	    address collateralAsset,
   589	    uint256 collateralAmount
   590	  ) internal view returns (uint256) {
   591	    IUniswapV2PairMinimal v2Pair = IUniswapV2PairMinimal(pair);
   592	    (uint112 reserve0, uint112 reserve1, ) = v2Pair.getReserves();
   593	    address token0 = v2Pair.token0();
   594	
   595	    if (collateralAsset == token0) {
   596	      return _getAmountIn(collateralAmount, uint256(reserve1), uint256(reserve0));
   597	    }
   598	    return _getAmountIn(collateralAmount, uint256(reserve0), uint256(reserve1));
   599	  }
   600	
   601	  function _toBase(address asset, uint256 amount) internal view returns (uint256) {
   602	    AssetConfig memory cfg = _readAssetConfig(asset);
   603	    return (amount * _oracle().getAssetPrice(asset)) / (10 ** cfg.decimals);
   604	  }
   605	
   606	  function _oracle() internal view returns (IPriceOracleGetterMinimal) {
   607	    return IPriceOracleGetterMinimal(ADDRESSES_PROVIDER.getPriceOracle());
   608	  }
   609	
   610	  function _factoryAt(uint256 index) internal pure returns (address) {
   611	    if (index == 0) {
   612	      return UNISWAP_V2_FACTORY;
   613	    }
   614	    if (index == 1) {
   615	      return SUSHISWAP_FACTORY;
   616	    }
   617	    return address(0);
   618	  }
   619	
   620	  function _getAmountIn(
   621	    uint256 amountOut,
   622	    uint256 reserveIn,
   623	    uint256 reserveOut
   624	  ) internal pure returns (uint256) {
   625	    if (amountOut == 0 || reserveIn == 0 || reserveOut <= amountOut) {
   626	      return type(uint256).max;
   627	    }
   628	
   629	    uint256 numerator = reserveIn * amountOut * 1000;
   630	    uint256 denominator = (reserveOut - amountOut) * 997;
   631	    return (numerator / denominator) + 1;
   632	  }
   633	
   634	  function _setUserEMode(uint8 category) internal returns (bool) {
   635	    (bool ok, ) = address(POOL).call(
   636	      abi.encodeWithSelector(IPoolMinimal.setUserEMode.selector, category)
   637	    );
   638	    return ok;
   639	  }
   640	
   641	  function _approveIfNeeded(address token, address spender, uint256 amount) internal returns (bool) {
   642	    uint256 current = IERC20Minimal(token).allowance(address(this), spender);
   643	    if (current >= amount) {
   644	      return true;
   645	    }
   646	
   647	    if (current != 0 && !_safeApprove(token, spender, 0)) {
   648	      return false;
   649	    }
   650	
   651	    return _safeApprove(token, spender, type(uint256).max);
   652	  }
   653	
   654	  function _safeApprove(address token, address spender, uint256 amount) internal returns (bool) {
   655	    (bool ok, bytes memory ret) = token.call(
   656	      abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, amount)
   657	    );
   658	    return ok && (ret.length == 0 || abi.decode(ret, (bool)));
   659	  }
   660	
   661	  function _readAssetConfig(address asset) internal view returns (AssetConfig memory cfg) {
   662	    cfg.raw = POOL.getConfiguration(asset).data;
   663	    cfg.ltv = cfg.raw & ~LTV_MASK;
   664	    cfg.decimals = (cfg.raw & ~DECIMALS_MASK) >> 48;
   665	    cfg.active = (cfg.raw & ~ACTIVE_MASK) != 0;
   666	    cfg.borrowingEnabled = (cfg.raw & ~BORROWING_MASK) != 0;
   667	    cfg.paused = (cfg.raw & ~PAUSED_MASK) != 0;
   668	    cfg.eModeCategory = (cfg.raw & ~EMODE_CATEGORY_MASK) >> 168;
   669	    cfg.debtCeiling = (cfg.raw & ~DEBT_CEILING_MASK) >> 212;
   670	  }
   671	}

