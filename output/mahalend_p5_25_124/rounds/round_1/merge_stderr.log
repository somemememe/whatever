   458	  /**
   459	   * @notice Validates a flashloan action.
   460	   * @param reservesData The state of all the reserves
   461	   * @param assets The assets being flash-borrowed
   462	   * @param amounts The amounts for each asset being borrowed
   463	   */
   464	  function validateFlashloan(
   465	    mapping(address => DataTypes.ReserveData) storage reservesData,
   466	    address[] memory assets,
   467	    uint256[] memory amounts
   468	  ) internal view {
   469	    require(assets.length == amounts.length, Errors.INCONSISTENT_FLASHLOAN_PARAMS);
   470	    for (uint256 i = 0; i < assets.length; i++) {
   471	      DataTypes.ReserveConfigurationMap memory configuration = reservesData[assets[i]]
   472	        .configuration;
   473	      require(!configuration.getPaused(), Errors.RESERVE_PAUSED);
   474	      require(configuration.getActive(), Errors.RESERVE_INACTIVE);
   475	    }
   476	  }
   477	
   478	  /**
   479	   * @notice Validates a flashloan action.
   480	   * @param reserve The state of the reserve
   481	   */
   482	  function validateFlashloanSimple(DataTypes.ReserveData storage reserve) internal view {
   483	    DataTypes.ReserveConfigurationMap memory configuration = reserve.configuration;
   484	    require(!configuration.getPaused(), Errors.RESERVE_PAUSED);
   485	    require(configuration.getActive(), Errors.RESERVE_INACTIVE);
   486	  }
