   634	
   635	  /**
   636	   * @notice Validates a drop reserve action.
   637	   * @param reservesList The addresses of all the active reserves
   638	   * @param reserve The reserve object
   639	   * @param asset The address of the reserve's underlying asset
   640	   **/
   641	  function validateDropReserve(
   642	    mapping(uint256 => address) storage reservesList,
   643	    DataTypes.ReserveData storage reserve,
   644	    address asset
   645	  ) internal view {
   646	    require(asset != address(0), Errors.ZERO_ADDRESS_NOT_VALID);
   647	    require(reserve.id != 0 || reservesList[0] == asset, Errors.ASSET_NOT_LISTED);
   648	    require(IERC20(reserve.stableDebtTokenAddress).totalSupply() == 0, Errors.STABLE_DEBT_NOT_ZERO);
   649	    require(
   650	      IERC20(reserve.variableDebtTokenAddress).totalSupply() == 0,
   651	      Errors.VARIABLE_DEBT_SUPPLY_NOT_ZERO
   652	    );
   653	    require(IERC20(reserve.aTokenAddress).totalSupply() == 0, Errors.ATOKEN_SUPPLY_NOT_ZERO);
   654	  }
   655	
   656	  /**
   657	   * @notice Validates the action of setting efficiency mode.
   658	   * @param reservesData The state of all the reserves
   659	   * @param reservesList The addresses of all the active reserves
   660	   * @param eModeCategories a mapping storing configurations for all efficiency mode categories
   661	   * @param userConfig the user configuration
   662	   * @param reservesCount The total number of valid reserves
   663	   * @param categoryId The id of the category
   664	   **/
   665	  function validateSetUserEMode(
   666	    mapping(address => DataTypes.ReserveData) storage reservesData,
   667	    mapping(uint256 => address) storage reservesList,
   668	    mapping(uint8 => DataTypes.EModeCategory) storage eModeCategories,
   669	    DataTypes.UserConfigurationMap memory userConfig,
   670	    uint256 reservesCount,
   671	    uint8 categoryId
   672	  ) internal view {
   673	    // category is invalid if the liq threshold is not set
   674	    require(
   675	      categoryId == 0 || eModeCategories[categoryId].liquidationThreshold != 0,
   676	      Errors.INCONSISTENT_EMODE_CATEGORY
   677	    );
   678	
   679	    //eMode can always be enabled if the user hasn't supplied anything
   680	    if (userConfig.isEmpty()) {
   681	      return;
   682	    }
   683	
   684	    // if user is trying to set another category than default we require that
   685	    // either the user is not borrowing, or it's borrowing assets of categoryId
   686	    if (categoryId != 0) {
   687	      unchecked {
   688	        for (uint256 i = 0; i < reservesCount; i++) {
   689	          if (userConfig.isBorrowing(i)) {
   690	            DataTypes.ReserveConfigurationMap memory configuration = reservesData[reservesList[i]]
   691	              .configuration;
   692	            require(
   693	              configuration.getEModeCategory() == categoryId,
   694	              Errors.INCONSISTENT_EMODE_CATEGORY
   695	            );
   696	          }
   697	        }
   698	      }
   699	    }
   700	  }
   701	
   702	  /**
   703	   * @notice Validates if an asset can be activated as collateral in the following actions: supply, transfer,
   704	   * set as collateral, mint unbacked, and liquidate
   705	   * @dev This is used to ensure that the constraints for isolated assets are respected by all the actions that
   706	   * generate transfers of aTokens
   707	   * @param reservesData The state of all the reserves
   708	   * @param reservesList The addresses of all the active reserves
   709	   * @param userConfig the user configuration
   710	   * @param reserveConfig The reserve configuration
   711	   * @return True if the asset can be activated as collateral, false otherwise
   712	   **/
   713	  function validateUseAsCollateral(
   714	    mapping(address => DataTypes.ReserveData) storage reservesData,
   715	    mapping(uint256 => address) storage reservesList,
   716	    DataTypes.UserConfigurationMap storage userConfig,
   717	    DataTypes.ReserveConfigurationMap memory reserveConfig
