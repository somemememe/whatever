   627	  /**
   628	   * @notice Validates a transfer action.
   629	   * @param reserve The reserve object
   630	   */
   631	  function validateTransfer(DataTypes.ReserveData storage reserve) internal view {
   632	    require(!reserve.configuration.getPaused(), Errors.RESERVE_PAUSED);
