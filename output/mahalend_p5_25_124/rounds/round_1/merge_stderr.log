   162	          0,
   163	          params.referralCode
   164	        );
   165	      }
   166	    }
   167	  }
   168	
   169	  /**
   170	   * @notice Implements the simple flashloan feature that allow users to access liquidity of ONE reserve for one
   171	   * transaction as long as the amount taken plus fee is returned.
   172	   * @dev Does not waive fee for approved flashborrowers nor allow taking on debt instead of repaying to save gas
   173	   * @dev At the end of the transaction the pool will pull amount borrowed + fee from the receiver,
   174	   * if the receiver have not approved the pool the transaction will revert.
   175	   * @dev Emits the `FlashLoan()` event
   176	   * @param reserve The state of the flashloaned reserve
   177	   * @param params The additional parameters needed to execute the simple flashloan function
   178	   */
   179	  function executeFlashLoanSimple(
   180	    DataTypes.ReserveData storage reserve,
   181	    DataTypes.FlashloanSimpleParams memory params
   182	  ) external {
   183	    // The usual action flow (cache -> updateState -> validation -> changeState -> updateRates)
   184	    // is altered to (validation -> user payload -> cache -> updateState -> changeState -> updateRates) for flashloans.
   185	    // This is done to protect against reentrance and rate manipulation within the user specified payload.
   186	
   187	    ValidationLogic.validateFlashloanSimple(reserve);
   188	
   189	    IFlashLoanSimpleReceiver receiver = IFlashLoanSimpleReceiver(params.receiverAddress);
   190	    uint256 totalPremium = params.amount.percentMul(params.flashLoanPremiumTotal);
   191	    IAToken(reserve.aTokenAddress).transferUnderlyingTo(params.receiverAddress, params.amount);
   192	
   193	    require(
   194	      receiver.executeOperation(
   195	        params.asset,
   196	        params.amount,
   197	        totalPremium,
   198	        msg.sender,
   199	        params.params
   200	      ),
   201	      Errors.INVALID_FLASHLOAN_EXECUTOR_RETURN
   202	    );
   203	
   204	    _handleFlashLoanRepayment(
   205	      reserve,
   206	      DataTypes.FlashLoanRepaymentParams({
   207	        asset: params.asset,
   208	        receiverAddress: params.receiverAddress,
   209	        amount: params.amount,
   210	        totalPremium: totalPremium,
   211	        flashLoanPremiumToProtocol: params.flashLoanPremiumToProtocol,
   212	        referralCode: params.referralCode
   213	      })
   214	    );
   215	  }
   216	
   217	  /**
   218	   * @notice Handles repayment of flashloaned assets + premium
   219	   * @dev Will pull the amount + premium from the receiver, so must have approved pool
   220	   * @param reserve The state of the flashloaned reserve
   221	   * @param params The additional parameters needed to execute the repayment function
   222	   */
   223	  function _handleFlashLoanRepayment(
   224	    DataTypes.ReserveData storage reserve,
   225	    DataTypes.FlashLoanRepaymentParams memory params
   226	  ) internal {
   227	    uint256 premiumToProtocol = params.totalPremium.percentMul(params.flashLoanPremiumToProtocol);
   228	    uint256 premiumToLP = params.totalPremium - premiumToProtocol;
   229	    uint256 amountPlusPremium = params.amount + params.totalPremium;
   230	
   231	    DataTypes.ReserveCache memory reserveCache = reserve.cache();
   232	    reserve.updateState(reserveCache);
   233	    reserveCache.nextLiquidityIndex = reserve.cumulateToLiquidityIndex(
   234	      IERC20(reserveCache.aTokenAddress).totalSupply(),
   235	      premiumToLP
   236	    );
   237	
   238	    reserve.accruedToTreasury += premiumToProtocol
   239	      .rayDiv(reserveCache.nextLiquidityIndex)
   240	      .toUint128();
   241	
   242	    reserve.updateInterestRates(reserveCache, params.asset, amountPlusPremium, 0);
   243	
   244	    IERC20(params.asset).safeTransferFrom(
   245	      params.receiverAddress,
   246	      reserveCache.aTokenAddress,
   247	      amountPlusPremium
   248	    );
   249	
   250	    IAToken(reserveCache.aTokenAddress).handleRepayment(params.receiverAddress, amountPlusPremium);
   251	
   252	    emit FlashLoan(
   253	      params.receiverAddress,
   254	      msg.sender,
   255	      params.asset,
   256	      params.amount,
   257	      DataTypes.InterestRateMode(0),
   258	      params.totalPremium,
   259	      params.referralCode
   260	    );
   261	  }
   262	}

