    85	    vars.totalPremiums = new uint256[](params.assets.length);
    86	
    87	    vars.receiver = IFlashLoanReceiver(params.receiverAddress);
    88	    (vars.flashloanPremiumTotal, vars.flashloanPremiumToProtocol) = params.isAuthorizedFlashBorrower
