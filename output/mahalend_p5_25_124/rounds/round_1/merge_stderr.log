   246	      collateralReserveCache,
   247	      params.collateralAsset,
   248	      0,
   249	      vars.actualCollateralToLiquidate
   250	    );
   251	
   252	    // Burn the equivalent amount of aToken, sending the underlying to the liquidator
   253	    vars.collateralAToken.burn(
   254	      params.user,
   255	      msg.sender,
   256	      vars.actualCollateralToLiquidate,
   257	      collateralReserveCache.nextLiquidityIndex
   258	    );
   259	  }
   260	
   261	  /**
   262	   * @notice Liquidates the user aTokens by transferring them to the liquidator.
   263	   * @dev   The function also checks the state of the liquidator and activates the aToken as collateral
   264	   *        as in standard transfers if the isolation mode constraints are respected.
   265	   * @param reservesData The state of all the reserves
   266	   * @param reservesList The addresses of all the active reserves
   267	   * @param usersConfig The users configuration mapping that track the supplied/borrowed assets
   268	   * @param collateralReserve The data of the collateral reserve
   269	   * @param params The additional parameters needed to execute the liquidation function
   270	   * @param vars The executeLiquidationCall() function local vars
   271	   */
   272	  function _liquidateATokens(
   273	    mapping(address => DataTypes.ReserveData) storage reservesData,
   274	    mapping(uint256 => address) storage reservesList,
   275	    mapping(address => DataTypes.UserConfigurationMap) storage usersConfig,
   276	    DataTypes.ReserveData storage collateralReserve,
   277	    DataTypes.ExecuteLiquidationCallParams memory params,
   278	    LiquidationCallLocalVars memory vars
   279	  ) internal {
   280	    uint256 liquidatorPreviousATokenBalance = IERC20(vars.collateralAToken).balanceOf(msg.sender);
   281	    vars.collateralAToken.transferOnLiquidation(
   282	      params.user,
   283	      msg.sender,
   284	      vars.actualCollateralToLiquidate
   285	    );
   286	
   287	    if (liquidatorPreviousATokenBalance == 0) {
   288	      DataTypes.UserConfigurationMap storage liquidatorConfig = usersConfig[msg.sender];
   289	      if (
   290	        ValidationLogic.validateUseAsCollateral(
   291	          reservesData,
   292	          reservesList,
   293	          liquidatorConfig,
   294	          collateralReserve.configuration
   295	        )
   296	      ) {
   297	        liquidatorConfig.setUsingAsCollateral(collateralReserve.id, true);
   298	        emit ReserveUsedAsCollateralEnabled(params.collateralAsset, msg.sender);
   299	      }
   300	    }
   301	  }
   302	
   303	  /**
   304	   * @notice Burns the debt tokens of the user up to the amount being repaid by the liquidator.
   305	   * @dev The function alters the `debtReserveCache` state in `vars` to update the debt related data.
   306	   * @param params The additional parameters needed to execute the liquidation function
   307	   * @param vars the executeLiquidationCall() function local vars
   308	   */
   309	  function _burnDebtTokens(
   310	    DataTypes.ExecuteLiquidationCallParams memory params,
   311	    LiquidationCallLocalVars memory vars
   312	  ) internal {
   313	    if (vars.userVariableDebt >= vars.actualDebtToLiquidate) {
   314	      vars.debtReserveCache.nextScaledVariableDebt = IVariableDebtToken(
   315	        vars.debtReserveCache.variableDebtTokenAddress
   316	      ).burn(
   317	          params.user,
   318	          vars.actualDebtToLiquidate,
   319	          vars.debtReserveCache.nextVariableBorrowIndex
   320	        );
   321	    } else {
   322	      // If the user doesn't have variable debt, no need to try to burn variable debt tokens
   323	      if (vars.userVariableDebt != 0) {
   324	        vars.debtReserveCache.nextScaledVariableDebt = IVariableDebtToken(
   325	          vars.debtReserveCache.variableDebtTokenAddress
   326	        ).burn(params.user, vars.userVariableDebt, vars.debtReserveCache.nextVariableBorrowIndex);
   327	      }
   328	      (
   329	        vars.debtReserveCache.nextTotalStableDebt,
   330	        vars.debtReserveCache.nextAvgStableBorrowRate
   331	      ) = IStableDebtToken(vars.debtReserveCache.stableDebtTokenAddress).burn(
   332	        params.user,
   333	        vars.actualDebtToLiquidate - vars.userVariableDebt
   334	      );
   335	    }
   336	  }
   337	
   338	  /**
   339	   * @notice Calculates the total debt of the user and the actual amount to liquidate depending on the health factor
   340	   * and corresponding close factor.
   341	   * @dev If the Health Factor is below CLOSE_FACTOR_HF_THRESHOLD, the close factor is increased to MAX_LIQUIDATION_CLOSE_FACTOR
   342	   * @param debtReserveCache The reserve cache data object of the debt reserve
   343	   * @param params The additional parameters needed to execute the liquidation function
   344	   * @param healthFactor The health factor of the position
   345	   * @return The variable debt of the user
   346	   * @return The total debt of the user
   347	   * @return The actual debt to liquidate as a function of the closeFactor
   348	   */
   349	  function _calculateDebt(
   350	    DataTypes.ReserveCache memory debtReserveCache,
   351	    DataTypes.ExecuteLiquidationCallParams memory params,
   352	    uint256 healthFactor
   353	  )
   354	    internal
   355	    view
   356	    returns (
   357	      uint256,
   358	      uint256,
   359	      uint256
   360	    )
   361	  {
   362	    (uint256 userStableDebt, uint256 userVariableDebt) = Helpers.getUserCurrentDebt(
   363	      params.user,
   364	      debtReserveCache
   365	    );
   366	
   367	    uint256 userTotalDebt = userStableDebt + userVariableDebt;
   368	
   369	    uint256 closeFactor = healthFactor > CLOSE_FACTOR_HF_THRESHOLD
   370	      ? DEFAULT_LIQUIDATION_CLOSE_FACTOR
   371	      : MAX_LIQUIDATION_CLOSE_FACTOR;
   372	
   373	    uint256 maxLiquidatableDebt = userTotalDebt.percentMul(closeFactor);
   374	
   375	    uint256 actualDebtToLiquidate = params.debtToCover > maxLiquidatableDebt
   376	      ? maxLiquidatableDebt
   377	      : params.debtToCover;
   378	
   379	    return (userVariableDebt, userTotalDebt, actualDebtToLiquidate);
   380	  }
   381	
   382	  /**
   383	   * @notice Returns the configuration data for the debt and the collateral reserves.
   384	   * @param eModeCategories The configuration of all the efficiency mode categories
   385	   * @param collateralReserve The data of the collateral reserve
   386	   * @param params The additional parameters needed to execute the liquidation function
   387	   * @return The collateral aToken
   388	   * @return The address to use as price source for the collateral
   389	   * @return The address to use as price source for the debt
   390	   * @return The liquidation bonus to apply to the collateral
   391	   */
   392	  function _getConfigurationData(
   393	    mapping(uint8 => DataTypes.EModeCategory) storage eModeCategories,
   394	    DataTypes.ReserveData storage collateralReserve,
   395	    DataTypes.ExecuteLiquidationCallParams memory params
   396	  )
   397	    internal
   398	    view
   399	    returns (
   400	      IAToken,
   401	      address,
   402	      address,
   403	      uint256
   404	    )
   405	  {
   406	    IAToken collateralAToken = IAToken(collateralReserve.aTokenAddress);
   407	    uint256 liquidationBonus = collateralReserve.configuration.getLiquidationBonus();
   408	
   409	    address collateralPriceSource = params.collateralAsset;
   410	    address debtPriceSource = params.debtAsset;
   411	
   412	    if (params.userEModeCategory != 0) {
   413	      address eModePriceSource = eModeCategories[params.userEModeCategory].priceSource;
   414	
   415	      if (
   416	        EModeLogic.isInEModeCategory(
   417	          params.userEModeCategory,
   418	          collateralReserve.configuration.getEModeCategory()
   419	        )
   420	      ) {
   421	        liquidationBonus = eModeCategories[params.userEModeCategory].liquidationBonus;
   422	
   423	        if (eModePriceSource != address(0)) {
   424	          collateralPriceSource = eModePriceSource;
   425	        }
   426	      }
   427	
   428	      // when in eMode, debt will always be in the same eMode category, can skip matching category check
   429	      if (eModePriceSource != address(0)) {
   430	        debtPriceSource = eModePriceSource;
   431	      }
   432	    }
   433	
   434	    return (collateralAToken, collateralPriceSource, debtPriceSource, liquidationBonus);
   435	  }
   436	
   437	  struct AvailableCollateralToLiquidateLocalVars {
   438	    uint256 collateralPrice;
   439	    uint256 debtAssetPrice;
   440	    uint256 maxCollateralToLiquidate;
   441	    uint256 baseCollateral;
   442	    uint256 bonusCollateral;
   443	    uint256 debtAssetDecimals;
   444	    uint256 collateralDecimals;
   445	    uint256 collateralAssetUnit;
   446	    uint256 debtAssetUnit;
   447	    uint256 collateralAmount;
   448	    uint256 debtAmountNeeded;
   449	    uint256 liquidationProtocolFeePercentage;
   450	    uint256 liquidationProtocolFee;
   451	  }
   452	
   453	  /**
   454	   * @notice Calculates how much of a specific collateral can be liquidated, given
   455	   * a certain amount of debt asset.
   456	   * @dev This function needs to be called after all the checks to validate the liquidation have been performed,
   457	   *   otherwise it might fail.
   458	   * @param collateralReserve The data of the collateral reserve
   459	   * @param debtReserveCache The cached data of the debt reserve
   460	   * @param collateralAsset The address of the underlying asset used as collateral, to receive as result of the liquidation
   461	   * @param debtAsset The address of the underlying borrowed asset to be repaid with the liquidation
   462	   * @param debtToCover The debt amount of borrowed `asset` the liquidator wants to cover
   463	   * @param userCollateralBalance The collateral balance for the specific `collateralAsset` of the user being liquidated
   464	   * @param liquidationBonus The collateral bonus percentage to receive as result of the liquidation
   465	   * @return The maximum amount that is possible to liquidate given all the liquidation constraints (user balance, close factor)
   466	   * @return The amount to repay with the liquidation
   467	   * @return The fee taken from the liquidation bonus amount to be paid to the protocol
   468	   **/
   469	  function _calculateAvailableCollateralToLiquidate(
   470	    DataTypes.ReserveData storage collateralReserve,
   471	    DataTypes.ReserveCache memory debtReserveCache,
   472	    address collateralAsset,
   473	    address debtAsset,
   474	    uint256 debtToCover,
   475	    uint256 userCollateralBalance,
   476	    uint256 liquidationBonus,
   477	    IPriceOracleGetter oracle
   478	  )
   479	    internal
   480	    view
   481	    returns (
   482	      uint256,
   483	      uint256,
   484	      uint256
   485	    )
   486	  {
   487	    AvailableCollateralToLiquidateLocalVars memory vars;
   488	
   489	    vars.collateralPrice = oracle.getAssetPrice(collateralAsset);
   490	    vars.debtAssetPrice = oracle.getAssetPrice(debtAsset);
   491	
   492	    vars.collateralDecimals = collateralReserve.configuration.getDecimals();
   493	    vars.debtAssetDecimals = debtReserveCache.reserveConfiguration.getDecimals();
   494	
   495	    unchecked {
   496	      vars.collateralAssetUnit = 10**vars.collateralDecimals;
   497	      vars.debtAssetUnit = 10**vars.debtAssetDecimals;
   498	    }
   499	
   500	    vars.liquidationProtocolFeePercentage = collateralReserve
   501	      .configuration
   502	      .getLiquidationProtocolFee();
   503	
   504	    // This is the base collateral to liquidate based on the given debt to cover
   505	    vars.baseCollateral =
   506	      ((vars.debtAssetPrice * debtToCover * vars.collateralAssetUnit)) /
   507	      (vars.collateralPrice * vars.debtAssetUnit);
   508	
   509	    vars.maxCollateralToLiquidate = vars.baseCollateral.percentMul(liquidationBonus);
   510	
   511	    if (vars.maxCollateralToLiquidate > userCollateralBalance) {
   512	      vars.collateralAmount = userCollateralBalance;
   513	      vars.debtAmountNeeded = ((vars.collateralPrice * vars.collateralAmount * vars.debtAssetUnit) /
   514	        (vars.debtAssetPrice * vars.collateralAssetUnit)).percentDiv(liquidationBonus);
   515	    } else {
   516	      vars.collateralAmount = vars.maxCollateralToLiquidate;
   517	      vars.debtAmountNeeded = debtToCover;
   518	    }
   519	
   520	    if (vars.liquidationProtocolFeePercentage != 0) {
   521	      vars.bonusCollateral =
   522	        vars.collateralAmount -
   523	        vars.collateralAmount.percentDiv(liquidationBonus);
   524	
   525	      vars.liquidationProtocolFee = vars.bonusCollateral.percentMul(
   526	        vars.liquidationProtocolFeePercentage
   527	      );
   528	
   529	      return (
   530	        vars.collateralAmount - vars.liquidationProtocolFee,
   531	        vars.debtAmountNeeded,
   532	        vars.liquidationProtocolFee
   533	      );
   534	    } else {
   535	      return (vars.collateralAmount, vars.debtAmountNeeded, 0);
   536	    }
   537	  }
   538	}

