   101	    require(
   102	      vars.receiver.executeOperation(
   103	        params.assets,
   104	        params.amounts,
   105	        vars.totalPremiums,
   106	        msg.sender,
   107	        params.params
   108	      ),
   109	      Errors.INVALID_FLASHLOAN_EXECUTOR_RETURN
   110	    );
   111	
   112	    for (vars.i = 0; vars.i < params.assets.length; vars.i++) {
   113	      vars.currentAsset = params.assets[vars.i];
   114	      vars.currentAmount = params.amounts[vars.i];
