    94	      vars.totalPremiums[vars.i] = vars.currentAmount.percentMul(vars.flashloanPremiumTotal);
    95	      IAToken(reservesData[params.assets[vars.i]].aTokenAddress).transferUnderlyingTo(
    96	        params.receiverAddress,
    97	        vars.currentAmount
    98	      );
    99	    }
