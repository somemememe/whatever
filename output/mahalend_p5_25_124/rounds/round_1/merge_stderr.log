   542	  /**
   543	   * @notice Validates the health factor of a user.
   544	   * @param reservesData The state of all the reserves
   545	   * @param reservesList The addresses of all the active reserves
   546	   * @param eModeCategories The configuration of all the efficiency mode categories
   547	   * @param userConfig The state of the user for the specific reserve
   548	   * @param user The user to validate health factor of
   549	   * @param userEModeCategory The users active efficiency mode category
   550	   * @param reservesCount The number of available reserves
   551	   * @param oracle The price oracle
   552	   */
   553	  function validateHealthFactor(
   554	    mapping(address => DataTypes.ReserveData) storage reservesData,
   555	    mapping(uint256 => address) storage reservesList,
   556	    mapping(uint8 => DataTypes.EModeCategory) storage eModeCategories,
   557	    DataTypes.UserConfigurationMap memory userConfig,
   558	    address user,
   559	    uint8 userEModeCategory,
   560	    uint256 reservesCount,
   561	    address oracle
   562	  ) internal view returns (uint256, bool) {
   563	    (, , , , uint256 healthFactor, bool hasZeroLtvCollateral) = GenericLogic
   564	      .calculateUserAccountData(
   565	        reservesData,
   566	        reservesList,
   567	        eModeCategories,
   568	        DataTypes.CalculateUserAccountDataParams({
   569	          userConfig: userConfig,
   570	          reservesCount: reservesCount,
   571	          user: user,
   572	          oracle: oracle,
   573	          userEModeCategory: userEModeCategory
   574	        })
   575	      );
   576	
   577	    require(
   578	      healthFactor >= HEALTH_FACTOR_LIQUIDATION_THRESHOLD,
   579	      Errors.HEALTH_FACTOR_LOWER_THAN_LIQUIDATION_THRESHOLD
   580	    );
   581	
   582	    return (healthFactor, hasZeroLtvCollateral);
   583	  }
