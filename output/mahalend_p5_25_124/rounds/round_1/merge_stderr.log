   442	  /**
   443	   * @notice Validates the action of setting an asset as collateral.
   444	   * @param reserveCache The cached data of the reserve
   445	   * @param userBalance The balance of the user
   446	   */
   447	  function validateSetUseReserveAsCollateral(
   448	    DataTypes.ReserveCache memory reserveCache,
   449	    uint256 userBalance
   450	  ) internal pure {
   451	    require(userBalance != 0, Errors.UNDERLYING_BALANCE_ZERO);
   452	
   453	    (bool isActive, , , , bool isPaused) = reserveCache.reserveConfiguration.getFlags();
   454	    require(isActive, Errors.RESERVE_INACTIVE);
   455	    require(!isPaused, Errors.RESERVE_PAUSED);
   456	  }
