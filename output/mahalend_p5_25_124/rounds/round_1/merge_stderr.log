   101	  /**
   102	   * @notice Back the current unbacked with `amount` and pay `fee`.
   103	   * @dev Emits the `BackUnbacked` event
   104	   * @param reserve The reserve to back unbacked for
   105	   * @param asset The address of the underlying asset to repay
   106	   * @param amount The amount to back
   107	   * @param fee The amount paid in fees
   108	   * @param protocolFeeBps The fraction of fees in basis points paid to the protocol
   109	   **/
   110	  function executeBackUnbacked(
   111	    DataTypes.ReserveData storage reserve,
   112	    address asset,
   113	    uint256 amount,
   114	    uint256 fee,
   115	    uint256 protocolFeeBps
   116	  ) external {
   117	    DataTypes.ReserveCache memory reserveCache = reserve.cache();
   118	
   119	    reserve.updateState(reserveCache);
   120	
   121	    uint256 backingAmount = (amount < reserve.unbacked) ? amount : reserve.unbacked;
   122	
   123	    uint256 feeToProtocol = fee.percentMul(protocolFeeBps);
   124	    uint256 feeToLP = fee - feeToProtocol;
   125	    uint256 added = backingAmount + fee;
   126	
   127	    reserveCache.nextLiquidityIndex = reserve.cumulateToLiquidityIndex(
   128	      IERC20(reserveCache.aTokenAddress).totalSupply(),
   129	      feeToLP
   130	    );
   131	
   132	    reserve.accruedToTreasury += feeToProtocol.rayDiv(reserveCache.nextLiquidityIndex).toUint128();
   133	
   134	    reserve.unbacked -= backingAmount.toUint128();
   135	    reserve.updateInterestRates(reserveCache, asset, added, 0);
   136	
   137	    IERC20(asset).safeTransferFrom(msg.sender, reserveCache.aTokenAddress, added);
   138	
   139	    emit BackUnbacked(asset, msg.sender, backingAmount, fee);
   140	  }
