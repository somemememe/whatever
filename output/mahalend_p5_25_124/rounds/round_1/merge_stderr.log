   488	  struct ValidateLiquidationCallLocalVars {
   489	    bool collateralReserveActive;
   490	    bool collateralReservePaused;
   491	    bool principalReserveActive;
   492	    bool principalReservePaused;
   493	    bool isCollateralEnabled;
   494	  }
   495	
   496	  /**
   497	   * @notice Validates the liquidation action.
   498	   * @param userConfig The user configuration mapping
   499	   * @param collateralReserve The reserve data of the collateral
   500	   * @param params Additional parameters needed for the validation
   501	   */
   502	  function validateLiquidationCall(
   503	    DataTypes.UserConfigurationMap storage userConfig,
   504	    DataTypes.ReserveData storage collateralReserve,
   505	    DataTypes.ValidateLiquidationCallParams memory params
   506	  ) internal view {
   507	    ValidateLiquidationCallLocalVars memory vars;
   508	
   509	    (vars.collateralReserveActive, , , , vars.collateralReservePaused) = collateralReserve
   510	      .configuration
   511	      .getFlags();
   512	
   513	    (vars.principalReserveActive, , , , vars.principalReservePaused) = params
   514	      .debtReserveCache
   515	      .reserveConfiguration
   516	      .getFlags();
   517	
   518	    require(vars.collateralReserveActive && vars.principalReserveActive, Errors.RESERVE_INACTIVE);
   519	    require(!vars.collateralReservePaused && !vars.principalReservePaused, Errors.RESERVE_PAUSED);
   520	
   521	    require(
   522	      params.priceOracleSentinel == address(0) ||
   523	        params.healthFactor < MINIMUM_HEALTH_FACTOR_LIQUIDATION_THRESHOLD ||
   524	        IPriceOracleSentinel(params.priceOracleSentinel).isLiquidationAllowed(),
   525	      Errors.PRICE_ORACLE_SENTINEL_CHECK_FAILED
   526	    );
   527	
   528	    require(
   529	      params.healthFactor < HEALTH_FACTOR_LIQUIDATION_THRESHOLD,
   530	      Errors.HEALTH_FACTOR_NOT_BELOW_THRESHOLD
   531	    );
   532	
   533	    vars.isCollateralEnabled =
   534	      collateralReserve.configuration.getLiquidationThreshold() != 0 &&
   535	      userConfig.isUsingAsCollateral(collateralReserve.id);
   536	
   537	    //if collateral isn't enabled as collateral by user, it cannot be liquidated
   538	    require(vars.isCollateralEnabled, Errors.COLLATERAL_CANNOT_BE_LIQUIDATED);
   539	    require(params.totalDebt != 0, Errors.SPECIFIED_CURRENCY_NOT_BORROWED_BY_USER);
   540	  }
