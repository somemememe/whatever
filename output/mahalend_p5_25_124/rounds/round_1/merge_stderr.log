   176	
   177	      vars.totalDebt =
   178	        params.reserveCache.currTotalStableDebt +
   179	        vars.totalSupplyVariableDebt +
   180	        params.amount;
   181	
   182	      unchecked {
   183	        require(vars.totalDebt <= vars.borrowCap * vars.assetUnit, Errors.BORROW_CAP_EXCEEDED);
   184	      }
   185	    }
   186	
   187	    if (params.isolationModeActive) {
   188	      // check that the asset being borrowed is borrowable in isolation mode AND
   189	      // the total exposure is no bigger than the collateral debt ceiling
   190	      require(
   191	        params.reserveCache.reserveConfiguration.getBorrowableInIsolation(),
   192	        Errors.ASSET_NOT_BORROWABLE_IN_ISOLATION
   193	      );
   194	
   195	      require(
   196	        reservesData[params.isolationModeCollateralAddress].isolationModeTotalDebt +
   197	          (params.amount / 10**(vars.reserveDecimals - ReserveConfiguration.DEBT_CEILING_DECIMALS))
   198	            .toUint128() <=
   199	          params.isolationModeDebtCeiling,
   200	        Errors.DEBT_CEILING_EXCEEDED
   201	      );
   202	    }
   203	
   204	    if (params.userEModeCategory != 0) {
   205	      require(
   206	        params.reserveCache.reserveConfiguration.getEModeCategory() == params.userEModeCategory,
   207	        Errors.INCONSISTENT_EMODE_CATEGORY
   208	      );
   209	      vars.eModePriceSource = eModeCategories[params.userEModeCategory].priceSource;
   210	    }
   211	
   212	    (
   213	      vars.userCollateralInBaseCurrency,
   214	      vars.userDebtInBaseCurrency,
   215	      vars.currentLtv,
   216	      ,
   217	      vars.healthFactor,
   218	
   219	    ) = GenericLogic.calculateUserAccountData(
   220	      reservesData,
   221	      reservesList,
   222	      eModeCategories,
   223	      DataTypes.CalculateUserAccountDataParams({
   224	        userConfig: params.userConfig,
   225	        reservesCount: params.reservesCount,
   226	        user: params.userAddress,
   227	        oracle: params.oracle,
   228	        userEModeCategory: params.userEModeCategory
   229	      })
   230	    );
   231	
   232	    require(vars.userCollateralInBaseCurrency != 0, Errors.COLLATERAL_BALANCE_IS_ZERO);
   233	    require(vars.currentLtv != 0, Errors.LTV_VALIDATION_FAILED);
   234	
   235	    require(
   236	      vars.healthFactor > HEALTH_FACTOR_LIQUIDATION_THRESHOLD,
   237	      Errors.HEALTH_FACTOR_LOWER_THAN_LIQUIDATION_THRESHOLD
   238	    );
   239	
   240	    vars.amountInBaseCurrency =
   241	      IPriceOracleGetter(params.oracle).getAssetPrice(
   242	        vars.eModePriceSource != address(0) ? vars.eModePriceSource : params.asset
   243	      ) *
   244	      params.amount;
   245	    unchecked {
   246	      vars.amountInBaseCurrency /= vars.assetUnit;
   247	    }
   248	
   249	    //add the current already borrowed amount to the amount requested to calculate the total collateral needed.
   250	    vars.collateralNeededInBaseCurrency = (vars.userDebtInBaseCurrency + vars.amountInBaseCurrency)
   251	      .percentDiv(vars.currentLtv); //LTV is calculated in percentage
   252	
   253	    require(
   254	      vars.collateralNeededInBaseCurrency <= vars.userCollateralInBaseCurrency,
   255	      Errors.COLLATERAL_CANNOT_COVER_NEW_BORROW
   256	    );
   257	
   258	    /**
   259	     * Following conditions need to be met if the user is borrowing at a stable rate:
   260	     * 1. Reserve must be enabled for stable rate borrowing
   261	     * 2. Users cannot borrow from the reserve if their collateral is (mostly) the same currency
   262	     *    they are borrowing, to prevent abuses.
   263	     * 3. Users will be able to borrow only a portion of the total available liquidity
   264	     **/
   265	
   266	    if (params.interestRateMode == DataTypes.InterestRateMode.STABLE) {
   267	      //check if the borrow mode is stable and if stable rate borrowing is enabled on this reserve
   268	
   269	      require(vars.stableRateBorrowingEnabled, Errors.STABLE_BORROWING_NOT_ENABLED);
   270	
   271	      require(
   272	        !params.userConfig.isUsingAsCollateral(reservesData[params.asset].id) ||
   273	          params.reserveCache.reserveConfiguration.getLtv() == 0 ||
   274	          params.amount > IERC20(params.reserveCache.aTokenAddress).balanceOf(params.userAddress),
   275	        Errors.COLLATERAL_SAME_AS_BORROWING_CURRENCY
   276	      );
   277	
   278	      vars.availableLiquidity = IERC20(params.asset).balanceOf(params.reserveCache.aTokenAddress);
   279	
   280	      //calculate the max available loan size in stable rate mode as a percentage of the
   281	      //available liquidity
   282	      uint256 maxLoanSizeStable = vars.availableLiquidity.percentMul(params.maxStableLoanPercent);
   283	
   284	      require(params.amount <= maxLoanSizeStable, Errors.AMOUNT_BIGGER_THAN_MAX_LOAN_SIZE_STABLE);
   285	    }
   286	
   287	    if (params.userConfig.isBorrowingAny()) {
   288	      (vars.siloedBorrowingEnabled, vars.siloedBorrowingAddress) = params
   289	        .userConfig
   290	        .getSiloedBorrowingState(reservesData, reservesList);
   291	
   292	      if (vars.siloedBorrowingEnabled) {
   293	        require(vars.siloedBorrowingAddress == params.asset, Errors.SILOED_BORROWING_VIOLATION);
   294	      } else {
   295	        require(
   296	          !params.reserveCache.reserveConfiguration.getSiloedBorrowing(),
   297	          Errors.SILOED_BORROWING_VIOLATION
   298	        );
   299	      }
   300	    }
   301	  }
   302	
   303	  /**
   304	   * @notice Validates a repay action.
   305	   * @param reserveCache The cached data of the reserve
   306	   * @param amountSent The amount sent for the repayment. Can be an actual value or uint(-1)
   307	   * @param interestRateMode The interest rate mode of the debt being repaid
   308	   * @param onBehalfOf The address of the user msg.sender is repaying for
   309	   * @param stableDebt The borrow balance of the user
   310	   * @param variableDebt The borrow balance of the user
   311	   */
   312	  function validateRepay(
   313	    DataTypes.ReserveCache memory reserveCache,
   314	    uint256 amountSent,
   315	    DataTypes.InterestRateMode interestRateMode,
   316	    address onBehalfOf,
   317	    uint256 stableDebt,
   318	    uint256 variableDebt
   319	  ) internal view {
   320	    require(amountSent != 0, Errors.INVALID_AMOUNT);
   321	    require(
   322	      amountSent != type(uint256).max || msg.sender == onBehalfOf,
   323	      Errors.NO_EXPLICIT_AMOUNT_TO_REPAY_ON_BEHALF
   324	    );
   325	
   326	    (bool isActive, , , , bool isPaused) = reserveCache.reserveConfiguration.getFlags();
   327	    require(isActive, Errors.RESERVE_INACTIVE);
   328	    require(!isPaused, Errors.RESERVE_PAUSED);
   329	
   330	    uint256 variableDebtPreviousIndex = IScaledBalanceToken(reserveCache.variableDebtTokenAddress)
   331	      .getPreviousIndex(onBehalfOf);
   332	
   333	    uint40 stableRatePreviousTimestamp = IStableDebtToken(reserveCache.stableDebtTokenAddress)
   334	      .getUserLastUpdated(onBehalfOf);
   335	
   336	    require(
   337	      (stableRatePreviousTimestamp < uint40(block.timestamp) &&
   338	        interestRateMode == DataTypes.InterestRateMode.STABLE) ||
   339	        (variableDebtPreviousIndex < reserveCache.nextVariableBorrowIndex &&
   340	          interestRateMode == DataTypes.InterestRateMode.VARIABLE),
   341	      Errors.SAME_BLOCK_BORROW_REPAY
   342	    );
   343	
   344	    require(
   345	      (stableDebt != 0 && interestRateMode == DataTypes.InterestRateMode.STABLE) ||
   346	        (variableDebt != 0 && interestRateMode == DataTypes.InterestRateMode.VARIABLE),
   347	      Errors.NO_DEBT_OF_SELECTED_TYPE
   348	    );
   349	  }
   350	
   351	  /**
   352	   * @notice Validates a swap of borrow rate mode.
   353	   * @param reserve The reserve state on which the user is swapping the rate
   354	   * @param reserveCache The cached data of the reserve
   355	   * @param userConfig The user reserves configuration
   356	   * @param stableDebt The stable debt of the user
   357	   * @param variableDebt The variable debt of the user
   358	   * @param currentRateMode The rate mode of the debt being swapped
   359	   */
   360	  function validateSwapRateMode(
   361	    DataTypes.ReserveData storage reserve,
   362	    DataTypes.ReserveCache memory reserveCache,
   363	    DataTypes.UserConfigurationMap storage userConfig,
   364	    uint256 stableDebt,
   365	    uint256 variableDebt,
   366	    DataTypes.InterestRateMode currentRateMode
   367	  ) internal view {
   368	    (bool isActive, bool isFrozen, , bool stableRateEnabled, bool isPaused) = reserveCache
   369	      .reserveConfiguration
   370	      .getFlags();
   371	    require(isActive, Errors.RESERVE_INACTIVE);
   372	    require(!isPaused, Errors.RESERVE_PAUSED);
   373	    require(!isFrozen, Errors.RESERVE_FROZEN);
   374	
   375	    if (currentRateMode == DataTypes.InterestRateMode.STABLE) {
   376	      require(stableDebt != 0, Errors.NO_OUTSTANDING_STABLE_DEBT);
   377	    } else if (currentRateMode == DataTypes.InterestRateMode.VARIABLE) {
   378	      require(variableDebt != 0, Errors.NO_OUTSTANDING_VARIABLE_DEBT);
   379	      /**
   380	       * user wants to swap to stable, before swapping we need to ensure that
   381	       * 1. stable borrow rate is enabled on the reserve
   382	       * 2. user is not trying to abuse the reserve by supplying
   383	       * more collateral than he is borrowing, artificially lowering
   384	       * the interest rate, borrowing at variable, and switching to stable
   385	       **/
   386	      require(stableRateEnabled, Errors.STABLE_BORROWING_NOT_ENABLED);
   387	
   388	      require(
   389	        !userConfig.isUsingAsCollateral(reserve.id) ||
   390	          reserveCache.reserveConfiguration.getLtv() == 0 ||
   391	          stableDebt + variableDebt > IERC20(reserveCache.aTokenAddress).balanceOf(msg.sender),
   392	        Errors.COLLATERAL_SAME_AS_BORROWING_CURRENCY
   393	      );
   394	    } else {
   395	      revert(Errors.INVALID_INTEREST_RATE_MODE_SELECTED);
   396	    }
   397	  }
   398	
   399	  /**
   400	   * @notice Validates a stable borrow rate rebalance action.
   401	   * @dev Rebalancing is accepted when depositors are earning <= 90% of their earnings in pure supply/demand market (variable rate only)
   402	   * For this to be the case, there has to be quite large stable debt with an interest rate below the current variable rate.
   403	   * @param reserve The reserve state on which the user is getting rebalanced
   404	   * @param reserveCache The cached state of the reserve
   405	   * @param reserveAddress The address of the reserve
   406	   */
   407	  function validateRebalanceStableBorrowRate(
   408	    DataTypes.ReserveData storage reserve,
   409	    DataTypes.ReserveCache memory reserveCache,
   410	    address reserveAddress
   411	  ) internal view {
   412	    (bool isActive, , , , bool isPaused) = reserveCache.reserveConfiguration.getFlags();
   413	    require(isActive, Errors.RESERVE_INACTIVE);
   414	    require(!isPaused, Errors.RESERVE_PAUSED);
   415	
   416	    uint256 totalDebt = IERC20(reserveCache.stableDebtTokenAddress).totalSupply() +
   417	      IERC20(reserveCache.variableDebtTokenAddress).totalSupply();
   418	
   419	    (uint256 liquidityRateVariableDebtOnly, , ) = IReserveInterestRateStrategy(
   420	      reserve.interestRateStrategyAddress
   421	    ).calculateInterestRates(
   422	        DataTypes.CalculateInterestRatesParams({
   423	          unbacked: reserve.unbacked,
   424	          liquidityAdded: 0,
   425	          liquidityTaken: 0,
   426	          totalStableDebt: 0,
   427	          totalVariableDebt: totalDebt,
   428	          averageStableBorrowRate: 0,
   429	          reserveFactor: reserveCache.reserveFactor,
   430	          reserve: reserveAddress,
   431	          aToken: reserveCache.aTokenAddress
   432	        })
   433	      );
   434	
   435	    require(
   436	      reserveCache.currLiquidityRate <=
   437	        liquidityRateVariableDebtOnly.percentMul(REBALANCE_UP_LIQUIDITY_RATE_THRESHOLD),
   438	      Errors.INTEREST_RATE_REBALANCE_CONDITIONS_NOT_MET
   439	    );
   440	  }
