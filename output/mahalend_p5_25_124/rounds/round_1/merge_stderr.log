   585	  /**
   586	   * @notice Validates the health factor of a user and the ltv of the asset being withdrawn.
   587	   * @param reservesData The state of all the reserves
   588	   * @param reservesList The addresses of all the active reserves
   589	   * @param eModeCategories The configuration of all the efficiency mode categories
   590	   * @param userConfig The state of the user for the specific reserve
   591	   * @param asset The asset for which the ltv will be validated
   592	   * @param from The user from which the aTokens are being transferred
   593	   * @param reservesCount The number of available reserves
   594	   * @param oracle The price oracle
   595	   * @param userEModeCategory The users active efficiency mode category
   596	   */
   597	  function validateHFAndLtv(
   598	    mapping(address => DataTypes.ReserveData) storage reservesData,
   599	    mapping(uint256 => address) storage reservesList,
   600	    mapping(uint8 => DataTypes.EModeCategory) storage eModeCategories,
   601	    DataTypes.UserConfigurationMap memory userConfig,
   602	    address asset,
   603	    address from,
   604	    uint256 reservesCount,
   605	    address oracle,
   606	    uint8 userEModeCategory
   607	  ) internal view {
   608	    DataTypes.ReserveData memory reserve = reservesData[asset];
   609	
   610	    (, bool hasZeroLtvCollateral) = validateHealthFactor(
   611	      reservesData,
   612	      reservesList,
   613	      eModeCategories,
   614	      userConfig,
   615	      from,
   616	      userEModeCategory,
   617	      reservesCount,
   618	      oracle
   619	    );
   620	
   621	    require(
   622	      !hasZeroLtvCollateral || reserve.configuration.getLtv() == 0,
   623	      Errors.LTV_VALIDATION_FAILED
   624	    );
   625	  }
