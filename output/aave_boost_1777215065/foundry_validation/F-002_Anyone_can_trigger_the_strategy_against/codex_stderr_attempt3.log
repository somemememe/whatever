exec
/bin/bash -lc 'TMP=/tmp/aave_boost_probe
rm -rf "$TMP" && mkdir -p "$TMP/test" "$TMP/src"
cat > "$TMP/foundry.toml" <<'"'EOF'
[profile.default]
src = 'src'
test = 'test'
out = 'out'
libs = []
optimizer = true
optimizer_runs = 200
via_ir = true
EOF
cat > \""'$TMP/test/Probe.t.sol" <<'"'EOF'
// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

interface Vm {
    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
    function envString(string calldata name) external returns (string memory);
}
address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));
contract ProbeTest {
    Vm constant vm = Vm(HEVM_ADDRESS);
    address constant TARGET = 0xd2933c86216dC0c938FfAFEca3C8a2D6e633e2cA;
    address constant HELPER = 0xf36f3976f288b2b4903aca8c177efc019b81d88b;
    event LogAddress(bytes4 sig, address a);
    event LogUint(bytes4 sig, uint256 v);
    event LogBool(bytes4 sig, bool ok, bytes data);
    function setUp() public {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 22685443);
    }
    function testProbe() public {
        _addr(TARGET, 0x819faf7b);
        _addr(TARGET, 0x16f0115b);
        _uint(TARGET, 0xcab34c08);
        _addr(HELPER, 0xe964b644);
        _uint(HELPER, 0x0f4bd1b9);
        _uint(HELPER, 0x1af8cbdd);
        _uint(HELPER, 0x3740ebb3);
        _uint(HELPER, 0xe07b098a);
        _uint(HELPER, 0xaa53e188);
        _bool(HELPER, 0x06a3fe59);
        _bool(HELPER, 0x41b71d49);
        _bool(HELPER, 0x58c93f78);
        _bool(HELPER, 0x61b699c4);
        _bool(HELPER, 0x6659c6f0);
        _bool(HELPER, 0xca49c621);
        _bool(HELPER, 0xcf59a799);
    }
    function _addr(address t, bytes4 sig) internal {
        (bool ok, bytes memory data) = t.staticcall(abi.encodeWithSelector(sig));
        emit LogBool(sig, ok, data);
        if (ok && data.length >= 32) emit LogAddress(sig, abi.decode(data,(address)));
    }
    function _uint(address t, bytes4 sig) internal {
        (bool ok, bytes memory data) = t.staticcall(abi.encodeWithSelector(sig));
        emit LogBool(sig, ok, data);
        if (ok && data.length >= 32) emit LogUint(sig, abi.decode(data,(uint256)));
    }
    function _bool(address t, bytes4 sig) internal {
        (bool ok, bytes memory data) = t.staticcall(abi.encodeWithSelector(sig));
        emit LogBool(sig, ok, data);
    }
}
EOF
