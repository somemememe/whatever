exec
/bin/bash -lc "python - <<'PY'
from pathlib import Path
p=Path('FlawVerifier.sol')
s=p.read_text()
old='''contract FlawVerifier is IBalancerFlashLoanRecipient {
    uint256 private constant BPS = 10_000;
    uint256 private constant MIN_REQUIRED_PROFIT = 0.1 ether;
'''
new='''contract FlawVerifier is IBalancerFlashLoanRecipient {
    uint256 private constant BPS = 10_000;
    uint256 private constant MIN_REQUIRED_PROFIT = 0.1 ether;

    struct SearchState {
        Strategy bestStrategy;
        uint256 bestAmount;
        uint256 bestProfit;
        uint256 lastSuccessfulAmount;
        uint256 firstFailedAmount;
        uint256 previousAmount;
    }
'''
s=s.replace(old,new)
old2='''    function _searchStrategy(
        Strategy strategy,
        uint256 reserveBase,
        uint256 vaultCap
    ) internal returns (Strategy bestStrategy, uint256 bestAmount, uint256 bestProfit) {
        uint256 lastSuccessfulAmount;
        uint256 firstFailedAmount;
        uint256 previousAmount;

        for (uint256 i = 0; i < 39; ++i) {
            uint256 amount = _capAmount((reserveBase * _coarseBps(i)) / BPS, vaultCap);
            if (amount == 0 || amount == previousAmount) {
                continue;
            }
            previousAmount = amount;

            (bool ok, uint256 profit) = _simulate(strategy, amount);
            if (ok) {
                lastSuccessfulAmount = amount;
                if (profit > bestProfit) {
                    bestProfit = profit;
                    bestAmount = amount;
                    bestStrategy = strategy;
                }
            } else if (lastSuccessfulAmount "'!= 0 && firstFailedAmount == 0) {
                firstFailedAmount = amount;
            }
        }

        if (lastSuccessfulAmount == 0) {
            return (Strategy.None, 0, 0);
        }

        if (firstFailedAmount == 0) {
            firstFailedAmount = vaultCap > lastSuccessfulAmount ? vaultCap : lastSuccessfulAmount;
        }

        uint256 low = lastSuccessfulAmount;
        uint256 high = firstFailedAmount;
        for (uint256 i = 0; i < 18; ++i) {
            if (high <= low + 1) {
                break;
            }
            uint256 mid = low + ((high - low) / 2);
            (bool ok, uint256 profit) = _simulate(strategy, mid);
            if (ok) {
                low = mid;
                if (profit > bestProfit) {
                    bestProfit = profit;
                    bestAmount = mid;
                    bestStrategy = strategy;
                }
            } else {
                high = mid;
            }
        }

        uint256 windowStart = bestAmount > (bestAmount / 10) ? bestAmount - (bestAmount / 10) : 1;
        uint256 windowEnd = high > bestAmount ? high : bestAmount;
        if (windowEnd < windowStart) {
            windowEnd = windowStart;
        }

        for (uint256 i = 0; i < 10; ++i) {
            uint256 probe = windowStart + ((windowEnd - windowStart) * i) / 9;
            if (probe == 0) {
                continue;
            }
            (bool ok, uint256 profit) = _simulate(strategy, probe);
            if (ok && profit > bestProfit) {
                bestProfit = profit;
                bestAmount = probe;
                bestStrategy = strategy;
            }
        }
    }
