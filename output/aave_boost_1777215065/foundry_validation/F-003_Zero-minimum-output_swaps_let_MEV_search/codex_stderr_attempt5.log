            if (profit > state.bestProfit) {
                state.bestProfit = profit;
                state.bestAmount = amount;
            }
        } else if (state.lastSuccessfulAmount != 0 && state.firstFailedAmount == 0) {
            state.firstFailedAmount = amount;
        }
        return state;
