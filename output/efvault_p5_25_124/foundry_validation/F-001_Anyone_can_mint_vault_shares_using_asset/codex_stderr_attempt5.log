    function _redeemEnoughForUSDC(IEFVaultLike vault, uint256 assetsNeeded) internal returns (bool) {
        for (uint256 i = 0; i < 24; ++i) {
            uint256 usdcBalance = IERC20Like(USDC).balanceOf(address(this));
            if (assetsNeeded != type(uint256).max && usdcBalance >= assetsNeeded) {
                return true;
            }

            uint256 shareBalance = vault.balanceOf(address(this));
            if (shareBalance == 0) {
                return assetsNeeded == type(uint256).max || IERC20Like(USDC).balanceOf(address(this)) >= assetsNeeded;
            }

            try vault.redeem(shareBalance, address(this)) returns (uint256) {
            } catch (bytes memory redeemErr) {
                lastError = redeemErr;
            }

            uint256 maxWithdraw = vault.maxWithdraw();
            if (maxWithdraw == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            uint256 claimable = vault.convertToAssets(shareBalance);
            if (claimable == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            uint256 chunk = claimable;
            if (assetsNeeded != type(uint256).max) {
                uint256 shortfall = assetsNeeded > usdcBalance ? assetsNeeded - usdcBalance : 0;
                if (shortfall != 0 && chunk > shortfall) {
                    chunk = shortfall;
                }
            }
            if (chunk > maxWithdraw) {
                chunk = maxWithdraw;
            }
            if (chunk == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            try vault.withdraw(chunk, address(this)) returns (uint256) {
            } catch (bytes memory withdrawErr) {
                lastError = withdrawErr;
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }
        }

        return assetsNeeded == type(uint256).max || IERC20Like(USDC).balanceOf(address(this)) >= assetsNeeded;
    }

    function _swapUsdcToWeth(uint256 amountIn) internal {
        if (amountIn == 0) {
            return;
        }

        IUniswapV2PairLike pair = IUniswapV2PairLike(UNISWAP_V2_USDC_WETH);
        bool usdcIsToken0 = pair.token0() == USDC;
        bool wethIsOtherSide =
            (usdcIsToken0 && pair.token1() == WETH) || (!usdcIsToken0 && pair.token0() == WETH);
        if (!wethIsOtherSide) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        uint256 reserveIn = usdcIsToken0 ? uint256(reserve0) : uint256(reserve1);
        uint256 reserveOut = usdcIsToken0 ? uint256(reserve1) : uint256(reserve0);
        if (reserveIn == 0 || reserveOut == 0) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        uint256 amountInWithFee = amountIn * 997;
        uint256 amountOut = (amountInWithFee * reserveOut) / ((reserveIn * 1000) + amountInWithFee);
        if (amountOut == 0) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        _safeTransfer(USDC, UNISWAP_V2_USDC_WETH, amountIn);
        pair.swap(usdcIsToken0 ? 0 : amountOut, usdcIsToken0 ? amountOut : 0, address(this), new bytes(0));
    }

    function _canContractCallerReachVault(IEFVaultLike vault) internal returns (bool) {
        address whitelist = vault.whiteList();
        if (whitelist == address(0)) {
            return false;
        }
        return _isWhitelisted(whitelist, address(this));
    }

    function _vaultAssetBalance(address assetToken) internal view returns (uint256) {
        if (assetToken == address(0)) {
            return TARGET.balance;
        }
        return IERC20Like(assetToken).balanceOf(TARGET);
    }

    function _isWhitelisted(address whitelist, address account) internal returns (bool) {
        try IWhitelistLike(whitelist).listed(account) returns (bool allowed) {
            return allowed;
        } catch {
            return false;
        }
    }

    function _sameTokenFlashRepayAmount(uint256 amountOut) internal pure returns (uint256) {
        return ((amountOut * 1000) / 997) + 1;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        require(ok && (ret.length == 0 || abi.decode(ret, (bool))), "transfer-failed");
    }

    function _revertSelector(bytes memory err) internal pure returns (bytes4 selector) {
        if (err.length < 4) {
            return bytes4(0);
        }
        assembly {
            selector := mload(add(err, 32))
        }
    }

    function _decodeRevertString(bytes memory err) internal pure returns (string memory reason) {
        if (err.length < 68) {
            return "";
        }
        assembly {
            err := add(err, 4)
        }
        reason = abi.decode(err, (string));
    }
