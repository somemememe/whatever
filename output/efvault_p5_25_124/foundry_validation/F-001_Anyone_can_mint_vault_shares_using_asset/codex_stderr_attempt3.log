        try vault.deposit(borrowed, address(this)) returns (uint256) {
            uint256 minted = vault.balanceOf(address(this)) - sharesBefore;
            require(minted > 0, "no-minted-shares");
        } catch (bytes memory err) {
            lastError = err;
