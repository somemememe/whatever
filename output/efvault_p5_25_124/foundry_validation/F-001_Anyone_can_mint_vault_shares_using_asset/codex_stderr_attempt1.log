+// SPDX-License-Identifier: MIT
+pragma solidity ^0.8.20;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+    function envString(string calldata name) external returns (string memory);
+}
+
+interface IERC20Like {
+    function balanceOf(address account) external view returns (uint256);
+}
+
+interface IWhitelistLike {
+    function listed(address account) external returns (bool);
+}
+
+interface IEFVaultLike {
+    function asset() external view returns (address);
+    function whiteList() external view returns (address);
+    function controller() external view returns (address);
+    function paused() external view returns (bool);
+    function totalSupply() external view returns (uint256);
+    function totalAssets() external view returns (uint256);
+    function maxDeposit() external view returns (uint256);
+    function maxWithdraw() external view returns (uint256);
+    function deposit(uint256 assets, address receiver) external returns (uint256);
+}
+
+address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));
+
+contract Helper {
+    function tryDeposit(address target, uint256 amount) external returns (bool, bytes memory) {
+        return target.call(abi.encodeWithSignature("deposit(uint256,address)", amount, address(this)));
+    }
+}
+
+contract ProbeTest {
+    Vm constant vm = Vm(HEVM_ADDRESS);
+    address constant TARGET = 0xBDB515028A6fA6CD1634B5A9651184494aBfD336;
+
+    event log_address(address);
+    event log_uint(uint256);
+    event log_bool(bool);
+    event log_bytes(bytes);
+
+    function testProbe() public {
+        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 16696239);
+        IEFVaultLike vault = IEFVaultLike(TARGET);
+        address asset = vault.asset();
+        address whitelist = vault.whiteList();
+        address controller = vault.controller();
+
+        emit log_address(asset);
+        emit log_address(whitelist);
+        emit log_address(controller);
+        emit log_bool(vault.paused());
+        emit log_uint(vault.totalSupply());
+        emit log_uint(vault.totalAssets());
+        emit log_uint(vault.maxDeposit());
+        emit log_uint(vault.maxWithdraw());
+        emit log_uint(IERC20Like(asset).balanceOf(TARGET));
+
+        Helper helper = new Helper();
+        bool listed = false;
+        if (whitelist != address(0)) {
+            try IWhitelistLike(whitelist).listed(address(helper)) returns (bool ok) {
+                listed = ok;
+            } catch {}
+        }
+        emit log_bool(listed);
+
+        (bool ok, bytes memory ret) = helper.tryDeposit(TARGET, 1e6);
+        emit log_bool(ok);
+        emit log_bytes(ret);
+    }
+}

