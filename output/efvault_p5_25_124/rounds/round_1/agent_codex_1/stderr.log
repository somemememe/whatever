    65	        require(tx.origin == msg.sender || IWhitelist(whiteList).listed(msg.sender), "NON_LISTED_CA");
    66	        _;
    67	    }
    68	
    69	    function initialize(
    70	        ERC20Upgradeable _asset,
    71	        string memory _name,
    72	        string memory _symbol,
    73	        uint256 _assetDecimal,
    74	        address _whiteList
    75	    ) public initializer {
    76	        __ERC20_init(_name, _symbol);
    77	        __Ownable_init();
    78	        __ReentrancyGuard_init();
    79	        asset = _asset;
    80	        assetDecimal = _assetDecimal;
    81	        maxDeposit = type(uint256).max;
    82	        maxWithdraw = type(uint256).max;
    83	
    84	        whiteList = _whiteList;
    85	    }
    86	
    87	    function deposit(uint256 assets, address receiver)
    88	        public
    89	        virtual
    90	        nonReentrant
    91	        unPaused
    92	        onlyAllowed
    93	        returns (uint256 shares)
    94	    {
    95	        require(assets != 0, "ZERO_ASSETS");
    96	        require(assets <= maxDeposit, "EXCEED_ONE_TIME_MAX_DEPOSIT");
    97	
    98	        require(getBalance(address(this)) >= assets, "INSUFFICIENT_TRANSFER");
    99	
   100	        // Need to transfer before minting or ERC777s could reenter.
   101	        TransferHelper.safeTransfer(address(asset), address(controller), assets);
   102	
   103	        // Total Assets amount until now
   104	        uint256 totalDeposit = IController(controller).totalAssets(false);
   105	        // Calls Deposit function on controller
   106	        uint256 newDeposit = IController(controller).deposit(assets);
   107	
   108	        require(newDeposit > 0, "INVALID_DEPOSIT_SHARES");
   109	
   110	        // Calculate share amount to be mint
   111	        shares = totalSupply() == 0 || totalDeposit == 0 ? assets : (totalSupply() * newDeposit) / totalDeposit;
   112	
   113	        // Mint ENF token to receiver
   114	        _mint(receiver, shares);
   115	
   116	        emit Deposit(address(asset), msg.sender, receiver, assets, shares);
   117	    }
   118	
   119	    function getBalance(address account) internal view returns (uint256) {
   120	        // Asset is zero address when it is ether
   121	        if (address(asset) == address(0)) return address(account).balance;
   122	        else return IERC20Upgradeable(asset).balanceOf(account);
   123	    }
   124	
   125	    function withdraw(uint256 assets, address receiver)
   126	        public
   127	        virtual
   128	        nonReentrant
   129	        unPaused
   130	        onlyAllowed
   131	        returns (uint256 shares)
   132	    {
   133	        require(assets != 0, "ZERO_ASSETS");
   134	        require(assets <= maxWithdraw, "EXCEED_ONE_TIME_MAX_WITHDRAW");
   135	
   136	        // Calculate share amount to be burnt
   137	        shares = (totalSupply() * assets) / IController(controller).totalAssets(false);
   138	
   139	        require(balanceOf(msg.sender) >= shares, "EXCEED_TOTAL_DEPOSIT");
   140	
   141	        // Withdraw asset
   142	        _withdraw(assets, shares, receiver);
   143	    }
   144	
   145	    function redeem(uint256 shares, address receiver)
   146	        public
   147	        virtual
   148	        nonReentrant
   149	        unPaused
   150	        onlyAllowed
   151	        returns (uint256 assets)
   152	    {
   153	        require(shares > 0, "ZERO_SHARES");
   154	        require(shares <= balanceOf(msg.sender), "EXCEED_TOTAL_BALANCE");
   155	
   156	        assets = (shares * assetsPerShare()) / 1e24;
   157	
   158	        require(assets <= maxWithdraw, "EXCEED_ONE_TIME_MAX_WITHDRAW");
   159	
   160	        // Withdraw asset
   161	        _withdraw(assets, shares, receiver);
   162	    }
   163	
   164	    function _withdraw(
   165	        uint256 assets,
   166	        uint256 shares,
   167	        address receiver
   168	    ) internal {
   169	        // Calls Withdraw function on controller
   170	        (uint256 withdrawn, uint256 fee) = IController(controller).withdraw(assets, receiver);
   171	        require(withdrawn > 0, "INVALID_WITHDRAWN_SHARES");
   172	
   173	        // Burn shares amount
   174	        _burn(msg.sender, shares);
   175	
   176	        emit Withdraw(address(asset), msg.sender, receiver, assets, shares, fee);
   177	    }
   178	
   179	    function assetsPerShare() internal view returns (uint256) {
   180	        return (IController(controller).totalAssets(false) * assetDecimal * 1e18) / totalSupply();
   181	    }
   182	
   183	    function totalAssets() public view virtual returns (uint256) {
   184	        return IController(controller).totalAssets(true);
   185	    }
   186	
   187	    function convertToShares(uint256 assets) public view virtual returns (uint256) {
   188	        uint256 supply = totalSupply();
   189	
   190	        return supply == 0 ? assets : (assets * supply) / totalAssets();
   191	    }
   192	
   193	    function convertToAssets(uint256 shares) public view virtual returns (uint256) {
   194	        uint256 supply = totalSupply();
   195	
   196	        return supply == 0 ? shares : (shares * totalAssets()) / supply;
   197	    }
   198	
   199	    ///////////////////////////////////////////////////////////////
   200	    //                 SET CONFIGURE LOGIC                       //
   201	    ///////////////////////////////////////////////////////////////
   202	
   203	    function setMaxDeposit(uint256 _maxDeposit) public onlyOwner {
   204	        require(_maxDeposit > 0, "INVALID_MAX_DEPOSIT");
   205	        maxDeposit = _maxDeposit;
   206	
   207	        emit SetMaxDeposit(maxDeposit);
   208	    }
   209	
   210	    function setMaxWithdraw(uint256 _maxWithdraw) public onlyOwner {
   211	        require(_maxWithdraw > 0, "INVALID_MAX_WITHDRAW");
   212	        maxWithdraw = _maxWithdraw;
   213	
   214	        emit SetMaxWithdraw(maxWithdraw);
   215	    }
   216	
   217	    function setController(address _controller) public onlyOwner {
   218	        require(_controller != address(0), "INVALID_ZERO_ADDRESS");
   219	        controller = _controller;
   220	
   221	        emit SetController(controller);
   222	    }
   223	
   224	    function setDepositApprover(address _approver) public onlyOwner {
   225	        require(_approver != address(0), "INVALID_ZERO_ADDRESS");
   226	        depositApprover = _approver;
   227	
   228	        emit SetDepositApprover(depositApprover);
   229	    }
   230	
   231	    function setWhitelist(address _whitelist) public onlyOwner {
   232	        require(_whitelist != address(0), "INVALID_ZERO_ADDRESS");
   233	        whiteList = _whitelist;
   234	
   235	        emit SetWhitelist(whiteList);
   236	    }
   237	
   238	    ////////////////////////////////////////////////////////////////////
   239	    //                      PAUSE/RESUME                              //
   240	    ////////////////////////////////////////////////////////////////////
   241	
   242	    function pause() public onlyOwner {
   243	        require(!paused, "CURRENTLY_PAUSED");
   244	        paused = true;
   245	    }
   246	
   247	    function resume() public onlyOwner {
   248	        require(paused, "CURRENTLY_RUNNING");
   249	        paused = false;
   250	    }
   251	}

