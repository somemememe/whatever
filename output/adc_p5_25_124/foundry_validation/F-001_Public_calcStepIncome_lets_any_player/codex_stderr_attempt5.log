   396	    function _selectJoinValue() internal view returns (uint256) {
   397	        uint256 rid = IMainPoolLike(TARGET).getRID();
   398	        (, uint256 totalDivBalance,,,) = IMainPoolLike(TARGET).getPoolInfo(rid);
   399	        uint256 withdrawBalance = IMainPoolLike(TARGET).mainPoolWithdrawBalance(rid);
   400	        uint256 safePool = totalDivBalance < withdrawBalance ? totalDivBalance : withdrawBalance;
   401	
   402	        if (safePool >= 60 ether) {
   403	            return HIGH_JOIN;
   404	        }
   405	        if (safePool >= 20 ether) {
   406	            return MID_JOIN;
   407	        }
   408	        return DIRECT_JOIN;
   409	    }
