        uint256 withdrawBalance = IMainPoolLike(TARGET).mainPoolWithdrawBalance(rid);
        uint256 safePool = totalDivBalance < withdrawBalance ? totalDivBalance : withdrawBalance;

        if (safePool >= 60 ether) {
