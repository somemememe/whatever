        if (safePool >= 20 ether) {
            return MID_JOIN;
        }
        return DIRECT_JOIN;
    }

    function _selectFlashAmount(uint256 desiredJoinValue) internal pure returns (uint256) {
        if (desiredJoinValue >= HIGH_JOIN) {
