   755	    function calcStepByList(uint256 stepNum_,uint256[] memory stepPlyerList,uint8 biggestNodeLevel,uint256 value_) internal{
   756	                uint8 dividendAccount  = nlIncome[biggestNodeLevel];
   757	                uint8 totalDiv;
   758	                uint8 curDiv;
   759	                uint8 plyNlevel;
   760	                uint256 steppid;
   761	                for(uint8 i=0;i<stepNum_;i++){
   762	                    steppid = stepPlyerList[i];
   763	                    
   764	                    plyNlevel = plyRShip[steppid].nodeLevel;
   765	                    if(totalDiv == 0){
   766	                        curDiv = nlIncome[plyNlevel];
   767	                    }else{
   768	                        if(dividendAccount >nlIncome[plyNlevel] - totalDiv){
   769	                            curDiv = nlIncome[plyNlevel] - totalDiv;
   770	                        }else{
   771	                            curDiv = dividendAccount;
   772	                        }
   773	                    } 
   774	                   
   775	                    calcStepIncome(steppid,value_,curDiv);
   776	                    
   777	                    totalDiv += curDiv;
   778	                    if(dividendAccount > curDiv){
   779	                        dividendAccount -=curDiv;
   780	                    }else{
   781	                        break;
   782	                    }
   783	                }
   784	            
   785	    }
