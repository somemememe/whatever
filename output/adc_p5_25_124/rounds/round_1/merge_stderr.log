   680	    function findParentByFor(uint256 plyID_,uint256 value_) internal{
   681	            
   682	            uint256 parentPID_ ;
   683	            uint256 pp = plyID_;
   684	            //uint8 dividendAccount = nlIncome[plyRShip[toppid].nodeLevel]; 
   685	            uint256 haveOneV6;
   686	            uint8 parnetNodeLevel;
   687	            uint8 biggestNodeLevel=0;
   688	            uint256[] memory stepPlyerList = new uint256[](120);
   689	            uint256 stepPlyNum;
   690	            
   691	            uint256 ambPid = 0 ;
   692	            
   693	            for(uint8 i=0;i<120;i++){
   694	                parentPID_ = plyRShip[pp].parentPID;
   695	                parnetNodeLevel = plyRShip[parentPID_].nodeLevel;
   696	                if(parentPID_ == 0){
   697	                    break;
   698	                }
   699	                
   700	                if(ambRewardMap[parentPID_] && ambPid == 0&&plyr[RID][parentPID_].isActive){
   701	                    ambPid = parentPID_;
   702	                }
   703	                //if(parentPID_ !=0){
   704	                    //set releaseship
   705	                    setRelationship(pp,parentPID_,value_);
   706	                
   707	                    //double v6
   708	                    if(parnetNodeLevel > 0){
   709	                        if(parnetNodeLevel == 6 && haveOneV6 >=1 && !isDoubleV6[parentPID_]){
   710	                            isDoubleV6[parentPID_] = true;
   711	                            totalV6Number +=1;
   712	                            doubleV6PID[totalV6Number] = parentPID_;
   713	                        }
   714	                        if(parnetNodeLevel == 6 && !isDoubleV6[parentPID_]){
   715	                            haveOneV6++;
   716	                        }
   717	                    
   718	                        //step income calc 
   719	                        if(plyr[RID][parentPID_].isActive){
   720	                            if(parnetNodeLevel > biggestNodeLevel){
   721	                                biggestNodeLevel = parnetNodeLevel;
   722	                                stepPlyerList[stepPlyNum] = parentPID_;
   723	                                stepPlyNum++;
   724	                            }
   725	                        }
   726	                    }
   727	                    //check level
   728	                    if((plyr[RID][parentPID_].ticketInCost >= 11*10**18 && plyRShip[parentPID_].sonNumber >= 5)){
   729	                        for (uint8 j = 1; j <= 6; j++) {
   730	                            if(plyRShip[parentPID_].totalRecmdAmount - plyRShip[parentPID_].sonTotalBalance[plyRShip[parentPID_].bigPotSonPID] > nlThdAmount[j]){
   731	                                plyRShip[parentPID_].nodeLevel = j;
   732	                            }
   733	                        }
   734	                    }
   735	                    
   736	                    pp = parentPID_;
   737	                
   738	                //}
   739	            }
   740	            
   741	            //calc step income
   742	            if(stepPlyNum >0){
