+
+        sDolaAmount = SDOLA.balanceOf(address(this));
+        SDOLA.redeem(sDolaAmount, address(this), address(this));
+        LLAMMA.exchange(0, 1, 0, 1);
+
+        // Path stage 5-7: compute inflated minimum collateral, mint the required sDOLA shares,
