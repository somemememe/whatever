+        if (!usedFlashLoan) {
+            usedFlashLoan = true;
+            MORPHO.flashLoan(address(WETH), WETH.balanceOf(address(MORPHO)), bytes(""));
+            USDC.approve(address(MORPHO), type(uint256).max);
