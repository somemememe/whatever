            tokenId = _nfts[index].tokenId;
            _store(userAddr, ptokenStaking, nftAsset, tokenId);
            amount = _nfts[index].amount;
            nftAmount += amount;
            
            emit StakeSingleNft(userAddr, nftAsset, tokenId, amount);
        }
        userInfo.stakeAmount[nftInfo.poolId] += nftAmount;

