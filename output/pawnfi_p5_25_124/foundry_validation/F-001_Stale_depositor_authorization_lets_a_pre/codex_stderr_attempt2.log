                });
            }
            
        }
        if(_nfts.length > 0 || _nftPairs.length > 0) {
            address userAddr = mainUserAddr != address(0) ? mainUserAddr : bakcUserAddr;
            _withdrawApeCoin(userAddr, pairVars.nftAsset, _nfts, _nftPairs, actionType);
        }
    }

