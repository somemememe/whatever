   475	    function _claimVerify(address userAddr, address ptokenStaking, address nftAsset, uint256 nftId) internal view returns (uint256 claimAmount) {
   476	        require(_validOwner(userAddr, ptokenStaking, nftAsset, nftId),"owner");
   477	        ( , , claimAmount) = getStakeInfo(_nftInfo[nftAsset].poolId, nftId);
   478	        require(claimAmount > 0,"claim");
   479	    }
