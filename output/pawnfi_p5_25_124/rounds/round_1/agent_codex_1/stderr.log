   170	    /**
   171	     * @notice Delete user deposit information
   172	     * @param userAddr User address
   173	     * @param nftAsset nft asset address
   174	     * @param nftId nft id
   175	     * @return iTokenAmount iToken amount
   176	     */
   177	    function _delUserDepositInfo(address userAddr, address nftAsset, uint256 nftId) internal returns (uint256 iTokenAmount){
   178	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   179	        iTokenAmount = nftInfo.iTokenAmount[nftId];
   180	        delete nftInfo.depositor[nftId];
   181	        delete nftInfo.iTokenAmount[nftId];
   182	
   183	        UserInfo storage userInfo = _userInfo[userAddr];
   184	        userInfo.depositIds[nftInfo.poolId].remove(nftId);
   185	        userInfo.iTokenAmount[nftInfo.poolId] -= iTokenAmount;
   186	    }
