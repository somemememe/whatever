   360	    /**
   361	     * @notice Verify NFT owner
   362	     * @param userAddr User address
   363	     * @param ptokenStaking Address of NFT staking agency
   364	     * @param nftAsset nft asset address
   365	     * @param nftId nft id
   366	     * @return bool true：Verification pass false：Verification fail
   367	     */
   368	    function _validOwner(address userAddr, address ptokenStaking, address nftAsset, uint256 nftId) internal view returns (bool) {
   369	        address holder = _nftInfo[nftAsset].depositor[nftId];
   370	        if(holder == address(0)) {
   371	            address nftOwner = IPTokenApeStaking(ptokenStaking).getNftOwner(nftId);
   372	            holder = INftGateway(nftOwner).nftOwner(userAddr, nftAsset, nftId);
   373	        }
   374	        return holder == userAddr;
   375	    }
