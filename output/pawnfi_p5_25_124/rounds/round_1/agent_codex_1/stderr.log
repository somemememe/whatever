   188	    /**
   189	     * @notice Withdraw NFT from lending market
   190	     * @param userAddr User address
   191	     * @param nftAsset nft asset address
   192	     * @param nftId nft id
   193	     */
   194	    function _withdrawNftFromLending(address userAddr, address nftAsset, uint256 nftId) internal {
   195	        uint256 iTokenAmount = _delUserDepositInfo(userAddr, nftAsset, nftId);
   196	        (address iTokenAddr, address pTokenAddr, uint256 pieceCount, , ) = INftGateway(nftGateway).marketInfo(nftAsset);
   197	
   198	        uint balanceBefore = IERC20Upgradeable(pTokenAddr).balanceOf(address(this));
   199	        ITokenLending(iTokenAddr).redeem(iTokenAmount);
   200	        uint balanceAfter = IERC20Upgradeable(pTokenAddr).balanceOf(address(this));
   201	        uint256 redeemAmount = balanceAfter - balanceBefore;
   202	        require(redeemAmount >= pieceCount,"less");
   203	
   204	        uint256[] memory tokenIds = new uint256[](1);
   205	        tokenIds[0] = nftId;
   206	        IPTokenApeStaking(pTokenAddr).withdraw(tokenIds);
   207	        IERC721Upgradeable(nftAsset).safeTransferFrom(address(this), userAddr, nftId);
   208	        uint256 remainingAmount = redeemAmount - pieceCount;
   209	        _transferAsset(pTokenAddr, userAddr, remainingAmount);
   210	        emit WithdrawNftFromStake(userAddr, nftAsset, nftId, redeemAmount, pieceCount);
   211	    }
