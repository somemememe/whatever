   598	    /**
   599	     * @notice Suspend staking for users with high health factor
   600	     * @param userAddr User address
   601	     * @param nftAssets Array of NFT address
   602	     * @param nftIds nft ids
   603	     */
   604	    function unstakeAndRepay(address userAddr, address[] calldata nftAssets, uint256[] calldata nftIds) external nonReentrant {
   605	        require(nftAssets.length == nftIds.length);
   606	        uint256 totalIncome;
   607	        uint256 totalPay;
   608	        (totalIncome, totalPay) = getUserHealth(userAddr);
   609	        require(totalIncome * BASE_PERCENTS < totalPay * stakingConfiguration.liquidateRate,"income");
   610	        for(uint256 i = 0; i < nftAssets.length; i++) {
   611	            require(userAddr == _nftInfo[nftAssets[i]].staker[nftIds[i]],"staker");
   612	            _onStopStake(nftAssets[i], nftIds[i], RewardAction.STOPSTAKE);
   613	            (totalIncome, totalPay) = getUserHealth(userAddr);
   614	            if(totalIncome * BASE_PERCENTS >= totalPay * stakingConfiguration.borrowSafeRate) {
   615	                _transferAsset(pawnToken, msg.sender, stakingConfiguration.liquidatePawnAmount);           
   616	                break;
   617	            }
   618	        }
   619	    }
   620	
   621	    /**
   622	     * @notice NFT can be withdrawn after withdrawing all staked ApeCoins
   623	     * @param baycTokenIds bayc nft ids
   624	     * @param maycTokenIds mayc nft ids
   625	     * @param bakcTokenIds bakc nft ids
   626	     */
   627	    function withdraw(
   628	        uint256[] calldata baycTokenIds,
   629	        uint256[] calldata maycTokenIds,
   630	        uint256[] calldata bakcTokenIds
   631	    ) external nonReentrant {
   632	        address userAddr = msg.sender;
   633	        for(uint256 i = 0; i < baycTokenIds.length; i++) {
   634	            _withdraw(userAddr, BAYC_ADDR, baycTokenIds[i], false);
   635	        }
   636	        for(uint256 i = 0; i < maycTokenIds.length; i++) {
   637	            _withdraw(userAddr, MAYC_ADDR, maycTokenIds[i], false);
   638	        }      
   639	        for(uint256 i = 0; i < bakcTokenIds.length; i++) {
   640	            _withdraw(userAddr, BAKC_ADDR, bakcTokenIds[i], true);
   641	        }
   642	    }
   643	
   644	    /**
   645	     * @notice Withdraw single staked NFT
   646	     * @param userAddr User address
   647	     * @param nftAsset nft asset address
   648	     * @param nftId nft id
   649	     * @param paired Whether to pair
   650	     */
   651	    function _withdraw(address userAddr, address nftAsset, uint256 nftId, bool paired) internal {
   652	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   653	        require(userAddr == nftInfo.depositor[nftId],"depositor");
   654	        require(nftInfo.staker[nftId] == address(0),"staker");
   655	
   656	        if(!paired) {
   657	            (uint256 tokenId,bool isPaired) = IApeCoinStaking(apeCoinStaking).mainToBakc(nftInfo.poolId, nftId);
   658	            if(isPaired){
   659	                require(_nftInfo[BAKC_ADDR].staker[tokenId] == address(0),"pair");
   660	            }
   661	        }
   662	        _withdrawNftFromLending(userAddr, nftAsset, nftId);
   663	    }
   664	
   665	    /**
   666	     * @notice Suspend staking due to third-party reasons
   667	     * @param caller Caller
   668	     * @param nftAsset nft asset address
   669	     * @param nftIds nft ids
   670	     * @param actionType Event type
   671	     */
   672	    function onStopStake(address caller, address nftAsset, uint256[] calldata nftIds, RewardAction actionType) external{
   673	        require(msg.sender == pbaycAddr || msg.sender == pmaycAddr || msg.sender == pbakcAddr);
   674	        if(caller != address(this)) {
   675	            for(uint i = 0; i < nftIds.length; i++) {
   676	                _onStopStake(nftAsset, nftIds[i], actionType);
   677	            }
   678	        }
   679	    }
   680	
   681	    struct PairVars {
   682	        address nftAsset;
   683	        bool isPaired;
   684	        uint256 mainTokenId;
   685	        uint256 bakcTokenId;
   686	    }
   687	
   688	    /**
   689	     * @notice Suspend staking due to third-party reasons
   690	     * @param nftAsset nft asset address
   691	     * @param nftId nft id
   692	     * @param actionType Event type
   693	     */
   694	    function _onStopStake(address nftAsset, uint256 nftId, RewardAction actionType) private {
   695	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   696	        IApeCoinStaking.SingleNft[] memory _nfts;
   697	        PairVars memory pairVars;
   698	
   699	        address userAddr = nftInfo.staker[nftId];
   700	        if(nftAsset == BAYC_ADDR || nftAsset == MAYC_ADDR) {
   701	            pairVars.nftAsset = nftAsset;
   702	            pairVars.mainTokenId = nftId;
   703	            ( , uint256 stakingAmount, ) = getStakeInfo(nftInfo.poolId, nftId);
   704	            (pairVars.bakcTokenId, pairVars.isPaired) = IApeCoinStaking(apeCoinStaking).mainToBakc(nftInfo.poolId, nftId);
   705	            
   706	            if(stakingAmount > 0 && userAddr != address(0)) {
   707	                _nfts = new IApeCoinStaking.SingleNft[](1);
   708	                _nfts[0] = IApeCoinStaking.SingleNft({
   709	                    tokenId: uint32(nftId),
   710	                    amount: uint224(stakingAmount)
   711	                });
   712	            }
   713	        } else if(nftAsset == BAKC_ADDR) {
   714	            pairVars.nftAsset = BAYC_ADDR;
   715	            pairVars.bakcTokenId = nftId;
   716	            (pairVars.mainTokenId, pairVars.isPaired) = IApeCoinStaking(apeCoinStaking).bakcToMain(nftId, _nftInfo[pairVars.nftAsset].poolId);
   717	            if(!pairVars.isPaired) {
   718	                pairVars.nftAsset = MAYC_ADDR;
   719	                (pairVars.mainTokenId, pairVars.isPaired) = IApeCoinStaking(apeCoinStaking).bakcToMain(nftId, _nftInfo[pairVars.nftAsset].poolId);
   720	            }
   721	        }
   722	        
   723	        _onStopStakePairNft(userAddr, pairVars, _nfts, actionType);
   724	    }
   725	
   726	    function _onStopStakePairNft(address mainUserAddr, PairVars memory pairVars, IApeCoinStaking.SingleNft[] memory _nfts, RewardAction actionType) internal {
   727	        IApeCoinStaking.PairNftWithdrawWithAmount[] memory _nftPairs;
   728	        address bakcUserAddr = _nftInfo[BAKC_ADDR].staker[pairVars.bakcTokenId];
   729	        if(pairVars.isPaired) {
   730	            ( , uint256 stakingAmount, ) = getStakeInfo(_nftInfo[BAKC_ADDR].poolId, pairVars.bakcTokenId);
   731	            if(stakingAmount > 0 && bakcUserAddr != address(0)) {
   732	                _nftPairs = new IApeCoinStaking.PairNftWithdrawWithAmount[](1);
   733	                _nftPairs[0] = IApeCoinStaking.PairNftWithdrawWithAmount({
   734	                    mainTokenId: uint32(pairVars.mainTokenId),
   735	                    bakcTokenId: uint32(pairVars.bakcTokenId),
   736	                    amount: uint184(stakingAmount),
   737	                    isUncommit: true
   738	                });
   739	            }
   740	            
   741	        }
   742	        if(_nfts.length > 0 || _nftPairs.length > 0) {
   743	            address userAddr = mainUserAddr != address(0) ? mainUserAddr : bakcUserAddr;
   744	            _withdrawApeCoin(userAddr, pairVars.nftAsset, _nfts, _nftPairs, actionType);
   745	        }
   746	    }
   747	
   748	    /**
   749	     * @notice Set collect rate
   750	     * @param newCollectRate Collect rate
   751	     */
   752	    function setCollectRate(uint256 newCollectRate) external {
   753	        require(newCollectRate <= BASE_PERCENTS);
   754	        _userInfo[msg.sender].collectRate = newCollectRate;
   755	        emit SetCollectRate(msg.sender, newCollectRate);
   756	    }
   757	
   758	    /**
   759	     * @notice Set fee address
   760	     * @param newFeeTo Fee address
