   260	    function _storeUserInfo(
   261	        address userAddr,
   262	        address nftAsset,
   263	        IApeCoinStaking.SingleNft[] memory _nfts,
   264	        IApeCoinStaking.PairNftDepositWithAmount[] memory _nftPairs
   265	    ) internal returns (uint256, uint256) {
   266	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   267	        UserInfo storage userInfo = _userInfo[userAddr];
   268	
   269	        address ptokenStaking = _getPTokenStaking(nftAsset);
   270	
   271	        uint256 amount;
   272	        uint256 tokenId;
   273	
   274	        uint256 nftAmount = 0;
   275	        for (uint256 index = 0; index < _nfts.length; index++) {
   276	            tokenId = _nfts[index].tokenId;
   277	            _store(userAddr, ptokenStaking, nftAsset, tokenId);
   278	            amount = _nfts[index].amount;
   279	            nftAmount += amount;
   280	            
   281	            emit StakeSingleNft(userAddr, nftAsset, tokenId, amount);
   282	        }
   283	        userInfo.stakeAmount[nftInfo.poolId] += nftAmount;
   284	
   285	        uint256 nftPairAmount = 0;
   286	        for (uint256 index = 0; index < _nftPairs.length; index++) {
   287	            tokenId = _nftPairs[index].bakcTokenId;
   288	            require(_validOwner(userAddr, ptokenStaking, nftAsset, _nftPairs[index].mainTokenId),"main");
   289	            _store(userAddr, pbakcAddr, BAKC_ADDR, tokenId);
   290	            amount =_nftPairs[index].amount;
   291	            nftPairAmount += amount;
   292	            emit StakePairNft(userAddr, nftAsset, _nftPairs[index].mainTokenId, tokenId, amount);
   293	        }
   294	        userInfo.stakeAmount[_nftInfo[BAKC_ADDR].poolId] += nftPairAmount;
   295	        return (nftAmount, nftPairAmount);
   296	    }
