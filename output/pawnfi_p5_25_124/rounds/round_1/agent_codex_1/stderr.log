   481	    function _claimApeCoin(
   482	        address userAddr,
   483	        address nftAsset,
   484	        uint256[] calldata nftIds,
   485	        IApeCoinStaking.PairNft[] calldata _nftPairs,
   486	        RewardAction actionType
   487	    ) internal {
   488	        address ptokenStaking = _getPTokenStaking(nftAsset);
   489	        uint256 totalClaimAmount = 0;
   490	
   491	        uint256 claimAmount;
   492	        uint256 tokenId;
   493	        // 1, check nfts owner
   494	        for (uint256 index = 0; index < nftIds.length; index++) {
   495	            tokenId = nftIds[index];
   496	            claimAmount = _claimVerify(userAddr, ptokenStaking, nftAsset, tokenId);
   497	            totalClaimAmount += claimAmount;
   498	            emit ClaimSingleNft(userAddr, nftAsset, tokenId, claimAmount);
   499	        }
   500	
   501	        for (uint256 index = 0; index < _nftPairs.length; index++) {
   502	            require(_validOwner(userAddr, ptokenStaking, nftAsset, _nftPairs[index].mainTokenId),"main");
   503	            tokenId = _nftPairs[index].bakcTokenId;
   504	            claimAmount = _claimVerify(userAddr, pbakcAddr, BAKC_ADDR, tokenId);
   505	            totalClaimAmount += claimAmount;
   506	            emit ClaimPairNft(userAddr, nftAsset, _nftPairs[index].mainTokenId, tokenId, claimAmount);
   507	        }
   508	
   509	        // 2, claim rewards
   510	        if(nftIds.length > 0) {
   511	            IPTokenApeStaking(ptokenStaking).claimApeCoin(nftIds, address(this));
   512	        }
   513	        if(_nftPairs.length > 0) {
   514	            IPTokenApeStaking(ptokenStaking).claimBAKC(_nftPairs, address(this));
   515	        }
   516	
   517	        // 3, repay if borrowed and mint and claim
   518	        _repayAndClaim(userAddr, 0, totalClaimAmount, actionType);
   519	    }
