   578	    /**
   579	     * @notice Reward reinvestment
   580	     * @param userAddr User address
   581	     * @param baycNfts bayc nft ids
   582	     * @param maycNfts mayc nft ids
   583	     * @param baycPairNfts List of bayc-bakc pair
   584	     * @param maycPairNfts List of mayc-bakc pair
   585	     */
   586	    function claimAndRestake(
   587	        address userAddr,
   588	        uint256[] calldata baycNfts,
   589	        uint256[] calldata maycNfts,
   590	        IApeCoinStaking.PairNft[] calldata baycPairNfts,
   591	        IApeCoinStaking.PairNft[] calldata maycPairNfts
   592	    ) external nonReentrant {
   593	        require(msg.sender == userAddr || hasRole(REINVEST_ROLE, msg.sender));
   594	        _claimApeCoin(userAddr, BAYC_ADDR, baycNfts, baycPairNfts, RewardAction.RESTAKE);
   595	        _claimApeCoin(userAddr, MAYC_ADDR, maycNfts, maycPairNfts, RewardAction.RESTAKE);
