   213	    function _approveMax(address tokenAddr, address spender, uint256 amount) internal {
   214	        IERC20Upgradeable token = IERC20Upgradeable(tokenAddr);
   215	        uint256 allowance = token.allowance(address(this), spender);
   216	        if(allowance < amount) {
   217	            token.safeApprove(spender, 0);
   218	            token.safeApprove(spender, type(uint256).max);
   219	        }
   220	    }
   221	
   222	    /**
   223	     * @notice Supply NFT to lending market
   224	     * @param userAddr User address
   225	     * @param nftAsset nft asset address
   226	     * @param nftIds nft ids
   227	     */
   228	    function _depositNftToLending(address userAddr, address nftAsset, uint256[] memory nftIds) internal {
   229	        uint length = nftIds.length;
   230	        if(length > 0) {
   231	            NftInfo storage nftInfo = _nftInfo[nftAsset];
   232	            UserInfo storage userInfo = _userInfo[userAddr];
   233	
   234	            (address iTokenAddr, address pTokenAddr, , , ) = INftGateway(nftGateway).marketInfo(nftAsset);
   235	            for(uint256 i = 0; i < length; i++) {
   236	                uint256 nftId = nftIds[i];
   237	                IERC721Upgradeable(nftAsset).safeTransferFrom(userAddr, address(this), nftId);
   238	                userInfo.depositIds[nftInfo.poolId].add(nftId);
   239	                nftInfo.depositor[nftId] = userAddr;
   240	            }
   241	            
   242	            uint256 tokenAmount = IPTokenApeStaking(pTokenAddr).deposit(nftIds, type(uint256).max);
   243	            _approveMax(pTokenAddr, iTokenAddr, tokenAmount);
   244	
   245	            uint256 iTokenBalanceBefore = IERC20Upgradeable(iTokenAddr).balanceOf(address(this));
   246	            ITokenLending(iTokenAddr).mint(tokenAmount);
   247	            uint256 iTokenBalanceAfter = IERC20Upgradeable(iTokenAddr).balanceOf(address(this));
   248	
   249	            uint256 amount = iTokenBalanceAfter - iTokenBalanceBefore;
   250	            uint256 singleQuantity = amount / length;
   251	            for(uint i = 0; i < length; i++) {
   252	                nftInfo.iTokenAmount[nftIds[i]] = singleQuantity;
   253	            }
   254	            userInfo.iTokenAmount[nftInfo.poolId] += amount;
   255	
   256	            emit DepositNftToStake(userAddr, nftAsset, nftIds, amount, tokenAmount);
   257	        }
   258	    }
