   151	        for(uint256 poolId = BAYC_POOL_ID; poolId <= BAKC_POOL_ID; poolId++) {
   152	            uint256 poolStakingRatePerBlock = getRewardRatePerBlock(poolId, 0);
   153	            totalIncome += userInfo.stakeAmount[poolId] * poolStakingRatePerBlock / BASE_PERCENTS;
   154	        }
   155	        uint256 borrowRate = IApePool(apePool).borrowRatePerBlock();
   156	        uint256 borrowedAmount = IApePool(apePool).borrowBalanceCurrent(userAddr);
   157	        totalPay = borrowedAmount * borrowRate / BASE_PERCENTS;
   158	    }
