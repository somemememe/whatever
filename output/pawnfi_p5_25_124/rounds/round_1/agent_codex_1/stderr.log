   298	    function _store(address userAddr, address ptokenStaking, address nftAsset, uint256 nftId) internal {
   299	        require(_validOwner(userAddr, ptokenStaking, nftAsset, nftId),"owner");
   300	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   301	        
   302	        if(nftInfo.staker[nftId] == address(0)) {
   303	            nftInfo.staker[nftId] = userAddr;
   304	            nftInfo.stakeIds.add(nftId);
   305	
   306	            UserInfo storage userInfo = _userInfo[userAddr];
   307	            userInfo.stakeIds[nftInfo.poolId].add(nftId);
   308	
   309	            (uint256 stakingAmount, ) = IApeCoinStaking(apeCoinStaking).nftPosition(nftInfo.poolId, nftId);
   310	            userInfo.stakeAmount[nftInfo.poolId] += stakingAmount;
   311	        }
   312	    }
