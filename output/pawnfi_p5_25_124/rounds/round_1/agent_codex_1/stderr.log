   386	    /**
   387	     * @notice Verify NFT staker
   388	     * @param userAddr User address
   389	     * @param ptokenStaking Address of NFT staking agency
   390	     * @param nftAsset nft asset address
   391	     * @param nftId nft id
   392	     * @param actionType Event type
   393	     * @return RewardAction Event type
   394	     */
   395	    function _validStaker(address userAddr, address ptokenStaking, address nftAsset, uint256 nftId, RewardAction actionType) internal view returns (RewardAction) {
   396	        address staker = _nftInfo[nftAsset].staker[nftId];
   397	        require(staker == userAddr,"staker");
   398	        if(!_validOwner(userAddr, ptokenStaking, nftAsset, nftId) && actionType == RewardAction.WITHDRAW){
   399	            return RewardAction.REDEEM;
   400	        }
   401	        return actionType;
   402	    }
