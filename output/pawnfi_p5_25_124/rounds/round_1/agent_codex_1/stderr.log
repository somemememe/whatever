   160	    /**
   161	     * @notice Get agency address of NFT staking
   162	     * @param nftAsset nft asset address
   163	     * @return address Agency address of staking
   164	     */
   165	    function _getPTokenStaking(address nftAsset) internal view returns (address) {
   166	        require(nftAsset == BAYC_ADDR || nftAsset == MAYC_ADDR);
   167	        return nftAsset == BAYC_ADDR ? pbaycAddr : pmaycAddr;
   168	    }
