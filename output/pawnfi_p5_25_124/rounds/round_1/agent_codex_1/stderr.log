   425	    function _withdrawApeCoin(
   426	        address userAddr,
   427	        address nftAsset,
   428	        IApeCoinStaking.SingleNft[] memory _nfts,
   429	        IApeCoinStaking.PairNftWithdrawWithAmount[] memory _nftPairs,
   430	        RewardAction actionType
   431	    ) internal {
   432	        address ptokenStaking = _getPTokenStaking(nftAsset);
   433	        uint256 totalWithdrawAmount = 0;
   434	        uint256 totalClaimAmount = 0;
   435	
   436	
   437	        // 1, check nfts owner
   438	        for (uint256 index = 0; index < _nfts.length; index++) {
   439	            actionType = _validStaker(userAddr, ptokenStaking, nftAsset, _nfts[index].tokenId, actionType);
   440	            (uint256 withdrawAmount, uint256 claimAmount) = _removeUserInfo(nftAsset, _nfts[index].tokenId, _nfts[index].amount, false);
   441	            totalWithdrawAmount += withdrawAmount;
   442	            totalClaimAmount += claimAmount;
   443	            emit UnstakeSingleNft(userAddr, nftAsset, _nfts[index].tokenId, _nfts[index].amount, claimAmount);
   444	        }
   445	
   446	        for (uint256 index = 0; index < _nftPairs.length; index++) {
   447	            actionType = _validStaker(userAddr, pbakcAddr, BAKC_ADDR, _nftPairs[index].bakcTokenId, actionType);
   448	            (uint256 withdrawAmount, uint256 claimAmount) = _removeUserInfo(BAKC_ADDR, _nftPairs[index].bakcTokenId, _nftPairs[index].amount, _nftPairs[index].isUncommit);
   449	            totalWithdrawAmount += withdrawAmount;
   450	            totalClaimAmount += claimAmount;
   451	            emit UnstakePairNft(userAddr, nftAsset, _nftPairs[index].mainTokenId, _nftPairs[index].bakcTokenId, _nftPairs[index].amount, claimAmount);
   452	        }
   453	
   454	        // 2, claim rewards
   455	        if(_nfts.length > 0) {
   456	            IPTokenApeStaking(ptokenStaking).withdrawApeCoin(_nfts, address(this));
   457	        }
   458	        if(_nftPairs.length > 0) {
   459	            IPTokenApeStaking(ptokenStaking).withdrawBAKC(_nftPairs, address(this));
   460	        }
   461	
   462	        // 3, repay if borrowed and mint and claim
   463	        _repayAndClaim(userAddr, totalWithdrawAmount, totalClaimAmount, actionType);
   464	    }
