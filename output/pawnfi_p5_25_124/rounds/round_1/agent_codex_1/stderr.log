   521	    /**
   522	     * @notice Repay and reinvest
   523	     * @param userAddr User address
   524	     * @param allAmount Deposit amount
   525	     * @param allClaimAmount Reward amount
   526	     * @param actionType Event type
   527	     */
   528	    function _repayAndClaim(address userAddr, uint256 allAmount, uint256 allClaimAmount, RewardAction actionType) internal {
   529	        uint256 fee = allClaimAmount * stakingConfiguration.feeRate / BASE_PERCENTS;
   530	        allClaimAmount -= fee;
   531	        _transferAsset(apeCoin, feeTo, fee);
   532	
   533	        uint256 totalAmount = allAmount + allClaimAmount;
   534	        _approveMax(address(apeCoin), apePool, totalAmount);
   535	
   536	        // 1, repay if borrowed
   537	        uint256 repayed = IApePool(apePool).borrowBalanceCurrent(userAddr);
   538	
   539	        if(repayed > 0) {
   540	            if(allAmount < repayed) {
   541	                repayed -= allAmount;
   542	                allAmount = 0;
   543	                if(allClaimAmount < repayed) {
   544	                    allClaimAmount = 0;
   545	                } else {
   546	                    allClaimAmount -= repayed;
   547	                }
   548	            } else {
   549	                allAmount -= repayed;
   550	            }
   551	            IApePool(apePool).repayBorrowBehalf(userAddr, totalAmount - (allAmount + allClaimAmount));
   552	        }
   553	
   554	        totalAmount = allAmount + allClaimAmount;
   555	        if(totalAmount > 0) {
   556	            if(actionType == RewardAction.REDEEM || actionType == RewardAction.ONREDEEM) {//only return staking amount
   557	                // transfer left Ape to user
   558	                _transferAsset(apeCoin, userAddr, allAmount);
   559	                // transfer left claim Ape to feeTo
   560	                _transferAsset(apeCoin, feeTo, allClaimAmount);
   561	            } else {
   562	                uint256 claimAmount = totalAmount * _userInfo[userAddr].collectRate / BASE_PERCENTS;
   563	                _transferAsset(apeCoin, userAddr, claimAmount);
   564	                if(totalAmount > claimAmount) {
   565	                    uint256 mintAmount = totalAmount - claimAmount;
   566	                    IApePool(apePool).mintBehalf(userAddr, mintAmount);
   567	                }            
   568	            }
   569	        }
   570	    }
   571	
   572	    function _transferAsset(address token, address to, uint256 amount) internal {
   573	        if(amount > 0) {
   574	            IERC20Upgradeable(token).safeTransfer(to, amount);
   575	        }
   576	    }
