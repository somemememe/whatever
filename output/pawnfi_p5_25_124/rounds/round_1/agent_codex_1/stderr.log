   404	    function _removeUserInfo(address nftAsset, uint256 nftId, uint withdrawAmount, bool maximum) internal returns (uint256, uint256) {
   405	        NftInfo storage nftInfo = _nftInfo[nftAsset];
   406	        uint256 poolId = nftInfo.poolId;
   407	        ( , uint256 stakingAmount, uint256 claimAmount) = getStakeInfo(poolId, nftId);
   408	        withdrawAmount = maximum ? stakingAmount : withdrawAmount;
   409	        require(stakingAmount >= withdrawAmount,"more");
   410	
   411	        UserInfo storage userInfo = _userInfo[nftInfo.staker[nftId]];
   412	        if(withdrawAmount == stakingAmount) {
   413	            
   414	            delete nftInfo.staker[nftId];
   415	            nftInfo.stakeIds.remove(nftId);
   416	            userInfo.stakeIds[poolId].remove(nftId);
   417	            
   418	        } else {
   419	            claimAmount = 0;
   420	        }
   421	        userInfo.stakeAmount[poolId] -= withdrawAmount;
   422	        return (withdrawAmount, claimAmount);
   423	    }
