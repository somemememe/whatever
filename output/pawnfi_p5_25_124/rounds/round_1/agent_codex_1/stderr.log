   314	    /**
   315	     * @notice Supply and stake NFT
   316	     * @param depositInfo NFT supplying info
   317	     * @param stakingInfo NFT staking info
   318	     * @param _nfts List of single NFT staking
   319	     * @param _nftPairs List of paired NFT staking
   320	     */
   321	    function depositAndBorrowApeAndStake(
   322	        DepositInfo memory depositInfo,
   323	        StakingInfo memory stakingInfo,
   324	        IApeCoinStaking.SingleNft[] calldata _nfts,
   325	        IApeCoinStaking.PairNftDepositWithAmount[] calldata _nftPairs
   326	    ) external nonReentrant {
   327	        address userAddr = msg.sender;
   328	        address ptokenStaking = _getPTokenStaking(stakingInfo.nftAsset);
   329	
   330	        // 1, handle borrow part and send ape to ptokenAddress
   331	        if(stakingInfo.borrowAmount > 0) {
   332	            uint256 borrowRate = IApePool(apePool).borrowRatePerBlock();
   333	            uint256 stakingRate = getRewardRatePerBlock(_nftInfo[stakingInfo.nftAsset].poolId, stakingInfo.borrowAmount);
   334	            require(borrowRate + stakingConfiguration.addMinStakingRate < stakingRate,"rate");
   335	            IApePool(apePool).borrowBehalf(userAddr, stakingInfo.borrowAmount);
   336	            IERC20Upgradeable(apeCoin).safeTransfer(ptokenStaking, stakingInfo.borrowAmount);
   337	        }
   338	
   339	        // 2, send cash part to ptokenAddress
   340	        if(stakingInfo.cashAmount > 0) {
   341	            IERC20Upgradeable(apeCoin).safeTransferFrom(userAddr, ptokenStaking, stakingInfo.cashAmount);
   342	        }
   343	
   344	        _depositNftToLending(userAddr, stakingInfo.nftAsset, depositInfo.mainTokenIds);
   345	        _depositNftToLending(userAddr, BAKC_ADDR, depositInfo.bakcTokenIds);
   346	
   347	        (uint256 nftAmount, uint256 nftPairAmount) = _storeUserInfo(userAddr, stakingInfo.nftAsset, _nfts, _nftPairs);
   348	
   349	        // 3, deposit bayc or mayc pool
   350	        if(_nfts.length > 0) {
   351	            IPTokenApeStaking(ptokenStaking).depositApeCoin(nftAmount, _nfts);
   352	        }
   353	
   354	        // 4, deposit bakc pool
   355	        if(_nftPairs.length > 0) {
   356	            IPTokenApeStaking(ptokenStaking).depositBAKC(nftPairAmount, _nftPairs);
   357	        }
   358	    }
