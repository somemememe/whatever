   457	        }
   458	        if(_nftPairs.length > 0) {
   459	            IPTokenApeStaking(ptokenStaking).withdrawBAKC(_nftPairs, address(this));
   460	        }
   461	
   462	        // 3, repay if borrowed and mint and claim
   463	        _repayAndClaim(userAddr, totalWithdrawAmount, totalClaimAmount, actionType);
   464	    }
   465	
   466	    /**
   467	     * @notice Claiming staking rewards for a single NFT
   468	     * @param nftAsset nft asset address
   469	     * @param _nfts Array of NFTs staked
   470	     */
   471	    function claimApeCoin(address nftAsset, uint256[] calldata _nfts, IApeCoinStaking.PairNft[] calldata _nftPairs) external nonReentrant {
   472	        _claimApeCoin(msg.sender, nftAsset, _nfts, _nftPairs, RewardAction.CLAIM);
   473	    }
   474	
   475	    function _claimVerify(address userAddr, address ptokenStaking, address nftAsset, uint256 nftId) internal view returns (uint256 claimAmount) {
   476	        require(_validOwner(userAddr, ptokenStaking, nftAsset, nftId),"owner");
   477	        ( , , claimAmount) = getStakeInfo(_nftInfo[nftAsset].poolId, nftId);
   478	        require(claimAmount > 0,"claim");
