   436	
   437	        // 1, check nfts owner
   438	        for (uint256 index = 0; index < _nfts.length; index++) {
   439	            actionType = _validStaker(userAddr, ptokenStaking, nftAsset, _nfts[index].tokenId, actionType);
   440	            (uint256 withdrawAmount, uint256 claimAmount) = _removeUserInfo(nftAsset, _nfts[index].tokenId, _nfts[index].amount, false);
