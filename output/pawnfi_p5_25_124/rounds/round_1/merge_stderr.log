   245	            uint256 iTokenBalanceBefore = IERC20Upgradeable(iTokenAddr).balanceOf(address(this));
   246	            ITokenLending(iTokenAddr).mint(tokenAmount);
   247	            uint256 iTokenBalanceAfter = IERC20Upgradeable(iTokenAddr).balanceOf(address(this));
   248	
   249	            uint256 amount = iTokenBalanceAfter - iTokenBalanceBefore;
   250	            uint256 singleQuantity = amount / length;
   251	            for(uint i = 0; i < length; i++) {
   252	                nftInfo.iTokenAmount[nftIds[i]] = singleQuantity;
   253	            }
   254	            userInfo.iTokenAmount[nftInfo.poolId] += amount;
   255	
