   228	    function _depositNftToLending(address userAddr, address nftAsset, uint256[] memory nftIds) internal {
   229	        uint length = nftIds.length;
   230	        if(length > 0) {
   231	            NftInfo storage nftInfo = _nftInfo[nftAsset];
   232	            UserInfo storage userInfo = _userInfo[userAddr];
   233	
   234	            (address iTokenAddr, address pTokenAddr, , , ) = INftGateway(nftGateway).marketInfo(nftAsset);
   235	            for(uint256 i = 0; i < length; i++) {
   236	                uint256 nftId = nftIds[i];
   237	                IERC721Upgradeable(nftAsset).safeTransferFrom(userAddr, address(this), nftId);
   238	                userInfo.depositIds[nftInfo.poolId].add(nftId);
   239	                nftInfo.depositor[nftId] = userAddr;
   240	            }
   241	            
