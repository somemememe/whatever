+    bool public targetCodePresent;
+
+    bool public localOwnerZero;
+    bool public localFactorZero;
+    bool public localPresaleAddressZero;
+    bool public localPresaleDoneFalse;
+    bool public localBalanceOfReverted;
+    bool public localUnlockedBalanceOfReverted;
+    bool public localPauseContractReverted;
+    bool public localMintReverted;
+
+    bool public targetOwnerZero;
+    bool public targetFactorZero;
+    bool public targetPresaleAddressZero;
+    bool public targetPresaleDoneFalse;
+    bool public targetBalanceOfReverted;
+    bool public targetUnlockedBalanceOfReverted;
+    bool public targetPauseContractReverted;
+    bool public targetMintReverted;
+
+    constructor() public {}
+
+    function executeOnOpportunity() external {
+        if (executed) {
+            return;
+        }
+        executed = true;
+
+        // Path stage 1: deploy XStable2 from the reviewed source pattern.
+        XStable2 deployed = new XStable2();
+        deployedInstance = address(deployed);
+        _probeInstance(
+            deployedInstance,
+            true
+        );
+
+        // Optional confirmation against the provided mainnet target at the fork block.
+        targetCodePresent = _hasCode(TARGET);
+        if (targetCodePresent) {
+            _probeInstance(
+                TARGET,
+                false
+            );
+        }
+
+        // This flaw is a permanent brick, not an extractable-value path:
+        // owner-only recovery is unreachable, presale minting is unreachable,
+        // and balance queries revert because factor == 0. No realistic public
+        // path yields positive net profit in an existing on-chain asset.
+        _profitTokenAddr = address(0);
+        _profitAmountValue = 0;
+    }
+
+    function profitToken() external view returns (address) {
+        return _profitTokenAddr;
+    }
+
+    function profitAmount() external view returns (uint256) {
+        return _profitAmountValue;
+    }
+
+    function exploitPath() external pure returns (string memory) {
+        return "deploy XStable2 -> balanceOf/unlockedBalanceOf revert via factor=0 -> pauseContract onlyOwner unreachable -> mint onlyPresale unreachable";
+    }
+
+    function hypothesisValidated() external view returns (bool) {
+        return localOwnerZero
+            && localFactorZero
+            && localPresaleAddressZero
+            && localPresaleDoneFalse
+            && localBalanceOfReverted
+            && localUnlockedBalanceOfReverted
+            && localPauseContractReverted
+            && localMintReverted;
+    }
+
+    function targetHypothesisValidated() external view returns (bool) {
+        if (!targetCodePresent) {
+            return false;
+        }
+        return targetOwnerZero
+            && targetFactorZero
+            && targetPresaleAddressZero
+            && targetPresaleDoneFalse
+            && targetBalanceOfReverted
+            && targetUnlockedBalanceOfReverted
+            && targetPauseContractReverted
+            && targetMintReverted;
+    }
+
+    function _probeInstance(address instance, bool local) internal {
+        (bool okOwner, bytes memory ownerData) = instance.staticcall(abi.encodeWithSignature("owner()"));
+        (bool okFactor, bytes memory factorData) = instance.staticcall(abi.encodeWithSignature("getFactor()"));
+        (bool okPresale, bytes memory presaleData) = instance.staticcall(abi.encodeWithSignature("getPresaleAddress()"));
+        (bool okDone, bytes memory doneData) = instance.staticcall(abi.encodeWithSignature("isPresaleDone()"));
+        (bool okBalance, ) = instance.staticcall(abi.encodeWithSignature("balanceOf(address)", address(this)));
+        (bool okUnlocked, ) = instance.staticcall(abi.encodeWithSignature("unlockedBalanceOf(address)", address(this)));
+        (bool okPause, ) = instance.call(abi.encodeWithSignature("pauseContract(bool)", true));
+        (bool okMint, ) = instance.call(abi.encodeWithSignature("mint(address,uint256)", address(this), 1));
+
+        bool ownerZero = okOwner && ownerData.length >= 32 && abi.decode(ownerData, (address)) == address(0);
+        bool factorZero = okFactor && factorData.length >= 32 && abi.decode(factorData, (uint256)) == 0;
+        bool presaleAddressZero = okPresale && presaleData.length >= 32 && abi.decode(presaleData, (address)) == address(0);
+        bool presaleDoneFalse = okDone && doneData.length >= 32 && abi.decode(doneData, (bool)) == false;
+
+        if (local) {
+            localOwnerZero = ownerZero;
+            localFactorZero = factorZero;
+            localPresaleAddressZero = presaleAddressZero;
+            localPresaleDoneFalse = presaleDoneFalse;
+            localBalanceOfReverted = !okBalance;
+            localUnlockedBalanceOfReverted = !okUnlocked;
+            localPauseContractReverted = !okPause;
+            localMintReverted = !okMint;
+            return;
+        }
+
+        targetOwnerZero = ownerZero;
+        targetFactorZero = factorZero;
+        targetPresaleAddressZero = presaleAddressZero;
+        targetPresaleDoneFalse = presaleDoneFalse;
+        targetBalanceOfReverted = !okBalance;
+        targetUnlockedBalanceOfReverted = !okUnlocked;
+        targetPauseContractReverted = !okPause;
+        targetMintReverted = !okMint;
+    }
+
+    function _hasCode(address account) internal view returns (bool) {
+        uint256 size;
+        assembly {
+            size := extcodesize(account)
+        }
+        return size > 0;
+    }
+}

