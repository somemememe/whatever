+        uint256 dust = reserve / 1e12;
+        if (dust == 0) {
+            dust = 1;
+        }
+        if (dust > bal) {
+            dust = bal;
+        }
+        if (dust >= reserve) {
+            dust = reserve - 1;
+        }
+        return dust;
+    }
+
+    function _selectProfitToken(address token0, address token1) internal {
+        if (_isPreferredProfitToken(token0)) {
