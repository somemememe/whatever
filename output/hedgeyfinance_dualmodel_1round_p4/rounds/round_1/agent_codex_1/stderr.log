   260	  /// @dev the internal verify function from the open zepellin library.
   261	  /// this function inputs the root, proof, wallet address of the claimer, and amount of tokens, and then computes the validity of the leaf with the proof and root.
   262	  /// @param root is the root of the merkle tree
   263	  /// @param proof is the proof for the specific leaf
   264	  /// @param claimer is the address of the claimer used in making the leaf
   265	  /// @param amount is the amount of tokens to be claimed, the other piece of data in the leaf
   266	  function verify(bytes32 root, bytes32[] memory proof, address claimer, uint256 amount) public pure returns (bool) {
   267	    bytes32 leaf = keccak256(bytes.concat(keccak256(abi.encode(claimer, amount))));
   268	    require(MerkleProof.verify(proof, root, leaf), 'Invalid proof');
   269	    return true;
   270	  }
   271	}

