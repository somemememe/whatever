   249	  /// @notice this function allows the campaign manager to cancel an ongoing campaign at anytime. Cancelling a campaign will return any unclaimed tokens, and then prevent anyone from claiming additional tokens
   250	  /// @param campaignId is the id of the campaign to be cancelled
   251	  function cancelCampaign(bytes16 campaignId) external nonReentrant {
   252	    Campaign memory campaign = campaigns[campaignId];
   253	    require(campaign.manager == msg.sender, '!manager');
   254	    delete campaigns[campaignId];
   255	    delete claimLockups[campaignId];
   256	    TransferHelper.withdrawTokens(campaign.token, msg.sender, campaign.amount);
   257	    emit CampaignCancelled(campaignId);
   258	  }
