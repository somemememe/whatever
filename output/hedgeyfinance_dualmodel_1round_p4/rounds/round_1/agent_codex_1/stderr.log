   225	        rate = claimAmount / c.periods;
   226	      } else {
   227	        rate = claimAmount / c.periods + 1;
   228	      }
   229	      uint256 start = c.start == 0 ? block.timestamp : c.start;
   230	      if (campaign.tokenLockup == TokenLockup.Locked) {
   231	        ILockupPlans(c.tokenLocker).createPlan(msg.sender, campaign.token, claimAmount, start, c.cliff, rate, c.period);
   232	      } else {
   233	        IVestingPlans(c.tokenLocker).createPlan(
   234	          msg.sender,
   235	          campaign.token,
   236	          claimAmount,
   237	          start,
   238	          c.cliff,
   239	          rate,
   240	          c.period,
   241	          campaign.manager,
   242	          false
   243	        );
   244	      }
   245	    }
