     4	/// @notice Library to assist with calculation methods of the balances, ends, period amounts for a given plan
     5	/// used by both the Lockup and Vesting Plans
     6	library TimelockLibrary {
     7	  function min(uint256 a, uint256 b) internal pure returns (uint256 _min) {
     8	    _min = (a <= b) ? a : b;
     9	  }
    10	
    11	  /// @notice function to calculate the end date of a plan based on its start, amount, rate and period
    12	  function endDate(uint256 start, uint256 amount, uint256 rate, uint256 period) internal pure returns (uint256 end) {
    13	    end = (amount % rate == 0) ? (amount / rate) * period + start : ((amount / rate) * period) + period + start;
    14	  }
    15	
    16	  /// @notice function to calculate the end period and validate that the parameters passed in are valid
    17	  function validateEnd(
    18	    uint256 start,
    19	    uint256 cliff,
    20	    uint256 amount,
    21	    uint256 rate,
    22	    uint256 period
    23	  ) internal pure returns (uint256 end, bool valid) {
    24	    require(amount > 0, '0_amount');
    25	    require(rate > 0, '0_rate');
    26	    require(rate <= amount, 'rate > amount');
    27	    require(period > 0, '0_period');
    28	    end = (amount % rate == 0) ? (amount / rate) * period + start : ((amount / rate) * period) + period + start;
    29	    require(cliff <= end, 'cliff > end');
    30	    valid = true;
    31	  }
    32	
    33	  /// @notice function to calculate the unlocked (claimable) balance, still locked balance, and the most recent timestamp the unlock would take place
    34	  /// the most recent unlock time is based on the periods, so if the periods are 1, then the unlock time will be the same as the redemption time,
    35	  /// however if the period more than 1 second, the latest unlock will be a discrete time stamp
    36	  /// @param start is the start time of the plan
    37	  /// @param cliffDate is the timestamp of the cliff of the plan
    38	  /// @param amount is the total unclaimed amount tokens still in the vesting plan
    39	  /// @param rate is the amount of tokens that unlock per period
    40	  /// @param period is the seconds in each period, a 1 is a period of 1 second whereby tokens unlock every second
    41	  /// @param currentTime is the current time being evaluated, typically the block.timestamp, but used just to check the plan is past the start or cliff
    42	  /// @param redemptionTime is the time requested for the plan to be redeemed, this can be the same as the current time or prior to it for partial redemptions
    43	  function balanceAtTime(
    44	    uint256 start,
    45	    uint256 cliffDate,
    46	    uint256 amount,
    47	    uint256 rate,
    48	    uint256 period,
    49	    uint256 currentTime,
    50	    uint256 redemptionTime
    51	  ) internal pure returns (uint256 unlockedBalance, uint256 lockedBalance, uint256 unlockTime) {
    52	    if (start > currentTime || cliffDate > currentTime || redemptionTime <= start) {
    53	      lockedBalance = amount;
    54	      unlockTime = start;
    55	    } else {
    56	      uint256 periodsElapsed = (redemptionTime - start) / period;
    57	      uint256 calculatedBalance = periodsElapsed * rate;
    58	      unlockedBalance = min(calculatedBalance, amount);
    59	      lockedBalance = amount - unlockedBalance;
    60	      unlockTime = start + (period * periodsElapsed);
    61	    }
    62	  }
    63	
    64	  function calculateCombinedRate(
    65	    uint256 combinedAmount,
    66	    uint256 combinedRates,
    67	    uint256 start,
    68	    uint256 period,
    69	    uint256 targetEnd
    70	  ) internal pure returns (uint256 rate, uint256 end) {
    71	    uint256 numerator = combinedAmount * period;
    72	    uint256 denominator = (combinedAmount % combinedRates == 0) ? targetEnd - start : targetEnd - start - period;
    73	    rate = numerator / denominator;
    74	    end = endDate(start, combinedAmount, rate, period);
    75	  }
    76	
    77	  function calculateSegmentRates(
    78	    uint256 originalRate,
    79	    uint256 originalAmount,
    80	    uint256 planAmount,
    81	    uint256 segmentAmount,
    82	    uint256 start,
    83	    uint256 end,
    84	    uint256 period,
    85	    uint256 cliff
    86	  ) internal pure returns (uint256 planRate, uint256 segmentRate, uint256 planEnd, uint256 segmentEnd) {
    87	    planRate = (originalRate * ((planAmount * (10 ** 18)) / originalAmount)) / (10 ** 18);
    88	    segmentRate = (segmentAmount % (originalRate - planRate) == 0)
    89	      ? (segmentAmount * period) / (end - start)
    90	      : (segmentAmount * period) / (end - start - period);
    91	    bool validPlanEnd;
    92	    bool validSegmentEnd;
    93	    (planEnd, validPlanEnd) = validateEnd(start, cliff, planAmount, planRate, period);
    94	    (segmentEnd, validSegmentEnd) = validateEnd(start, cliff, segmentAmount, segmentRate, period);
    95	    require(validPlanEnd && validSegmentEnd, 'invalid end date');
    96	  }
    97	}

