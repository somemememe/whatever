   280	
   281	    function _executeSwap(
   282	        TransferWay way,
   283	        UniversalRouterExecute calldata swapParam
   284	    ) private {
   285	        if (way == TransferWay.NativeTransfer && address(this).balance > 0) {
   286	            /// buy with eth
   287	            UNIVERSAL_ROUTER.execute{ value: address(this).balance }(
   288	                swapParam.commands,
   289	                swapParam.inputs,
   290	                swapParam.deadline
   291	            );
   292	        } else {
   293	            UNIVERSAL_ROUTER.execute(
   294	                swapParam.commands,
   295	                swapParam.inputs,
   296	                swapParam.deadline
   297	            );
   298	        }
   299	    }
   300	
   301	    function _executeTransfer(
   302	        TransferWay way,
   303	        bytes calldata transferParam
   304	    ) private {
   305	        if (way == TransferWay.NativeTransfer) return;
   306	
   307	        if (way == TransferWay.PermittedTransfer) {
   308	            (address to, uint160 amount, address token) = abi.decode(
   309	                transferParam,
   310	                (address, uint160, address)
   311	            );
   312	            PERMIT2.transferFrom(msg.sender, to, amount, token);
   313	        } else if (way == TransferWay.AllowanceTransfer) {
   314	            AllowancePermitTransfer memory param = abi.decode(
   315	                transferParam,
   316	                (AllowancePermitTransfer)
   317	            );
   318	            PERMIT2.permit(msg.sender, param.permit, param.signature);
   319	            PERMIT2.transferFrom(
   320	                msg.sender,
   321	                param.to,
   322	                param.amount,
   323	                param.token
   324	            );
   325	        } else if (way == TransferWay.SignatureTransfer) {
   326	            SignPermitTransfer memory param = abi.decode(
   327	                transferParam,
   328	                (SignPermitTransfer)
   329	            );
   330	            /// transfer selling tokens to UNIVERSAL_ROUTER
   331	            PERMIT2.permitTransferFrom(
   332	                param.permit,
   333	                param.transferDetails,
   334	                msg.sender,
   335	                param.signature
   336	            );
   337	        } else {
   338	            revert InvalidParameter();
   339	        }
   340	    }
   341	
   342	    function _executeBatchTransfer(
   343	        TransferWay way,
   344	        bytes calldata transferParam
   345	    ) private {
   346	        if (way == TransferWay.NativeTransfer) return;
   347	
   348	        if (way == TransferWay.PermittedTransfer) {
   349	            IAllowanceTransfer.AllowanceTransferDetails[] memory param = abi
   350	                .decode(
   351	                    transferParam,
   352	                    (IAllowanceTransfer.AllowanceTransferDetails[])
   353	                );
   354	            for (uint256 i; i < param.length; ++i) {
   355	                if (param[i].from != msg.sender) revert InvalidPermitOwner();
   356	            }
   357	            PERMIT2.transferFrom(param);
   358	        } else if (way == TransferWay.AllowanceTransfer) {
   359	            AllowancePermitBatchTransfer memory param = abi.decode(
   360	                transferParam,
   361	                (AllowancePermitBatchTransfer)
   362	            );
   363	            PERMIT2.permit(msg.sender, param.permit, param.signature);
   364	            for (uint256 i; i < param.transferDetails.length; ++i) {
   365	                if (param.transferDetails[i].from != msg.sender)
   366	                    revert InvalidPermitOwner();
   367	            }
   368	            PERMIT2.transferFrom(param.transferDetails);
   369	        } else if (way == TransferWay.SignatureTransfer) {
   370	            SignPermitBatchTransfer memory param = abi.decode(
   371	                transferParam,
   372	                (SignPermitBatchTransfer)
   373	            );
   374	            /// transfer selling tokens to UNIVERSAL_ROUTER
   375	            PERMIT2.permitTransferFrom(
   376	                param.permit,
   377	                param.transferDetails,
   378	                msg.sender,
   379	                param.signature
   380	            );
   381	        } else {
   382	            revert InvalidParameter();
   383	        }
   384	    }
   385	
   386	    function approveAllERC20(
   387	        address token,
   388	        address spender,
   389	        uint256 desireAmount
   390	    ) private {
   391	        if (desireAmount == 0) {
   392	            return;
   393	        }
   394	        uint256 allowance = IERC20(token).allowance(address(this), spender);
   395	        if (allowance < desireAmount) {
   396	            IERC20(token).approve(spender, type(uint256).max);
   397	        }
   398	    }
   399	
   400	    function approveAllERC721(address collection, address spender) private {
   401	        bool approved = IERC721(collection).isApprovedForAll(
   402	            address(this),
   403	            spender
   404	        );
   405	        if (!approved) {
   406	            IERC721(collection).setApprovalForAll(spender, true);
   407	        }
   408	    }
