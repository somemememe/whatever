   410	    function onERC721Received(
   411	        address,
   412	        /*operator*/ address,
   413	        /*from*/ uint256,
   414	        /*tokenId*/ bytes calldata /*data*/
   415	    ) external pure override returns (bytes4) {
   416	        return this.onERC721Received.selector;
   417	    }
   418	
