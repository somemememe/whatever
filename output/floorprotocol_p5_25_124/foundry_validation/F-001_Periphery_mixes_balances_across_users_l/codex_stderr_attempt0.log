+            return nftIds.length != 0;
+        } catch {
+            return false;
+        }
+    }
+
+    function _safeFragmentTokenOf(IFloorGetterLike getter, address collection) internal view returns (address token) {
+        try getter.fragmentTokenOf(collection) returns (address queried) {
+            token = queried;
+        } catch {}
