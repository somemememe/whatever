+            redemptionBase = uint256(cfg.vaultFee.redemptionBase);
+        } catch {}
+
+        if (redemptionBase != 0) {
+            fees[1] = ONE_NFT + ((ONE_NFT * redemptionBase) / 10_000);
+        }
+
