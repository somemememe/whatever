+// SPDX-License-Identifier: UNLICENSED
+pragma solidity ^0.8.20;
+
+import "../FlawVerifier.sol";
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+    function load(address target, bytes32 slot) external view returns (bytes32 data);
+}
+
+contract ProbeTest {
+    address constant TARGET = 0x49AD262C49C7aA708Cc2DF262eD53B64A17Dd5EE;
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+    event LogUint(string key, uint256 val);
+    event LogAddress(string key, address val);
+
+    function test_probe() external {
+        vm.createSelectFork("https://eth-mainnet.g.alchemy.com/v2/ugA3TDW3tlXhwhc3SHfuk", 18_802_287);
+
+        emit LogUint("target_eth", TARGET.balance);
+
+        bytes32 slot = vm.load(
+            TARGET,
+            bytes32(uint256(0x360894A13BA1A3210667C828492DB98DCA3E2076CC3735A920A3CA505D382BBC))
+        );
+        emit LogAddress("impl", address(uint160(uint256(slot))));
+
+        FlawVerifier verifier = new FlawVerifier();
+        (bool ok,) = address(verifier).call(abi.encodeWithSignature("executeOnOpportunity()"));
+        emit LogUint("execute_ok", ok ? 1 : 0);
+        emit LogAddress("profit_token", verifier.profitToken());
+        emit LogUint("profit_amount", verifier.profitAmount());
+    }
+}

