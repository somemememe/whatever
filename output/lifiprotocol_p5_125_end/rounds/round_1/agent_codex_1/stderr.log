     9	/// @title LibSwap
    10	/// @custom:version 1.1.0
    11	/// @notice This library contains functionality to execute mostly swaps but also
    12	///         other calls such as fee collection, token wrapping/unwrapping or
    13	///         sending gas to destination chain
    14	library LibSwap {
    15	    /// @notice Struct containing all necessary data to execute a swap or generic call
    16	    /// @param callTo The address of the contract to call for executing the swap
    17	    /// @param approveTo The address that will receive token approval (can be different than callTo for some DEXs)
    18	    /// @param sendingAssetId The address of the token being sent
    19	    /// @param receivingAssetId The address of the token expected to be received
    20	    /// @param fromAmount The exact amount of the sending asset to be used in the call
    21	    /// @param callData Encoded function call data to be sent to the `callTo` contract
    22	    /// @param requiresDeposit A flag indicating whether the tokens must be deposited (pulled) before the call
    23	    struct SwapData {
    24	        address callTo;
    25	        address approveTo;
    26	        address sendingAssetId;
    27	        address receivingAssetId;
    28	        uint256 fromAmount;
    29	        bytes callData;
    30	        bool requiresDeposit;
    31	    }
    32	
    33	    /// @notice Emitted after a successful asset swap or related operation
    34	    /// @param transactionId    The unique identifier associated with the swap operation
    35	    /// @param dex              The address of the DEX or contract that handled the swap
    36	    /// @param fromAssetId      The address of the token that was sent
    37	    /// @param toAssetId        The address of the token that was received
    38	    /// @param fromAmount       The amount of `fromAssetId` sent
    39	    /// @param toAmount         The amount of `toAssetId` received
    40	    /// @param timestamp        The timestamp when the swap was executed
    41	    event AssetSwapped(
    42	        bytes32 transactionId,
    43	        address dex,
    44	        address fromAssetId,
    45	        address toAssetId,
    46	        uint256 fromAmount,
    47	        uint256 toAmount,
    48	        uint256 timestamp
    49	    );
    50	
    51	    function swap(bytes32 transactionId, SwapData calldata _swap) internal {
    52	        // make sure callTo is a contract
    53	        if (!LibAsset.isContract(_swap.callTo)) revert InvalidContract();
    54	
    55	        // make sure that fromAmount is not 0
    56	        uint256 fromAmount = _swap.fromAmount;
    57	        if (fromAmount == 0) revert NoSwapFromZeroBalance();
    58	
    59	        // determine how much native value to send with the swap call
    60	        uint256 nativeValue = LibAsset.isNativeAsset(_swap.sendingAssetId)
    61	            ? _swap.fromAmount
    62	            : 0;
    63	
    64	        // store initial balance (required for event emission)
    65	        uint256 initialReceivingAssetBalance = LibAsset.getOwnBalance(
    66	            _swap.receivingAssetId
    67	        );
    68	
    69	        // max approve (if ERC20)
    70	        if (nativeValue == 0) {
    71	            LibAsset.maxApproveERC20(
    72	                IERC20(_swap.sendingAssetId),
    73	                _swap.approveTo,
    74	                _swap.fromAmount
    75	            );
    76	        }
    77	
    78	        // we used to have a sending asset balance check here (initialSendingAssetBalance >= _swap.fromAmount)
    79	        // this check was removed to allow for more flexibility with rebasing/fee-taking tokens
    80	        // the general assumption is that if not enough tokens are available to execute the calldata,
    81	        // the transaction will fail anyway
    82	        // the error message might not be as explicit though
    83	
    84	        // execute the swap
    85	        // solhint-disable-next-line avoid-low-level-calls
    86	        (bool success, bytes memory res) = _swap.callTo.call{
    87	            value: nativeValue
    88	        }(_swap.callData);
    89	        if (!success) {
    90	            LibUtil.revertWith(res);
    91	        }
    92	
    93	        // get post-swap balance
    94	        uint256 newBalance = LibAsset.getOwnBalance(_swap.receivingAssetId);
    95	
    96	        // emit event
    97	        emit AssetSwapped(
    98	            transactionId,
    99	            _swap.callTo,
   100	            _swap.sendingAssetId,
   101	            _swap.receivingAssetId,
   102	            _swap.fromAmount,
   103	            newBalance > initialReceivingAssetBalance
   104	                ? newBalance - initialReceivingAssetBalance
   105	                : newBalance,
   106	            block.timestamp
   107	        );
   108	    }
   109	}

