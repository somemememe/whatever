   174	        if (spender == NULL_ADDRESS) {
   175	            revert NullAddrIsNotAValidSpender();
   176	        }
   177	
   178	        // check if allowance is sufficient, otherwise set allowance to provided amount
   179	        // If the initial attempt to approve fails, attempts to reset the approved amount to zero,
   180	        // then retries the approval again (some tokens, e.g. USDT, requires this).
   181	        // Reverts upon failure
   182	        if (assetId.allowance(address(this), spender) < requiredAllowance) {
   183	            address(assetId).safeApproveWithRetry(spender, setAllowanceTo);
   184	        }
   185	    }
