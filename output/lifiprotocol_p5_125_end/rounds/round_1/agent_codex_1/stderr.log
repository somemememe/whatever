   187	    /// @notice Determines whether the given assetId is the native asset
   188	    /// @param assetId The asset identifier to evaluate
   189	    /// @return Boolean indicating if the asset is the native asset
   190	    function isNativeAsset(address assetId) internal pure returns (bool) {
   191	        return assetId == NULL_ADDRESS;
   192	    }
