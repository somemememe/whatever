   149	    function maxApproveERC20(
   150	        IERC20 assetId,
   151	        address spender,
   152	        uint256 amount
   153	    ) internal {
   154	        approveERC20(assetId, spender, amount, type(uint256).max);
   155	    }
   156	
   157	    /// @notice If the current allowance is insufficient, the allowance for a given spender
   158	    ///         is set to the amount provided
   159	    /// @param assetId Token address to transfer
   160	    /// @param spender Address to give spend approval to
   161	    /// @param requiredAllowance Allowance required for current transaction
   162	    /// @param setAllowanceTo The amount the allowance should be set to if current allowance is insufficient
   163	    function approveERC20(
   164	        IERC20 assetId,
   165	        address spender,
   166	        uint256 requiredAllowance,
   167	        uint256 setAllowanceTo
   168	    ) internal {
