        uint256 scaledCollateralShare = currentCollateralShare * (EXCHANGE_RATE_PRECISION / COLLATERIZATION_RATE_PRECISION);
        uint256 collateralValue = IBentoBoxLike(TARGET.bentoBox()).toAmount(
