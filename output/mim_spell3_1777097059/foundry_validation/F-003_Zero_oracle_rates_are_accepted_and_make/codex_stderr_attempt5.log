            bestPair = pair1;
            bestQuote = USDC;
        }

        (address pair2, uint256 reserve2) = _pairWithReserve(SUSHI_FACTORY, USDT);
        if (reserve2 > bestReserve) {
            bestReserve = reserve2;
            bestPair = pair2;
            bestQuote = USDT;
        }

        (address pair3, uint256 reserve3) = _pairWithReserve(SUSHI_FACTORY, DAI);
        if (reserve3 > bestReserve) {
            bestReserve = reserve3;
            bestPair = pair3;
            bestQuote = DAI;
        }

        (address pair4, uint256 reserve4) = _pairWithReserve(UNISWAP_V2_FACTORY, WETH);
        if (reserve4 > bestReserve) {
            bestReserve = reserve4;
            bestPair = pair4;
            bestQuote = WETH;
        }

        (address pair5, uint256 reserve5) = _pairWithReserve(UNISWAP_V2_FACTORY, USDC);
        if (reserve5 > bestReserve) {
