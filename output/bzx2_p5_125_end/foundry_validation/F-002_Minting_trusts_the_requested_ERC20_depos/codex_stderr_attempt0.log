+// SPDX-License-Identifier: UNLICENSED
+pragma solidity ^0.8.26;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+}
+
+interface ILoanToken {
+    function loanTokenAddress() external view returns (address);
+    function symbol() external view returns (string memory);
+    function name() external view returns (string memory);
+    function totalSupply() external view returns (uint256);
+}
+
+interface IERC20Metadata {
+    function symbol() external view returns (string memory);
+    function name() external view returns (string memory);
+    function decimals() external view returns (uint8);
+    function balanceOf(address) external view returns (uint256);
+}
+
+contract InspectTest {
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+    address internal constant TARGET = 0x7F3Fe9D492A9a60aEBb06d82cBa23c6F32CAd10b;
+
+    event LogAddress(string key, address value);
+    event LogUint(string key, uint256 value);
+    event LogString(string key, string value);
+
+    function test_inspect() external {
+        vm.createSelectFork("https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240", 18_695_728);
+
+        ILoanToken pool = ILoanToken(TARGET);
+        address underlying = pool.loanTokenAddress();
+
+        emit LogAddress("underlying", underlying);
+        emit LogString("poolSymbol", pool.symbol());
+        emit LogString("poolName", pool.name());
+        emit LogUint("poolSupply", pool.totalSupply());
+        emit LogString("underlyingSymbol", IERC20Metadata(underlying).symbol());
+        emit LogString("underlyingName", IERC20Metadata(underlying).name());
+        emit LogUint("underlyingDecimals", IERC20Metadata(underlying).decimals());
+        emit LogUint("poolUnderlyingBalance", IERC20Metadata(underlying).balanceOf(TARGET));
+    }
+}

