+++ b/test/Inspect.t.sol
@@ -0,0 +1,106 @@
+// SPDX-License-Identifier: UNLICENSED
+pragma solidity ^0.8.20;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+}
+
+interface IERC20I {
+    function balanceOf(address account) external view returns (uint256);
+    function approve(address spender, uint256 amount) external returns (bool);
+    function transfer(address to, uint256 amount) external returns (bool);
+}
+
+interface ILoanTokenI {
+    function loanTokenAddress() external view returns (address);
+    function tokenPrice() external view returns (uint256);
+    function mint(address receiver, uint256 depositAmount) external returns (uint256);
+    function burn(address receiver, uint256 burnAmount) external returns (uint256);
+    function totalSupply() external view returns (uint256);
+}
+
+interface IUniPairI {
+    function token0() external view returns (address);
+    function token1() external view returns (address);
+    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
+    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
+}
+
+contract InspectTest {
+    Vm internal constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+    event log_named_uint(string key, uint256 val);
+    event log_named_address(string key, address val);
+
+    address internal constant TARGET = 0x7F3Fe9D492A9a60aEBb06d82cBa23c6F32CAd10b;
+    address internal constant YFI = 0x0bc529c00C6401aEF6D220BE8C6Ea1667F6Ad93e;
+    address internal constant SUSHI_YFI_WETH = 0x088ee5007C98a9677165D78dD2109AE4a3D04d0C;
+    address internal constant UNI_YFI_WETH = 0x2fDbAdf3C4D5A8666Bc06645B8358ab803996E28;
+    address internal constant UNI_YFI_USDC = 0xdE37cD310c70e7Fa9d7eD3261515B107D5Fe1F2d;
+    address internal constant SUSHI_YFI_DAI = 0x3CD132ac73A4043Bb4f1674369E70BE6f88EdD73;
+    address internal constant SUSHI_YFI_USDT = 0xAcD2556F64D4BE9Aaa205278895653D3e6d639aE;
+
+    uint256 internal repayAmount;
+
+    function testInspect() external {
+        vm.createSelectFork("https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240", 18695728);
+
+        ILoanTokenI pool = ILoanTokenI(TARGET);
+        emit log_named_address("loanToken", pool.loanTokenAddress());
+        emit log_named_uint("tokenPrice", pool.tokenPrice());
+        emit log_named_uint("poolUnderlyingBefore", IERC20I(YFI).balanceOf(TARGET));
+        emit log_named_uint("iYFITotalSupply", pool.totalSupply());
+
+        _logPair("sushiYfiWeth", SUSHI_YFI_WETH);
+        _logPair("uniYfiWeth", UNI_YFI_WETH);
+        _logPair("uniYfiUsdc", UNI_YFI_USDC);
+        _logPair("sushiYfiDai", SUSHI_YFI_DAI);
+        _logPair("sushiYfiUsdt", SUSHI_YFI_USDT);
+
+        IERC20I(YFI).approve(TARGET, type(uint256).max);
+
+        IUniPairI pair = IUniPairI(SUSHI_YFI_WETH);
+        uint256 amountOut = 1e18;
+        bytes memory data = abi.encode(amountOut);
+        if (pair.token0() == YFI) {
+            pair.swap(amountOut, 0, address(this), data);
+        } else {
+            pair.swap(0, amountOut, address(this), data);
+        }
+
+        emit log_named_uint("repaid", repayAmount);
+        emit log_named_uint("finalContractYfi", IERC20I(YFI).balanceOf(address(this)));
+        emit log_named_uint("finalPoolUnderlying", IERC20I(YFI).balanceOf(TARGET));
+    }
+
+    function uniswapV2Call(address, uint256 amount0, uint256 amount1, bytes calldata data) external {
+        uint256 borrowed = amount0 > 0 ? amount0 : amount1;
+        uint256 nominal = abi.decode(data, (uint256));
+        require(borrowed == nominal, "amount mismatch");
+
+        uint256 balanceBefore = IERC20I(YFI).balanceOf(TARGET);
+        uint256 iBefore = IERC20I(TARGET).balanceOf(address(this));
+        uint256 mintAmount = ILoanTokenI(TARGET).mint(address(this), borrowed);
+        uint256 receivedByPool = IERC20I(YFI).balanceOf(TARGET) - balanceBefore;
+        uint256 iAfter = IERC20I(TARGET).balanceOf(address(this));
+        emit log_named_uint("borrowed", borrowed);
+        emit log_named_uint("poolReceivedOnMint", receivedByPool);
+        emit log_named_uint("mintReturn", mintAmount);
+        emit log_named_uint("iMintedDelta", iAfter - iBefore);
+
+        uint256 burnPaid = ILoanTokenI(TARGET).burn(address(this), iAfter - iBefore);
+        emit log_named_uint("burnPaid", burnPaid);
+
+        repayAmount = ((borrowed * 1000) / 997) + 1;
+        IERC20I(YFI).transfer(msg.sender, repayAmount);
+    }
+
+    function _logPair(string memory name, address pair) internal {
+        IUniPairI uni = IUniPairI(pair);
+        (uint112 reserve0, uint112 reserve1,) = uni.getReserves();
+        emit log_named_address(string.concat(name, "_token0"), uni.token0());
+        emit log_named_address(string.concat(name, "_token1"), uni.token1());
+        emit log_named_uint(string.concat(name, "_reserve0"), uint256(reserve0));
+        emit log_named_uint(string.concat(name, "_reserve1"), uint256(reserve1));
+    }
+}

