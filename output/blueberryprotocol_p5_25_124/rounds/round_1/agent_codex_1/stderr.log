   957	            // If user has no supply / borrow balance on this asset, and user is not redeeming / borrowing this asset, skip it.
   958	            if (
   959	                vars.bTokenBalance == 0 &&
   960	                vars.borrowBalance == 0 &&
   961	                asset != bTokenModify
