  1066	            Exp({mantissa: liquidationIncentiveMantissa}),
  1067	            Exp({mantissa: priceBorrowedMantissa})
  1068	        );
  1069	        Exp memory denominator = mul_(
  1070	            Exp({mantissa: priceCollateralMantissa}),
  1071	            Exp({mantissa: exchangeRateMantissa})
  1072	        );
  1073	        Exp memory ratio = div_(numerator, denominator);
  1074	        uint256 seizeTokens = mul_ScalarTruncate(ratio, actualRepayAmount);
  1075	
  1076	        return (uint256(Error.NO_ERROR), seizeTokens);
  1077	    }
