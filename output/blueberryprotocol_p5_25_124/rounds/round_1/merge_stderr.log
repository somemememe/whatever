        );

        /* Fail if borrower = liquidator */
        require(borrower != liquidator, "invalid account pair");

        /* Fail if repayAmount = 0 or repayAmount = -1 */
        require(
            repayAmount > 0 && repayAmount != uint256(-1),
            "invalid amount"
        );

        LiquidateBorrowLocalVars memory vars;

