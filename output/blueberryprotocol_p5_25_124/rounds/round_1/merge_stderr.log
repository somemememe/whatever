        uint256 seizeError;
        if (address(bTokenCollateral) == address(this)) {
            seizeError = seizeInternal(
                address(this),
                liquidator,
                borrower,
                vars.seizeTokens
            );
        } else {
            seizeError = bTokenCollateral.seize(
                liquidator,
                borrower,
                vars.seizeTokens
