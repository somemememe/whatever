+        uint256 collateralAmount = _mulDiv(ctx.reserveCollateral, sliceBps, BPS_DENOMINATOR);
+        if (collateralAmount == 0 || collateralAmount >= ctx.reserveCollateral / 3 || collateralAmount < MIN_PROFIT) {
+            return amounts;
