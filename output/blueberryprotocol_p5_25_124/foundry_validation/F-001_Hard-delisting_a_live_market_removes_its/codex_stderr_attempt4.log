             return best;
         }
+
+        address debtUnderlying = debtMarket.underlying;
+        uint256 debtPrice = debtMarket.price;
+        uint256 borrowHeadroom = _borrowHeadroom(debtMarket);
+        uint256 collateralPrice = collateralMarket.price;
+        uint256 collateralFactorMantissa = collateralMarket.collateralFactorMantissa;
+        bool repayInDebtTokenDirectly = bridgeToken == debtUnderlying;
