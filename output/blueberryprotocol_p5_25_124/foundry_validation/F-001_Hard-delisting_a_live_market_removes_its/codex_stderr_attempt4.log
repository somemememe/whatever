+    function _safeTransfer(address token, address recipient, uint256 amount) internal {
+        require(
+            _callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.transfer.selector, recipient, amount)),
+            "transfer failed"
+        );
+    }
