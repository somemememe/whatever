+
+    function _mulDiv(uint256 x, uint256 y, uint256 denominator) internal pure returns (uint256) {
+        if (x == 0 || y == 0) {
+            return 0;
+        }
+        return (x * y) / denominator;
+    }
+
+    function _ceilDiv(uint256 x, uint256 y) internal pure returns (uint256) {
+        return x == 0 ? 0 : ((x - 1) / y) + 1;
