+        if (IUniswapV2PairLike(pair).token1() == hate) {
+            return uint256(reserve1);
+        }
+        return 0;
+    }
+
+    function _checkPathPreconditions(IHATEStaking staking) internal view {
+        (uint256 length,, uint256 end,) = staking.epoch();
