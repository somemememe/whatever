    81	
    82	    ///@notice Trigger rebase if epoch over
    83	    function rebase() public {
    84	        if (epoch.end <= block.timestamp) {
    85	            sQWA.rebase(epoch.distribute, epoch.number);
    86	
    87	            epoch.end = epoch.end + epoch.length;
    88	            epoch.number++;
    89	
    90	            if (address(distributor) != address(0)) {
    91	                distributor.distribute();
    92	            }
    93	
    94	            uint256 balance = QWA.balanceOf(address(this));
    95	            uint256 staked = sQWA.circulatingSupply();
    96	
    97	            if (balance <= staked) {
    98	                epoch.distribute = 0;
    99	            } else {
   100	                epoch.distribute = balance - staked;
   101	            }
   102	        }
   103	    }
   104	
   105	    /// INTERNAL FUNCTIONS ///
   106	
   107	    /// @notice         Send sQWA upon staking
   108	    /// @param _to      Address of where sending sQWA
   109	    /// @param _amount  Amount of sQWA to send
   110	    /// @return _sent   Amount of sQWA sent
   111	    function _send(
   112	        address _to,
   113	        uint256 _amount
   114	    ) internal returns (uint256 _sent) {
   115	        sQWA.transfer(_to, _amount); // send as sQWA (equal unit as QWA)
   116	        return _amount;
   117	    }
   118	
   119	    /// VIEW FUNCTIONS ///
   120	
