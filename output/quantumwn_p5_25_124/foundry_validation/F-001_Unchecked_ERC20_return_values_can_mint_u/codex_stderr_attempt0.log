+            );
+            qwaAfter = IERC20Like(qwa).balanceOf(address(this));
+
+            if (okUnstake && qwaAfter > initialQwa) {
+                pathFlags |= PATH_UNSTAKE_FALSE_RETURN;
+                hypothesisValidated = true;
+            } else {
+                // Concrete infeasibility at the fork:
