// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

interface Vm {
    function createSelectFork(string calldata,uint256) external returns (uint256);
}

interface IERC20Meta {
    function name() external view returns (string memory);
    function symbol() external view returns (string memory);
    function decimals() external view returns (uint8);
    function totalSupply() external view returns (uint256);
    function balanceOf(address) external view returns (uint256);
}

interface ISR {
    function totalSupply() external view returns (uint256);
    function rewardRate() external view returns (uint256);
    function rewardsToken() external view returns (address);
    function stakingToken() external view returns (address);
    function owner() external view returns (address);
    function rewardsDistribution() external view returns (address);
    function timeData() external view returns (uint32,uint32,uint32,uint96);
}

interface IODT {
    function owner() external view returns (address);
    function maxAllowedTotalSupply() external view returns (uint256);
    function everMinted() external view returns (uint256);
    function minters(address) external view returns (bool);
}

contract Probe {
    Vm constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
    address constant TARGET = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
    address constant STAKE = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
    address constant REWARD = 0xAe9aCa5d20F5b139931935378C4489308394ca2C;

    event LogAddr(string key, address val);
    event LogUint(string key, uint256 val);
    event LogStr(string key, string val);

    function testProbe() external {
        vm.createSelectFork(vmEnv("RPC"), 14421983);
        ISR farm = ISR(TARGET);
        IERC20Meta stake = IERC20Meta(STAKE);
        IERC20Meta reward = IERC20Meta(REWARD);
        IODT odt = IODT(REWARD);

        emit LogStr("stake.name", stake.name());
        emit LogStr("stake.symbol", stake.symbol());
        emit LogUint("stake.decimals", stake.decimals());
        emit LogUint("stake.totalSupply", stake.totalSupply());
        emit LogUint("stake.farmBal", stake.balanceOf(TARGET));
        emit LogUint("farm.totalSupply", farm.totalSupply());
        emit LogUint("reward.totalSupply", reward.totalSupply());
        emit LogUint("reward.everMinted", odt.everMinted());
        emit LogUint("reward.cap", odt.maxAllowedTotalSupply());
        emit LogAddr("farm.owner", farm.owner());
        emit LogAddr("farm.rd", farm.rewardsDistribution());
        emit LogAddr("reward.owner", odt.owner());
        emit LogUint("rd stake bal", stake.balanceOf(farm.rewardsDistribution()));
        emit LogUint("owner stake bal", stake.balanceOf(farm.owner()));
        emit LogUint("rd reward bal", reward.balanceOf(farm.rewardsDistribution()));
        emit LogUint("owner reward bal", reward.balanceOf(farm.owner()));
        (uint32 pf,uint32 dur,uint32 lut,uint96 trs)=farm.timeData();
        emit LogUint("periodFinish", pf);
        emit LogUint("rewardsDuration", dur);
        emit LogUint("lastUpdateTime", lut);
        emit LogUint("trackedRewards", trs);
        emit LogUint("rewardRate", farm.rewardRate());
    }

    function vmEnv(string memory key) internal view returns (string memory val) {
        (bool ok, bytes memory data) = address(vm).staticcall(abi.encodeWithSignature("envString(string)", key));
        require(ok, "envString failed");
        val = abi.decode(data, (string));
    }
}
