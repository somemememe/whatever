// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface Vm {
    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
    function envString(string calldata name) external returns (string memory);
}

interface IERC20Meta {
    function name() external view returns (string memory);
    function symbol() external view returns (string memory);
    function decimals() external view returns (uint8);
    function totalSupply() external view returns (uint256);
    function balanceOf(address) external view returns (uint256);
}

interface IODT {
    function owner() external view returns (address);
    function minters(address) external view returns (bool);
    function maxAllowedTotalSupply() external view returns (uint256);
    function everMinted() external view returns (uint256);
}

interface ISR {
    function owner() external view returns (address);
    function rewardsDistribution() external view returns (address);
    function stakingToken() external view returns (address);
    function rewardsToken() external view returns (address);
    function totalSupply() external view returns (uint256);
    function rewardRate() external view returns (uint256);
    function timeData() external view returns (uint32,uint32,uint32,uint96);
}

address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));

contract Probe {
    Vm constant vm = Vm(HEVM_ADDRESS);
    event LogAddr(string key, address val);
    event LogUint(string key, uint256 val);
    event LogStr(string key, string val);

    function testProbe() public {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 14421983);
        address farm = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
        address stake = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
        address reward = 0xAe9aCa5d20F5b139931935378C4489308394ca2C;
        emit LogAddr("farm.owner", ISR(farm).owner());
        emit LogAddr("farm.rewardsDistribution", ISR(farm).rewardsDistribution());
        emit LogUint("farm.totalSupply", ISR(farm).totalSupply());
        emit LogUint("farm.rewardRate", ISR(farm).rewardRate());
        (uint32 pf,uint32 rd,uint32 lu,uint96 trs) = ISR(farm).timeData();
        emit LogUint("farm.periodFinish", pf);
        emit LogUint("farm.rewardsDuration", rd);
        emit LogUint("farm.lastUpdateTime", lu);
        emit LogUint("farm.totalRewardsSupply", trs);
        emit LogStr("stake.name", IERC20Meta(stake).name());
        emit LogStr("stake.symbol", IERC20Meta(stake).symbol());
        emit LogUint("stake.decimals", IERC20Meta(stake).decimals());
        emit LogUint("stake.totalSupply", IERC20Meta(stake).totalSupply());
        emit LogUint("stake.balanceOfFarm", IERC20Meta(stake).balanceOf(farm));
        emit LogStr("reward.name", IERC20Meta(reward).name());
        emit LogStr("reward.symbol", IERC20Meta(reward).symbol());
        emit LogUint("reward.decimals", IERC20Meta(reward).decimals());
        emit LogUint("reward.totalSupply", IERC20Meta(reward).totalSupply());
        emit LogAddr("reward.owner", IODT(reward).owner());
        emit LogUint("reward.maxAllowedTotalSupply", IODT(reward).maxAllowedTotalSupply());
        emit LogUint("reward.everMinted", IODT(reward).everMinted());
        emit LogUint("reward.farmIsMinter", IODT(reward).minters(farm) ? 1 : 0);
        emit LogUint("reward.ownerIsMinter", IODT(reward).minters(IODT(reward).owner()) ? 1 : 0);
    }
}
