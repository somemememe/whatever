}

address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));

contract Probe {
    Vm constant vm = Vm(HEVM_ADDRESS);
    event LogAddr(string key, address val);
    event LogUint(string key, uint256 val);
    event LogStr(string key, string val);

    function testProbe() public {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 14421983);
        address farm = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
        address stake = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
