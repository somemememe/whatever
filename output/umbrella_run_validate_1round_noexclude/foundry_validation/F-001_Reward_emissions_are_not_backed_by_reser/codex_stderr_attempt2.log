        _pathAnchorChecksum ''^= uint32(IStakingRewardsLike.exit.selector);
        _pathAnchorChecksum ''^= uint32(IStakingRewardsLike.withdraw.selector);
        _pathAnchorChecksum ''^= uint32(IOnDemandTokenLike.mint.selector);
