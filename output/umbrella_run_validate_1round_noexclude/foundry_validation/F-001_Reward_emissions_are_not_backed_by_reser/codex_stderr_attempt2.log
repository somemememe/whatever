/bin/bash -lc "cat > test/ProbeState.t.sol <<'SOL'
// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

interface Vm {
    function envString(string calldata) external returns (string memory);
    function createSelectFork(string calldata, uint256) external returns (uint256);
}

interface IERC20Meta {
    function name() external view returns (string memory);
    function symbol() external view returns (string memory);
    function decimals() external view returns (uint8);
    function totalSupply() external view returns (uint256);
    function balanceOf(address) external view returns (uint256);
}

interface ISR {
    function owner() external view returns (address);
    function rewardsDistribution() external view returns (address);
    function rewardRate() external view returns (uint256);
    function timeData() external view returns (uint32,uint32,uint32,uint96);
}

interface IODT is IERC20Meta {
    function owner() external view returns (address);
    function everMinted() external view returns (uint256);
    function maxAllowedTotalSupply() external view returns (uint256);
    function minters(address) external view returns (bool);
}

contract Probe {
    Vm constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
    event LogAddr(string key, address val);
    event LogStr(string key, string val);
    event LogUint(string key, uint256 val);

    function testProbe() external {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 14421983);
        address farm = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
        address staking = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
        address reward = 0xAe9aCa5d20F5b139931935378C4489308394ca2C;
        address owner = ISR(farm).owner();
        address rd = ISR(farm).rewardsDistribution();

        emit LogStr("reward.name", IERC20Meta(reward).name());
        emit LogStr("reward.symbol", IERC20Meta(reward).symbol());
        emit LogUint("reward.decimals", IERC20Meta(reward).decimals());
        emit LogUint("reward.totalSupply", IERC20Meta(reward).totalSupply());
        emit LogUint("reward.balance[farm]", IERC20Meta(reward).balanceOf(farm));
        emit LogUint("staking.totalSupply", IERC20Meta(staking).totalSupply());
        emit LogUint("staking.balance[farm]", IERC20Meta(staking).balanceOf(farm));
        emit LogUint("reward.cap", IODT(reward).maxAllowedTotalSupply());
        emit LogUint("reward.everMinted", IODT(reward).everMinted());
        emit LogAddr("farm.owner", owner);
        emit LogAddr("farm.rd", rd);
        emit LogAddr("reward.owner", IODT(reward).owner());
        emit LogUint("rd stake bal", IERC20Meta(staking).balanceOf(rd));
        emit LogUint("owner stake bal", IERC20Meta(staking).balanceOf(owner));
        emit LogUint("rd reward bal", IERC20Meta(reward).balanceOf(rd));
        emit LogUint("owner reward bal", IERC20Meta(reward).balanceOf(owner));
        emit LogUint("minter[farm]", IODT(reward).minters(farm) ? 1 : 0);
        emit LogUint("minter[owner]", IODT(reward).minters(owner) ? 1 : 0);
        emit LogUint("minter[rd]", IODT(reward).minters(rd) ? 1 : 0);
        (uint32 pf, uint32 dur, uint32 lut, uint96 tracked) = ISR(farm).timeData();
        emit LogUint("periodFinish", pf);
        emit LogUint("rewardsDuration", dur);
        emit LogUint("lastUpdateTime", lut);
        emit LogUint("trackedRewards", tracked);
        emit LogUint("rewardRate", ISR(farm).rewardRate());
    }
}
