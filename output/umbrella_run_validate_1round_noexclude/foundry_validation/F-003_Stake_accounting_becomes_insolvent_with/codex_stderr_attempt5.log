        (uint112 reserve0, uint112 reserve1,) = IUniswapV2PairLike(pair).getReserves();
        reserveBase = IUniswapV2PairLike(pair).token0() == baseToken ? uint256(reserve0) : uint256(reserve1);
        ok = reserveBase != 0;
