// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.20;

interface Vm {
    function envString(string calldata) external returns (string memory);
    function createSelectFork(string calldata, uint256) external returns (uint256);
    function deal(address who, uint256 newBalance) external;
    function prank(address) external;
}

interface IERC20 {
    function balanceOf(address) external view returns (uint256);
    function transfer(address, uint256) external returns (bool);
    function transferFrom(address, address, uint256) external returns (bool);
    function totalSupply() external view returns (uint256);
    function decimals() external view returns (uint8);
    function symbol() external view returns (string memory);
}

interface IFactoryV2 { function getPair(address,address) external view returns (address); }
interface IPairV2 { function token0() external view returns (address); function token1() external view returns (address); function getReserves() external view returns (uint112,uint112,uint32); }
interface IStaking {
    function stakingToken() external view returns (address);
    function rewardsToken() external view returns (address);
    function totalSupply() external view returns (uint256);
    function rewardRate() external view returns (uint256);
    function timeData() external view returns (uint32,uint32,uint32,uint96);
}

contract TempProbe {
    Vm constant vm = Vm(address(uint160(uint256(keccak256('"'hevm cheat code')))));
    address constant TARGET = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
    address constant STAKE = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
    address constant REWARD = 0xAe9aCa5d20F5b139931935378C4489308394ca2C;
    address constant BALANCER = 0xBA12222222228d8Ba445958a75a0704d566BF2C8;
    address constant UNI_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;
    address constant UNI_V3_FACTORY = 0x1F98431c8aD98523631AE4a59f267346ea31F984;
    address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;

    event LogAddress(string key, address val);
    event LogUint(string key, uint256 val);
    event LogString(string key, string val);

    function testProbe() external {
        vm.createSelectFork(vm.envString(\"AUDITHOUND_RPC_URL\"), 14421983);
        emit LogAddress(\"stakingToken\", IStaking(TARGET).stakingToken());
        emit LogAddress(\"rewardToken\", IStaking(TARGET).rewardsToken());
        emit LogUint(\"targetBalanceStake\", IERC20(STAKE).balanceOf(TARGET));
        emit LogUint(\"targetSupply\", IStaking(TARGET).totalSupply());
        emit LogUint(\"balancerStake\", IERC20(STAKE).balanceOf(BALANCER));
        emit LogUint(\"stakeTotalSupply\", IERC20(STAKE).totalSupply());
        emit LogString(\"stakeSymbol\", IERC20(STAKE).symbol());
        emit LogUint(\"stakeDecimals\", IERC20(STAKE).decimals());
        _pair(UNI_V2_FACTORY, WETH);
        _pair(UNI_V2_FACTORY, DAI);
        _pair(UNI_V2_FACTORY, USDC);
        _pair(UNI_V2_FACTORY, USDT);
        _pair(SUSHI_FACTORY, WETH);
        _pair(SUSHI_FACTORY, DAI);
        _pair(SUSHI_FACTORY, USDC);
        _pair(SUSHI_FACTORY, USDT);
    }

    function _pair(address factory, address base) internal {
        address pair = IFactoryV2(factory).getPair(base, STAKE);
        emit LogAddress(\"pair\", pair);
        if (pair "'!= address(0)) {
            (uint112 r0, uint112 r1,) = IPairV2(pair).getReserves();
            emit LogUint("r0", r0); emit LogUint("r1", r1);
            emit LogAddress("t0", IPairV2(pair).token0());
            emit LogAddress("t1", IPairV2(pair).token1());
        }
    }
}
EOF
