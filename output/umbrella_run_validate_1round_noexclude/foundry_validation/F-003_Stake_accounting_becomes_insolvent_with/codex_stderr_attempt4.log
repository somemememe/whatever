D /Users/zhanglongqin/AuditHoundV2/cases/umbrella/src/test/ProbeState.t.sol
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface Vm {
    function envString(string calldata) external returns (string memory);
    function createSelectFork(string calldata, uint256) external returns (uint256);
}

interface IERC20 {
    function balanceOf(address) external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function allowance(address, address) external view returns (uint256);
    function approve(address, uint256) external returns (bool);
    function transfer(address, uint256) external returns (bool);
    function transferFrom(address, address, uint256) external returns (bool);
}

interface ISR {
    function stakingToken() external view returns (address);
    function rewardsToken() external view returns (address);
    function rewardRate() external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function balanceOf(address) external view returns (uint256);
    function earned(address) external view returns (uint256);
    function timeData() external view returns (uint32, uint32, uint32, uint96);
}

contract Probe {
    Vm constant vm = Vm(address(uint160(uint256(keccak256('hevm cheat code')))));

    event LogAddr(string key, address val);
    event LogUint(string key, uint256 val);

    address constant TARGET = 0xB3FB1D01B07A706736Ca175f827e4F56021b85dE;
    address constant STAKE = 0xB1BbeEa2dA2905E6B0A30203aEf55c399C53D042;
    address constant REWARD = 0xAe9aCa5d20F5b139931935378C4489308394ca2C;
    address constant BALANCER = 0xBA12222222228d8Ba445958a75a0704d566BF2C8;
    address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;

    function testProbe() public {
        vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 14421983);
        ISR farm = ISR(TARGET);
        emit LogAddr("stakingToken", farm.stakingToken());
        emit LogAddr("rewardsToken", farm.rewardsToken());
        emit LogUint("rewardRate", farm.rewardRate());
        emit LogUint("farm.totalSupply", farm.totalSupply());
        emit LogUint("farm actual staking bal", IERC20(STAKE).balanceOf(TARGET));
        emit LogUint("balancer stake bal", IERC20(STAKE).balanceOf(BALANCER));
        emit LogUint("balancer weth bal", IERC20(WETH).balanceOf(BALANCER));
        emit LogUint("balancer dai bal", IERC20(DAI).balanceOf(BALANCER));
        emit LogUint("stake totalSupply", IERC20(STAKE).totalSupply());
        emit LogUint("reward totalSupply", IERC20(REWARD).totalSupply());
    }
}
