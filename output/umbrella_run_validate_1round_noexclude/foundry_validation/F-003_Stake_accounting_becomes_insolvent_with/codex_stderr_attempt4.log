    function _routeReserveV2(address baseToken, address factory) internal view returns (uint256 reserveBase, bool ok) {
        address pair = IUniswapV2FactoryLike(factory).getPair(baseToken, stakingTokenAtEntry);
        if (pair == address(0)) {
