    function _attemptOneV3Route(address baseToken, uint24 feeTier, uint256 rounds) internal {
        address pool = IUniswapV3FactoryLike(UNISWAP_V3_FACTORY).getPool(baseToken, stakingTokenAtEntry, feeTier);
        if (pool == address(0)) {
            return;
        }
