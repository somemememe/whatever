            for (uint j; j < quotes.length; j++) {
                address pair = IFactory(factories[i]).getPair(TARGET, quotes[j]);
                emit LogAddr("pair", pair);
                if (pair == address(0)) continue;
                emit LogBool("membership", comp.checkMembership(pair, TARGET));
                emit LogBool("init", target.isCollateralTokenInit(pair));
                emit LogUint("cBal", target.balanceOf(pair));
                (uint112 r0, uint112 r1,) = IPair(pair).getReserves();
                emit LogUint("r0", r0);
                emit LogUint("r1", r1);
                emit LogAddr("t0", IPair(pair).token0());
                emit LogAddr("t1", IPair(pair).token1());
            }
        }
    }
}
