+                return false;
+            }
+            uint256 ampAfter = _balanceOf(_profitToken, address(this));
+            return ampAfter > ampBalanceBefore && ampAfter - ampBalanceBefore >= MIN_PROFIT;
+        } catch {
+            return false;
+        }
+    }
