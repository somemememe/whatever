+            return false;
+        }
+        if (target.isCollateralTokenInit(candidate)) {
+            return false;
+        }
+        if (!comptroller.checkMembership(candidate, TARGET)) {
+            return false;
+        }
+
+        uint256 legacyCTokens = target.balanceOf(candidate);
+        if (legacyCTokens == 0) {
+            return false;
+        }
+
+        (uint256 err, , uint256 shortfall) = comptroller.getAccountLiquidity(candidate);
+        if (err != 0 || shortfall == 0) {
+            return false;
+        }
+
+        uint256 debt = target.borrowBalanceStored(candidate);
+        if (debt == 0) {
+            return false;
+        }
+
+        uint256 repayAmount = (debt * closeFactor) / 1e18;
+        repayAmount = (repayAmount * 9990) / 10000;
+        if (repayAmount == 0 || repayAmount > maxFlash) {
+            if (maxFlash == 0) {
+                return false;
+            }
+            repayAmount = maxFlash;
+        }
+
+        (uint256 seizeErr, uint256 seizeTokens) = comptroller.liquidateCalculateSeizeTokens(TARGET, TARGET, repayAmount);
