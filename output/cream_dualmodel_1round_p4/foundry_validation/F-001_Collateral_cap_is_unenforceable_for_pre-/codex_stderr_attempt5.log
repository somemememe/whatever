+    function _trySameMarketLiquidationCandidate(
+        ICTokenLike target,
+        IComptrollerLike comptroller,
+        uint256 ampBalanceBefore,
+        address candidate,
+        uint256 closeFactor,
+        uint256 exchangeRate,
