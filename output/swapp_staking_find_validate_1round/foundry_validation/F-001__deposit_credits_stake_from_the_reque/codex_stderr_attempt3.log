// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "../FlawVerifier.sol";

contract MockStaking is IStakingLike {
    mapping(address => mapping(address => uint256)) public balances;
    mapping(address => mapping(uint128 => bool)) public initialized;
    uint128 public currentEpoch = 3;

    function deposit(address tokenAddress, uint256 amount, address) external {
        require(IERC20Like(tokenAddress).allowance(msg.sender, address(this)) >= amount, "allowance too small");
