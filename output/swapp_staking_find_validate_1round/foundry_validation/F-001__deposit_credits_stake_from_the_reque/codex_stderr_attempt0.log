-        "approve a legacy token whose transferFrom can soft-fail -> call deposit(token, amount, ...) and receive full internal credit despite zero receipt -> let a separate honest depositor fund the same token pool -> withdraw real tokens against the inflated stake";
-
-    uint256 public constant SUPPORTED_PATH_INDEX = 0;
