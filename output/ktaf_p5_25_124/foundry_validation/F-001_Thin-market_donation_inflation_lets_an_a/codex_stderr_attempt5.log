        _safeTransfer(IERC20Like(fundingToken), flashPool, repayment);

        _updateFundingProfit();
    }

    function profitToken() external view returns (address) {
        if (reportedProfitToken != address(0)) {
            return reportedProfitToken;
        }

        address underlying = cachedUnderlying;
        if (underlying == address(0)) {
            return ICTokenLike(TARGET).underlying();
        }
        return underlying;
    }

