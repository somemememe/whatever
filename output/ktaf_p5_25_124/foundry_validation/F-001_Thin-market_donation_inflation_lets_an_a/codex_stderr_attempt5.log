-        _updateProfit(underlyingToken);
-    }
-
-    function _bootstrapDustFromMarket(IERC20Like underlyingToken) internal {
-        // The case workspace exposes no victim-specific helper contract and the verifier starts
-        // unfunded. As a last-resort bootstrap, harvest only the target market's already-live
-        // on-chain underlying cash through the target's public zero-burn path, then immediately
-        // run the F-001 seed/donate/victim/redeem sequence with that real balance.
