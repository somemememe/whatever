@@ -0,0 +1,89 @@
+// SPDX-License-Identifier: MIT
+pragma solidity ^0.8.20;
+
+interface Vm {
+  function envString(string calldata key) external returns (string memory);
+  function createSelectFork(string calldata rpcUrl, uint256 blockNumber) external returns (uint256);
+}
+
+interface IERC20Q {
+  function balanceOf(address account) external view returns (uint256);
+  function totalSupply() external view returns (uint256);
+  function symbol() external view returns (string memory);
+}
+
+interface IIndexQ is IERC20Q {
+  function lpStakingPool() external view returns (address);
+  function lpRewardsToken() external view returns (address);
+  function getAllAssets() external view returns (Asset[] memory);
+}
+
+interface IStakingPoolQ {
+  function stakingToken() external view returns (address);
+  function poolRewards() external view returns (address);
+}
+
+interface IPairQ is IERC20Q {
+  function token0() external view returns (address);
+  function token1() external view returns (address);
+  function factory() external view returns (address);
+  function getReserves() external view returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast);
+}
+
+interface IFactoryQ {
+  function getPair(address tokenA, address tokenB) external view returns (address);
+}
+
+struct Asset {
+  address token;
+  uint256 weighting;
+  uint256 basePriceUSDX96;
+  address c1;
+  uint256 q1;
+}
+
+contract QueryTest {
+  Vm constant vm = Vm(address(uint160(uint256(keccak256("hevm cheat code")))));
+
+  event log_named_address(string key, address val);
+  event log_named_uint(string key, uint256 val);
+  event log_named_string(string key, string val);
+
+  address constant TARGET = 0xdbB20A979a92ccCcE15229e41c9B082D5b5d7E31;
+  address constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
+  address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
+  address constant UNIV2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
+  address constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777Ce9e4f2Ac;
+
+  function testQuery() external {
+    vm.createSelectFork(vm.envString("AUDITHOUND_RPC_URL"), 19109652);
+
+    address stakingPool = IIndexQ(TARGET).lpStakingPool();
+    address pair = IStakingPoolQ(stakingPool).stakingToken();
+    address rewards = IStakingPoolQ(stakingPool).poolRewards();
+    Asset[] memory assets = IIndexQ(TARGET).getAllAssets();
+
+    emit log_named_address("stakingPool", stakingPool);
+    emit log_named_address("pair", pair);
+    emit log_named_address("rewards", rewards);
+    emit log_named_address("pair.factory", IPairQ(pair).factory());
+    emit log_named_address("pair.token0", IPairQ(pair).token0());
+    emit log_named_address("pair.token1", IPairQ(pair).token1());
+    emit log_named_uint("target.balanceOf(target)", IERC20Q(TARGET).balanceOf(TARGET));
+    emit log_named_uint("target.balanceOf(pair)", IERC20Q(TARGET).balanceOf(pair));
+    emit log_named_uint("dai.balanceOf(pair)", IERC20Q(DAI).balanceOf(pair));
+    emit log_named_uint("pair.totalSupply", IERC20Q(pair).totalSupply());
+    emit log_named_address("uni.targetWeth", IFactoryQ(UNIV2_FACTORY).getPair(TARGET, WETH));
+    emit log_named_address("sushi.targetWeth", IFactoryQ(SUSHI_FACTORY).getPair(TARGET, WETH));
+    emit log_named_address("uni.targetDai", IFactoryQ(UNIV2_FACTORY).getPair(TARGET, DAI));
+    emit log_named_address("sushi.targetDai", IFactoryQ(SUSHI_FACTORY).getPair(TARGET, DAI));
+    emit log_named_address("uni.daiWeth", IFactoryQ(UNIV2_FACTORY).getPair(DAI, WETH));
+    emit log_named_address("sushi.daiWeth", IFactoryQ(SUSHI_FACTORY).getPair(DAI, WETH));
+
+    for (uint256 i; i < assets.length; i++) {
+      emit log_named_address("asset", assets[i].token);
+      emit log_named_uint("weight", assets[i].weighting);
+      emit log_named_uint("q1", assets[i].q1);
+    }
+  }
+}

