   162	  function addLiquidityV2(
   163	    uint256 _idxLPTokens,
   164	    uint256 _daiLPTokens,
   165	    uint256 _slippage // 100 == 10%, 1000 == 100%
   166	  ) external override noSwap {
   167	    uint256 _idxTokensBefore = balanceOf(address(this));
   168	    uint256 _daiBefore = IERC20(DAI).balanceOf(address(this));
   169	
   170	    _transfer(_msgSender(), address(this), _idxLPTokens);
   171	    _approve(address(this), V2_ROUTER, _idxLPTokens);
   172	
   173	    IERC20(DAI).safeTransferFrom(_msgSender(), address(this), _daiLPTokens);
   174	    IERC20(DAI).safeIncreaseAllowance(V2_ROUTER, _daiLPTokens);
   175	
   176	    IUniswapV2Router02(V2_ROUTER).addLiquidity(
   177	      address(this),
   178	      DAI,
   179	      _idxLPTokens,
   180	      _daiLPTokens,
   181	      (_idxLPTokens * (1000 - _slippage)) / 1000,
   182	      (_daiLPTokens * (1000 - _slippage)) / 1000,
   183	      _msgSender(),
   184	      block.timestamp
   185	    );
   186	
   187	    // check & refund excess tokens from LPing
   188	    if (balanceOf(address(this)) > _idxTokensBefore) {
   189	      _transfer(
   190	        address(this),
   191	        _msgSender(),
   192	        balanceOf(address(this)) - _idxTokensBefore
   193	      );
   194	    }
   195	    if (IERC20(DAI).balanceOf(address(this)) > _daiBefore) {
   196	      IERC20(DAI).safeTransfer(
   197	        _msgSender(),
   198	        IERC20(DAI).balanceOf(address(this)) - _daiBefore
   199	      );
   200	    }
   201	    emit AddLiquidity(_msgSender(), _idxLPTokens, _daiLPTokens);
   202	  }
   203	
   204	  function removeLiquidityV2(
   205	    uint256 _lpTokens,
   206	    uint256 _minIdxTokens, // 0 == 100% slippage
   207	    uint256 _minDAI // 0 == 100% slippage
   208	  ) external override noSwap {
   209	    _lpTokens = _lpTokens == 0
   210	      ? IERC20(V2_POOL).balanceOf(_msgSender())
   211	      : _lpTokens;
   212	    require(_lpTokens > 0, 'LPREM');
   213	
   214	    uint256 _balBefore = IERC20(V2_POOL).balanceOf(address(this));
   215	    IERC20(V2_POOL).safeTransferFrom(_msgSender(), address(this), _lpTokens);
   216	    IERC20(V2_POOL).safeIncreaseAllowance(V2_ROUTER, _lpTokens);
   217	    IUniswapV2Router02(V2_ROUTER).removeLiquidity(
   218	      address(this),
   219	      DAI,
