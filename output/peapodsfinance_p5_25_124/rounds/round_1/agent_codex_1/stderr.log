   250	    require(IERC20(_token).balanceOf(address(this)) >= _balance, 'FLASHAFTER');
   251	    emit FlashLoan(_msgSender(), _recipient, _token, _amount);
   252	  }
   253	
   254	  function rescueERC20(address _token) external {
   255	    // cannot withdraw tokens/assets that belong to the index
   256	    require(!isAsset(_token) && _token != address(this), 'UNAVAILABLE');
   257	    IERC20(_token).safeTransfer(
   258	      Ownable(address(V3_TWAP_UTILS)).owner(),
   259	      IERC20(_token).balanceOf(address(this))
   260	    );

