   225	    );
   226	    if (IERC20(V2_POOL).balanceOf(address(this)) > _balBefore) {
   227	      IERC20(V2_POOL).safeTransfer(
   228	        _msgSender(),
   229	        IERC20(V2_POOL).balanceOf(address(this)) - _balBefore
   230	      );
   231	    }
   232	    emit RemoveLiquidity(_msgSender(), _lpTokens);
   233	  }
   234	
   235	  function flash(
   236	    address _recipient,
   237	    address _token,
   238	    uint256 _amount,
   239	    bytes calldata _data
   240	  ) external override {
   241	    address _rewards = StakingPoolToken(lpStakingPool).poolRewards();
   242	    IERC20(DAI).safeTransferFrom(
