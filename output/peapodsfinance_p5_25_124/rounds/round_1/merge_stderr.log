    49	      indexTokens.push(
    50	        IndexAssetInfo({
    51	          token: _tokens[_i],
    52	          basePriceUSDX96: 0,
    53	          weighting: _weights[_i],
    54	          c1: address(0),
    55	          q1: 0 // amountsPerIdxTokenX96
    56	        })
    57	      );
    58	      _totalWeights += _weights[_i];
    59	      _fundTokenIdx[_tokens[_i]] = _i;
    60	      _isTokenInIndex[_tokens[_i]] = true;
    61	    }
    62	    // at idx == 0, need to find X in [1/X = tokenWeightAtIdx/totalWeights]
    63	    // at idx > 0, need to find Y in (Y/X = tokenWeightAtIdx/totalWeights)
    64	    uint256 _xX96 = (FixedPoint96.Q96 * _totalWeights) / _weights[0];
    65	    for (uint256 _i; _i < _tokens.length; _i++) {
    66	      indexTokens[_i].q1 =
    67	        (_weights[_i] * _xX96 * 10 ** IERC20Metadata(_tokens[_i]).decimals()) /
    68	        _totalWeights;
