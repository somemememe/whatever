   123	    }
   124	    for (uint256 _i; _i < indexTokens.length; _i++) {
   125	      uint256 _transferAmount = _i == _tokenIdx
   126	        ? _amount
   127	        : (_amount *
   128	          indexTokens[_i].weighting *
   129	          10 ** IERC20Metadata(indexTokens[_i].token).decimals()) /
   130	          indexTokens[_tokenIdx].weighting /
   131	          10 ** IERC20Metadata(_token).decimals();
   132	      _transferAndValidate(
   133	        IERC20(indexTokens[_i].token),
