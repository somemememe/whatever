    97	    }
    98	    IUniswapV2Pair _pool = IUniswapV2Pair(V2_FACTORY.getPair(_token, WETH));
    99	    address _token0 = _pool.token0();
   100	    uint8 _decimals0 = IERC20Metadata(_token0).decimals();
   101	    uint8 _decimals1 = IERC20Metadata(_pool.token1()).decimals();
   102	    (uint112 _res0, uint112 _res1, ) = _pool.getReserves();
   103	    uint256 _nativePriceUSDX96 = _getNativePriceUSDX96();
   104	    return
   105	      _token0 == WETH
   106	        ? (_nativePriceUSDX96 * _res0 * 10 ** _decimals1) /
   107	          _res1 /
   108	          10 ** _decimals0
   109	        : (_nativePriceUSDX96 * _res1 * 10 ** _decimals0) /
   110	          _res0 /
   111	          10 ** _decimals1;
   112	  }
   113	
   114	  function bond(address _token, uint256 _amount) external override noSwap {
   115	    require(_isTokenInIndex[_token], 'INVALIDTOKEN');
   116	    uint256 _tokenIdx = _fundTokenIdx[_token];
   117	    uint256 _tokensMinted = (_amount * FixedPoint96.Q96 * 10 ** decimals()) /
