   154	      uint256 _tokenSupply = IERC20(indexTokens[_i].token).balanceOf(
   155	        address(this)
   156	      );
   157	      uint256 _debondAmount = (_tokenSupply * _percAfterFeeX96) /
   158	        FixedPoint96.Q96;
   159	      IERC20(indexTokens[_i].token).safeTransfer(_msgSender(), _debondAmount);
   160	      require(
   161	        IERC20(indexTokens[_i].token).balanceOf(address(this)) >=
   162	          _tokenSupply - _debondAmount,
   163	        'HEAVY'
   164	      );
   165	    }
   166	    emit Debond(_msgSender(), _amount);
   167	  }
