    85	    V3_TWAP_UTILS = _v3TwapUtilities;
    86	    emit Create(address(this), _msgSender());
    87	  }
    88	
    89	  function _transfer(
    90	    address _from,
    91	    address _to,
    92	    uint256 _amount
    93	  ) internal virtual override {
    94	    if (_swapOn && !_swapping) {
    95	      uint256 _bal = balanceOf(address(this));
    96	      uint256 _min = totalSupply() / 10000; // 0.01%
    97	      if (_from != V2_POOL && _bal >= _min && balanceOf(V2_POOL) > 0) {
    98	        _swapping = true;
    99	        _feeSwap(
   100	          _bal >= _min * 100 ? _min * 100 : _bal >= _min * 20 ? _min * 20 : _min
   101	        );
   102	        _swapping = false;
   103	      }
   104	    }
   105	    super._transfer(_from, _to, _amount);
   106	  }
   107	
   108	  function _feeSwap(uint256 _amount) internal {
   109	    address[] memory path = new address[](2);
   110	    path[0] = address(this);
   111	    path[1] = DAI;
   112	    _approve(address(this), V2_ROUTER, _amount);
   113	    address _rewards = StakingPoolToken(lpStakingPool).poolRewards();
   114	    IUniswapV2Router02(V2_ROUTER)
   115	      .swapExactTokensForTokensSupportingFeeOnTransferTokens(
   116	        _amount,
   117	        0,
   118	        path,
   119	        _rewards,
   120	        block.timestamp
   121	      );
   122	    uint256 _rewardsDAIBal = IERC20(DAI).balanceOf(_rewards);
   123	    if (_rewardsDAIBal > 0) {
   124	      ITokenRewards(_rewards).depositFromDAI(0);
   125	    }
   126	  }
   127	
   128	  function _transferAndValidate(
   129	    IERC20 _token,
   130	    address _sender,
   131	    uint256 _amount
   132	  ) internal {
   133	    uint256 _balanceBefore = _token.balanceOf(address(this));
   134	    _token.safeTransferFrom(_sender, address(this), _amount);
   135	    require(
   136	      _token.balanceOf(address(this)) >= _balanceBefore + _amount,
   137	      'TFRVAL'
   138	    );
   139	  }
   140	
   141	  function _isFirstIn() internal view returns (bool) {
   142	    return totalSupply() == 0;
   143	  }
   144	
   145	  function _isLastOut(uint256 _debondAmount) internal view returns (bool) {
   146	    return _debondAmount >= (totalSupply() * 98) / 100;
   147	  }
   148	
   149	  function isAsset(address _token) public view override returns (bool) {
   150	    return _isTokenInIndex[_token];
   151	  }
   152	
   153	  function getAllAssets()
   154	    external
   155	    view
   156	    override
   157	    returns (IndexAssetInfo[] memory)
   158	  {
   159	    return indexTokens;
   160	  }
   161	
   162	  function addLiquidityV2(
   163	    uint256 _idxLPTokens,
   164	    uint256 _daiLPTokens,
   165	    uint256 _slippage // 100 == 10%, 1000 == 100%
   166	  ) external override noSwap {
   167	    uint256 _idxTokensBefore = balanceOf(address(this));
   168	    uint256 _daiBefore = IERC20(DAI).balanceOf(address(this));
   169	
   170	    _transfer(_msgSender(), address(this), _idxLPTokens);
   171	    _approve(address(this), V2_ROUTER, _idxLPTokens);
   172	
   173	    IERC20(DAI).safeTransferFrom(_msgSender(), address(this), _daiLPTokens);
   174	    IERC20(DAI).safeIncreaseAllowance(V2_ROUTER, _daiLPTokens);
   175	
   176	    IUniswapV2Router02(V2_ROUTER).addLiquidity(
   177	      address(this),
   178	      DAI,
   179	      _idxLPTokens,
   180	      _daiLPTokens,
   181	      (_idxLPTokens * (1000 - _slippage)) / 1000,
   182	      (_daiLPTokens * (1000 - _slippage)) / 1000,
   183	      _msgSender(),
   184	      block.timestamp
   185	    );
   186	
   187	    // check & refund excess tokens from LPing
   188	    if (balanceOf(address(this)) > _idxTokensBefore) {
   189	      _transfer(
   190	        address(this),
   191	        _msgSender(),
   192	        balanceOf(address(this)) - _idxTokensBefore
   193	      );
   194	    }
   195	    if (IERC20(DAI).balanceOf(address(this)) > _daiBefore) {
   196	      IERC20(DAI).safeTransfer(
   197	        _msgSender(),
   198	        IERC20(DAI).balanceOf(address(this)) - _daiBefore
   199	      );
   200	    }
   201	    emit AddLiquidity(_msgSender(), _idxLPTokens, _daiLPTokens);
   202	  }
   203	
   204	  function removeLiquidityV2(
   205	    uint256 _lpTokens,
   206	    uint256 _minIdxTokens, // 0 == 100% slippage
   207	    uint256 _minDAI // 0 == 100% slippage
   208	  ) external override noSwap {
   209	    _lpTokens = _lpTokens == 0
   210	      ? IERC20(V2_POOL).balanceOf(_msgSender())
   211	      : _lpTokens;
   212	    require(_lpTokens > 0, 'LPREM');
   213	
   214	    uint256 _balBefore = IERC20(V2_POOL).balanceOf(address(this));
   215	    IERC20(V2_POOL).safeTransferFrom(_msgSender(), address(this), _lpTokens);
   216	    IERC20(V2_POOL).safeIncreaseAllowance(V2_ROUTER, _lpTokens);
   217	    IUniswapV2Router02(V2_ROUTER).removeLiquidity(
   218	      address(this),
   219	      DAI,
   220	      _lpTokens,
   221	      _minIdxTokens,
   222	      _minDAI,
   223	      _msgSender(),
   224	      block.timestamp
   225	    );
   226	    if (IERC20(V2_POOL).balanceOf(address(this)) > _balBefore) {
   227	      IERC20(V2_POOL).safeTransfer(
   228	        _msgSender(),
   229	        IERC20(V2_POOL).balanceOf(address(this)) - _balBefore
   230	      );
   231	    }
   232	    emit RemoveLiquidity(_msgSender(), _lpTokens);
   233	  }
   234	
   235	  function flash(
   236	    address _recipient,
   237	    address _token,
   238	    uint256 _amount,
   239	    bytes calldata _data
   240	  ) external override {
   241	    address _rewards = StakingPoolToken(lpStakingPool).poolRewards();
   242	    IERC20(DAI).safeTransferFrom(
   243	      _msgSender(),
   244	      _rewards,
   245	      FLASH_FEE_DAI * 10 ** IERC20Metadata(DAI).decimals()
   246	    );
   247	    uint256 _balance = IERC20(_token).balanceOf(address(this));
   248	    IERC20(_token).safeTransfer(_recipient, _amount);
   249	    IFlashLoanRecipient(_recipient).callback(_data);
   250	    require(IERC20(_token).balanceOf(address(this)) >= _balance, 'FLASHAFTER');
   251	    emit FlashLoan(_msgSender(), _recipient, _token, _amount);
   252	  }
   253	
   254	  function rescueERC20(address _token) external {
   255	    // cannot withdraw tokens/assets that belong to the index
   256	    require(!isAsset(_token) && _token != address(this), 'UNAVAILABLE');
   257	    IERC20(_token).safeTransfer(
   258	      Ownable(address(V3_TWAP_UTILS)).owner(),
   259	      IERC20(_token).balanceOf(address(this))
   260	    );
   261	  }
   262	
   263	  function rescueETH() external {
   264	    require(address(this).balance > 0, 'NOETH');
   265	    _rescueETH(address(this).balance);
   266	  }
   267	
   268	  function _rescueETH(uint256 _amount) internal {
   269	    if (_amount == 0) {
   270	      return;
   271	    }
   272	    (bool _sent, ) = Ownable(address(V3_TWAP_UTILS)).owner().call{
   273	      value: _amount
   274	    }('');
   275	    require(_sent, 'SENT');
   276	  }
   277	
   278	  receive() external payable {
   279	    _rescueETH(msg.value);
   280	  }
   281	}

