    74	      V2_FACTORY.getPair(DAI, WETH)
    75	    );
    76	    address _token0 = _nativeStablePool.token0();
    77	    (uint8 _decimals0, uint8 _decimals1) = (
    78	      IERC20Metadata(_token0).decimals(),
    79	      IERC20Metadata(_nativeStablePool.token1()).decimals()
    80	    );
    81	    (uint112 _res0, uint112 _res1, ) = _nativeStablePool.getReserves();
    82	    return
    83	      _token0 == DAI
    84	        ? (FixedPoint96.Q96 * _res0 * 10 ** _decimals1) /
    85	          _res1 /
    86	          10 ** _decimals0
    87	        : (FixedPoint96.Q96 * _res1 * 10 ** _decimals0) /
    88	          _res0 /
    89	          10 ** _decimals1;
    90	  }
    91	
    92	  function _getTokenPriceUSDX96(
    93	    address _token
    94	  ) internal view returns (uint256) {
