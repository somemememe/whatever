            uint256 cappedByLiquidity = liveReserveLiquidity - RESERVE_LIQUIDITY_BUFFER;
            if (borrowAmount > cappedByLiquidity) {
                borrowAmount = cappedByLiquidity;
            }
        } else {
            borrowAmount = 0;
        }

        require(borrowAmount != 0, "zero-borrow");
