    }

    function _buildJoinRequest(uint256 minBptOut) internal pure returns (IBalancerVault.JoinPoolRequest memory request) {
        uint256[] memory maxAmountsIn = new uint256[](2);
        maxAmountsIn[0] = JOIN_WSTETH_AMOUNT;
