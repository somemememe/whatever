        candidates[9] = 0xF147b8125d2ef93FB6965Db97D6746952a133934;
        candidates[10] = 0xbD17B1ce622d73bD438b9E658acA5996dc394b0d;
        candidates[11] = 0xca719728Ef172d0961768581fdF35CB116e0B7a4;
        candidates[12] = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;
    }

    function _pairQuoteCandidates() internal pure returns (address[] memory quotes) {
        quotes = new address[](7);
        quotes[0] = WETH;
        quotes[1] = DAI;
        quotes[2] = USDC;
        quotes[3] = USDT;
        quotes[4] = WBTC;
        quotes[5] = SUSD;
        quotes[6] = RENBTC;
    }

    function _sourceDerivedCandidates() internal pure returns (address[] memory tokens) {
        tokens = new address[](49);
        tokens[0] = 0x429881672B9AE42b8EbA0E26cD9C73711b891Ca5;
        tokens[1] = 0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984;
