        if (!_safeApprove(token, UNISWAP_V2_ROUTER, amount)) {
            return;
        }

        address[] memory path = new address[](2);
        path[0] = token;
        path[1] = WETH;

        try ROUTER.swapExactTokensForTokens(
            amount,
            0,
            path,
            address(this),
            block.timestamp
        ) returns (uint256[] memory) {
            return;
        } catch {}
