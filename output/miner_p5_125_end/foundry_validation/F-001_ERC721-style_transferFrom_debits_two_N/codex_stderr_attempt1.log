+++ b/tmpscan/src/Scan.t.sol
@@ -0,0 +1,24 @@
+// SPDX-License-Identifier: UNLICENSED
+pragma solidity ^0.8.20;
+
+interface Vm {
+    function createSelectFork(string calldata urlOrAlias, uint256 blockNumber) external returns (uint256);
+}
+
+interface ITarget {
+    function tokensPerNFT() external view returns (uint256);
+}
+
+address constant HEVM_ADDRESS = address(uint160(uint256(keccak256("hevm cheat code"))));
+
+contract Scan {
+    Vm constant vm = Vm(HEVM_ADDRESS);
+    address constant TARGET = 0xE77EC1bF3A5C95bFe3be7BDbACfe3ac1c7E454CD;
+
+    event LogUint(string key, uint256 val);
+
+    function testScan() public {
+        vm.createSelectFork("https://mainnet.infura.io/v3/a5fc4fc5ece34a6eb6e8dfe627dce240", 19226507);
+        emit LogUint("tokensPerNFT", ITarget(TARGET).tokensPerNFT());
+    }
+}

