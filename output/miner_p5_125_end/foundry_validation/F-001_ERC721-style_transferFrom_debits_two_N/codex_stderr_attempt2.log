        uint256 holderBalance = target.balanceOf(holder);
        uint256 neededForBug = unit * 2;
        if (holderBalance >= neededForBug) {
            return false;
        }

        uint256 borrowAmount = neededForBug - holderBalance;
        uint256 fee = _v2Fee(borrowAmount);
        if (holderBalance <= fee) {
            return false;
