        if (!_isAuthorized(target, holder, tokenId)) {
            return false;
        }

        uint256 recipientBefore = target.balanceOf(recipient);

        try target.transferFrom(holder, recipient, tokenId) returns (bool ok) {
            if (!ok) {
                return false;
            }
        } catch {
            return false;
        }

