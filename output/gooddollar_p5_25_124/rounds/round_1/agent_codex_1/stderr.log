   219					distributionRecipients[i] = _recipient;
   220					emit RecipientUpdated(_recipient, i);
   221					return;
   222				}
   223			}
   224			//if reached here then add new one
   225			emit RecipientAdded(_recipient, distributionRecipients.length);
   226			distributionRecipients.push(_recipient);
   227		}
   228	
   229		/**
   230		 * @notice internal function that takes care of sending the G$s according to the transfer type
   231		 * @param _recipient data about the recipient
   232		 * @param _amount how much to send
   233		 */
   234		function distribute(
   235			DistributionRecipient storage _recipient,
   236			uint256 _amount
   237		) internal {
   238			if (_recipient.transferType == TransferType.DEPRECATED_FuseBridge) {
   239				revert("DEPRECATED");
   240			} else if (_recipient.transferType == TransferType.LayerZeroBridge) {
   241				nativeToken().approve(address(mpbBridge), _amount);
   242				(uint256 lzFee, ) = ILayerZeroFeeEstimator(address(mpbBridge))
   243					.estimateSendFee(
   244						mpbBridge.toLzChainId(_recipient.chainId),
   245						address(this),
   246						_recipient.addr,
   247						_amount,
   248						false,
   249						abi.encodePacked(uint16(1), uint256(400000)) // 400k gas to execute bridge at target chain
   250					);
   251				if (lzFee > feeSettings.maxFee) revert FEE_LIMIT(lzFee);
   252	
   253				mpbBridge.bridgeToWithLz{ value: lzFee }(
   254					_recipient.addr,
   255					_recipient.chainId,
   256					_amount,
   257					""
   258				);
   259			} else if (_recipient.transferType == TransferType.AxelarBridge) {
   260				nativeToken().approve(address(mpbBridge), _amount);
   261				uint256 axlFee = getAxelarFee(_recipient.chainId);
   262	
   263				if (axlFee > feeSettings.maxFee) revert FEE_LIMIT(axlFee);
   264	
   265				mpbBridge.bridgeToWithAxelar{ value: axlFee }(
   266					_recipient.addr,
   267					_recipient.chainId,
   268					_amount,
   269					getTargetChainRefundAddress(_recipient.chainId)
   270				);
   271			} else if (_recipient.transferType == TransferType.Contract) {
   272				nativeToken().transferAndCall(_recipient.addr, _amount, "");
   273			}
   274		}
   275	
   276		function calcGDToSell(
   277			uint256 maxAmountToSell
   278		) public view returns (uint256 gdToSell) {
   279			uint24[] memory fees = new uint24[](1);
   280			fees[0] = 500;
   281	
   282			uint256 ethToBuy = feeSettings.minBalanceForFees * 3;
   283			(uint256 ethValueInUSDC, ) = STATIC_ORACLE
   284				.quoteSpecificFeeTiersWithTimePeriod(
   285					uint128(ethToBuy),
   286					WETH_TOKEN,
   287					USDC_TOKEN,
   288					fees,
   289					60 //last 1 minute
   290				);
   291	
   292			uint256 gdPriceInDai = GoodReserveCDai(nameService.getAddress("RESERVE"))
   293				.currentPriceDAI();
   294			gdToSell = (ethValueInUSDC * 1e12 * 100) / gdPriceInDai; //* 1e12 to increase usdc to 18 decimals, mul by 100 so result is in 2 G$ 2 decimals
   295			gdToSell = gdToSell > maxAmountToSell ? maxAmountToSell : gdToSell;
   296		}
   297	
   298		function buyNativeWithGD(uint256 amountToSell) internal {
   299			address[] memory path = new address[](2);
   300			path[0] = nameService.getAddress("DAI");
   301			path[1] = address(0);
   302			address exchg = nameService.getAddress("EXCHANGE_HELPER");
   303			nativeToken().approve(exchg, amountToSell);
   304			ExchangeHelper(exchg).sell(path, amountToSell, 0, 0, address(this));
   305		}
   306	}

