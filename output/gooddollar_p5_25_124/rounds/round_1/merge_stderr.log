   234		function distribute(
   235			DistributionRecipient storage _recipient,
   236			uint256 _amount
   237		) internal {
   238			if (_recipient.transferType == TransferType.DEPRECATED_FuseBridge) {
   239				revert("DEPRECATED");
   240			} else if (_recipient.transferType == TransferType.LayerZeroBridge) {
   241				nativeToken().approve(address(mpbBridge), _amount);
   242				(uint256 lzFee, ) = ILayerZeroFeeEstimator(address(mpbBridge))
   243					.estimateSendFee(
