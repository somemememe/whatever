   276		function calcGDToSell(
   277			uint256 maxAmountToSell
   278		) public view returns (uint256 gdToSell) {
   279			uint24[] memory fees = new uint24[](1);
   280			fees[0] = 500;
   281	
   282			uint256 ethToBuy = feeSettings.minBalanceForFees * 3;
   283			(uint256 ethValueInUSDC, ) = STATIC_ORACLE
   284				.quoteSpecificFeeTiersWithTimePeriod(
   285					uint128(ethToBuy),
   286					WETH_TOKEN,
   287					USDC_TOKEN,
   288					fees,
   289					60 //last 1 minute
   290				);
   291	
   292			uint256 gdPriceInDai = GoodReserveCDai(nameService.getAddress("RESERVE"))
   293				.currentPriceDAI();
   294			gdToSell = (ethValueInUSDC * 1e12 * 100) / gdPriceInDai; //* 1e12 to increase usdc to 18 decimals, mul by 100 so result is in 2 G$ 2 decimals
   295			gdToSell = gdToSell > maxAmountToSell ? maxAmountToSell : gdToSell;
   296		}
