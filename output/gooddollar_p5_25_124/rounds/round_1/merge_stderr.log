    21			bytes32[] memory _nameHashes,
    22			address[] memory _addresses
    23		) public virtual initializer {
    24			dao = _dao;
    25			for (uint256 i = 0; i < _nameHashes.length; i++) {
    26				addresses[_nameHashes[i]] = _addresses[i];
    27			}
    28			addresses[keccak256(bytes("CONTROLLER"))] = address(_dao);
    29			addresses[keccak256(bytes("AVATAR"))] = address(_dao.avatar());
    30		}
    31	
    32		function _authorizeUpgrade(address) internal override {
    33			_onlyAvatar();
    34		}
