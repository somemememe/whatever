    action_terms = [
        "borrow",
        "cook",
        "accrue",
        "remove_collateral",
        "add_collateral",
        "withdraw",
        "liquidate",
        "oracle.get",
        "exchangeRate",
    ]
    path_lower = path_text.lower()
    for term in action_terms:
        if term.lower() in path_lower and term.lower() not in anchors:
            anchors.append(term.lower())
    deduped: list[str] = []
    seen: set[str] = set()
    for a in anchors:
        if a not in seen:
            seen.add(a)
            deduped.append(a)
    return deduped


