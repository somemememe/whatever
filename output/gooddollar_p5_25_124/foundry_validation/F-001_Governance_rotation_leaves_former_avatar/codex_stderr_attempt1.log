-            targetCdaiOut = 1;
-        }
-
-        uint256 low = 1;
-        uint256 high = 1e6;
-
-        while (high < remainingCap && IMarketMakerLike(marketMaker).sellReturn(cDai, high) < targetCdaiOut) {
