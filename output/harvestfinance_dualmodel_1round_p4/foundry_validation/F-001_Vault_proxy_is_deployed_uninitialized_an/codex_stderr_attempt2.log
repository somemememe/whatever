        require(msg.sender == governance, "not governance");
        _safeTransfer(token, recipient, amount);
    }

    function sweep(address recipient, address token, uint256 amount) external {
        require(msg.sender == governance, "not governance");
        _safeTransfer(token, recipient, amount);
