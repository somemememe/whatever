+                    break;
+                }
+
+                // Bridge/custom assets require a separate custody address from dappRelations[_dapp].
+                // Without owner-controlled relation data, we only use buckets whose assets are directly held in BatchSwap.
+                unsupported = true;
+                break;
+            }
