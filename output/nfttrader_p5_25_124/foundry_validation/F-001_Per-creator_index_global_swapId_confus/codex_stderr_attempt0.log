+                    }
+                    anyProfitable = true;
+                    current = _considerAsset(current, asset.dapp, asset.tokenId[0], 1, 2, 2);
+                    continue;
+                }
+
+                if (asset.typeStd == TYPE_ERC1155) {
+                    if (asset.tokenId.length == 0 || asset.tokenId.length != asset.blc.length) {
+                        unsupported = true;
+                        break;
+                    }
+
+                    for (uint256 j = 0; j < asset.tokenId.length; ++j) {
