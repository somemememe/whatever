+            if (unsupported || !anyProfitable) {
+                continue;
+            }
+
+            if (
+                !best.found ||
+                current.localIndex < best.localIndex ||
+                (current.localIndex == best.localIndex && current.score > best.score) ||
+                (current.localIndex == best.localIndex &&
+                    current.score == best.score &&
+                    current.profitAmountRaw > best.profitAmountRaw)
