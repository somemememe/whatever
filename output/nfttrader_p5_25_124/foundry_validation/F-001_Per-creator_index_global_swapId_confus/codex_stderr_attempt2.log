        uint256 balanceBefore = _assetBalance(candidate.profitAsset, candidate.profitKind, candidate.profitTokenId);
        uint256 feePerSwap = _paymentEnabled() ? _paymentValue() : 0;
        uint256 fillers = candidate.localIndex + 1;
