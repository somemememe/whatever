   143	            if(ERC721Interface(TRADESQUAD).balanceOf(msg.sender)==0) {
   144	                require(msg.value>=payment.value.add(_swapIntent.valueOne), "Not enought WEI for handle the transaction");
   145	                _swapIntent.swapFee = getWeiPayValueAmount() ;
   146	            }
   147	            else {
   148	                require(msg.value>=_swapIntent.valueOne, "Not enought WEI for handle the transaction");
   149	                _swapIntent.swapFee = 0 ;
   150	            }
   151	        }
   152	        else
   153	            require(msg.value>=_swapIntent.valueOne, "Not enought WEI for handle the transaction");
   154	
   155	        _swapIntent.addressOne = msg.sender;
   156	        _swapIntent.id = _swapIds.current();
   157	        _swapIntent.swapStart = block.timestamp;
   158	        _swapIntent.swapEnd = 0;
   159	        _swapIntent.status = swapStatus.Opened ;
   160	
   161	        swapMatch[_swapIds.current()] = swapList[msg.sender].length;
   162	        swapList[msg.sender].push(_swapIntent);
   163	        
   164	        uint256 i;
   165	        for(i=0; i<_nftsOne.length; i++)
   166	            nftsOne[_swapIntent.id].push(_nftsOne[i]);
   167	            
   168	        for(i=0; i<_nftsTwo.length; i++)
   169	            nftsTwo[_swapIntent.id].push(_nftsTwo[i]);
   170	        
   171	        for(i=0; i<nftsOne[_swapIntent.id].length; i++) {
   172	            require(whiteList[nftsOne[_swapIntent.id][i].dapp], "A DAPP is not handled by the system");
   173	            if(nftsOne[_swapIntent.id][i].typeStd == ERC20) {
   174	                ERC20Interface(nftsOne[_swapIntent.id][i].dapp).transferFrom(_swapIntent.addressOne, address(this), nftsOne[_swapIntent.id][i].blc[0]);
   175	            }
   176	            else if(nftsOne[_swapIntent.id][i].typeStd == ERC721) {
   177	                ERC721Interface(nftsOne[_swapIntent.id][i].dapp).safeTransferFrom(_swapIntent.addressOne, address(this), nftsOne[_swapIntent.id][i].tokenId[0], nftsOne[_swapIntent.id][i].data);
   178	            }
   179	            else if(nftsOne[_swapIntent.id][i].typeStd == ERC1155) {
   180	                ERC1155Interface(nftsOne[_swapIntent.id][i].dapp).safeBatchTransferFrom(_swapIntent.addressOne, address(this), nftsOne[_swapIntent.id][i].tokenId, nftsOne[_swapIntent.id][i].blc, nftsOne[_swapIntent.id][i].data);
   181	            }
   182	            else if(nftsOne[_swapIntent.id][i].typeStd == CRYPTOPUNK) { // Controllo che il CP sia presente sul proxy e che non sia in uso in un altro trade
   183	                require(punkInUse[nftsOne[_swapIntent.id][i].tokenId[0]] == false, "Punk in use on another trade");
   184	                require(CPInterface(CRYPTOPUNK).punkIndexToAddress(nftsOne[_swapIntent.id][i].tokenId[0]) == address(punkProxies[msg.sender]), "CryptoPunk missing");
   185	                punkInUse[nftsOne[_swapIntent.id][i].tokenId[0]] = true;
   186	            }
   187	            else {
   188	                customInterface(dappRelations[nftsOne[_swapIntent.id][i].dapp]).bridgeSafeTransferFrom(nftsOne[_swapIntent.id][i].dapp, _swapIntent.addressOne, dappRelations[nftsOne[_swapIntent.id][i].dapp], nftsOne[_swapIntent.id][i].tokenId, nftsOne[_swapIntent.id][i].blc, nftsOne[_swapIntent.id][i].data);
   189	            }
   190	        }
   191	
   192	        emit swapEvent(msg.sender, (block.timestamp-(block.timestamp%secs)), _swapIntent.status, _swapIntent.id, _swapIntent.addressTwo);
   193	        _swapIds.increment();
   194	    }
