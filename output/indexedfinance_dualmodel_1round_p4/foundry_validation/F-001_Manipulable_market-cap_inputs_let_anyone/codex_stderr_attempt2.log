    function _simulate(
        address pool,
        uint16 categoryID,
        bool useReindex,
        address tokenIn,
        address tokenOut,
        uint8 fundingMode,
        uint256 amountIn
    ) internal returns (uint256) {
        (bool ok, bytes memory ret) = address(this).call(
            abi.encodeWithSelector(
                this.simulateCandidate.selector,
                pool,
                categoryID,
                useReindex,
                tokenIn,
                tokenOut,
                fundingMode,
                amountIn
            )
        );
