        uint256 beforeWeth = _balanceOf(WETH, address(this));
        _executeCandidate(
            Candidate({
                pool: pool,
                tokenIn: tokenIn,
                tokenOut: tokenOut,
                categoryID: categoryID,
                useReindex: useReindex,
                fundingMode: fundingMode,
                amountIn: amountIn,
                expectedProfit: 0
            })
        );
