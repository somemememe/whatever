+        address pool;
+        address tokenIn;
+        address tokenOut;
+        uint16 categoryID;
+        bool useReindex;
+        uint8 fundingMode;
+        uint256 amountIn;
+        uint256 expectedProfit;
+    }
+
+    struct FlashContext {
