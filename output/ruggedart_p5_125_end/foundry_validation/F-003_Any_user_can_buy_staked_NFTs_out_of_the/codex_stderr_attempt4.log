/bin/bash -lc "python3 - <<'PY'
import json, glob, os
paths = glob.glob(os.path.expanduser('~/.foundry/cache/rpc/mainnet/*'))
selectors = ['6352211e','95d89b41','06fdde03','23b872dd','70a08231']
for path in paths:
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        continue
    for addr, acc in data.get('accounts', {}).items():
        code = ''
        if isinstance(acc, dict):
            code = acc.get('code', {}).get('LegacyAnalyzed', {}).get('bytecode', '')
        if code and all(s in code for s in selectors):
            print(path, addr)
