codex
The local Etherscan source cache turned out to be useful: it already contains verified source bundles with DN404/erc404-style contracts. I’m extracting contract names and constructor/init details from that cache now, because this looks like the missing link between the market and the underlying token.
exec
/bin/bash -lc "python3 - <<'PY'
import json, os, glob
for path in glob.glob(os.path.expanduser('~/.foundry/cache/etherscan/mainnet/sources/*.json')):
    try:
        with open(path) as f: data=json.load(f)
    except Exception:
        continue
    arr=data.get('data') or []
    for item in arr:
        source=json.dumps(item)
        if any(term in source.lower() for term in ['rugged','targetedpurchase','stakenfts','dn404','deeznutz']):
            print('FILE', os.path.basename(path))
            print('ContractName', item.get('ContractName'))
            print('ConstructorArguments', item.get('ConstructorArguments'))
            print('ABI first fn names maybe:')
            abi=item.get('ABI')
            if abi and abi.startswith('['):
                try:
                    abi_json=json.loads(abi)
                    print([x.get('name') for x in abi_json[:10] if isinstance(x,dict)])
                except Exception:
                    print('abi parse fail')
            print('---')
