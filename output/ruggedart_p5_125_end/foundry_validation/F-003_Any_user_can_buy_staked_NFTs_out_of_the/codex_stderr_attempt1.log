    function _targetedPurchase(uint256[] memory _tokenIds) private {
        for (uint256 i = 0; i < _tokenIds.length; i++) {
            if (_tokenIds[i] > ERC721_TOTAL_SUPPLY) {
                revert InvalidAmount();
            }
