        if (elapsedTime == 0) {
            return;
        }
        _accruedInterest.lastAccrued = uint64(block.timestamp);

        Rebase memory _totalBorrow = totalBorrow;
        if (_totalBorrow.base == 0) {
            accruedInterest = _accruedInterest;
            return;
