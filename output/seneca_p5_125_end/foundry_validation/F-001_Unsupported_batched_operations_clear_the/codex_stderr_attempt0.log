+            if (_borrowFits(mid, feeRate, totalCap, perAddressPart, totalElastic, totalBase)) {
+                low = mid;
+            } else {
+                high = mid - 1;
+            }
+        }
+
+        return low;
+    }
+
+    function _borrowFits(
+        uint256 amount,
+        uint256 feeRate,
+        uint128 totalCap,
+        uint128 perAddressPart,
+        uint128 totalElastic,
+        uint128 totalBase
+    ) internal pure returns (bool) {
