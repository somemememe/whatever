+        uint128 totalElastic,
+        uint128 totalBase,
+        uint256 elastic,
+        bool roundUp
+    ) internal pure returns (uint256 base) {
+        if (totalElastic == 0) {
+            return elastic;
+        }
+
+        base = (elastic * uint256(totalBase)) / uint256(totalElastic);
+        if (roundUp && (base * uint256(totalElastic)) / uint256(totalBase) < elastic) {
+            base += 1;
+        }
+    }
