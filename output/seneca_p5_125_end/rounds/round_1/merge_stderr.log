   130	    /// @notice Accrues the interest on the borrowed tokens and handles the accumulation of fees.
   131	    function accumulate() whenNotPaused public {
   132	        AccruedInfo memory _accruedInterest = accruedInterest;
   133	        // Number of seconds since accrue was called
   134	        uint256 elapsedTime = block.timestamp - _accruedInterest.lastAccrued;
   135	        if (elapsedTime == 0) {
   136	            return;
   137	        }
   138	        _accruedInterest.lastAccrued = uint64(block.timestamp);
   139	
   140	        Rebase memory _totalBorrow = totalBorrow;
   141	        if (_totalBorrow.base == 0) {
   142	            accruedInterest = _accruedInterest;
   143	            return;
   144	        }
   145	
   146	
   147	        uint128 extraAmount = uint128(uint256(_totalBorrow.elastic).mul(_accruedInterest.INTEREST_PER_SECOND).mul(elapsedTime) / 1e18);
   148	        _totalBorrow.elastic = uint128(_totalBorrow.elastic.add(extraAmount));
   149	
   150	        _accruedInterest.feesEarned = uint128(_accruedInterest.feesEarned.add(extraAmount));
   151	        totalBorrow = _totalBorrow;
   152	        accruedInterest = _accruedInterest;
   153	
   154	        emit AccumulateInterestEvent(extraAmount);
   155	    }
