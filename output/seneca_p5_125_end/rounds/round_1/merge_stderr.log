   157	    /// @notice Concrete implementation of `isSolvent`. Includes a third parameter to allow caching `exchangeRate`.
   158	    /// @param _exchangeRate The exchange rate. Used to cache the `exchangeRate` between calls.
   159	    function _isSolvent(address user, uint256 _exchangeRate) virtual internal view returns (bool) {
   160	        // accrue must have already been called!
   161	        uint256 borrowPart = userBorrowPart[user];
   162	        if (borrowPart == 0) return true;
   163	        uint256 collateralShare = userCollateralShare[user];
   164	        if (collateralShare == 0) return false;
   165	
   166	        Rebase memory _totalBorrow = totalBorrow;
   167	
   168	        return
   169	            bentoBox.toAmount(
   170	                collateral,
   171	                collateralShare.mul(Constants.EXCHANGE_RATE_PRECISION / Constants.COLLATERIZATION_RATE_PRECISION).mul(COLLATERIZATION_RATE),
   172	                false
   173	            ) >=
   174	            // Moved exchangeRate here instead of dividing the other side to preserve more precision
   175	            borrowPart.mul(_totalBorrow.elastic).mul(_exchangeRate) / _totalBorrow.base;
   176	    }
