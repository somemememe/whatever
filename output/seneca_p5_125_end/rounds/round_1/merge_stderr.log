   604	    function changeInterestRate(uint16 newInterestRateBps) public onlyMasterContractOwner {
   605	        uint64 oldInterestRate = accruedInterest.INTEREST_PER_SECOND;
   606	
   607	        uint64 newInterestRate = fromBps(newInterestRateBps);
   608	        
   609	        require(newInterestRate < oldInterestRate + oldInterestRate * 3 / 4 || newInterestRate <= ONE_PERCENT_RATE(), "Interest rate increase > 75%");
   610	        require(lastInterestUpdate + 3 days < block.timestamp, "Update only every 3 days");
   611	
   612	        lastInterestUpdate = block.timestamp;
   613	        accruedInterest.INTEREST_PER_SECOND = newInterestRate;
   614	        emit InterestChangeEvent(oldInterestRate, newInterestRate);
   615	    }
