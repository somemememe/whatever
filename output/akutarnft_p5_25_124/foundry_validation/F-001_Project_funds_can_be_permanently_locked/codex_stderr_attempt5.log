            }
            if (bidsPlaced > 1) {
                return (i, bidsPlaced);
            }
        }
    }

    function _recordCount(uint256 bidIndex_) internal pure returns (uint256) {
        return bidIndex_ == 0 ? 0 : bidIndex_ - 1;
    }

