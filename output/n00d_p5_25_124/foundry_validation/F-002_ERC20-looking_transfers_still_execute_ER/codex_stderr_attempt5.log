-
-        for (uint256 i = 0; i < fees.length; ++i) {
-            address pool = IUniswapV3FactoryLike(UNISWAP_V3_FACTORY).getPool(tokenIn, WETH, fees[i]);
-            if (pool == address(0) || pool.code.length == 0) {
-                continue;
