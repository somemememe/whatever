-    function _executeHop(Hop memory hop, uint256 amountIn) internal returns (uint256 amountOut) {
-        if (hop.venueKind == 1) {
-            return _swapExactInputViaV2Pair(hop.tokenIn, hop.venue, hop.tokenInIsToken0, amountIn);
-        }
-        if (hop.venueKind == 2) {
