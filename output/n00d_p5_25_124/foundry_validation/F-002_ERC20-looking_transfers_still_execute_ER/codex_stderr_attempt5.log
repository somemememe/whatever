-
-            (uint256 wethOut, bool ok) = _quoteV3ExactInput(tokenIn, WETH, fees[i], amountIn);
-            if (!ok || wethOut <= bestOut) {
-                continue;
-            }
-
-            bestOut = wethOut;
-            bestHop = Hop({
-                venueKind: 2,
-                venue: pool,
-                tokenIn: tokenIn,
-                tokenOut: WETH,
-                tokenInIsToken0: IUniswapV3PoolLike(pool).token0() == tokenIn,
-                fee: fees[i]
-            });
-        }
-    }
