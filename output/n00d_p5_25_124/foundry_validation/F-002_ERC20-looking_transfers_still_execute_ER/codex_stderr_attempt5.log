    function _findBestRoute() internal returns (RoutePlan memory bestPlan) {
        PairInfo[MAX_NOOD_PAIRS] memory pairs;
        uint256 pairCount = _loadNoodPairs(pairs);
        uint256[12] memory numerators = [uint256(1), 2, 3, 4, 5, 7, 10, 15, 20, 30, 40, 50];

        for (uint256 i = 0; i < pairCount; ++i) {
            PairInfo memory source = pairs[i];
            if (source.quoteToken != WETH) {
                continue;
            }

            for (uint256 k = 0; k < numerators.length; ++k) {
                uint256 rawBorrow = (source.reserveNood * numerators[k]) / 1000;
                uint256 borrowAmount = _floorToMultiple(rawBorrow, REENTRANCY_SLICES);
                if (borrowAmount == 0 || borrowAmount >= source.reserveNood) {
                    continue;
                }

                uint256 repayWeth = _getAmountIn(borrowAmount, source.reserveQuote, source.reserveNood);
                bestPlan = _considerV2Sinks(source, pairs, pairCount, borrowAmount, repayWeth, bestPlan);
                bestPlan = _considerV3Sinks(source, borrowAmount, repayWeth, bestPlan);
            }
        }
    }

    function _considerV2Sinks(
        PairInfo memory source,
        PairInfo[MAX_NOOD_PAIRS] memory pairs,
        uint256 pairCount,
        uint256 borrowAmount,
        uint256 repayWeth,
        RoutePlan memory bestPlan
    ) internal returns (RoutePlan memory) {
        for (uint256 j = 0; j < pairCount; ++j) {
            PairInfo memory sink = pairs[j];
            if (sink.pair == source.pair) {
                continue;
            }

            uint256 quoteOut = _getAmountOut(borrowAmount, sink.reserveNood, sink.reserveQuote);
            RoutePlan memory candidate = _finalizeCandidate(
                source,
                borrowAmount,
                repayWeth,
                Hop({
                    venueKind: 1,
                    venue: sink.pair,
                    tokenIn: NOOD,
                    tokenOut: sink.quoteToken,
                    tokenInIsToken0: sink.noodIsToken0,
                    fee: 0
                }),
                quoteOut
            );
            if (_better(candidate, bestPlan)) {
                bestPlan = candidate;
            }
        }
        return bestPlan;
    }

    function _considerV3Sinks(
        PairInfo memory source,
        uint256 borrowAmount,
        uint256 repayWeth,
        RoutePlan memory bestPlan
    ) internal returns (RoutePlan memory) {
        address[8] memory quotes = [WETH, USDC, USDT, DAI, WBTC, FRAX, FEI, MIM];
        uint24[4] memory fees = [uint24(100), 500, 3000, 10000];

        for (uint256 q = 0; q < quotes.length; ++q) {
            address quote = quotes[q];
            for (uint256 f = 0; f < fees.length; ++f) {
                address pool = IUniswapV3FactoryLike(UNISWAP_V3_FACTORY).getPool(NOOD, quote, fees[f]);
                if (pool == address(0) || pool.code.length == 0) {
                    continue;
                }

                (uint256 quoteOut, bool ok) = _quoteV3ExactInput(NOOD, quote, fees[f], borrowAmount);
                if (!ok || quoteOut == 0) {
                    continue;
                }

                RoutePlan memory candidate = _finalizeCandidate(
                    source,
                    borrowAmount,
                    repayWeth,
                    Hop({
                        venueKind: 2,
                        venue: pool,
                        tokenIn: NOOD,
                        tokenOut: quote,
                        tokenInIsToken0: IUniswapV3PoolLike(pool).token0() == NOOD,
                        fee: fees[f]
                    }),
                    quoteOut
                );
                if (_better(candidate, bestPlan)) {
                    bestPlan = candidate;
                }
            }
        }
        return bestPlan;
    }

    function _finalizeCandidate(
        PairInfo memory source,
        uint256 borrowAmount,
        uint256 repayWeth,
        Hop memory firstHop,
        uint256 firstHopOut
    ) internal returns (RoutePlan memory candidate) {
        if (firstHopOut == 0) {
            return candidate;
        }

        uint256 wethOut = firstHopOut;
        Hop memory secondHop;

        if (firstHop.tokenOut != WETH) {
            (secondHop, wethOut) = _bestBridgeToWeth(firstHop.tokenOut, firstHopOut);
            if (secondHop.venueKind == 0 || wethOut == 0) {
                return candidate;
            }
        }

        if (wethOut <= repayWeth) {
            return candidate;
        }

        candidate = RoutePlan({
            borrowPair: source.pair,
            borrowAmount: borrowAmount,
            repayWethAmount: repayWeth,
            expectedWethOut: wethOut,
            borrowNoodIsToken0: source.noodIsToken0,
            slices: REENTRANCY_SLICES,
            firstHop: firstHop,
            secondHop: secondHop,
            viable: true
        });
    }

    function _bestBridgeToWeth(address tokenIn, uint256 amountIn) internal returns (Hop memory bestHop, uint256 bestOut) {
