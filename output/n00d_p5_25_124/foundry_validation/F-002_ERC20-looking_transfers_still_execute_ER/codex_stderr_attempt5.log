-                address quote = quotes[j];
-                address pair = IUniswapV2FactoryLike(factories[i]).getPair(NOOD, quote);
-                if (pair == address(0) || pair.code.length == 0 || _containsPair(pairs, pairCount, pair)) {
-                    continue;
