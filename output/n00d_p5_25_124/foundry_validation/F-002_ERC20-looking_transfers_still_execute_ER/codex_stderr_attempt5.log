-        if (realizedProfit == 0 && bytes(concreteInfeasibility).length == 0) {
-            concreteInfeasibility =
-                "The ERC777 recipient-hook reentrancy reproduced correctly, but every discovered public exit route still failed to leave residual WETH after repaying the flashswapped n00d/WETH source pair at the fork block.";
