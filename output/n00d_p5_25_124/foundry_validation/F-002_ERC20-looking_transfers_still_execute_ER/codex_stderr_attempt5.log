-            }
-
-            uint256 quoteOut = _getAmountOut(borrowAmount, sink.reserveNood, sink.reserveQuote);
-            RoutePlan memory candidate = _finalizeCandidate(
-                source,
-                borrowAmount,
-                repayWeth,
-                Hop({
-                    venueKind: 1,
-                    venue: sink.pair,
-                    tokenIn: NOOD,
-                    tokenOut: sink.quoteToken,
-                    tokenInIsToken0: sink.noodIsToken0,
-                    fee: 0
-                }),
-                quoteOut
-            );
