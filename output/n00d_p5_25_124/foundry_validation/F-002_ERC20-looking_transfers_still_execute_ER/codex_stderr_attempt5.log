-    ) internal returns (RoutePlan memory) {
-        address[8] memory quotes = [WETH, USDC, USDT, DAI, WBTC, FRAX, FEI, MIM];
-        uint24[4] memory fees = [uint24(100), 500, 3000, 10000];
-
-        for (uint256 q = 0; q < quotes.length; ++q) {
