-    function _considerV3Sinks(
-        PairInfo memory source,
-        uint256 borrowAmount,
-        uint256 repayWeth,
-        RoutePlan memory bestPlan
-    ) internal returns (RoutePlan memory) {
-        address[8] memory quotes = [WETH, USDC, USDT, DAI, WBTC, FRAX, FEI, MIM];
-        uint24[4] memory fees = [uint24(100), 500, 3000, 10000];
-
-        for (uint256 q = 0; q < quotes.length; ++q) {
-            address quote = quotes[q];
-            for (uint256 f = 0; f < fees.length; ++f) {
-                address pool = IUniswapV3FactoryLike(UNISWAP_V3_FACTORY).getPool(NOOD, quote, fees[f]);
-                if (pool == address(0) || pool.code.length == 0) {
-                    continue;
-                }
-
-                (uint256 quoteOut, bool ok) = _quoteV3ExactInput(NOOD, quote, fees[f], borrowAmount);
-                if (!ok || quoteOut == 0) {
-                    continue;
-                }
-
-                RoutePlan memory candidate = _finalizeCandidate(
-                    source,
-                    borrowAmount,
-                    repayWeth,
-                    Hop({
-                        venueKind: 2,
-                        venue: pool,
-                        tokenIn: NOOD,
-                        tokenOut: quote,
-                        tokenInIsToken0: IUniswapV3PoolLike(pool).token0() == NOOD,
-                        fee: fees[f]
-                    }),
-                    quoteOut
-                );
-                if (_better(candidate, bestPlan)) {
-                    bestPlan = candidate;
-                }
-            }
-        }
-        return bestPlan;
-    }
-
-    function _finalizeCandidate(
-        PairInfo memory source,
-        uint256 borrowAmount,
-        uint256 repayWeth,
-        Hop memory firstHop,
-        uint256 firstHopOut
-    ) internal returns (RoutePlan memory candidate) {
-        if (firstHopOut == 0) {
-            return candidate;
-        }
-
-        uint256 wethOut = firstHopOut;
-        Hop memory secondHop;
-
-        if (firstHop.tokenOut != WETH) {
-            (secondHop, wethOut) = _bestBridgeToWeth(firstHop.tokenOut, firstHopOut);
-            if (secondHop.venueKind == 0 || wethOut == 0) {
-                return candidate;
-            }
-        }
-
-        if (wethOut <= repayWeth) {
-            return candidate;
-        }
-
-        candidate = RoutePlan({
-            borrowPair: source.pair,
-            borrowAmount: borrowAmount,
-            repayWethAmount: repayWeth,
-            expectedWethOut: wethOut,
-            borrowNoodIsToken0: source.noodIsToken0,
-            slices: REENTRANCY_SLICES,
-            firstHop: firstHop,
-            secondHop: secondHop,
-            viable: true
-        });
-    }
