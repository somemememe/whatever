-                bestOut = wethOut;
-                bestHop = Hop({
-                    venueKind: 1,
-                    venue: pair,
-                    tokenIn: tokenIn,
-                    tokenOut: WETH,
-                    tokenInIsToken0: tokenInIsToken0,
-                    fee: 0
-                });
