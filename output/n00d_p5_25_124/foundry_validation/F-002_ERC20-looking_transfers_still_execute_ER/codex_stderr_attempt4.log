-    }
-
-    function _findBestAlternateRoute() internal view returns (RoutePlan memory bestPlan) {
-        PairInfo[MAX_NOOD_PAIRS] memory pairs;
-        uint256 pairCount = _loadNoodPairs(pairs);
-
-        for (uint256 i = 0; i < pairCount; ++i) {
-            PairInfo memory source = pairs[i];
-            if (source.quoteToken != WETH) {
-                continue;
-            }
-
-            for (uint256 j = 0; j < pairCount; ++j) {
-                PairInfo memory sink = pairs[j];
-                if (sink.pair == source.pair) {
-                    continue;
-                }
-
-                RoutePlan memory candidate = _bestRouteForSourceSink(source, sink);
-                if (!candidate.viable) {
-                    continue;
-                }
-
-                if (
-                    !bestPlan.viable
-                        || candidate.expectedWethOut - candidate.repayWethAmount
-                            > bestPlan.expectedWethOut - bestPlan.repayWethAmount
-                ) {
-                    bestPlan = candidate;
-                }
-            }
-        }
-    }
-
-    function _bestRouteForSourceSink(PairInfo memory source, PairInfo memory sink)
-        internal
-        view
-        returns (RoutePlan memory bestPlan)
-    {
-        uint256[12] memory numerators = [uint256(1), 2, 3, 4, 5, 7, 10, 15, 20, 30, 40, 50];
-
-        for (uint256 k = 0; k < numerators.length; ++k) {
-            uint256 rawBorrow = (source.reserveNood * numerators[k]) / 1000;
-            uint256 borrowAmount = _floorToMultiple(rawBorrow, REENTRANCY_SLICES);
-            if (borrowAmount == 0 || borrowAmount >= source.reserveNood) {
-                continue;
-            }
-
-            uint256 repayWeth = _getAmountIn(borrowAmount, source.reserveQuote, source.reserveNood);
-            uint256 sinkQuoteOut = _getAmountOut(borrowAmount, sink.reserveNood, sink.reserveQuote);
-
-            uint256 wethOut;
-            address bridgePair;
-            bool bridgeTokenInIsToken0;
-
-            if (sink.quoteToken == WETH) {
-                wethOut = sinkQuoteOut;
-            } else {
-                BridgeInfo memory bridge = _bestBridgeToWeth(sink.quoteToken, sinkQuoteOut);
-                if (!bridge.viable) {
-                    continue;
-                }
-
-                wethOut = _getAmountOut(sinkQuoteOut, bridge.reserveIn, bridge.reserveOut);
