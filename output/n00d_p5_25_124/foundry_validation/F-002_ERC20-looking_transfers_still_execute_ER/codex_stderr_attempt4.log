-        require(msg.sender == plan.borrowPair, "unexpected pair");
-
-        uint256 borrowedNood = amount0 != 0 ? amount0 : amount1;
-        require(borrowedNood == plan.borrowAmount, "unexpected amount");
-
-        IERC20Like nood = IERC20Like(NOOD);
