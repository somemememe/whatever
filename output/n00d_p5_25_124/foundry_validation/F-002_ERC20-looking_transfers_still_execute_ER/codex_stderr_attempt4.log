-            IUniswapV2PairLike(plan.borrowPair).swap(plan.borrowAmount, 0, address(this), data);
-        } else {
-            IUniswapV2PairLike(plan.borrowPair).swap(0, plan.borrowAmount, address(this), data);
-        }
