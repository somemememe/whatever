// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Minimal {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IRestakedETHLike is IERC20Minimal {
    function stakedTokenAddress() external view returns (address);
    function scaledBalanceOf(address who) external view returns (uint256);
    function scaledBalanceToBalance(uint256 scaledBalance) external view returns (uint256);
    function mint(address to, uint256 amount) external;
    function burn(address from, uint256 amount) external;
    function rebase(uint256 epoch, bool isRebasePositive, uint256 supplyDelta) external returns (uint256);
}

interface IAstridProtocol {
    function stakedTokens(address stakedToken)
        external
        view
        returns (bool whitelisted, address restakedTokenAddress, address eigenLayerStrategyAddress);

    function totalClaimableWithdrawals(address stakedToken) external view returns (uint256);
    function processWithdrawalsOnWithdraw() external view returns (bool);
    function withdrawalRequestsByUserLength(address withdrawer) external view returns (uint256);
    function withdraw(address restakedTokenAddress, uint256 amount) external;
    function processWithdrawals() external;
    function claim(uint256 withdrawerIndex) external;
}

contract FakeRestakedETH is IRestakedETHLike {
    string public constant name = "Fake Astrid Restaked ETH";
    string public constant symbol = "frETH";
    uint8 public constant decimals = 18;

    address public immutable override stakedTokenAddress;
    address public immutable controller;

    uint256 public override totalSupply;
    mapping(address => uint256) public override balanceOf;
    mapping(address => mapping(address => uint256)) public override allowance;

    constructor(address _stakedTokenAddress, address _controller) {
        stakedTokenAddress = _stakedTokenAddress;
        controller = _controller;
    }

    function scaledBalanceOf(address who) external view override returns (uint256) {
        return balanceOf[who];
    }

    function scaledBalanceToBalance(uint256 scaledBalance) external pure override returns (uint256) {
        return scaledBalance;
    }

    function mint(address to, uint256 amount) external override {
        require(msg.sender == controller, "not controller");
        _mint(to, amount);
    }

    function burn(address from, uint256 amount) external override {
        // Astrid trusts this attacker-controlled hook during withdrawal processing.
        _burn(from, amount);
    }

    function rebase(uint256, bool, uint256) external view override returns (uint256) {
        return totalSupply;
    }

    function approve(address spender, uint256 amount) external override returns (bool) {
        allowance[msg.sender][spender] = amount;
        return true;
    }

    function transfer(address to, uint256 amount) external override returns (bool) {
        _transfer(msg.sender, to, amount);
        return true;
    }

    function transferFrom(address from, address to, uint256 amount) external override returns (bool) {
        uint256 allowed = allowance[from][msg.sender];
        if (msg.sender != from && allowed != type(uint256).max) {
            require(allowed >= amount, "insufficient allowance");
            allowance[from][msg.sender] = allowed - amount;
        }
        _transfer(from, to, amount);
        return true;
    }

    function _mint(address to, uint256 amount) internal {
        totalSupply += amount;
        balanceOf[to] += amount;
    }

    function _burn(address from, uint256 amount) internal {
        require(balanceOf[from] >= amount, "insufficient balance");
        unchecked {
            balanceOf[from] -= amount;
            totalSupply -= amount;
        }
    }

    function _transfer(address from, address to, uint256 amount) internal {
        require(balanceOf[from] >= amount, "insufficient balance");
        unchecked {
            balanceOf[from] -= amount;
            balanceOf[to] += amount;
        }
    }
}

