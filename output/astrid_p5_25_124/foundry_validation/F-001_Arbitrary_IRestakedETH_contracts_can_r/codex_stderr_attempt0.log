                profitAmount_ = balanceAfter - balanceBefore;
            }
        } catch {}

        executed = true;
    }

    function profitToken() external view returns (address) {
        return profitToken_;
    }

    function profitAmount() external view returns (uint256) {
        return profitAmount_;
    }

    function candidateCount() external view returns (uint256) {
        return candidateStakedTokens.length;
    }

    function _selectTargetToken() internal {
        uint256 bestAvailable;
        address bestToken;

        for (uint256 i = 0; i < candidateStakedTokens.length; ++i) {
