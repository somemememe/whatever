   377	    function deposit(address _stakedTokenAddress, uint256 amount) public nonReentrant whenNotPaused {
   378	        require(Utils.contractExists(_stakedTokenAddress), "AstridProtocol: Contract does not exist");
   379	        require(amount > 0, "AstridProtocol: Amount must be greater than 0");
   380	        StakedTokenMapping memory stakedTokenMapping = stakedTokens[_stakedTokenAddress];
   381	
   382	        require(stakedTokenMapping.whitelisted, "AstridProtocol: Staked token not whitelisted");
   383	        require(IERC20(_stakedTokenAddress).balanceOf(msg.sender) >= amount, "AstridProtocol: Insufficient balance of staked token");
   384	        require(IERC20(_stakedTokenAddress).allowance(msg.sender, address(this)) >= amount, "AstridProtocol: Insufficient allowance of staked token");
   385	
   386	        // receive staked token from user
   387	        bool amountSent = Utils.payMe(msg.sender, amount, _stakedTokenAddress);
   388	        require(amountSent, "AstridProtocol: Failed to send staked token");
   389	
   390	        // mint restaked token to user
   391	        IRestakedETH(stakedTokenMapping.restakedTokenAddress).mint(msg.sender, amount);
   392	
   393	        // save stake info
   394	        deposits[msg.sender].push(DepositInfo({
   395	            staker: msg.sender,
   396	            stakedTokenAddress: _stakedTokenAddress,
   397	            amount: amount,
   398	            stakedAt: block.timestamp
   399	        }));
   400	
   401	        // emit staked performed event
   402	        emit DepositPerformed(msg.sender, _stakedTokenAddress, amount);
   403	    }
   404	
   405	    function withdraw(address _restakedTokenAddress, uint256 amount) public nonReentrant whenNotPaused {
   406	        require(Utils.contractExists(_restakedTokenAddress), "AstridProtocol: Contract does not exist");
   407	        require(amount > 0, "AstridProtocol: Amount must be greater than 0");
   408	        require(IERC20(_restakedTokenAddress).balanceOf(msg.sender) >= amount, "AstridProtocol: Insufficient balance of restaked token");
   409	        require(IERC20(_restakedTokenAddress).allowance(msg.sender, address(this)) >= amount, "AstridProtocol: Insufficient allowance of restaked token");
   410	
   411	        uint256 sharesBefore = IRestakedETH(_restakedTokenAddress).scaledBalanceOf(address(this));
   412	
   413	        // receive restaked token from user to "lock" it
   414	        bool amountSent = Utils.payMe(msg.sender, amount, _restakedTokenAddress);
   415	        require(amountSent, "AstridProtocol: Failed to send restaked token");
   416	
   417	        uint256 sharesAfter = IRestakedETH(_restakedTokenAddress).scaledBalanceOf(address(this));
   418	        uint256 shares = sharesAfter.sub(sharesBefore); // we store shares of restakedETH to ensure that it is still subject to rebase when locked
   419	
   420	        WithdrawalRequest memory request = WithdrawalRequest({
   421	            withdrawer: msg.sender,
   422	            restakedTokenAddress: _restakedTokenAddress,
   423	            amount: amount,
   424	            requestedRestakedTokenShares: shares,
   425	            claimableStakedTokenAmount: 0, // placeholder
   426	            status: WithdrawalStatus.REQUESTED,
   427	            withdrawalStartBlock: uint32(block.number),
   428	            withdrawRequestedAt: block.timestamp,
   429	            withdrawProcessedAt: 0,
   430	            withdrawClaimedAt: 0,
   431	            withdrawalRequestsIndex: withdrawalRequests.length,
   432	            withdrawalRequestsByUserIndex: withdrawalRequestsByUser[msg.sender].length
   433	        });
   434	
   435	        totalWithdrawalRequests[_restakedTokenAddress] += shares;
   436	        withdrawalRequests.push(request);
   437	        withdrawalRequestsByUser[msg.sender].push(request);
   438	
   439	        emit WithdrawalRequested(msg.sender, _restakedTokenAddress, amount, shares);
   440	
   441	        if (processWithdrawalsOnWithdraw) {
   442	            _processWithdrawals();
   443	        }
   444	    }
   445	
   446	    function processWithdrawals() public nonReentrant whenNotPaused onlyRole(DEFAULT_ADMIN_ROLE) {
   447	        _processWithdrawals();
   448	    }
   449	
   450	    function _processWithdrawals() internal whenNotPaused {
   451	        uint256 _withdrawalRequestsLength = withdrawalRequests.length;
   452	        while(withdrawalProcessingCurrentIndex < _withdrawalRequestsLength) {
   453	            WithdrawalRequest memory request = withdrawalRequests[withdrawalProcessingCurrentIndex];
   454	            require(request.status == WithdrawalStatus.REQUESTED, "AstridProtocol: Withdrawal status mismatch");
   455	
   456	            address _restakedTokenAddress = request.restakedTokenAddress;
   457	            address _stakedTokenAddress = IRestakedETH(_restakedTokenAddress).stakedTokenAddress();
   458	            uint256 requestedAmount = IRestakedETH(_restakedTokenAddress).scaledBalanceToBalance(request.requestedRestakedTokenShares);
   459	            if (requestedAmount > IERC20(_stakedTokenAddress).balanceOf(address(this)) - totalClaimableWithdrawals[_stakedTokenAddress]) {
   460	                break;
   461	            }
   462	
   463	            totalWithdrawalRequests[_restakedTokenAddress] -= request.requestedRestakedTokenShares;
   464	            IRestakedETH(_restakedTokenAddress).burn(address(this), requestedAmount);
   465	            totalClaimableWithdrawals[_stakedTokenAddress] += requestedAmount;
   466	
   467	            withdrawalRequests[withdrawalProcessingCurrentIndex].claimableStakedTokenAmount = requestedAmount;
   468	            withdrawalRequests[withdrawalProcessingCurrentIndex].status = WithdrawalStatus.PROCESSED;
   469	            withdrawalRequests[withdrawalProcessingCurrentIndex].withdrawProcessedAt = block.timestamp;
   470	
   471	            uint256 withdrawerIndex = request.withdrawalRequestsByUserIndex;
   472	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].claimableStakedTokenAmount = requestedAmount;
   473	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].status = WithdrawalStatus.PROCESSED;
   474	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].withdrawProcessedAt = block.timestamp;
   475	
   476	            emit WithdrawalProcessed(withdrawalProcessingCurrentIndex);
   477	
   478	            withdrawalProcessingCurrentIndex += 1;
   479	        }
   480	    }
   481	
   482	    function claim(uint256 withdrawerIndex) public nonReentrant whenNotPaused {
   483	        require(withdrawerIndex < withdrawalRequestsByUser[msg.sender].length, "AstridProtocol: withdrawerIndex out of bounds");
   484	        WithdrawalRequest memory request = withdrawalRequestsByUser[msg.sender][withdrawerIndex];
   485	
   486	        require(request.status == WithdrawalStatus.PROCESSED, "AstridProtocol: Withdrawal status mismatch");
   487	        require(request.withdrawer == msg.sender, "AstridProtocol: Invalid withdrawer");
   488	
   489	        address _stakedTokenAddress = IRestakedETH(request.restakedTokenAddress).stakedTokenAddress();
   490	
   491	        withdrawalRequests[request.withdrawalRequestsIndex].status = WithdrawalStatus.CLAIMED;
   492	        withdrawalRequests[request.withdrawalRequestsIndex].withdrawClaimedAt = block.timestamp;
   493	        withdrawalRequestsByUser[msg.sender][withdrawerIndex].status = WithdrawalStatus.CLAIMED;
   494	        withdrawalRequestsByUser[msg.sender][withdrawerIndex].withdrawClaimedAt = block.timestamp;
   495	
   496	        totalClaimableWithdrawals[_stakedTokenAddress] -= request.claimableStakedTokenAmount;
   497	
   498	        bool sent = Utils.payDirect(msg.sender, request.claimableStakedTokenAmount, _stakedTokenAddress);
   499	        require(sent, "AstridProtocol: Failed to send staked token");
   500	
   501	        emit WithdrawalClaimed(msg.sender, request.withdrawalRequestsIndex);
   502	    }
   503	
   504	    /* TO BE DEPRECATED */
   505	    function restakesLength(address staker) public view returns (uint256) {
   506	        return restakes[staker].length + deposits[staker].length;
   507	    }
   508	
   509	    function withdrawalsLength(address withdrawer) public view returns (uint256) {
   510	        return withdrawals[withdrawer].length;
   511	    }
   512	
   513	    event WithdrawCompleted(address indexed to, uint96 withdrawalIndex);
   514	
   515	    // Supports completion of old withdrawals
   516	    function completeQueuedWithdrawal(uint96 withdrawalIndex, uint256 middlewareTimesIndex) public nonReentrant whenNotPaused {
   517	        require(withdrawalIndex < withdrawals[msg.sender].length, "AstridProtocol: withdrawalIndex out of bounds");
   518	        WithdrawalInfo memory withdrawalInfo = withdrawals[msg.sender][withdrawalIndex];
   519	
   520	        require(withdrawalInfo.withdrawCompletedAt == 0, "AstridProtocol: Withdrawal already completed");
   521	        require(withdrawalInfo.withdrawer == msg.sender, "AstridProtocol: Invalid withdrawer");
   522	
   523	        address _stakedTokenAddress = IRestakedETH(withdrawalInfo.restakedTokenAddress).stakedTokenAddress();
   524	
   525	        IStrategy[] memory strategiesArr = new IStrategy[](1);
   526	        strategiesArr[0] = IStrategy(stakedTokens[_stakedTokenAddress].eigenLayerStrategyAddress);
   527	        uint256[] memory sharesArr = new uint256[](1);
   528	        sharesArr[0] = withdrawalInfo.shares;
   529	
   530	        address operator = IDelegationManager(IStrategyManager(eigenLayerStrategyManagerAddress).delegation()).delegatedTo(address(this));
   531	
   532	        IStrategyManager.QueuedWithdrawal memory queuedWithdrawal = IStrategyManager.QueuedWithdrawal({
   533	            strategies: strategiesArr,
   534	            shares: sharesArr,
   535	            depositor: address(this),
   536	            withdrawerAndNonce: IStrategyManager.WithdrawerAndNonce({
   537	                withdrawer: address(this),
   538	                nonce: uint96(withdrawalInfo.nonce)
   539	            }),
   540	            withdrawalStartBlock: withdrawalInfo.withdrawalStartBlock,
   541	            delegatedAddress: operator
   542	        });
   543	
   544	        IERC20[] memory tokens = new IERC20[](1);
   545	        tokens[0] = IERC20(_stakedTokenAddress);
   546	
   547	        uint256 balanceBefore = IERC20(_stakedTokenAddress).balanceOf(address(this));
   548	        IStrategyManager(eigenLayerStrategyManagerAddress).completeQueuedWithdrawal(
   549	            queuedWithdrawal,
   550	            tokens,
   551	            middlewareTimesIndex,
   552	            true
   553	        );
   554	        uint256 balanceAfter = IERC20(_stakedTokenAddress).balanceOf(address(this));
   555	
   556	        withdrawals[msg.sender][withdrawalIndex].pending = false;
   557	        withdrawals[msg.sender][withdrawalIndex].withdrawCompletedAt = block.timestamp;
   558	
   559	        bool sent = Utils.payDirect(msg.sender, balanceAfter.sub(balanceBefore), _stakedTokenAddress);
   560	        require(sent, "AstridProtocol: Failed to send staked token");
   561	
   562	        emit WithdrawCompleted(msg.sender, withdrawalIndex);
   563	    }
   564	    /* END TO BE DEPRECATED */
   565	
   566	}
