   325	        StakedTokenMapping memory stakedTokenMapping = stakedTokens[_stakedTokenAddress];
   326	
   327	        uint256 _stakedTokenBackedSupply;
   328	        for (uint256 i; i < delegators.length; i++) {
   329	            _stakedTokenBackedSupply += delegators[i].getAssetBalance(_stakedTokenAddress, stakedTokenMapping.eigenLayerStrategyAddress);
   330	        }
   331	        _stakedTokenBackedSupply += IERC20(_stakedTokenAddress).balanceOf(address(this));
   332	        _stakedTokenBackedSupply -= totalClaimableWithdrawals[_stakedTokenAddress];
   333	
   334	        ReBaseInfo memory info = ReBaseInfo({
   335	            restakedTokenTotalSupply: IRestakedETH(stakedTokenMapping.restakedTokenAddress).totalSupply(),
   336	            stakedTokenBackedSupply: _stakedTokenBackedSupply,
   337	            currentBlock: uint32(block.number),
   338	            currentTimestamp: block.timestamp
   339	        });
   340	
   341	        return info;
   342	    }
   343	
   344	    function rebase(address _stakedTokenAddress) public whenNotPaused onlyRole(REBASER_ROLE) returns (uint256 _totalSupply) {
   345	        require(Utils.contractExists(_stakedTokenAddress), "AstridProtocol: Contract does not exist");
   346	        ReBaseInfo memory info = rebaseInfo(_stakedTokenAddress);
   347	        require(info.restakedTokenTotalSupply != info.stakedTokenBackedSupply, "AstridProtocol: restakedTokenTotalSupply = stakedTokenBackedSupply");
   348	
   349	        address _restakedTokenAddress = stakedTokens[_stakedTokenAddress].restakedTokenAddress;
   350	        uint256 _supplyDelta;
   351	        bool _isRebasePositive;
   352	
   353	        if (info.restakedTokenTotalSupply < info.stakedTokenBackedSupply) {
   354	            _supplyDelta = info.stakedTokenBackedSupply - info.restakedTokenTotalSupply;
   355	            _isRebasePositive = true;
   356	        } else {
   357	            _supplyDelta = info.restakedTokenTotalSupply - info.stakedTokenBackedSupply;
   358	            _isRebasePositive = false;
   359	        }
   360	
   361	        _totalSupply = IRestakedETH(_restakedTokenAddress).rebase(info.currentTimestamp, _isRebasePositive, _supplyDelta);
   362	        emit RebasePerformed(_restakedTokenAddress, info.currentTimestamp, _totalSupply, _isRebasePositive, _supplyDelta);
   363	    }
   364	
   365	    function depositsLength(address staker) public view returns (uint256) {
   366	        return deposits[staker].length;
   367	    }
