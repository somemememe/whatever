   489	        address _stakedTokenAddress = IRestakedETH(request.restakedTokenAddress).stakedTokenAddress();
   490	
   491	        withdrawalRequests[request.withdrawalRequestsIndex].status = WithdrawalStatus.CLAIMED;
   492	        withdrawalRequests[request.withdrawalRequestsIndex].withdrawClaimedAt = block.timestamp;
   493	        withdrawalRequestsByUser[msg.sender][withdrawerIndex].status = WithdrawalStatus.CLAIMED;
   494	        withdrawalRequestsByUser[msg.sender][withdrawerIndex].withdrawClaimedAt = block.timestamp;
   495	
   496	        totalClaimableWithdrawals[_stakedTokenAddress] -= request.claimableStakedTokenAmount;
   497	
   498	        bool sent = Utils.payDirect(msg.sender, request.claimableStakedTokenAmount, _stakedTokenAddress);
   499	        require(sent, "AstridProtocol: Failed to send staked token");
   500	
   501	        emit WithdrawalClaimed(msg.sender, request.withdrawalRequestsIndex);
   502	    }
