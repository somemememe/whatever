   513	    event WithdrawCompleted(address indexed to, uint96 withdrawalIndex);
   514	
   515	    // Supports completion of old withdrawals
   516	    function completeQueuedWithdrawal(uint96 withdrawalIndex, uint256 middlewareTimesIndex) public nonReentrant whenNotPaused {
   517	        require(withdrawalIndex < withdrawals[msg.sender].length, "AstridProtocol: withdrawalIndex out of bounds");
