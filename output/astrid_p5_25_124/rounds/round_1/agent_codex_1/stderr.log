   446	    function processWithdrawals() public nonReentrant whenNotPaused onlyRole(DEFAULT_ADMIN_ROLE) {
   447	        _processWithdrawals();
   448	    }
   449	
   450	    function _processWithdrawals() internal whenNotPaused {
   451	        uint256 _withdrawalRequestsLength = withdrawalRequests.length;
   452	        while(withdrawalProcessingCurrentIndex < _withdrawalRequestsLength) {
   453	            WithdrawalRequest memory request = withdrawalRequests[withdrawalProcessingCurrentIndex];
   454	            require(request.status == WithdrawalStatus.REQUESTED, "AstridProtocol: Withdrawal status mismatch");
   455	
   456	            address _restakedTokenAddress = request.restakedTokenAddress;
   457	            address _stakedTokenAddress = IRestakedETH(_restakedTokenAddress).stakedTokenAddress();
   458	            uint256 requestedAmount = IRestakedETH(_restakedTokenAddress).scaledBalanceToBalance(request.requestedRestakedTokenShares);
   459	            if (requestedAmount > IERC20(_stakedTokenAddress).balanceOf(address(this)) - totalClaimableWithdrawals[_stakedTokenAddress]) {
   460	                break;
   461	            }
   462	
   463	            totalWithdrawalRequests[_restakedTokenAddress] -= request.requestedRestakedTokenShares;
   464	            IRestakedETH(_restakedTokenAddress).burn(address(this), requestedAmount);
   465	            totalClaimableWithdrawals[_stakedTokenAddress] += requestedAmount;
   466	
   467	            withdrawalRequests[withdrawalProcessingCurrentIndex].claimableStakedTokenAmount = requestedAmount;
   468	            withdrawalRequests[withdrawalProcessingCurrentIndex].status = WithdrawalStatus.PROCESSED;
   469	            withdrawalRequests[withdrawalProcessingCurrentIndex].withdrawProcessedAt = block.timestamp;
   470	
   471	            uint256 withdrawerIndex = request.withdrawalRequestsByUserIndex;
   472	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].claimableStakedTokenAmount = requestedAmount;
   473	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].status = WithdrawalStatus.PROCESSED;
   474	            withdrawalRequestsByUser[request.withdrawer][withdrawerIndex].withdrawProcessedAt = block.timestamp;
   475	
   476	            emit WithdrawalProcessed(withdrawalProcessingCurrentIndex);
   477	
   478	            withdrawalProcessingCurrentIndex += 1;
   479	        }
   480	    }
   481	
   482	    function claim(uint256 withdrawerIndex) public nonReentrant whenNotPaused {
   483	        require(withdrawerIndex < withdrawalRequestsByUser[msg.sender].length, "AstridProtocol: withdrawerIndex out of bounds");
   484	        WithdrawalRequest memory request = withdrawalRequestsByUser[msg.sender][withdrawerIndex];
   485	
   486	        require(request.status == WithdrawalStatus.PROCESSED, "AstridProtocol: Withdrawal status mismatch");
   487	        require(request.withdrawer == msg.sender, "AstridProtocol: Invalid withdrawer");
