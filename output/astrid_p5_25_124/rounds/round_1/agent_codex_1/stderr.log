   377	    function deposit(address _stakedTokenAddress, uint256 amount) public nonReentrant whenNotPaused {
   378	        require(Utils.contractExists(_stakedTokenAddress), "AstridProtocol: Contract does not exist");
   379	        require(amount > 0, "AstridProtocol: Amount must be greater than 0");
   380	        StakedTokenMapping memory stakedTokenMapping = stakedTokens[_stakedTokenAddress];
   381	
   382	        require(stakedTokenMapping.whitelisted, "AstridProtocol: Staked token not whitelisted");
