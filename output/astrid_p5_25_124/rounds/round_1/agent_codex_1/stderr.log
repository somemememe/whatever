   384	        require(IERC20(_stakedTokenAddress).allowance(msg.sender, address(this)) >= amount, "AstridProtocol: Insufficient allowance of staked token");
   385	
   386	        // receive staked token from user
   387	        bool amountSent = Utils.payMe(msg.sender, amount, _stakedTokenAddress);
   388	        require(amountSent, "AstridProtocol: Failed to send staked token");
   389	
   390	        // mint restaked token to user
   391	        IRestakedETH(stakedTokenMapping.restakedTokenAddress).mint(msg.sender, amount);
   392	
   393	        // save stake info
   394	        deposits[msg.sender].push(DepositInfo({
   395	            staker: msg.sender,
   396	            stakedTokenAddress: _stakedTokenAddress,
   397	            amount: amount,
   398	            stakedAt: block.timestamp
   399	        }));
   400	
   401	        // emit staked performed event
