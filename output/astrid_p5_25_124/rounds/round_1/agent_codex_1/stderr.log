   405	    function withdraw(address _restakedTokenAddress, uint256 amount) public nonReentrant whenNotPaused {
   406	        require(Utils.contractExists(_restakedTokenAddress), "AstridProtocol: Contract does not exist");
   407	        require(amount > 0, "AstridProtocol: Amount must be greater than 0");
   408	        require(IERC20(_restakedTokenAddress).balanceOf(msg.sender) >= amount, "AstridProtocol: Insufficient balance of restaked token");
   409	        require(IERC20(_restakedTokenAddress).allowance(msg.sender, address(this)) >= amount, "AstridProtocol: Insufficient allowance of restaked token");
   410	
   411	        uint256 sharesBefore = IRestakedETH(_restakedTokenAddress).scaledBalanceOf(address(this));
   412	
   413	        // receive restaked token from user to "lock" it
   414	        bool amountSent = Utils.payMe(msg.sender, amount, _restakedTokenAddress);
   415	        require(amountSent, "AstridProtocol: Failed to send restaked token");
   416	
   417	        uint256 sharesAfter = IRestakedETH(_restakedTokenAddress).scaledBalanceOf(address(this));
   418	        uint256 shares = sharesAfter.sub(sharesBefore); // we store shares of restakedETH to ensure that it is still subject to rebase when locked
   419	
   420	        WithdrawalRequest memory request = WithdrawalRequest({
   421	            withdrawer: msg.sender,
   422	            restakedTokenAddress: _restakedTokenAddress,
   423	            amount: amount,
   424	            requestedRestakedTokenShares: shares,
   425	            claimableStakedTokenAmount: 0, // placeholder
   426	            status: WithdrawalStatus.REQUESTED,
   427	            withdrawalStartBlock: uint32(block.number),
   428	            withdrawRequestedAt: block.timestamp,
   429	            withdrawProcessedAt: 0,
   430	            withdrawClaimedAt: 0,
   431	            withdrawalRequestsIndex: withdrawalRequests.length,
   432	            withdrawalRequestsByUserIndex: withdrawalRequestsByUser[msg.sender].length
   433	        });
   434	
   435	        totalWithdrawalRequests[_restakedTokenAddress] += shares;
   436	        withdrawalRequests.push(request);
   437	        withdrawalRequestsByUser[msg.sender].push(request);
   438	
   439	        emit WithdrawalRequested(msg.sender, _restakedTokenAddress, amount, shares);
   440	
   441	        if (processWithdrawalsOnWithdraw) {
   442	            _processWithdrawals();
   443	        }
   444	    }
