    31	    }
    32	
    33	    address public override trackingToken;
    34	    address public override rewardsToken;
    35	    uint256 public override totalShares;
    36	    uint256 public override totalStakers;
    37	    mapping(address => uint256) public shares;
    38	    mapping(address => Reward) public rewards;
    39	
    40	    uint256 _rewardsSwapSlippage = 10; // 1%
    41	    uint256 _rewardsPerShare;
    42	    uint256 public rewardsDistributed;
    43	    uint256 public rewardsDeposited;
    44	    mapping(uint256 => uint256) public rewardsDepMonthly;
    45	
    46	    modifier onlyTrackingToken() {
    47	        require(_msgSender() == trackingToken, "UNAUTHORIZED");
    48	        _;
    49	    }
    50	
    51	    constructor(
    52	        IV3TwapUtilities _v3TwapUtilities,
    53	        address _dai,
    54	        address _trackingToken,
    55	        address _rewardsToken
    56	    ) {
    57	        V3_TWAP_UTILS = _v3TwapUtilities;
    58	        DAI = _dai;
    59	
    60	        trackingToken = _trackingToken;
    61	        rewardsToken = _rewardsToken;
    62	    }
    63	
    64	    function updateReferral(address _referral) external {
    65	        if (address(referral) == address(0)) {
    66	            referral = IReferral(_referral);
    67	        } else {
    68	            require(_msgSender() == referral.owner(), "UNAUTHORIZED");
    69	            referral = IReferral(_referral);
    70	        }
    71	    }
    72	
    73	    function setShares(
    74	        address _wallet,
    75	        uint256 _amount,
    76	        bool _sharesRemoving
    77	    ) external override onlyTrackingToken {
    78	        _setShares(_wallet, _amount, _sharesRemoving);
    79	    }
    80	
    81	    function _setShares(
    82	        address _wallet,
    83	        uint256 _amount,
    84	        bool _sharesRemoving
    85	    ) internal {
    86	        if (_sharesRemoving) {
    87	            _removeShares(_wallet, _amount);
    88	            emit RemoveShares(_wallet, _amount);
    89	        } else {
    90	            _addShares(_wallet, _amount);
    91	            emit AddShares(_wallet, _amount);
    92	        }
    93	    }
    94	
    95	    function _addShares(address _wallet, uint256 _amount) internal {
    96	        if (shares[_wallet] > 0) {
    97	            _distributeReward(_wallet);
    98	        }
    99	        uint256 sharesBefore = shares[_wallet];
   100	        totalShares += _amount;
   101	        shares[_wallet] += _amount;
   102	        if (sharesBefore == 0 && shares[_wallet] > 0) {
   103	            totalStakers++;
   104	        }
   105	        rewards[_wallet].excluded = _cumulativeRewards(shares[_wallet]);
   106	    }
   107	
   108	    function _removeShares(address _wallet, uint256 _amount) internal {
   109	        require(shares[_wallet] > 0 && _amount <= shares[_wallet], "REMOVE");
   110	        _distributeReward(_wallet);
   111	        totalShares -= _amount;
   112	        shares[_wallet] -= _amount;
   113	        if (shares[_wallet] == 0) {
   114	            totalStakers--;
   115	        }
   116	        rewards[_wallet].excluded = _cumulativeRewards(shares[_wallet]);
   117	    }
   118	
   119	    function depositFromDAI(uint256 _amountDAIDepositing) external override {
   120	        if (_amountDAIDepositing > 0) {
   121	            IERC20(DAI).safeTransferFrom(
   122	                _msgSender(),
   123	                address(this),
   124	                _amountDAIDepositing
   125	            );
   126	        }
   127	        uint256 _amountDAI = IERC20(DAI).balanceOf(address(this));
   128	        require(_amountDAI > 0, "NEEDDAI");
   129	        (address _token0, address _token1) = DAI < rewardsToken
   130	            ? (DAI, rewardsToken)
   131	            : (rewardsToken, DAI);
   132	        PoolAddress.PoolKey memory _poolKey = PoolAddress.PoolKey({
   133	            token0: _token0,
   134	            token1: _token1,
   135	            fee: REWARDS_POOL_FEE
   136	        });
   137	        address _pool = PoolAddress.computeAddress(
   138	            IPeripheryImmutableState(V3_ROUTER).factory(),
   139	            _poolKey
   140	        );
   141	        uint160 _rewardsSqrtPriceX96 = V3_TWAP_UTILS
   142	            .sqrtPriceX96FromPoolAndInterval(_pool);
   143	        uint256 _rewardsPriceX96 = V3_TWAP_UTILS.priceX96FromSqrtPriceX96(
   144	            _rewardsSqrtPriceX96
   145	        );
   146	        uint256 _amountOut = _token0 == DAI
   147	            ? (_rewardsPriceX96 * _amountDAI) / FixedPoint96.Q96
   148	            : (_amountDAI * FixedPoint96.Q96) / _rewardsPriceX96;
   149	
   150	        uint256 _rewardsBalBefore = IERC20(rewardsToken).balanceOf(
   151	            address(this)
   152	        );
   153	        IERC20(DAI).safeIncreaseAllowance(V3_ROUTER, _amountDAI);
   154	        try
   155	            ISwapRouter(V3_ROUTER).exactInputSingle(
   156	                ISwapRouter.ExactInputSingleParams({
   157	                    tokenIn: DAI,
   158	                    tokenOut: rewardsToken,
   159	                    fee: REWARDS_POOL_FEE,
   160	                    recipient: address(this),
   161	                    deadline: block.timestamp,
   162	                    amountIn: _amountDAI,
   163	                    amountOutMinimum: (_amountOut *
   164	                        (1000 - _rewardsSwapSlippage)) / 1000,
   165	                    sqrtPriceLimitX96: 0
   166	                })
   167	            )
   168	        {
   169	            _rewardsSwapSlippage = 10;
   170	            _depositRewards(
   171	                IERC20(rewardsToken).balanceOf(address(this)) -
   172	                    _rewardsBalBefore
   173	            );
   174	        } catch {
   175	            _rewardsSwapSlippage += 10;
   176	            IERC20(DAI).safeDecreaseAllowance(V3_ROUTER, _amountDAI);
   177	        }
   178	    }
   179	
   180	    function depositRewards(uint256 _amount) external override {
   181	        require(_amount > 0, "DEPAM");
   182	        uint256 _rewardsBalBefore = IERC20(rewardsToken).balanceOf(
   183	            address(this)
   184	        );
   185	        IERC20(rewardsToken).safeTransferFrom(
   186	            _msgSender(),
   187	            address(this),
   188	            _amount
   189	        );
   190	        _depositRewards(
   191	            IERC20(rewardsToken).balanceOf(address(this)) - _rewardsBalBefore
   192	        );
   193	    }
   194	
   195	    function _depositRewards(uint256 _amountTotal) internal {
   196	        if (_amountTotal == 0) {
   197	            return;
   198	        }
   199	        if (totalShares == 0) {
   200	            _burnRewards(_amountTotal);
   201	            return;
   202	        }
   203	
   204	        uint256 _burnAmount = _amountTotal / 20; // 5% burn, 95% to rewards
   205	        uint256 _depositAmount = _amountTotal - _burnAmount;
   206	        _burnRewards(_burnAmount);
   207	        rewardsDeposited += _depositAmount;
   208	        rewardsDepMonthly[beginningOfMonth(block.timestamp)] += _depositAmount;
   209	        _rewardsPerShare += (PRECISION * _depositAmount) / totalShares;
   210	        emit DepositRewards(_msgSender(), _depositAmount);
   211	    }
   212	
   213	    function _distributeReward(address _wallet) internal {
   214	        if (shares[_wallet] == 0) {
   215	            return;
   216	        }
   217	        uint256 _amount = getUnpaid(_wallet);
   218	        rewards[_wallet].realized += _amount;
   219	        rewards[_wallet].excluded = _cumulativeRewards(shares[_wallet]);
   220	        if (_amount > 0) {
   221	            rewardsDistributed += _amount;
   222	
   223	            address[2] memory referrers = referral.getRelationsREF(_wallet);
   224	
   225	            uint256 amount2Referrer = (_amount * ((100 - 5) * 7)) / 10000;
   226	
   227	            IERC20(rewardsToken).safeTransfer(
   228	                _wallet,
   229	                _amount - amount2Referrer
   230	            );
   231	
   232	            emit DistributeReward(_wallet, _amount);
   233	
   234	            uint256 amount2Level1 = (amount2Referrer * 5) / 7;
   235	            uint256 amount2Level2 = amount2Referrer - amount2Level1;
   236	
   237	            if (referrers[0] == address(0)) {
   238	                _burnRewards(amount2Level1);
   239	            } else {
   240	                IERC20(rewardsToken).safeTransfer(referrers[0], amount2Level1);
   241	                emit ReferralDistribution(
   242	                    _wallet,
   243	                    referrers[0],
   244	                    1,
   245	                    amount2Level1
   246	                );
   247	            }
   248	
   249	            if (referrers[1] == address(0)) {
   250	                _burnRewards(amount2Level2);
   251	            } else {
   252	                IERC20(rewardsToken).safeTransfer(referrers[1], amount2Level2);
   253	                emit ReferralDistribution(
   254	                    _wallet,
   255	                    referrers[1],
   256	                    2,
   257	                    amount2Level2
   258	                );
   259	            }
   260	        }
   261	    }
   262	
   263	    function _burnRewards(uint256 _burnAmount) internal {
   264	        try IBARL(rewardsToken).burn(_burnAmount) {} catch {
   265	            IERC20(rewardsToken).safeTransfer(address(0xdead), _burnAmount);
   266	        }
   267	    }
   268	
   269	    function beginningOfMonth(
   270	        uint256 _timestamp
   271	    ) public pure returns (uint256) {
   272	        (, , uint256 _dayOfMonth) = BokkyPooBahsDateTimeLibrary.timestampToDate(
   273	            _timestamp
   274	        );
   275	        return
   276	            _timestamp - ((_dayOfMonth - 1) * 1 days) - (_timestamp % 1 days);
   277	    }
   278	
   279	    function claimReward(address _wallet, address _referrer) external override {
   280	        if (!referral.isSetted(_wallet) && _referrer != address(0)) {
   281	            referral.setReferral(_referrer, _wallet);
   282	        }
   283	        _distributeReward(_wallet);
   284	        emit ClaimReward(_wallet);
   285	    }
   286	
   287	    function getUnpaid(address _wallet) public view returns (uint256) {
   288	        if (shares[_wallet] == 0) {
   289	            return 0;
   290	        }
   291	        uint256 earnedRewards = _cumulativeRewards(shares[_wallet]);
   292	        uint256 rewardsExcluded = rewards[_wallet].excluded;
   293	        if (earnedRewards <= rewardsExcluded) {
   294	            return 0;
   295	        }
   296	        return earnedRewards - rewardsExcluded;
   297	    }
   298	
   299	    function _cumulativeRewards(
   300	        uint256 _share
   301	    ) internal view returns (uint256) {
   302	        return (_share * _rewardsPerShare) / PRECISION;
   303	    }
   304	}

