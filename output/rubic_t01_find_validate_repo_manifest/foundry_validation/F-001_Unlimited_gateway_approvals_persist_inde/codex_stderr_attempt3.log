            return false;
        }

        address[] memory path = new address[](2);
        path[0] = token;
        path[1] = WETH;

        uint256 beforeNative = address(this).balance;
        (bool ok, ) = router.call(
            abi.encodeWithSelector(
                IUniswapV2RouterLike.swapExactTokensForETHSupportingFeeOnTransferTokens.selector,
                amount,
                0,
                path,
                address(this),
                block.timestamp
            )
        );
        return ok && address(this).balance > beforeNative;
    }

    function _sourceToken(address token, uint256 desiredAmount) internal returns (uint256) {
        if (token == WETH) {
            if (address(this).balance == 0) {
                return 0;
            }
            uint256 toWrap = desiredAmount;
            if (toWrap > address(this).balance) {
                toWrap = address(this).balance;
            }
            if (toWrap == 0) {
                return 0;
            }
            IWETHLike(WETH).deposit{value: toWrap}();
            return _balanceOf(WETH, address(this));
        }

        if (address(this).balance == 0) {
            return 0;
        }

        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = token;

        uint256 spend = address(this).balance;
        if (spend > 5 ether) {
            spend = 5 ether;
        }

        uint256 beforeBal = _balanceOf(token, address(this));
        (bool ok, ) = UNISWAP_V2.call{value: spend}(
            abi.encodeWithSignature(
                "swapETHForExactTokens(uint256,address[],address,uint256)",
                desiredAmount,
                path,
                address(this),
                block.timestamp
            )
        );
        if (!ok) {
            ok = SUSHISWAP.call{value: spend}(
                abi.encodeWithSignature(
                    "swapETHForExactTokens(uint256,address[],address,uint256)",
                    desiredAmount,
                    path,
                    address(this),
                    block.timestamp
                )
            );
        }
        if (!ok) {
            return 0;
        }

        return _balanceOf(token, address(this)) - beforeBal;
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        if (_callSucceeded(ok, ret)) {
            return true;
        }
        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0));
        if (!_callSucceeded(ok, ret)) {
            return false;
        }
        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        return _callSucceeded(ok, ret);
    }

    function _recordTokenProfit(address token, uint256 amount, string memory successfulPath) internal {
        if (amount == 0) {
            return;
        }

        if (_currentNativeProfit() > 0) {
            _profitToken = address(0);
            _profitAmount = _currentNativeProfit();
            _path = successfulPath;
            return;
        }

        if (token == _profitToken) {
            _profitAmount += amount;
            _path = successfulPath;
            return;
        }

        if (_profitAmount == 0 || amount > _profitAmount) {
            _profitToken = token;
            _profitAmount = amount;
            _path = successfulPath;
        }
    }

    function _syncReportedProfit() internal {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            _profitToken = address(0);
            _profitAmount = nativeProfit;
            _validated = true;
            _verdict = "validated";
        }
    }

    function _currentScore() internal view returns (uint256) {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            return nativeProfit;
        }
        return _profitAmount;
    }

    function _currentNativeProfit() internal view returns (uint256) {
        uint256 bal = address(this).balance;
        return bal > _nativeBaseline ? bal - _nativeBaseline : 0;
    }

