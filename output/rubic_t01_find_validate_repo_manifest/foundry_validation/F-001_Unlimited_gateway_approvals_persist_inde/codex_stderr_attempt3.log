        if (!ok || afterBalance <= beforeBalance) {
            return false;
        }

        _recordTokenProfit(token, afterBalance - beforeBalance, successfulPath);
        return true;
    }

    function _realizeToken(address token) internal {
        uint256 balance = _balanceOf(token, address(this));
        if (balance == 0) {
            return;
        }

        if (token == WETH) {
            IWETHLike(WETH).withdraw(balance);
            _syncReportedProfit();
            return;
        }

        uint256 beforeNative = address(this).balance;
        if (_swapTokenForEth(token, balance, UNISWAP_V2) || _swapTokenForEth(token, balance, SUSHISWAP)) {
            uint256 gained = address(this).balance - beforeNative;
            if (gained > 0) {
                _profitToken = address(0);
                _profitAmount = _currentNativeProfit();
                _validated = true;
                _verdict = "validated";
            }
            return;
