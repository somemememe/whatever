  40     struct DepositInfo {
  41     uint256 amount;
  42     uint256 lockupPeriod;
  43     uint256 interestRate;
  44     uint256 depositTime;
  45     uint256 lastClaimTime;
  46 }
  47 
  48 
  49      function deposit(uint256 amount, uint256 lockupPeriod, address referral) external {
  50          require(amount > 0, "Amount must be greater than 0.");
  51          require(lockupPeriod >= 7 && lockupPeriod <= 90, "Invalid lockup period.");
  52          require(!_blacklisted[msg.sender], "You are not allowed to deposit.");
  53          require(_token.allowance(msg.sender, address(this)) >= amount, "Token allowance not sufficient.");
  54 
  55         uint256 currentLockupPeriod = lockupPeriod * 1 days;
  56         uint256 currentInterestRate;
  57 
  58 if (lockupPeriod == 7) {
  59     currentLockupPeriod = 7 * 1 days;
  60     require(amount >= 5 * 10**8 && amount <= 5 * 10**9, "Invalid deposit amount for 7-day lockup.");
  61     currentInterestRate = 47142857142857; // 0.047142857142857%
  62 } else if (lockupPeriod == 14) {
  63     currentLockupPeriod = 14 * 1 days;
  64     require(amount >= 5 * 10**9 && amount <= 10**10, "Invalid deposit amount for 14-day lockup.");
  65     currentInterestRate = 157142857142857; // 0.157142857142857%
  66 } else if (lockupPeriod == 30) {
  67     currentLockupPeriod = 30 * 1 days;
  68     require(amount >= 10**10 && amount <= 3 * 10**10, "Invalid deposit amount for 30-day lockup.");
  69     currentInterestRate = 183333333333333; // 0.183333333333333%
  70 } else if (lockupPeriod == 60) {
  71     currentLockupPeriod = 60 * 1 days;
  72     require(amount >= 2 * 10**10 && amount <= 5 * 10**10, "Invalid deposit amount for 60-day lockup.");
  73     currentInterestRate = 216666666666667; // 0.216666666666667%
  74 } else if (lockupPeriod == 90) {
  75     currentLockupPeriod = 90 * 1 days;
  76     require(amount >= 3 * 10**10 && amount <= 10**11, "Invalid deposit amount for 90-day lockup.");
  77     currentInterestRate = 222222222222222; // 0.222222222222222%
  78 }
  79 
  80     if (_referrals[msg.sender] == address(0) && referral != msg.sender && referral != address(0)) {
  81         _referrals[msg.sender] = referral;
  82     }
  83 
  84        DepositInfo memory newDeposit = DepositInfo({
  85             amount: amount,
  86             lockupPeriod: currentLockupPeriod,
  87             interestRate: currentInterestRate,
  88             depositTime: block.timestamp,
  89             lastClaimTime: block.timestamp
  90         });
  91 
  92     _balances[msg.sender] += amount;
  93     _lockupPeriod[msg.sender] = currentLockupPeriod;
  94     _interestRate[msg.sender] = currentInterestRate;
  95     _depositTime[msg.sender] = block.timestamp;
  96     _lastClaimTime[msg.sender] = block.timestamp;
  97     _initialDeposits[msg.sender] = amount;
  98     _deposits[msg.sender].push(newDeposit);
  99     _token.safeTransferFrom(msg.sender, address(this), amount); 
 100 
 101     emit Deposit(msg.sender, amount, lockupPeriod);
 102 }
