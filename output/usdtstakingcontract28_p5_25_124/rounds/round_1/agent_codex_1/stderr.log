 177 function getDepositInfo(address user) external view returns (uint256[] memory depositIndices, uint256[] memory unlockTimes, uint256[] memory stakedAmounts, uint256[] memory lockupPeriods) {
 178      uint256 depositCount = _deposits[user].length;
 179 
 180      depositIndices = new uint256[](depositCount);
 181      unlockTimes = new uint256[](depositCount);
 182      stakedAmounts = new uint256[](depositCount);
 183      lockupPeriods = new uint256[](depositCount);
 184 
 185      for (uint256 i = 0; i < depositCount; i++) {
 186          depositIndices[i] = i;
 187          unlockTimes[i] = _deposits[user][i].depositTime + _deposits[user][i].lockupPeriod;
 188          stakedAmounts[i] = _deposits[user][i].amount;
 189          lockupPeriods[i] = _deposits[user][i].lockupPeriod;
 190      }
 191  }
