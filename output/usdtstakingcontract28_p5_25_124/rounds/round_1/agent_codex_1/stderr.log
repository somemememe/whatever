 105     function blacklist(address user) external onlyOwner {
 106         require(!_blacklisted[user], "User is already blacklisted.");
 107         _blacklisted[user] = true;
 108 
 109         emit Blacklisted(user);
 110     }
 111 
 112     function unblacklist(address user) external onlyOwner {
 113         require(_blacklisted[user], "User is not blacklisted.");
 114         _blacklisted[user] = false;
 115 
 116         emit Unblacklisted(user);
 117     }
