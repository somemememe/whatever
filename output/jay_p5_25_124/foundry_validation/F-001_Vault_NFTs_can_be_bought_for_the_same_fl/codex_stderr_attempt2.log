        if (!success || data.length < 32) {
            return (false, 0);
        }

        uint256[] memory tokenIds = abi.decode(data, (uint256[]));
        if (tokenIds.length == 0) {
            return (false, 0);
        }
        return (true, tokenIds[0]);
    }

