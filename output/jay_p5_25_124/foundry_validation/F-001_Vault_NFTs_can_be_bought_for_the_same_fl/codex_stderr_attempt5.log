+        }
+
+        uint256 amountInWithFee = amountIn * AMM_FEE_NUMERATOR;
+        uint256 numerator = amountInWithFee * reserveOut;
+        uint256 denominator = (reserveIn * AMM_FEE_DENOMINATOR) + amountInWithFee;
+        return numerator / denominator;
+    }
