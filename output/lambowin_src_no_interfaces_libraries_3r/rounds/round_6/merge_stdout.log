    {
      "id": "F-015",
      "severity": "Low",
      "confidence": "high",
      "title": "Native ETH accepted by router and rebalancer has no recovery path",
      "locations": [
        "LamboVEthRouter.sol:188",
        "rebalance/LamboRebalanceOnUniwap.sol:55",
