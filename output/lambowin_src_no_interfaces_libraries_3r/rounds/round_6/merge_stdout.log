        "codex_1",
        "opencode_1"
      ]
    },
    {
      "id": "F-009",
      "severity": "Low",
      "confidence": "medium",
      "title": "Router and rebalance flows never enforce that configured vETH is native-backed, enabling full functional DoS via misconfiguration",
