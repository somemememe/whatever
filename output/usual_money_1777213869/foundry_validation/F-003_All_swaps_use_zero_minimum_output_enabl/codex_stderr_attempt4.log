    function _runOneArgSweep(Plan memory plan, uint256 loanAmount, uint256 seedEth, uint256 ethBefore) internal returns (bool) {
        bytes4[5] memory selectors = [
            SELECTOR_6EB7F72E,
            SELECTOR_785590D6,
            SELECTOR_CD3543E1,
            SELECTOR_D3E1ECE2,
            SELECTOR_RECONSTRUCTED_ENTRY
        ];

