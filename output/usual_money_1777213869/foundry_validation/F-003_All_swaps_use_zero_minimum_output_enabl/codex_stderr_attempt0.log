+    function _loanLadder(Plan memory plan) internal pure returns (uint256[5] memory ladder) {
+        uint256 amount = plan.expectedVictimAmount;
+        if (amount == 0) return ladder;
+        ladder[0] = amount / 4;
+        ladder[1] = amount / 2;
+        ladder[2] = amount;
+        ladder[3] = amount * 2;
+        ladder[4] = amount * 4;
+        for (uint256 i = 0; i < ladder.length; i++) {
+            if (ladder[i] == 0) {
+                ladder[i] = amount;
+            }
         }
     }
 
