        uint256 actualWalletAReceived = TOKEN.balanceOf(address(walletA)) - walletABefore;
        uint256 contractAfterBuy = TOKEN.balanceOf(address(TOKEN));

        _validated = actualWalletAReceived > 0 || contractAfterBuy > contractBefore;
