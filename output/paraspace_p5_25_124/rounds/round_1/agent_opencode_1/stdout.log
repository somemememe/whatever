[{"id": "F-001", "severity": "Critical", "confidence": "high", "title": "Incorrect debt calculation uses balanceOf instead of scaledBalanceOf", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/helpers/Helpers.sol:30-35"], "claim": "The getUserCurrentDebt function uses IERC20(debtTokenAddress).balanceOf(user) to calculate user debt instead of the scaled balance mechanism. For variable debt tokens using Aave-style scaled balances, debt should be calculated as scaledBalanceOf(user) * currentIndex.", "impact": "This causes critical accounting errors throughout the protocol. Debt calculations will be incorrect, leading to users being able to borrow more than allowed, incorrect liquidation triggers, and protocol insolvency. The function is used in LiquidationLogic._calculateDebt (line 617) and BorrowLogic.executeRepay (line 150).", "paths": ["Call getUserCurrentDebt in liquidation to calculate user's total debt", "Call getUserCurrentDebt in repay to validate repayment amount"]}, {"id": "F-002", "severity": "High", "confidence": "high", "title": "Integer overflow in GenericLogic liquidity threshold calculation", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:176-178", "0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:223-225", "0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:231"], "claim": "The liquidation threshold and LTV calculations multiply userBalanceInBaseCurrency by liquidationThreshold/LTV without overflow checks. For large collateral values, this can overflow causing incorrect health factor calculations.", "impact": "Integer overflow can cause health factor to be calculated incorrectly, potentially allowing undercollateralized positions to be opened or preventing valid liquidations.", "paths": ["Supply large amount of collateral", "Attempt to borrow - overflow causes incorrect collateral calculation", "Health factor calculation uses incorrect values"]}, {"id": "F-003", "severity": "High", "confidence": "high", "title": "Division by zero when liquidation bonus is zero", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:830-832"], "claim": "In _calculateERC721LiquidationParameters, the function calls percentDiv(superVars.liquidationBonus) without checking if liquidationBonus is zero. If the reserve's liquidation bonus is configured as zero, this will cause division by zero.", "impact": "Protocol would be unable to liquidate ERC721 positions when liquidation bonus is zero, potentially leading to stuck positions and protocol insolvency.", "paths": ["Configure reserve with zero liquidation bonus", "Attempt liquidation - reverts due to division by zero"]}, {"id": "F-004", "severity": "High", "confidence": "medium", "title": "Reentrancy vulnerability in FlashClaimLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/FlashClaimLogic.sol:61-79"], "claim": "The executeFlashClaim function transfers NFTs to the receiver contract (step 1) BEFORE executing the callback (step 2). A malicious receiver could trigger a reentrancy attack by calling back into the pool during the executeOperation callback.", "impact": "An attacker could potentially steal NFTs from other users or manipulate the protocol state during the callback before the health factor check in step 4.", "paths": ["Deploy malicious flash claim receiver", "Call executeFlashClaim with malicious receiver", "During callback, exploit state before HF check"]}, {"id": "F-005", "severity": "High", "confidence": "medium", "title": "Reentrancy in marketplace flash loan pattern", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/MarketplaceLogic.sol:143-172"], "claim": "The _buyWithCredit function performs _flashSupplyFor, _flashLoanTo, then makes an external delegatecall to the marketplace adapter before handling repayments. The callback to the marketplace can reenter the pool.", "impact": "A malicious marketplace adapter could reenter the pool during the delegatecall, potentially manipulating state before flash loan repayment.", "paths": ["Create malicious marketplace", "Call buyWithCredit through malicious marketplace", "During delegatecall, manipulate state before repayment"]}, {"id": "F-006", "severity": "Medium", "confidence": "high", "title": "NFT transferred before state update in supply", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/SupplyLogic.sol:234-247"], "claim": "executeSupplyERC721 transfers NFTs to the xToken address (line 235-240) before calling executeSupplyERC721Base which updates the user's collateral state (minting nTokens). If the transfer succeeds but the mint fails, NFTs could be locked in the xToken without proper accounting.", "impact": " NFTs could become locked in the xToken without corresponding nToken mint, causing permanent loss of user's NFTs.", "paths": ["Call executeSupplyERC721", "NFT transferred to xToken", "Mint fails due to validation - NFT stuck"]}, {"id": "F-007", "severity": "Medium", "confidence": "medium", "title": "Unchecked return value in MarketplaceLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/MarketplaceLogic.sol:152-160"], "claim": "The Address.functionDelegateCall to the marketplace adapter does not check if the call succeeded before proceeding to handle flash loan repayment. Failed marketplace executions could be silently ignored.", "impact": "If the marketplace execution fails silently, the protocol would still proceed with flash loan repayment, potentially causing fund loss or inconsistent state.", "paths": ["Call buyWithCredit with failing marketplace", "delegatecall fails silently", "Protocol continues with repayment handling"]}, {"id": "F-008", "severity": "Medium", "confidence": "high", "title": "Repay with pTokens allows repaying more than debt", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/BorrowLogic.sol:165-174"], "claim": "When usePTokens is true and amount is type(uint256).max, the repay amount is set to the caller's pToken balance. There's no validation that this doesn't exceed the actual debt. Additionally, the calculation paybackAmount = params.amount when params.amount < paybackAmount allows over-repayment.", "impact": "Users could over-repay their debt, losing excess funds. The protocol would have excess tokens with no corresponding debt.", "paths": ["Borrow funds", "Acquire pTokens through other means", "Repay more than debt via usePTokens"]}, {"id": "F-009", "severity": "Low", "confidence": "medium", "title": "Missing initialization check in ParaProxy constructor", "locations": ["0x638a98bbb92a7582d07c52ff407d49664dc8b3ee/contracts/protocol/libraries/paraspace-upgradeability/ParaProxy.sol:13-15"], "claim": "The ParaProxy constructor sets the contract owner without checking if _contractOwner is address(0). A proxy with address(0) as owner would have no admin.", "impact": "If deployed with address(0) as owner, the proxy becomes non-upgradeable as no one can call updateImplementation.", "paths": ["Deploy proxy with address(0) as owner"]}, {"id": "F-010", "severity": "Low", "confidence": "medium", "title": "Potential division by zero in GenericLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:251-264"], "claim": "The avgLtv, avgLiquidationThreshold, and avgERC721LiquidationThreshold calculations use division after a previous check for non-zero totalCollateralInBaseCurrency, but totalCollateralInBaseCurrency could equal totalERC721CollateralInBaseCurrency causing issues in later calculations.", "impact": "Could cause incorrect health factor calculations in certain edge cases with mixed collateral types.", "paths": ["User supplies both ERC20 and ERC721 collateral", "Calculate health factor", "Division edge case"]}]
