+            if (!_canBorrow(candidate)) {
+                continue;
+            }
+
+            uint256 score = candidate.liquidity;
+            if (candidate.decimals == 18) {
+                score *= 2;
+            }
+
+            if (candidate.siloed) {
+                if (score > bestSiloScore) {
