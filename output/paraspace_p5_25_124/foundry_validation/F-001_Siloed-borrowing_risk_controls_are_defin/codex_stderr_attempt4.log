    function _executeMixedBorrowPath(
        IParaSpacePoolLike pool,
        IPriceOracleLike oracle,
        address flashAsset,
        address weth,
        uint256 flashPrice,
        uint256 flashUnit,
        uint256 repayAmount,
        uint256 profitBuffer
    ) internal {
