-        uint256 balanceBeforeSecondBorrow = _balanceOf(flashAsset);
-        uint256 topUp = repayAmount > balanceBeforeSecondBorrow ? repayAmount - balanceBeforeSecondBorrow : 0;
-        topUp += profitBuffer;
