-
-        address[] memory path = new address[](2);
-        path[0] = token;
-        path[1] = WETH;
-
-        IUniswapRouter02(SUSHISWAP).swapExactTokensForTokens(
-            amountIn,
-            0,
-            path,
-            address(this),
-            block.timestamp
-        );
-    }
-
-    function _swapCncOnCurve() internal {
