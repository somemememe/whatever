-        _forceApprove(IERC20(CVX), SUSHISWAP, type(uint256).max);
-        _forceApprove(IERC20(CNC), CNC_WETH_CURVE_POOL, type(uint256).max);
-    }
-
-    function _swapOnSushi(address token) internal {
