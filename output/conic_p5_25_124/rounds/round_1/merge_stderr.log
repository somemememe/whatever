   677	    function getWeights() external view override returns (PoolWeight[] memory) {
   678	        uint256 length_ = _curvePools.length();
   679	        PoolWeight[] memory weights_ = new PoolWeight[](length_);
   680	        for (uint256 i; i < length_; i++) {
   681	            (address pool_, uint256 weight_) = weights.at(i);
   682	            weights_[i] = PoolWeight(pool_, weight_);
   683	        }
   684	        return weights_;
   685	    }
   686	
   687	    function getAllocatedUnderlying() external view override returns (PoolWithAmount[] memory) {
   688	        PoolWithAmount[] memory perPoolAllocated = new PoolWithAmount[](_curvePools.length());
   689	        (, , uint256[] memory allocated) = getTotalAndPerPoolUnderlying();
   690	
   691	        for (uint256 i; i < perPoolAllocated.length; i++) {
   692	            perPoolAllocated[i] = PoolWithAmount(_curvePools.at(i), allocated[i]);
   693	        }
   694	        return perPoolAllocated;
   695	    }
   696	
   697	    function computeTotalDeviation() external view override returns (uint256) {
   698	        (
   699	            ,
   700	            uint256 allocatedUnderlying_,
   701	            uint256[] memory perPoolUnderlying
   702	        ) = getTotalAndPerPoolUnderlying();
   703	        return _computeTotalDeviation(allocatedUnderlying_, perPoolUnderlying);
   704	    }
   705	
   706	    function computeDeviationRatio() external view returns (uint256) {
   707	        (
   708	            ,
   709	            uint256 allocatedUnderlying_,
   710	            uint256[] memory perPoolUnderlying
