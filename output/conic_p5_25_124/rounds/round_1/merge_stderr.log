   771	            address curvePool_ = _curvePools.at(i);
   772	            uint256 poolUnderlying_ = _curveLpToUnderlying(
   773	                controller.curveRegistryCache().lpToken(curvePool_),
   774	                totalCurveLpBalance(curvePool_),
   775	                underlyingPrice_
   776	            );
   777	            perPoolUnderlying_[i] = poolUnderlying_;
