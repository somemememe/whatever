   398	    function _swapRewardTokenForWeth(address rewardToken_) internal {
   399	        uint256 tokenBalance_ = IERC20(rewardToken_).balanceOf(address(this));
   400	        if (tokenBalance_ == 0) return;
   401	
   402	        ICurvePoolV2 curvePool_ = ICurvePoolV2(extraRewardsCurvePool[rewardToken_]);
   403	        if (address(curvePool_) != address(0)) {
   404	            (int128 i, int128 j, ) = controller.curveRegistryCache().coinIndices(
   405	                address(curvePool_),
   406	                rewardToken_,
   407	                address(WETH)
   408	            );
   409	            (uint256 from_, uint256 to_) = (uint256(uint128(i)), uint256(uint128(j)));
   410	            curvePool_.exchange(
   411	                from_,
   412	                to_,
   413	                tokenBalance_,
   414	                _minAmountOut(address(rewardToken_), address(WETH), tokenBalance_),
   415	                false,
   416	                address(this)
   417	            );
   418	            return;
   419	        }
   420	
   421	        address[] memory path_ = new address[](2);
   422	        path_[0] = rewardToken_;
   423	        path_[1] = address(WETH);
   424	        SUSHISWAP.swapExactTokensForTokens(
   425	            tokenBalance_,
   426	            _minAmountOut(address(rewardToken_), address(WETH), tokenBalance_),
   427	            path_,
   428	            address(this),
   429	            block.timestamp
   430	        );
   431	    }
