   383	    function _withdrawFromCurve(
   384	        uint256 totalUnderlying_,
   385	        uint256[] memory allocatedPerPool,
   386	        uint256 amount_
   387	    ) internal {
   388	        uint256 withdrawalsRemaining_ = amount_;
   389	        uint256 totalAfterWithdrawal_ = totalUnderlying_ - amount_;
   390	
   391	        // NOTE: avoid modifying `allocatedPerPool`
   392	        uint256[] memory allocatedPerPoolCopy = allocatedPerPool.copy();
   393	
   394	        while (withdrawalsRemaining_ > 0) {
   395	            (uint256 curvePoolIndex_, uint256 maxWithdrawal_) = _getWithdrawPool(
   396	                totalAfterWithdrawal_,
   397	                allocatedPerPoolCopy
   398	            );
   399	            address curvePool_ = _curvePools.at(curvePoolIndex_);
   400	
   401	            // Withdrawing from least balanced Curve pool
   402	            uint256 toWithdraw_ = _min(withdrawalsRemaining_, maxWithdrawal_);
   403	            _withdrawFromCurvePool(curvePool_, toWithdraw_);
   404	            withdrawalsRemaining_ -= toWithdraw_;
   405	            allocatedPerPoolCopy[curvePoolIndex_] -= toWithdraw_;
   406	        }
   407	    }
   408	
   409	    function _getWithdrawPool(
   410	        uint256 totalUnderlying_,
   411	        uint256[] memory allocatedPerPool
   412	    ) internal view returns (uint256 withdrawPoolIndex, uint256 maxWithdrawalAmount) {
   413	        uint256 curvePoolCount_ = allocatedPerPool.length;
   414	        int256 iWithdrawPoolIndex = -1;
   415	        for (uint256 i; i < curvePoolCount_; i++) {
   416	            address curvePool_ = _curvePools.at(i);
   417	            uint256 weight_ = weights.get(curvePool_);
   418	            uint256 allocatedUnderlying_ = allocatedPerPool[i];
   419	
   420	            // If a curve pool has a weight of 0,
   421	            // withdraw from it if it has more than the max lp value
   422	            if (weight_ == 0) {
   423	                uint256 price_ = controller.priceOracle().getUSDPrice(address(underlying));
   424	                uint256 allocatedUsd = (price_ * allocatedUnderlying_) /
   425	                    10 ** underlying.decimals();
   426	                if (allocatedUsd >= _MAX_USD_LP_VALUE_FOR_REMOVING_CURVE_POOL / 2) {
   427	                    return (uint256(i), allocatedUnderlying_);
   428	                }
   429	            }
   430	
   431	            uint256 targetAllocation_ = totalUnderlying_.mulDown(weight_);
   432	            if (allocatedUnderlying_ <= targetAllocation_) continue;
   433	            uint256 minBalance_ = targetAllocation_ - targetAllocation_.mulDown(_getMaxDeviation());
   434	            uint256 maxWithdrawalAmount_ = allocatedUnderlying_ - minBalance_;
   435	            if (maxWithdrawalAmount_ <= maxWithdrawalAmount) continue;
   436	            maxWithdrawalAmount = maxWithdrawalAmount_;
   437	            iWithdrawPoolIndex = int256(i);
   438	        }
   439	        require(iWithdrawPoolIndex > -1, "error retrieving withdraw pool");
   440	        withdrawPoolIndex = uint256(iWithdrawPoolIndex);
   441	    }
   442	
   443	    function _withdrawFromCurvePool(address curvePool_, uint256 underlyingAmount_) internal {
   444	        ICurveRegistryCache registryCache_ = controller.curveRegistryCache();
   445	        address curveLpToken_ = registryCache_.lpToken(curvePool_);
   446	        uint256 lpToWithdraw_ = _underlyingToCurveLp(curveLpToken_, underlyingAmount_);
   447	        if (lpToWithdraw_ == 0) return;
   448	
   449	        uint256 idleCurveLpBalance_ = _idleCurveLpBalance(curvePool_);
   450	        address rewardPool = registryCache_.getRewardPool(curvePool_);
   451	        uint256 stakedLpBalance = IBaseRewardPool(rewardPool).balanceOf(address(this));
   452	        uint256 totalAvailableLp = idleCurveLpBalance_ + stakedLpBalance;
   453	        // Due to rounding errors with the conversion of underlying to LP tokens,
   454	        // we may not have the precise amount of LP tokens to withdraw from the pool.
   455	        // In this case, we withdraw the maximum amount of LP tokens available.
   456	        if (totalAvailableLp < lpToWithdraw_) {
   457	            lpToWithdraw_ = totalAvailableLp;
   458	        }
   459	
   460	        if (lpToWithdraw_ > idleCurveLpBalance_) {
   461	            controller.convexHandler().functionDelegateCall(
   462	                abi.encodeWithSignature(
   463	                    "withdraw(address,uint256)",
   464	                    curvePool_,
   465	                    lpToWithdraw_ - idleCurveLpBalance_
   466	                )
   467	            );
   468	        }
   469	
   470	        controller.curveHandler().functionDelegateCall(
   471	            abi.encodeWithSignature(
   472	                "withdraw(address,address,uint256)",
   473	                curvePool_,
   474	                underlying,
   475	                lpToWithdraw_
   476	            )
   477	        );
   478	    }
