   322	    /// @notice Unstake LP Tokens and withdraw underlying
   323	    /// @param conicLpAmount Amount of LP tokens to burn
   324	    /// @param minUnderlyingReceived Minimum amount of underlying to redeem
   325	    /// This should always be set to a reasonable value (e.g. 2%), otherwise
   326	    /// the user withdrawing could be forced into paying a withdrawal penalty fee
   327	    /// by another user
   328	    /// @return uint256 Total underlying withdrawn
   329	    function unstakeAndWithdraw(
   330	        uint256 conicLpAmount,
   331	        uint256 minUnderlyingReceived
   332	    ) external returns (uint256) {
   333	        controller.lpTokenStaker().unstakeFrom(conicLpAmount, msg.sender);
   334	        return withdraw(conicLpAmount, minUnderlyingReceived);
   335	    }
   336	
   337	    /// @notice Withdraw underlying
   338	    /// @param conicLpAmount Amount of LP tokens to burn
   339	    /// @param minUnderlyingReceived Minimum amount of underlying to redeem
   340	    /// This should always be set to a reasonable value (e.g. 2%), otherwise
   341	    /// the user withdrawing could be forced into paying a withdrawal penalty fee
   342	    /// by another user
   343	    /// @return uint256 Total underlying withdrawn
   344	    function withdraw(
   345	        uint256 conicLpAmount,
   346	        uint256 minUnderlyingReceived
   347	    ) public override returns (uint256) {
   348	        // Preparing Withdrawals
   349	        require(lpToken.balanceOf(msg.sender) >= conicLpAmount, "insufficient balance");
   350	        uint256 underlyingBalanceBefore_ = underlying.balanceOf(address(this));
   351	
   352	        // Processing Withdrawals
   353	        (
   354	            uint256 totalUnderlying_,
   355	            uint256 allocatedUnderlying_,
   356	            uint256[] memory allocatedPerPool
   357	        ) = getTotalAndPerPoolUnderlying();
   358	        uint256 underlyingToReceive_ = conicLpAmount.mulDown(_exchangeRate(totalUnderlying_));
   359	        {
   360	            if (underlyingBalanceBefore_ < underlyingToReceive_) {
   361	                uint256 underlyingToWithdraw_ = underlyingToReceive_ - underlyingBalanceBefore_;
   362	                _withdrawFromCurve(allocatedUnderlying_, allocatedPerPool, underlyingToWithdraw_);
   363	            }
   364	        }
   365	
   366	        // Sending Underlying and burning LP Tokens
   367	        uint256 underlyingWithdrawn_ = _min(
   368	            underlying.balanceOf(address(this)),
   369	            underlyingToReceive_
   370	        );
   371	        require(underlyingWithdrawn_ >= minUnderlyingReceived, "too much slippage");
   372	        lpToken.burn(msg.sender, conicLpAmount);
   373	        underlying.safeTransfer(msg.sender, underlyingWithdrawn_);
   374	
   375	        _cachedTotalUnderlying = totalUnderlying_ - underlyingWithdrawn_;
   376	        _cacheUpdatedTimestamp = block.timestamp;
   377	
   378	        emit Withdraw(msg.sender, underlyingWithdrawn_);
   379	        _reentrancyCheck();
   380	        return underlyingWithdrawn_;
   381	    }
