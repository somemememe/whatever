    78	    /// @notice Updates the internal fee accounting state. Returns `true` if rewards were claimed
    79	    function poolCheckpoint() public override returns (bool) {
    80	        IConvexHandler convexHandler = IConvexHandler(controller.convexHandler());
    81	
    82	        (uint256 crvHoldings, uint256 cvxHoldings, uint256 cncHoldings) = _getHoldings(
    83	            convexHandler
    84	        );
    85	        uint256 crvEarned = crvHoldings - _rewardsMeta[_CRV_KEY].lastHoldings;
    86	        uint256 cvxEarned = cvxHoldings - _rewardsMeta[_CVX_KEY].lastHoldings;
    87	        uint256 cncEarned = cncHoldings - _rewardsMeta[_CNC_KEY].lastHoldings;
    88	
    89	        uint256 crvFee;
    90	        uint256 cvxFee;
    91	
    92	        if (feesEnabled) {
    93	            crvFee = crvEarned.mulDown(feePercentage);
    94	            cvxFee = cvxEarned.mulDown(feePercentage);
    95	            crvEarned -= crvFee;
    96	            cvxEarned -= cvxFee;
    97	            crvHoldings -= crvFee;
    98	            cvxHoldings -= cvxFee;
    99	        }
   100	
   101	        uint256 _totalStaked = controller.lpTokenStaker().getBalanceForPool(pool);
   102	        if (_totalStaked > 0) {
   103	            _updateEarned(_CVX_KEY, cvxHoldings, cvxEarned, _totalStaked);
   104	            _updateEarned(_CRV_KEY, crvHoldings, crvEarned, _totalStaked);
   105	            _updateEarned(_CNC_KEY, cncHoldings, cncEarned, _totalStaked);
   106	        }
   107	
   108	        if (!feesEnabled) {
   109	            return false;
   110	        }
   111	
   112	        bool rewardsClaimed = false;
   113	
   114	        if (crvFee > CRV.balanceOf(pool) || cvxFee > CVX.balanceOf(pool)) {
   115	            _claimPoolEarningsAndSellRewardTokens();
   116	            rewardsClaimed = true;
   117	        }
   118	
   119	        CRV.safeTransferFrom(pool, address(this), crvFee);
   120	        CVX.safeTransferFrom(pool, address(this), cvxFee);
   121	
   122	        // Fee transfer to the CNC locker
   123	        CRV.safeApprove(address(locker), crvFee);
   124	        CVX.safeApprove(address(locker), cvxFee);
   125	        locker.receiveFees(crvFee, cvxFee);
   126	
   127	        return rewardsClaimed;
   128	    }
