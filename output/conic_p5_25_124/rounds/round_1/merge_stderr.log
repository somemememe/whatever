   792	
   793	    function _curveLpToUnderlying(
   794	        address curveLpToken_,
   795	        uint256 curveLpAmount_,
   796	        uint256 underlyingPrice_
   797	    ) internal view returns (uint256) {
   798	        return
   799	            curveLpAmount_
   800	                .mulDown(controller.priceOracle().getUSDPrice(curveLpToken_))
   801	                .divDown(underlyingPrice_)
   802	                .convertScale(18, underlying.decimals());
   803	    }
   804	
   805	    function _underlyingToCurveLp(
   806	        address curveLpToken_,
   807	        uint256 underlyingAmount_
   808	    ) internal view returns (uint256) {
   809	        return
   810	            underlyingAmount_
   811	                .mulDown(controller.priceOracle().getUSDPrice(address(underlying)))
   812	                .divDown(controller.priceOracle().getUSDPrice(curveLpToken_))
   813	                .convertScale(underlying.decimals(), 18);
   814	    }
   815	
   816	    function _computeTotalDeviation(
   817	        uint256 allocatedUnderlying_,
   818	        uint256[] memory perPoolAllocations_
   819	    ) internal view returns (uint256) {
   820	        uint256 totalDeviation;
   821	        for (uint256 i; i < perPoolAllocations_.length; i++) {
   822	            uint256 weight = weights.get(_curvePools.at(i));
   823	            uint256 targetAmount = allocatedUnderlying_.mulDown(weight);
   824	            totalDeviation += targetAmount.absSub(perPoolAllocations_[i]);
   825	        }
   826	        return totalDeviation;
   827	    }
   828	
   829	    function _handleRebalancingRewards(
   830	        address account,
   831	        uint256 allocatedBalanceBefore_,
   832	        uint256[] memory allocatedPerPoolBefore,
   833	        uint256 allocatedBalanceAfter_,
   834	        uint256[] memory allocatedPerPoolAfter
   835	    ) internal {
   836	        if (!rebalancingRewardActive) return;
   837	        uint256 deviationBefore = _computeTotalDeviation(
   838	            allocatedBalanceBefore_,
   839	            allocatedPerPoolBefore
   840	        );
   841	        uint256 deviationAfter = _computeTotalDeviation(
   842	            allocatedBalanceAfter_,
   843	            allocatedPerPoolAfter
   844	        );
   845	
   846	        controller.inflationManager().handleRebalancingRewards(
   847	            account,
   848	            deviationBefore,
   849	            deviationAfter
   850	        );
   851	
   852	        if (_isBalanced(allocatedPerPoolAfter, allocatedBalanceAfter_)) {
   853	            rebalancingRewardActive = false;
   854	        }
   855	    }
   856	
   857	    function _min(uint256 a, uint256 b) internal pure returns (uint256) {
   858	        return a < b ? a : b;
   859	    }
   860	
   861	    function _isBalanced(
   862	        uint256[] memory allocatedPerPool_,
   863	        uint256 totalAllocated_
   864	    ) internal view returns (bool) {
   865	        if (totalAllocated_ == 0) return true;
   866	        for (uint256 i; i < allocatedPerPool_.length; i++) {
   867	            uint256 weight_ = weights.get(_curvePools.at(i));
   868	            uint256 currentAllocated_ = allocatedPerPool_[i];
   869	
   870	            // If a curve pool has a weight of 0,
   871	            if (weight_ == 0) {
   872	                uint256 price_ = controller.priceOracle().getUSDPrice(address(underlying));
   873	                uint256 allocatedUsd_ = (price_ * currentAllocated_) / 10 ** underlying.decimals();
   874	                if (allocatedUsd_ >= _MAX_USD_LP_VALUE_FOR_REMOVING_CURVE_POOL / 2) {
   875	                    return false;
   876	                }
   877	                continue;
   878	            }
   879	
   880	            uint256 targetAmount = totalAllocated_.mulDown(weight_);
   881	            uint256 deviation = targetAmount.absSub(currentAllocated_);
   882	            uint256 deviationRatio = deviation.divDown(targetAmount);
   883	
   884	            if (deviationRatio > maxDeviation) return false;
   885	        }
   886	        return true;
   887	    }
   888	
   889	    function _getMaxDeviation() internal view returns (uint256) {
   890	        return rebalancingRewardActive ? 0 : maxDeviation;
   891	    }
   892	
   893	    function _reentrancyCheck() internal {
   894	        for (uint256 i; i < _curvePools.length(); i++) {
   895	            address curvePool_ = _curvePools.at(i);
   896	            ICurveHandlerV3(controller.curveHandler()).reentrancyCheck(curvePool_);
   897	        }
   898	    }
   899	}

