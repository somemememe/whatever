   589	
   590	    /// @notice Called when an underlying of a Curve Pool has depegged and we want to exit the pool.
   591	    /// Will check if a coin has depegged, and will revert if not.
   592	    /// Sets the weight of the Curve Pool to 0, and re-enables CNC rewards for deposits.
   593	    /// @dev Cannot be called if the underlying of this pool itself has depegged.
   594	    /// @param curvePool_ The Curve Pool to handle.
   595	    function handleDepeggedCurvePool(address curvePool_) external override {
   596	        // Validation
   597	        require(isRegisteredCurvePool(curvePool_), "pool is not registered");
   598	        require(weights.get(curvePool_) != 0, "pool weight already 0");
   599	        address lpToken_ = controller.curveRegistryCache().lpToken(curvePool_);
   600	        require(_isDepegged(lpToken_), "pool is not depegged");
   601	
   602	        // Set target curve pool weight to 0
   603	        // Scale up other weights to compensate
   604	        _setWeightToZero(curvePool_);
   605	        rebalancingRewardActive = true;
   606	
   607	        emit HandledDepeggedCurvePool(curvePool_);
   608	    }
   609	
   610	    function _setWeightToZero(address curvePool_) internal {
   611	        uint256 weight_ = weights.get(curvePool_);
   612	        if (weight_ == 0) return;
   613	        require(weight_ != ScaledMath.ONE, "can't remove last pool");
   614	        uint256 scaleUp_ = ScaledMath.ONE.divDown(ScaledMath.ONE - weights.get(curvePool_));
   615	        uint256 curvePoolLength_ = _curvePools.length();
   616	        for (uint256 i; i < curvePoolLength_; i++) {
   617	            address pool_ = _curvePools.at(i);
   618	            uint256 newWeight_ = pool_ == curvePool_ ? 0 : weights.get(pool_).mulDown(scaleUp_);
   619	            weights.set(pool_, newWeight_);
   620	            emit NewWeight(pool_, newWeight_);
   621	        }
   622	
   623	        // Updating total deviation
   624	        (
   625	            uint256 totalUnderlying_,
   626	            ,
   627	            uint256[] memory allocatedPerPool
   628	        ) = getTotalAndPerPoolUnderlying();
   629	        uint256 totalDeviation = _computeTotalDeviation(totalUnderlying_, allocatedPerPool);
   630	        totalDeviationAfterWeightUpdate = totalDeviation;
   631	    }
   632	
   633	    function _isDepegged(address asset_) internal view returns (bool) {
   634	        uint256 cachedPrice_ = _cachedPrices[asset_];
   635	        IOracle priceOracle_ = controller.priceOracle();
   636	        uint256 ethUsdPrice_ = priceOracle_.getUSDPrice(address(0));
   637	        uint256 currentPriceUsd_ = priceOracle_.getUSDPrice(asset_);
   638	        uint256 currentPrice_ = currentPriceUsd_.divDown(ethUsdPrice_);
   639	        uint256 priceDiff_ = cachedPrice_.absSub(currentPrice_);
   640	        uint256 priceDiffPercent_ = priceDiff_.divDown(cachedPrice_);
   641	        return priceDiffPercent_ > depegThreshold;
   642	    }
   643	
   644	    /**
   645	     * @notice Allows anyone to set the weight of a Curve pool to 0 if the Convex pool for the
