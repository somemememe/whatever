    15	
    16	contract ConvexHandlerV3 is IConvexHandler {
    17	    using SafeERC20 for IERC20;
    18	
    19	    uint256 internal constant _CLIFF_COUNT = 1000;
    20	    uint256 internal constant _CLIFF_SIZE = 100_000e18;
    21	    uint256 internal constant _MAX_CVX_SUPPLY = 100_000_000e18;
    22	    uint256 internal constant _MAX_CLIFF_THRESHOLD = 0.3e18;
    23	    address internal constant _CVX_TOKEN = address(0x4e3FBD56CD56c3e72c1403e103b45Db9da5B9D2B);
    24	
    25	    uint256 public cliffThreshold = 0.05e18;
    26	
    27	    uint256 public currentCliff;
    28	
    29	    IController public immutable controller;
    30	
    31	    constructor(address _controller) {
    32	        controller = IController(_controller);
    33	    }
    34	
    35	    /// @notice Deposits a Curve LP token on Convex and stakes the Convex
    36	    /// Curve LP token in the respective CRV rewards contract on Convex.
    37	    /// @param _curvePool Curve Pool for which LP tokens should be deposited
    38	    /// @param _amount Amount of Curve LP tokens to deposit
    39	    function deposit(address _curvePool, uint256 _amount) external {
    40	        uint256 pid = controller.curveRegistryCache().getPid(_curvePool);
    41	        IBooster(controller.convexBooster()).deposit(pid, _amount, true);
    42	    }
    43	
    44	    /// @notice Withdraws Curve LP tokens from Convex.
    45	    /// @dev Curve LP tokens get unstaked from the Convex CRV rewards contract.
    46	    /// @param _curvePool Curve pool for which LP tokens should be withdrawn.
    47	    /// @param _amount Amount of Curve LP tokens to withdraw.
    48	    function withdraw(address _curvePool, uint256 _amount) external {
    49	        address rewardPool = controller.curveRegistryCache().getRewardPool(_curvePool);
    50	        IBaseRewardPool(rewardPool).withdrawAndUnwrap(_amount, false);
    51	    }
    52	
    53	    /// @notice Claims CRV, CVX and extra rewards from Convex on behalf of a Conic pool.
    54	    /// @param _curvePool Curve pool from which LP tokens have been deposited on Convex.
    55	    /// @param _conicPool Conic pool for which rewards will be claimed.
    56	    function claimEarnings(address _curvePool, address _conicPool) external {
    57	        _claimConvexReward(_curvePool, _conicPool);
    58	    }
    59	
    60	    /// @notice Claims CRV, CVX and extra rewards from Convex for multiple Curve LP tokens staked.
    61	    /// @param _curvePools List of Curve pools from which LP tokens have been deposited
    62	    /// @param _conicPool Conic pool for which rewards will be claimed.
    63	    function claimBatchEarnings(address[] memory _curvePools, address _conicPool) external {
    64	        for (uint256 i; i < _curvePools.length; i++) {
    65	            address pool = _curvePools[i];
    66	            _claimConvexReward(pool, _conicPool);
    67	        }
    68	    }
    69	
    70	    function getRewardPool(address _curvePool) public view returns (address) {
    71	        return controller.curveRegistryCache().getRewardPool(_curvePool);
    72	    }
    73	
    74	    function _claimConvexReward(address _curvePool, address _conicPool) internal {
    75	        address rewardPool = controller.curveRegistryCache().getRewardPool(_curvePool);
    76	        IBaseRewardPool(rewardPool).getReward(_conicPool, true);
    77	        _updateCliff();
    78	    }
    79	
    80	    /// @notice Gets total amount of CRV earned by an account from staking an amount of
    81	    /// Curve LP tokens via Convex for a single Curve pool.
    82	    /// @param _account Account which staked an amount of Curve LP tokens.
    83	    /// @param _curvePool Curve pool for which earned CRV should be computed.
    84	    /// @return Total amount of CRV earned.
    85	    function getCrvEarned(address _account, address _curvePool) public view returns (uint256) {
    86	        address rewardPool = controller.curveRegistryCache().getRewardPool(_curvePool);
    87	        return IBaseRewardPool(rewardPool).earned(_account);
    88	    }
    89	
    90	    /// @notice Gets total amount of CRV earned by an account from staking multiple Curve
    91	    /// LP tokens via Convex.
    92	    /// @param _account Account which staked Curve LP tokens.
    93	    /// @param _curvePools List of Curve pools for which earned CRV should be computed.
    94	    /// @return Total amount of CRV earned.
    95	    function getCrvEarnedBatch(
    96	        address _account,
    97	        address[] memory _curvePools
    98	    ) external view returns (uint256) {
    99	        uint256 totalCrvEarned;
   100	        for (uint256 i; i < _curvePools.length; i++) {
   101	            address pool = _curvePools[i];
   102	            totalCrvEarned += getCrvEarned(_account, pool);
   103	        }
   104	        return totalCrvEarned;
   105	    }
   106	
   107	    /// @notice Computes how much CVX can be claimed for an amount of CRV earned
   108	    /// @dev Not easily computable from the CVX token contract
   109	    /// @param crvAmount Amount of CRV for which CVX will be minted pro rata.
   110	    /// @return CVX amount that would be minted.
   111	    function computeClaimableConvex(uint256 crvAmount) external view returns (uint256) {
   112	        uint256 cvxTotalSupply = IERC20(_CVX_TOKEN).totalSupply();
   113	        uint256 cliff = cvxTotalSupply / _CLIFF_SIZE;
   114	        if (cliff >= _CLIFF_COUNT) {
   115	            return 0;
   116	        }
   117	
   118	        cliff = cliff > currentCliff ? cliff : currentCliff;
   119	        uint256 remaining = _CLIFF_COUNT - cliff;
   120	        uint256 cvxEarned = (crvAmount * remaining) / _CLIFF_COUNT;
   121	        uint256 amountTillMax = _MAX_CVX_SUPPLY - cvxTotalSupply;
   122	        if (cvxEarned > amountTillMax) {
   123	            cvxEarned = amountTillMax;
   124	        }
   125	        return cvxEarned;
   126	    }
   127	
   128	    function _updateCliff() internal {
   129	        uint256 cvxTotalSupply = IERC20(_CVX_TOKEN).totalSupply();
   130	        uint256 cliff = cvxTotalSupply / _CLIFF_SIZE;
   131	
   132	        // calculate % left until next cliff
   133	        // if <= cliffThreshold then use next cliff
   134	        uint256 cvxNeededUntilNextCliff = _CLIFF_SIZE - (cvxTotalSupply % _CLIFF_SIZE);
   135	        if (cvxNeededUntilNextCliff <= (_CLIFF_SIZE * cliffThreshold) / 1e18) {
   136	            if (currentCliff <= cliff && cliff < _CLIFF_COUNT - 1) {
   137	                currentCliff = cliff + 1;
   138	            }
   139	        }
   140	    }
   141	
   142	    function updateCliffThreshold(uint256 _cliffThreshold) external {
   143	        require(
   144	            msg.sender == IOwnable(address(controller)).owner(),
   145	            "caller is not governance proxy"
   146	        );
   147	        require(_cliffThreshold <= _MAX_CLIFF_THRESHOLD, "new cliff threshold is too high");
   148	        require(_cliffThreshold != cliffThreshold, "new cliff threshold must be higher or lower");
   149	        cliffThreshold = _cliffThreshold;
   150	    }
   151	}

