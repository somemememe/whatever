   191	    function _updateAccountRewardsMeta(bytes32 key, address account, uint256 balance) internal {
   192	        RewardMeta storage meta = _rewardsMeta[key];
   193	        uint256 share = balance.mulDown(meta.earnedIntegral - meta.accountIntegral[account]);
   194	        meta.accountShare[account] += share;
   195	        meta.accountIntegral[account] = meta.earnedIntegral;
