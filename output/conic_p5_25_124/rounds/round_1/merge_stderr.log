   198	    /// @notice Claims all CRV, CVX and CNC earned by a user. All extra reward
   199	    /// tokens earned will be sold for CNC.
   200	    /// @dev Conic pool LP tokens need to be staked in the `LpTokenStaker` in
   201	    /// order to receive a share of the CRV, CVX and CNC earnings.
   202	    /// after selling all extra reward tokens.
   203	    function claimEarnings() public override returns (uint256, uint256, uint256) {
   204	        _accountCheckpoint(msg.sender);
   205	        uint256 crvAmount = _rewardsMeta[_CRV_KEY].accountShare[msg.sender];
   206	        uint256 cvxAmount = _rewardsMeta[_CVX_KEY].accountShare[msg.sender];
   207	        uint256 cncAmount = _rewardsMeta[_CNC_KEY].accountShare[msg.sender];
   208	
   209	        if (
   210	            crvAmount > CRV.balanceOf(pool) ||
   211	            cvxAmount > CVX.balanceOf(pool) ||
   212	            cncAmount > CNC.balanceOf(pool)
   213	        ) {
   214	            _claimPoolEarningsAndSellRewardTokens();
   215	        }
   216	        _rewardsMeta[_CNC_KEY].accountShare[msg.sender] = 0;
   217	        _rewardsMeta[_CVX_KEY].accountShare[msg.sender] = 0;
   218	        _rewardsMeta[_CRV_KEY].accountShare[msg.sender] = 0;
   219	
   220	        CRV.safeTransferFrom(pool, msg.sender, crvAmount);
   221	        CVX.safeTransferFrom(pool, msg.sender, cvxAmount);
   222	        CNC.safeTransferFrom(pool, msg.sender, cncAmount);
   223	
   224	        (
   225	            uint256 currentHoldingsCRV,
   226	            uint256 currentHoldingsCVX,
   227	            uint256 currentHoldingsCNC
   228	        ) = _getHoldings(IConvexHandler(controller.convexHandler()));
   229	        _rewardsMeta[_CRV_KEY].lastHoldings = currentHoldingsCRV;
   230	        _rewardsMeta[_CVX_KEY].lastHoldings = currentHoldingsCVX;
   231	        _rewardsMeta[_CNC_KEY].lastHoldings = currentHoldingsCNC;
   232	
   233	        emit EarningsClaimed(msg.sender, cncAmount, crvAmount, cvxAmount);
   234	        return (cncAmount, crvAmount, cvxAmount);
   235	    }
