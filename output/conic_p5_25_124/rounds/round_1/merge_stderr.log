   433	    function _swapWethForCNC() internal {
   434	        uint256 wethBalance_ = WETH.balanceOf(address(this));
   435	        if (wethBalance_ == 0) return;
   436	        CNC_ETH_POOL.exchange(
   437	            0,
   438	            1,
   439	            wethBalance_,
   440	            _minAmountOut(address(WETH), address(CNC), wethBalance_),
   441	            false,
   442	            pool
   443	        );
   444	    }
   445	
   446	    function _minAmountOut(
   447	        address tokenIn_,
   448	        address tokenOut_,
   449	        uint256 amountIn_
   450	    ) internal view returns (uint256) {
   451	        IOracle oracle_ = controller.priceOracle();
   452	
   453	        if (tokenIn_ == tokenOut_) {
   454	            return amountIn_;
   455	        }
   456	
   457	        // If we don't have a price for either token, we can't calculate the min amount out
   458	        // This should only ever happen for very minor tokens, so we accept the risk of not having
   459	        // slippage protection in that case
   460	        if (!oracle_.isTokenSupported(tokenIn_) || !oracle_.isTokenSupported(tokenOut_)) {
   461	            return 0;
   462	        }
   463	
   464	        return
   465	            amountIn_
   466	                .mulDown(oracle_.getUSDPrice(tokenIn_))
   467	                .divDown(oracle_.getUSDPrice(tokenOut_))
   468	                .convertScale(
   469	                    IERC20Metadata(tokenIn_).decimals(),
   470	                    IERC20Metadata(tokenOut_).decimals()
   471	                )
   472	                .mulDown(SLIPPAGE_THRESHOLD);
   473	    }
   474	}

