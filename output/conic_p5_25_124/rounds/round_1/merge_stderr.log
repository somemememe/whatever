   582	
   583	    function updateDepegThreshold(uint256 newDepegThreshold_) external onlyOwner {
   584	        require(newDepegThreshold_ >= _MIN_DEPEG_THRESHOLD, "invalid depeg threshold");
   585	        require(newDepegThreshold_ <= _MAX_DEPEG_THRESHOLD, "invalid depeg threshold");
   586	        depegThreshold = newDepegThreshold_;
