   750	    /**
   751	     * @notice Returns several values related to the Omnipools's underlying assets.
   752	     * @param underlyingPrice_ Price of the underlying asset in USD
   753	     * @return totalUnderlying_ Total underlying value of the Omnipool
   754	     * @return totalAllocated_ Total underlying value of the Omnipool that is allocated to Curve pools
   755	     * @return perPoolUnderlying_ Array of underlying values of the Omnipool that is allocated to each Curve pool
   756	     */
   757	    function _getTotalAndPerPoolUnderlying(
   758	        uint256 underlyingPrice_
   759	    )
   760	        internal
   761	        view
   762	        returns (
   763	            uint256 totalUnderlying_,
   764	            uint256 totalAllocated_,
   765	            uint256[] memory perPoolUnderlying_
   766	        )
   767	    {
   768	        uint256 curvePoolsLength_ = _curvePools.length();
