contract FlawVerifier {
    enum ExecutionStatus {
        NotRun,
        BlockedNoActionablePath,
        ExecutedNoProfit,
        ExecutedWithProfit
    }

    struct FlashRoute {
        address sourcePair;
        address sellPair;
