                    lender: lender,
                    borrower: lien.borrower,
                    collection: lien.collection,
                    tokenId: tokenId,
                    price: lien.price,
                    rate: lien.rate,
                    loanStartTime: block.timestamp,
                    auctionStartTime: 0
                })
            )
        );

        emit AcceptBid(lienId, lender, tokenId, amount, block.timestamp);
    }

