   563	    /// @inheritdoc IParticleExchange
   564	    function refinanceLoan(
   565	        Lien calldata oldLien,
   566	        uint256 oldLienId,
   567	        Lien calldata newLien,
   568	        uint256 newLienId
   569	    ) external payable override validateLien(oldLien, oldLienId) validateLien(newLien, newLienId) nonReentrant {
   570	        if (msg.sender != oldLien.borrower) {
   571	            revert Errors.Unauthorized();
   572	        }
   573	
   574	        if (oldLien.loanStartTime == 0) {
   575	            revert Errors.InactiveLoan();
   576	        }
   577	
   578	        if (newLien.loanStartTime != 0) {
   579	            // cannot swap to another active loan
   580	            revert Errors.LoanStarted();
   581	        }
   582	
   583	        if (newLien.lender == address(0)) {
   584	            revert Errors.BidNotTaken();
   585	        }
   586	
   587	        if (oldLien.collection != newLien.collection) {
   588	            // cannot swap to a new loan with different collection
   589	            revert Errors.UnmatchedCollections();
   590	        }
   591	
   592	        uint256 accruedInterest = MathUtils.calculateCurrentInterest(
   593	            oldLien.price,
   594	            oldLien.rate,
   595	            oldLien.loanStartTime
   596	        );
   597	
   598	        /// @dev old price + msg.value is available now, new price + interest is the need to spend
   599	        /// @dev account balancing ensures balance > new price + interest - (old price + msg.value) (i.e., no overspend)
   600	        _balanceAccount(msg.sender, newLien.price + accruedInterest, oldLien.price + msg.value);
   601	
   602	        // accrue interest to the lender
   603	        _accrueInterest(oldLien.lender, accruedInterest);
   604	
   605	        // update old lien
   606	        liens[oldLienId] = keccak256(
   607	            abi.encode(
   608	                Lien({
   609	                    lender: oldLien.lender,
   610	                    borrower: address(0),
   611	                    collection: oldLien.collection,
   612	                    tokenId: newLien.tokenId,
   613	                    price: oldLien.price,
   614	                    rate: oldLien.rate,
   615	                    loanStartTime: 0,
   616	                    auctionStartTime: 0
   617	                })
   618	            )
   619	        );
   620	
   621	        // update new lien
   622	        liens[newLienId] = keccak256(
   623	            abi.encode(
   624	                Lien({
   625	                    lender: newLien.lender,
   626	                    borrower: oldLien.borrower,
   627	                    collection: newLien.collection,
   628	                    tokenId: newLien.tokenId,
   629	                    price: newLien.price,
   630	                    rate: newLien.rate,
   631	                    loanStartTime: block.timestamp,
   632	                    auctionStartTime: 0
   633	                })
   634	            )
   635	        );
   636	
   637	        emit Refinance(oldLienId, newLienId, block.timestamp);
   638	    }
