   346	
   347	    /// @inheritdoc IParticleExchange
   348	    function buyNftFromMarket(
   349	        Lien calldata lien,
   350	        uint256 lienId,
   351	        uint256 tokenId,
   352	        uint256 amount,
   353	        address spender,
   354	        address marketplace,
   355	        bytes calldata tradeData
   356	    ) external override validateLien(lien, lienId) nonReentrant {
   357	        if (msg.sender != lien.borrower) {
   358	            revert Errors.Unauthorized();
   359	        }
   360	
   361	        if (lien.loanStartTime == 0) {
   362	            revert Errors.InactiveLoan();
   363	        }
   364	
   365	        uint256 accruedInterest = MathUtils.calculateCurrentInterest(lien.price, lien.rate, lien.loanStartTime);
   366	
   367	        // since: lien.price = sold amount + margin
   368	        // and:   payback    = sold amount + margin - bought amount - interest
   369	        // hence: payback    = lien.price - bought amount - interest
   370	        /// @dev cannot overspend, i.e., will revert if payback to borrower < 0. Payback < 0
   371	        /// means the borrower loses all the margin, and still owes some interest. Notice that
   372	        /// this function is not payable because rational borrower won't deposit even more cost
   373	        /// to exit an already liquidated position.
   374	        uint256 payback = lien.price - amount - accruedInterest;
   375	
   376	        // accrue interest to lender
   377	        _accrueInterest(lien.lender, accruedInterest);
   378	
   379	        // payback PnL to borrower
   380	        if (payback > 0) {
   381	            accountBalance[lien.borrower] += payback;
   382	        }
   383	
   384	        // update lien (by default, the lien is open to accept new loan)
   385	        liens[lienId] = keccak256(
   386	            abi.encode(
   387	                Lien({
   388	                    lender: lien.lender,
   389	                    borrower: address(0),
   390	                    collection: lien.collection,
   391	                    tokenId: tokenId,
   392	                    price: lien.price,
   393	                    rate: lien.rate,
   394	                    loanStartTime: 0,
   395	                    auctionStartTime: 0
   396	                })
   397	            )
   398	        );
   399	
   400	        // route trade execution to marketplace
   401	        _execBuyNftFromMarket(lien.collection, tokenId, amount, spender, marketplace, tradeData);
   402	
   403	        emit BuyMarketNFT(lienId, tokenId, amount);
   404	    }
   405	
   406	    function _execBuyNftFromMarket(
   407	        address collection,
   408	        uint256 tokenId,
   409	        uint256 amount,
   410	        address spender,
   411	        address marketplace,
   412	        bytes calldata tradeData
   413	    ) internal {
   414	        if (!registeredMarketplaces[marketplace]) {
   415	            revert Errors.UnregisteredMarketplace();
   416	        }
   417	
   418	        if (IERC721(collection).ownerOf(tokenId) == address(this)) {
   419	            revert Errors.InvalidNFTBuy();
   420	        }
   421	
   422	        uint256 ethBalanceBefore = address(this).balance;
   423	        uint256 wethBalanceBefore = weth.balanceOf(address(this));
   424	
   425	        // execute raw order on registered marketplace
   426	        bool success;
   427	        if (spender == address(0)) {
   428	            // use ETH
   429	            // solhint-disable-next-line avoid-low-level-calls
   430	            (success, ) = marketplace.call{value: amount}(tradeData);
   431	        } else {
   432	            // use WETH
   433	            weth.deposit{value: amount}();
   434	            weth.approve(spender, amount);
   435	            // solhint-disable-next-line avoid-low-level-calls
   436	            (success, ) = marketplace.call(tradeData);
   437	        }
   438	
   439	        if (!success) {
   440	            revert Errors.MartketplaceFailedToTrade();
   441	        }
   442	
   443	        // conert back any unspent WETH to ETH
   444	        uint256 wethBalance = weth.balanceOf(address(this));
   445	        if (wethBalance > 0) {
   446	            weth.withdraw(wethBalance);
   447	        }
   448	
   449	        // verify that the declared NFT is acquired and the balance decrease is correct
   450	        if (
   451	            IERC721(collection).ownerOf(tokenId) != address(this) ||
   452	            ethBalanceBefore + wethBalanceBefore - address(this).balance != amount
   453	        ) {
   454	            revert Errors.InvalidNFTBuy();
   455	        }
   456	    }
