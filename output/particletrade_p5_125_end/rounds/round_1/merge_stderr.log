    /// @inheritdoc IParticleExchange
    function stopLoanAuction(
        Lien calldata lien,
        uint256 lienId
    ) external override validateLien(lien, lienId) nonReentrant {
        if (msg.sender != lien.lender) {
            revert Errors.Unauthorized();
        }

