   897	    /// @inheritdoc IParticleExchange
   898	    function auctionSellNft(
   899	        Lien calldata lien,
   900	        uint256 lienId,
   901	        uint256 tokenId
   902	    ) external override validateLien(lien, lienId) nonReentrant {
   903	        if (lien.auctionStartTime == 0) {
   904	            revert Errors.AuctionNotStarted();
   905	        }
   906	
   907	        // transfer fund to corresponding recipients
   908	        _execAuctionSellNft(lien, lienId, tokenId, msg.sender);
   909	
   910	        // transfer NFT to the contract
   911	        /// @dev receiver is this contract, no need to safeTransferFrom
   912	        /// @dev at this point, collection.setApprovalForAll should have been called
