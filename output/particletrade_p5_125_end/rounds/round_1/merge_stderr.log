   916	    /// @dev unchecked function, make sure lien is validated, auction is live and collection is matched
   917	    function _execAuctionSellNft(Lien memory lien, uint256 lienId, uint256 tokenId, address auctionBuyer) internal {
   918	        uint256 accruedInterest = MathUtils.calculateCurrentInterest(lien.price, lien.rate, lien.loanStartTime);
   919	
   920	        /// @dev: arithmetic revert if accruedInterest > lien.price, i.e., even 0 buyback cannot cover the interest
   921	        uint256 currentAuctionPrice = MathUtils.calculateCurrentAuctionPrice(
   922	            lien.price - accruedInterest,
   923	            block.timestamp - lien.auctionStartTime,
   924	            _AUCTION_DURATION
   925	        );
   926	
   927	        // pay PnL to borrower
   928	        uint256 payback = lien.price - currentAuctionPrice - accruedInterest;
   929	        if (payback > 0) {
   930	            accountBalance[lien.borrower] += payback;
   931	        }
   932	
   933	        // pay auction price to new NFT supplier
   934	        payable(auctionBuyer).sendValue(currentAuctionPrice);
   935	
   936	        // accrue interest to lender
   937	        _accrueInterest(lien.lender, accruedInterest);
   938	
   939	        // update lien (by default, the lien is open to accept new loan)
   940	        liens[lienId] = keccak256(
   941	            abi.encode(
   942	                Lien({
   943	                    lender: lien.lender,
   944	                    borrower: address(0),
   945	                    collection: lien.collection,
   946	                    tokenId: tokenId,
   947	                    price: lien.price,
   948	                    rate: lien.rate,
   949	                    loanStartTime: 0,
   950	                    auctionStartTime: 0
   951	                })
   952	            )
   953	        );
   954	
   955	        emit AuctionSellNFT(lienId, auctionBuyer, tokenId, currentAuctionPrice);
   956	    }
