   958	    /*==============================================================
   959	                             Push-Based Logic
   960	    ==============================================================*/
   961	
   962	    /**
   963	     * @notice Receiver function upon ERC721 transfer
   964	     *
   965	     * @dev We modify this receiver to enable "push based" NFT supply, where one of the following is embedded in the
   966	     * data bytes that are piggy backed with the SafeTransferFrom call:
   967	     * (1) the price and rate (for nft supply) (64 bytes) or
   968	     * (2) lien information (for NFT repay or auction buy) (288 bytes) or
   969	     * (3) lien information and market sell information (accept bid to NFT market sell) (>= 384 bytes).
   970	     * This way, the lender doesn't need to additionally sign the "setApprovalForAll" transaction, which saves gas and
   971	     * creates a better user experience.
   972	     *
   973	     * @param from the address which previously owned the NFT
   974	     * @param tokenId the NFT identifier which is being transferred
   975	     * @param data additional data with no specified format
   976	     */
   977	    function onERC721Received(address, address from, uint256 tokenId, bytes calldata data) external returns (bytes4) {
   978	        /// @dev NFT transfer coming from buyNftFromMarket will be flagged as already enterred (re-entrancy status),
   979	        /// where the NFT is matched with an existing lien already. If it proceeds (to supply), this NFT will be tied
   980	        /// with two liens, which creates divergence.
   981	        if (!isEntered()) {
   982	            _pushBasedNftSupply(from, tokenId, data);
   983	        }
   984	        return this.onERC721Received.selector;
   985	    }
   986	
   987	    function _pushBasedNftSupply(address from, uint256 tokenId, bytes calldata data) internal nonReentrant {
   988	        /// @dev this function is external and can be called by anyone, we need to check the NFT is indeed received
   989	        /// at this point to proceed, message sender is the NFT collection in nominal function call
   990	        if (IERC721(msg.sender).ownerOf(tokenId) != address(this)) {
   991	            revert Errors.NFTNotReceived();
   992	        }
   993	        // use data.length to branch different conditions
   994	        if (data.length == 64) {
   995	            // Conditon (1): NFT supply
   996	            (uint256 price, uint256 rate) = abi.decode(data, (uint256, uint256));
   997	            /// @dev the msg.sender is the NFT collection (called by safeTransferFrom's _checkOnERC721Received check)
   998	            _supplyNft(from, msg.sender, tokenId, price, rate);
   999	        } else if (data.length == 288) {
  1000	            // Conditon (2): NFT repay or auction buy
  1001	            (Lien memory lien, uint256 lienId) = abi.decode(data, (Lien, uint256));
  1002	            /// @dev equivalent to modifier validateLien, replacing calldata to memory
  1003	            if (liens[lienId] != keccak256(abi.encode(lien))) {
  1004	                revert Errors.InvalidLien();
  1005	            }
  1006	            /// @dev msg.sender is the NFT collection address
  1007	            if (msg.sender != lien.collection) {
  1008	                revert Errors.UnmatchedCollections();
  1009	            }
  1010	            if (from == lien.borrower) {
  1011	                /// @dev repayWithNft branch
  1012	                /// @dev notice that for borrower repayWithNft and auctionSellNft (at any price point) yield the same
  1013	                /// return, since repayNft's payback = auction's payback + auction price, and auction price goes to the
  1014	                /// same "from" (the borrower) too. Routing to repayNft is more gas efficient for one less receiver.
  1015	                if (lien.loanStartTime == 0) {
  1016	                    revert Errors.InactiveLoan();
  1017	                }
  1018	                _execRepayWithNft(lien, lienId, tokenId);
  1019	            } else {
  1020	                /// @dev auctionSellNft branch
  1021	                /// @dev equivalent to modifier auctionLive, replacing calldata to memory
  1022	                if (lien.auctionStartTime == 0) {
  1023	                    revert Errors.AuctionNotStarted();
  1024	                }
  1025	                /// @dev "from" (acution buyer) is the auction buyer address that calls safeTransferFrom
  1026	                _execAuctionSellNft(lien, lienId, tokenId, from);
  1027	            }
  1028	        } else if (data.length >= 384) {
  1029	            // Conditon (3): Accept bid to sell NFT to market
  1030	            /// @dev flexible data.length because tradeData can be of any non-zero length
  1031	            (
  1032	                Lien memory lien,
  1033	                uint256 lienId,
  1034	                uint256 amount,
  1035	                address marketplace,
  1036	                address puller,
  1037	                bytes memory tradeData
  1038	            ) = abi.decode(data, (Lien, uint256, uint256, address, address, bytes));
  1039	            /// @dev equivalent to modifier validateLien, replacing calldata to memory
  1040	            if (liens[lienId] != keccak256(abi.encode(lien))) {
  1041	                revert Errors.InvalidLien();
  1042	            }
  1043	            /// @dev msg.sender is the NFT collection address
  1044	            if (msg.sender != lien.collection) {
  1045	                revert Errors.UnmatchedCollections();
  1046	            }
  1047	            /// @dev "from" (nft supplier) is address that calls safeTransferFrom
  1048	            /// @dev zero address puller, means sell to market using push based flow
  1049	            if (puller == address(0)) {
  1050	                _acceptBidSellNftToMarketCheck(lien, amount);
  1051	                _acceptBidSellNftToMarketLienUpdate(lien, lienId, tokenId, amount, from);
  1052	                _execSellNftToMarketPush(lien, tokenId, amount, marketplace, tradeData);
  1053	            } else {
  1054	                _acceptBidSellNftToMarketCheck(lien, amount);
  1055	                _acceptBidSellNftToMarketLienUpdate(lien, lienId, tokenId, amount, from);
  1056	                _execSellNftToMarketPull(lien, tokenId, amount, marketplace, puller, tradeData);
  1057	            }
  1058	        } else {
  1059	            revert Errors.InvalidParameters();
  1060	        }
  1061	    }
