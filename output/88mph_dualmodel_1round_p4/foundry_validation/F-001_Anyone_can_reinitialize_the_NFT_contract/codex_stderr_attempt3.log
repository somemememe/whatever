                if (fundingID == 0) {
                    tokenId = 0;
                    continue;
                }
            }
            return (tokenId, fundingID, useEarly);
        }
    }

    function _findFundingCandidate(IDInterestLike market, INFTLike nft) internal view returns (uint256 tokenId) {
        uint256 len = market.fundingListLength();
        for (uint256 i = 1; i <= len; i++) {
