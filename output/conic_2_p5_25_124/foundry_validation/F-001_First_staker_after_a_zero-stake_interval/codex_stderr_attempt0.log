+        require(stakedBalance > 0, "not staked");
+
+        // Path stage 3 preview: after the first post-gap stake, claimable rewards should immediately
+        // reflect the previously uncheckpointed backlog. If all previews are zero, the fork block
+        // does not satisfy the documented accrual precondition.
+        (uint256 cncPreview, uint256 crvPreview, uint256 cvxPreview) = rewardManager.claimableRewards(
+            address(this)
+        );
+        require(cncPreview != 0 || crvPreview != 0 || cvxPreview != 0, "no backlog");
+
+        // Path stage 4: claim triggers accountCheckpoint -> poolCheckpoint and assigns the
+        // backlog against the now-nonzero supply, which this contract fully owns.
+        rewardManager.claimEarnings();
+
+        uint256 crvProfit = IERC20(CRV).balanceOf(address(this)) - crvBefore;
+        uint256 cvxProfit = IERC20(CVX).balanceOf(address(this)) - cvxBefore;
+        uint256 cncProfit = IERC20(CNC).balanceOf(address(this)) - cncBefore;
+
+        uint256 stakeToExit = staker.getUserBalanceForPool(pool, address(this));
+        if (stakeToExit > 0) {
+            conicPool.unstakeAndWithdraw(stakeToExit, 0);
+        }
+
+        require(
+            underlying.balanceOf(address(this)) >= capitalAmount + flashFee,
+            "cannot repay temporary capital"
+        );
+
+        _hypothesisValidated = true;
