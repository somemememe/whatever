    /// @return lpReceived The amount of LP received
    function depositFor(
        address account,
        uint256 underlyingAmount,
        uint256 minLpReceived,
        bool stake
    ) public override returns (uint256) {
        DepositVars memory vars;

        // Preparing deposit
        require(!isShutdown, "pool is shutdown");
