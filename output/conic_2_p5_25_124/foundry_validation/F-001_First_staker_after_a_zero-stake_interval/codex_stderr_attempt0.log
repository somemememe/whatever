/Users/zhanglongqin/AuditHoundV2/output/paraspace_p5_25_124/rounds/round_1/merge_stderr.log:100:[{"id": "F-001", "severity": "Critical", "confidence": "high", "title": "Incorrect debt calculation uses balanceOf instead of scaledBalanceOf", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/helpers/Helpers.sol:30-35"], "claim": "The getUserCurrentDebt function uses IERC20(debtTokenAddress).balanceOf(user) to calculate user debt instead of the scaled balance mechanism. For variable debt tokens using Aave-style scaled balances, debt should be calculated as scaledBalanceOf(user) * currentIndex.", "impact": "This causes critical accounting errors throughout the protocol. Debt calculations will be incorrect, leading to users being able to borrow more than allowed, incorrect liquidation triggers, and protocol insolvency. The function is used in LiquidationLogic._calculateDebt (line 617) and BorrowLogic.executeRepay (line 150).", "paths": ["Call getUserCurrentDebt in liquidation to calculate user's total debt", "Call getUserCurrentDebt in repay to validate repayment amount"]}, {"id": "F-002", "severity": "High", "confidence": "high", "title": "Integer overflow in GenericLogic liquidity threshold calculation", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:176-178", "0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:223-225", "0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:231"], "claim": "The liquidation threshold and LTV calculations multiply userBalanceInBaseCurrency by liquidationThreshold/LTV without overflow checks. For large collateral values, this can overflow causing incorrect health factor calculations.", "impact": "Integer overflow can cause health factor to be calculated incorrectly, potentially allowing undercollateralized positions to be opened or preventing valid liquidations.", "paths": ["Supply large amount of collateral", "Attempt to borrow - overflow causes incorrect collateral calculation", "Health factor calculation uses incorrect values"]}, {"id": "F-003", "severity": "High", "confidence": "high", "title": "Division by zero when liquidation bonus is zero", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:830-832"], "claim": "In _calculateERC721LiquidationParameters, the function calls percentDiv(superVars.liquidationBonus) without checking if liquidationBonus is zero. If the reserve's liquidation bonus is configured as zero, this will cause division by zero.", "impact": "Protocol would be unable to liquidate ERC721 positions when liquidation bonus is zero, potentially leading to stuck positions and protocol insolvency.", "paths": ["Configure reserve with zero liquidation bonus", "Attempt liquidation - reverts due to division by zero"]}, {"id": "F-004", "severity": "High", "confidence": "medium", "title": "Reentrancy vulnerability in FlashClaimLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/FlashClaimLogic.sol:61-79"], "claim": "The executeFlashClaim function transfers NFTs to the receiver contract (step 1) BEFORE executing the callback (step 2). A malicious receiver could trigger a reentrancy attack by calling back into the pool during the executeOperation callback.", "impact": "An attacker could potentially steal NFTs from other users or manipulate the protocol state during the callback before the health factor check in step 4.", "paths": ["Deploy malicious flash claim receiver", "Call executeFlashClaim with malicious receiver", "During callback, exploit state before HF check"]}, {"id": "F-005", "severity": "High", "confidence": "medium", "title": "Reentrancy in marketplace flash loan pattern", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/MarketplaceLogic.sol:143-172"], "claim": "The _buyWithCredit function performs _flashSupplyFor, _flashLoanTo, then makes an external delegatecall to the marketplace adapter before handling repayments. The callback to the marketplace can reenter the pool.", "impact": "A malicious marketplace adapter could reenter the pool during the delegatecall, potentially manipulating state before flash loan repayment.", "paths": ["Create malicious marketplace", "Call buyWithCredit through malicious marketplace", "During delegatecall, manipulate state before repayment"]}, {"id": "F-006", "severity": "Medium", "confidence": "high", "title": "NFT transferred before state update in supply", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/SupplyLogic.sol:234-247"], "claim": "executeSupplyERC721 transfers NFTs to the xToken address (line 235-240) before calling executeSupplyERC721Base which updates the user's collateral state (minting nTokens). If the transfer succeeds but the mint fails, NFTs could be locked in the xToken without proper accounting.", "impact": " NFTs could become locked in the xToken without corresponding nToken mint, causing permanent loss of user's NFTs.", "paths": ["Call executeSupplyERC721", "NFT transferred to xToken", "Mint fails due to validation - NFT stuck"]}, {"id": "F-007", "severity": "Medium", "confidence": "medium", "title": "Unchecked return value in MarketplaceLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/MarketplaceLogic.sol:152-160"], "claim": "The Address.functionDelegateCall to the marketplace adapter does not check if the call succeeded before proceeding to handle flash loan repayment. Failed marketplace executions could be silently ignored.", "impact": "If the marketplace execution fails silently, the protocol would still proceed with flash loan repayment, potentially causing fund loss or inconsistent state.", "paths": ["Call buyWithCredit with failing marketplace", "delegatecall fails silently", "Protocol continues with repayment handling"]}, {"id": "F-008", "severity": "Medium", "confidence": "high", "title": "Repay with pTokens allows repaying more than debt", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/BorrowLogic.sol:165-174"], "claim": "When usePTokens is true and amount is type(uint256).max, the repay amount is set to the caller's pToken balance. There's no validation that this doesn't exceed the actual debt. Additionally, the calculation paybackAmount = params.amount when params.amount < paybackAmount allows over-repayment.", "impact": "Users could over-repay their debt, losing excess funds. The protocol would have excess tokens with no corresponding debt.", "paths": ["Borrow funds", "Acquire pTokens through other means", "Repay more than debt via usePTokens"]}, {"id": "F-009", "severity": "Low", "confidence": "medium", "title": "Missing initialization check in ParaProxy constructor", "locations": ["0x638a98bbb92a7582d07c52ff407d49664dc8b3ee/contracts/protocol/libraries/paraspace-upgradeability/ParaProxy.sol:13-15"], "claim": "The ParaProxy constructor sets the contract owner without checking if _contractOwner is address(0). A proxy with address(0) as owner would have no admin.", "impact": "If deployed with address(0) as owner, the proxy becomes non-upgradeable as no one can call updateImplementation.", "paths": ["Deploy proxy with address(0) as owner"]}, {"id": "F-010", "severity": "Low", "confidence": "medium", "title": "Potential division by zero in GenericLogic", "locations": ["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/GenericLogic.sol:251-264"], "claim": "The avgLtv, avgLiquidationThreshold, and avgERC721LiquidationThreshold calculations use division after a previous check for non-zero totalCollateralInBaseCurrency, but totalCollateralInBaseCurrency could equal totalERC721CollateralInBaseCurrency causing issues in later calculations.", "impact": "Could cause incorrect health factor calculations in certain edge cases with mixed collateral types.", "paths": ["User supplies both ERC20 and ERC721 collateral", "Calculate health factor", "Division edge case"]}]
/Users/zhanglongqin/AuditHoundV2/output/paraspace_p5_25_124/rounds/round_1/merge_stderr.log:4589:{"findings":[{"id":"F-001","severity":"High","confidence":"high","title":"Siloed-borrowing risk controls are defined but never enforced on borrow","locations":["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/ValidationLogic.sol:253","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/configuration/UserConfiguration.sol:196","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/configuration/ReserveConfiguration.sol:303","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/helpers/Errors.sol:84"],"claim":"The protocol includes silo-borrowing state helpers (`getSiloedBorrowingState`, `getSiloedBorrowing`) and an explicit `SILOED_BORROWING_VIOLATION` error, but `BorrowLogic.executeBorrow()` delegates to `ValidationLogic.validateBorrow()` and that validation never checks either the requested reserve's silo flag or the user's existing siloed-borrowing state. As a result, borrowing a siloed reserve does not prevent additional borrows, and existing borrows do not prevent borrowing a siloed reserve.","impact":"If governance lists any reserve expecting isolated exposure, borrowers can still combine it with other debts. That defeats the intended risk model for siloed assets and can convert isolated risk into cross-reserve bad debt and insolvency during adverse price moves.","paths":["borrow() -> BorrowLogic.executeBorrow() -> ValidationLogic.validateBorrow()"],"round":1,"source_agents":["codex_1"]},{"id":"F-002","severity":"High","confidence":"high","title":"ERC721 liquidation can seize NFT collateral using any listed ERC20 without repaying or even bounding against actual debt","locations":["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:337","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:344","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:389","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:564","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/LiquidationLogic.sol:755","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/ValidationLogic.sol:677","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/ValidationLogic.sol:695"],"claim":"`executeLiquidateERC721()` computes `actualLiquidationAmount` solely from the NFT price and the caller-chosen `liquidationAsset`. `_calculateERC721LiquidationParameters()` returns the borrower's global debt converted into that asset's units, but `validateLiquidateERC721()` only checks that `globalDebt != 0`; it does not require that the borrower owes the chosen `liquidationAsset`, and it does not cap liquidation by reserve-specific debt or even total debt. After validation, the flow calls `_supplyNewCollateral()` to deposit the chosen ERC20 as fresh collateral for the borrower instead of burning any debt token in that reserve.","impact":"Any undercollateralized NFT-backed account with nonzero debt can have an NFT seized by paying with any listed ERC20 priced by the oracle, even if the borrower never borrowed that asset and even if the amount paid exceeds the borrower's real debt. If a listed ERC20 has a weak or manipulable oracle, an attacker can cheaply seize valuable NFTs while leaving the original debt outstanding, directly harming users and worsening protocol insolvency.","paths":["liquidateERC721(collateralAsset, liquidationAsset=X) -> _calculateERC721LiquidationParameters() -> validateLiquidateERC721() -> _supplyNewCollateral()"],"round":1,"source_agents":["codex_1"]},{"id":"F-003","severity":"Medium","confidence":"high","title":"supplyERC721FromNToken is bricked by `ownerOf` on nonexistent nToken ids","locations":["0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/ValidationLogic.sol:118","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/ValidationLogic.sol:139","0xaef900f14710d067ae96555486232c7189784f50/contracts/protocol/libraries/logic/SupplyLogic.sol:267","0xaef900f14710d067ae96555486232c7189784f50/contracts/dependencies/openzeppelin/contracts/ERC721.sol:76"],"claim":"Before `executeSupplyERC721FromNToken()` remints the nToken position, `validateSupplyFromNToken()` requires `IERC721(reserveCache.xTokenAddress).ownerOf(tokenId) == address(0)`. Standard OpenZeppelin ERC721 `ownerOf` reverts for nonexistent tokens rather than returning the zero address, so the validation itself reverts precisely in the normal case where the nToken for that tokenId has not been minted yet.","impact":"The `supplyERC721FromNToken` path is effectively unusable, causing a protocol-level denial of service for any recovery, migration, or atomic re-collateralization flow that depends on re-supplying NFTs already held by the NToken contract without a fresh underlying transfer.","paths":["supplyERC721FromNToken() -> SupplyLogic.executeSupplyERC721FromNToken() -> ValidationLogic.validateSupplyFromNToken()"],"round":1,"source_agents":["codex_1"]}],"rejected_candidates":[{"title":"Incorrect debt calculation uses balanceOf instead of scaledBalanceOf","source_agents":["opencode_1"],"reason":"Not supported. `IVariableDebtToken` explicitly exposes `balanceOf(user)` as the current debt view, and this helper is used where current debt is needed. The separate `scaledBalanceOf` path in `GenericLogic` is an optimization, not evidence that `balanceOf` is wrong here."},{"title":"Integer overflow in GenericLogic liquidity threshold calculation","source_agents":["opencode_1"],"reason":"Not reportable. The cited multiplications are executed under Solidity 0.8 checked arithmetic, so overflow reverts instead of silently corrupting health factor calculations."},{"title":"Division by zero when liquidation bonus is zero","source_agents":["opencode_1"],"reason":"Only arises from administrator misconfiguration of reserve parameters. The code does not show an attacker-triggerable path, so this is not a protocol vulnerability."},{"title":"Reentrancy vulnerability in FlashClaimLogic","source_agents":["opencode_1"],"reason":"Insufficiently supported. The report does not identify a concrete state-corruption path, and the repository snapshot does not expose a vulnerable public `flashClaim` entrypoint that would make the callback reentrancy claim reportable on its own."},{"title":"Reentrancy in marketplace flash loan pattern","source_agents":["opencode_1"],"reason":"Not supported. The public marketplace entrypoints in `PoolMarketplace` are protected by `nonReentrant`, so a generic callback/reentrancy claim against `_buyWithCredit` is not enough."},{"title":"NFT transferred before state update in supply","source_agents":["opencode_1"],"reason":"Not reportable. If `executeSupplyERC721Base` reverts, the prior `safeTransferFrom` is reverted as part of the same transaction, so the NFT is not permanently stranded by this ordering alone."},{"title":"Unchecked return value in MarketplaceLogic","source_agents":["opencode_1"],"reason":"Incorrect. `Address.functionDelegateCall` reverts on failure; the delegatecall result is not silently ignored."},{"title":"Repay with pTokens allows repaying more than debt","source_agents":["opencode_1"],"reason":"Incorrect. `paybackAmount` is initialized to actual debt and only reduced when `params.amount` is smaller, so repayment is capped at `min(requestedAmount, variableDebt)`."},{"title":"Missing initialization check in ParaProxy constructor","source_agents":["opencode_1"],"reason":"Deployment self-misconfiguration only. Passing `address(0)` as owner does not create an attacker-triggerable protocol issue."},{"title":"Potential division by zero in GenericLogic","source_agents":["opencode_1"],"reason":"Not supported. The cited divisions are guarded by explicit nonzero checks on the relevant collateral totals, and the ERC721 health-factor denominator is separately guarded by `payableDebtByERC20Assets >= totalDebtInBaseCurrency`."}]}
