            uint256 _totalBorrowShares,
            uint256 _borrowRate
        ) {
            return (_allowBorrow, _pseudoTotalBorrowAmount, _totalBorrowShares, _borrowRate);
        } catch {
            return (false, 0, 0, 0);
        }
