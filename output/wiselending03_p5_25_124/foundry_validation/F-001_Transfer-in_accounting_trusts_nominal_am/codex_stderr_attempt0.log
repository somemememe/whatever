+    function _probeAmount(address token) internal view returns (uint256) {
+        uint8 dec = 18;
+        try IERC20Like(token).decimals() returns (uint8 fetched) {
+            dec = fetched > 18 ? 18 : fetched;
+        } catch {}
+
+        return 10 ** uint256(dec);
