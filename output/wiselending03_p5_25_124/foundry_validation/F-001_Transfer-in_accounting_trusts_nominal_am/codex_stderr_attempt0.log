+}
+
+contract TokenVault {
+    address public immutable owner;
+
+    constructor() {
+        owner = msg.sender;
+    }
+
+    function sweep(address token, address to) external {
+        require(msg.sender == owner, "only owner");
+        uint256 amount = IERC20Like(token).balanceOf(address(this));
+        if (amount == 0) {
