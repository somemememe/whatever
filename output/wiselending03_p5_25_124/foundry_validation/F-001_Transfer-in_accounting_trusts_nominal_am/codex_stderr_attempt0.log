+    address public vulnerableToken;
+    uint256 public depositPathNft;
+    uint256 public solelyPathNft;
+    uint256 public liquidatorNft;
+
+    modifier onlySelf() {
+        require(msg.sender == address(this), "only self");
+        _;
+    }
