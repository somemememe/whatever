+            return true;
+        } catch {
+            return false;
+        }
+    }
+
+    function _tryBorrow(uint256 nftId, address token, uint256 amount) internal returns (bool) {
+        try this.callBorrow(nftId, token, amount) returns (uint256) {
+            return true;
+        } catch {
+            return false;
+        }
