+
+    function _tryDepositWithEscalation(uint256 nftId, address token, uint256 amount) internal returns (bool) {
+        if (_tryDeposit(nftId, token, amount)) {
+            return true;
+        }
+
+        uint256 next = amount * 10;
+        if (next > amount && _tryDeposit(nftId, token, next)) {
+            return true;
+        }
+
+        next = next * 10;
+        if (next > amount && _tryDeposit(nftId, token, next)) {
