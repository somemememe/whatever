+    constructor() {
+        WISE = IWiseLendingLike(TARGET);
+        WETH = WISE.WETH_ADDRESS();
+        SECURITY = IWiseSecurityLike(WISE.WISE_SECURITY());
+        POSITION_NFT = IPositionNFTLike(WISE.POSITION_NFT());
+        VAULT = new TokenVault();
