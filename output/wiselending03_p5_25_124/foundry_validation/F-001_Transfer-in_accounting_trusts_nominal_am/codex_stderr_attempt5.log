        list[11] = 0x4e3FBD56CD56c3e72c1403e103b45Db9da5B9D2B; // CVX
        list[12] = WETH;
        list[13] = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48; // USDC
