            uint256 debtRatio;
            try SECURITY.getLiveDebtRatio(nftId) returns (uint256 ratio) {
                debtRatio = ratio;
            } catch {
                continue;
            }

            if (debtRatio <= 1e18) {
                continue;
            }

            uint256 borrowShares = WISE.getPositionBorrowShares(nftId, token);
            if (borrowShares == 0) {
                continue;
            }

