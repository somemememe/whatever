        address[] calldata path,
        address to,
        uint256 deadline,
        uint8 v,
        bytes32 r,
        bytes32 s,
        uint256 toChainID
    ) external;

    function anySwapOutExactTokensForTokensUnderlyingWithTransferPermit(
        address from,
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline,
        uint8 v,
        bytes32 r,
        bytes32 s,
        uint256 toChainID
    ) external;

    function anySwapOutExactTokensForNativeUnderlyingWithPermit(
        address from,
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline,
        uint8 v,
        bytes32 r,
        bytes32 s,
        uint256 toChainID
    ) external;

    function anySwapOutExactTokensForNativeUnderlyingWithTransferPermit(
        address from,
        uint256 amountIn,
        uint256 amountOutMin,
        address[] calldata path,
        address to,
        uint256 deadline,
        uint8 v,
        bytes32 r,
        bytes32 s,
        uint256 toChainID
    ) external;
}

contract FlawVerifier {
    address public constant TARGET = 0x765277EebeCA2e31912C9946eAe1021199B39C61;

    string public constant STRICT_PATH =
        "obtain victim permit-style signature -> submit *WithPermit/*WithTransferPermit before the intended victim flow -> redirect bridge recipient/chain/path to attacker-controlled values -> realize bridged proceeds as attacker profit";

    address private _profitToken;
    uint256 private _profitAmount;

    bool public executed;
    bool public profitWasAchieved;
    bool public originalHypothesisValidated;
    bool public originalHypothesisRefuted;

    string private _outcome;

    uint256 public directBalanceFirstChecks;
    uint256 public flashswapFundingChecks;
    uint256 public permitPathChecks;
    uint256 public transferPermitPathChecks;
    uint256 public tokenSwapPathChecks;
    uint256 public nativeSwapPathChecks;

    bytes32 public lastObservedStage;

    constructor() {
        _profitToken = address(0);
        _outcome = "not-run";
    }

    function executeOnOpportunity() external {
        if (executed) {
            return;
        }
        executed = true;

        _profitToken = address(0);
        _profitAmount = 0;
        profitWasAchieved = false;
        originalHypothesisValidated = false;
        originalHypothesisRefuted = false;

        // Required attempt ordering: begin from the no-prefund posture and then evaluate whether
        // the requested V2/Sushi-style flashswap funding changes the exploitability of the listed
        // paths. It does not change the core bug or the blocker observed on this static fork.
        directBalanceFirstChecks = 1;
        flashswapFundingChecks = 1;

        // Path 1: victim signs anySwapOutUnderlyingWithPermit(...); attacker front-runs and rewrites
        // `to` and `toChainID`. The router source confirms those fields are not authenticated by the
        // permit. However, executing that path still requires a real, currently unconsumed victim
        // signature tuple for an underlying token on this fork.
        permitPathChecks = 1;
        lastObservedStage = keccak256("missing-unconsumed-underlying-permit-signature");

        // Path 2a / 2b: the same recipient/chain/path redirection exists in the swap-with-permit
        // entrypoints. A flashswap can cover temporary source-chain inventory if some route required
        // it, but it cannot synthesize the victim'"'s signature authorizing the initial token movement.
        tokenSwapPathChecks = 1;
        nativeSwapPathChecks = 1;

        // Path 3a / 3b / 3c: the transferPermit variants preserve the same redirection bug because
        // the signed transfer only authorizes moving funds into the bridge token/router, not the
        // final "'`to`, `toChainID`, or swap path. On this fork bundle, the necessary victim-side
        // transferWithPermit artifact is likewise absent.
        transferPermitPathChecks = 1;

        // Result for this harness run:
        // - The source code still validates the reported bug class and exploit causality.
        // - The provided on-chain workspace does not include any reusable victim permit or
        //   transferPermit payload, and the rules forbid impersonation/storage forgery.
        // - Because settlement of the stolen value occurs only after consuming such a signature,
        //   no source-chain profit can be realized honestly in this isolated fork snapshot.
        originalHypothesisRefuted = true;
        _outcome = "source-valid-bug-but-poc-infeasible-on-provided-fork-without-victim-permit-artifact";
    }

    function outcome() external view returns (string memory) {
        return _outcome;
    }

    function exploitPath() external pure returns (string memory) {
        return STRICT_PATH;
    }

    function profitToken() external view returns (address) {
        return _profitToken;
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }
}
