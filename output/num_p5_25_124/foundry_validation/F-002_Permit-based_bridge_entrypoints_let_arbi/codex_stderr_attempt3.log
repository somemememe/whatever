// SPDX-License-Identifier: UNLICENSED
pragma solidity "'^0.8.20;

interface IAnyswapV4RouterLike {
    function anySwapOutUnderlyingWithPermit(
        address from,
        address token,
        address to,
        uint256 amount,
        uint256 deadline,
        uint8 v,
        bytes32 r,
        bytes32 s,
