   347	  function setDynamicSaleState(bool _state) external onlyOwner {
   348	    dynamicSaleState = _state;
   349	  }
   350	
   351	  function setMaxTokensToSell(uint256 _tokensToSell) external onlyOwner {
   352	    maxTokensToSell = _tokensToSell;
   353	  }
   354	
   355	  function setRouter(address _router) external onlyOwner {
   356	    router = IRouter(_router);
   357	  }
   358	
   359	  function fetchPrice(uint256 amount) public view returns (uint256) {
   360	    return (staticTokenPrice * amount ) ;
   361	  }
   362	
   363	  function setPercent(uint256 _percent) external onlyOwner {
   364	    percent = _percent;
   365	  }
   366	  function setStaticTokenPrice(uint256 _staticTokenPrice) external onlyOwner {
   367	    staticTokenPrice = _staticTokenPrice;
   368	  }
