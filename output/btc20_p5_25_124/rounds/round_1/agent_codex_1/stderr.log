   317	  function buyWithEthDynamic(uint256 amount) external payable whenNotPaused nonReentrant returns (bool) {
   318	    require(dynamicSaleState, 'dynamic sale not active');
   319	    require(amount <= maxTokensToSell - directTotalTokensSold, 'amount exceeds max tokens to be sold');
   320	    directTotalTokensSold += amount;
   321	    uint256 usdPrice = fetchPrice(amount);
   322	    uint256 ethAmount = (usdPrice * baseDecimals)/getLatestPrice(); 
   323	    require(msg.value >= ethAmount, 'Less payment');
   324	    uint256 excess = msg.value - ethAmount;
   325	    sendValue(payable(paymentWallet), ethAmount);
   326	    if (excess > 0) sendValue(payable(_msgSender()), excess);
   327	    bool success = IERC20Upgradeable(saleToken).transfer(_msgSender(), (amount * baseDecimals));
   328	    require(success, 'Token transfer failed');
   329	    emit TokensBought(_msgSender(), amount, address(0), ethAmount, 0, block.timestamp);
   330	    return true;
   331	  }
   332	
   333	  function buyWithUSDTDynamic(uint256 amount) external whenNotPaused returns (bool) {
   334	    require(dynamicSaleState, 'dynamic sale not active');
   335	    require(amount <= maxTokensToSell - directTotalTokensSold, 'amount exceeds max tokens to be sold');
   336	    directTotalTokensSold += amount;
   337	    uint256 usdPrice = fetchPrice(amount);
   338	    uint256 price = usdPrice / (10 ** 12);
   339	    (bool success, ) = address(USDTInterface).call(abi.encodeWithSignature('transferFrom(address,address,uint256)', _msgSender(), paymentWallet, price));
   340	    require(success, 'Token payment failed');
   341	    bool tokenTransferSuccess = IERC20Upgradeable(saleToken).transfer(_msgSender(), (amount * baseDecimals));
   342	    require(tokenTransferSuccess, 'Token transfer failed');
   343	    emit TokensBought(_msgSender(), amount, address(USDTInterface), price, usdPrice, block.timestamp);
   344	    return true;
   345	  }
