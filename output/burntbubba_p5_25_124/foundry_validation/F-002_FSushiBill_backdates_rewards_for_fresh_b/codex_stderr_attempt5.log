+            path = new address[](2);
+            path[0] = sushi;
+            path[1] = tokenOut;
+            return path;
+        }
+
+        path = new address[](3);
+        path[0] = sushi;
+        path[1] = WETH;
+        path[2] = tokenOut;
+    }
