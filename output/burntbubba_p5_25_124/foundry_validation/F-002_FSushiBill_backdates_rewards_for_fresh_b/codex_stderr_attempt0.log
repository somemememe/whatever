+        (bool okBill, bytes memory billData) = candidate.staticcall(abi.encodeWithSelector(ISousChef.getBill.selector, pid));
+        return okBill && billData.length >= 32;
+    }
+
+    function _attemptDirectFlashSwap(Context memory ctx) internal returns (bool) {
+        address pair = _findBestPair(ctx.fToken, ctx.fSushi);
