+        (uint256 reserveFToken, uint256 reserveFSushi, bool token0IsFToken) = _orderedReserves(pair, ctx.fToken, ctx.fSushi);
+        if (reserveFToken <= 1 || reserveFSushi <= 1) {
+            return false;
