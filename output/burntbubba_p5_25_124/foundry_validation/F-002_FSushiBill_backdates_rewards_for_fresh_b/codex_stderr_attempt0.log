+        ctx.fSushi = ISousChef(ctx.sousChef).fSushi();
+    }
+
+    function _discoverSousChef(address flpToken, uint256 pid) internal view returns (address) {
+        address factory = IFarmingLPToken(flpToken).factory();
+        address[] memory candidates = new address[](8);
+        candidates[0] = flpToken;
+        candidates[1] = factory;
+        candidates[2] = IFarmingLPToken(flpToken).router();
+        candidates[3] = IFarmingLPToken(flpToken).masterChef();
+        candidates[4] = _tryGetAddress(factory, IFarmingLPTokenFactory.yieldVault.selector);
+        candidates[5] = _tryGetAddress(factory, IFarmingLPTokenFactory.migrator.selector);
