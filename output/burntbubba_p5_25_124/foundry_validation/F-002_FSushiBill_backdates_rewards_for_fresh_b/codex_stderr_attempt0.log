+    function _estimateFreshClaim(Context memory ctx, uint256 amount) internal returns (uint256 totalRewards) {
+        uint256 fromWeek = ISousChef(ctx.sousChef).startWeek();
+        uint256 toWeek = block.timestamp / WEEK;
