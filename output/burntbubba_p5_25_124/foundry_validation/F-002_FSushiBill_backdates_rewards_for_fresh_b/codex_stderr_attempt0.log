        uint256 stakeDuration
    ) external onlyOwner returns (uint256) {
        uint256 deadline = block.timestamp;
        address lpToken = IFarmingLPToken(flpToken).lpToken();
        _approveMax(lpToken, flpToken);
        IFarmingLPToken(flpToken).deposit(amountLP, path0, path1, 0, address(this), deadline);

        uint256 amountFLP = IFarmingLPToken(flpToken).balanceOf(address(this));
        address protocol = IFlashStrategySushiSwap(strategy).flashProtocol();
        _approveMax(flpToken, protocol);
        (, , , , , , , uint256 fTokensToUser, , , ) = IFlashProtocolLike(protocol).stake(
            strategy,
            amountFLP,
            stakeDuration,
            address(this),
            false
        );

        address fToken = IFlashStrategySushiSwap(strategy).fToken();
        _approveMax(fToken, bill);
        IFSushiBill(bill).deposit(fTokensToUser, beneficiary);
        return fTokensToUser;
    }

    function withdrawBill(address bill, uint256 amount, address beneficiary) external onlyOwner {
        IFSushiBill(bill).withdraw(amount, beneficiary);
    }

    function sweep(address token, address to) external onlyOwner {
        _safeTransfer(token, to, IERC20Minimal(token).balanceOf(address(this)));
    }

    function _approveMax(address token, address spender) internal {
        (bool ok, bytes memory data) = token.call(abi.encodeWithSelector(IERC20Minimal.approve.selector, spender, type(uint256).max));
