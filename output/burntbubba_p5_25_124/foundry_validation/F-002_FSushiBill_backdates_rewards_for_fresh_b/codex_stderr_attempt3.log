-    function _scanCreateAddressesForStrategyFactory(address creator, address flpFactory)
-        internal
-        view
-        returns (address)
-    {
-        for (uint256 nonce = 1; nonce <= MAX_DISCOVERY_NONCE; ++nonce) {
-            address candidate = _computeCreateAddress(creator, nonce);
