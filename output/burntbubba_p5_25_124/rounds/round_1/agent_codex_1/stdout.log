      "0xa44e79a2c9a8965e7a6fa77bf0ca8faf50e6c73e/contracts/FSushiBill.sol:86"
    ],
    "claim": "FSushiBill.deposit manually increments `_balanceOf[msg.sender]` and `_totalSupply` before calling `_mint(beneficiary, amount)`, and withdraw manually decrements them before `_burn`. A self-beneficiary deposit therefore gives 2x bill balance for 1x fToken deposited, doubling the account's reward weight.",
    "impact": "Bill holders can claim materially more fSUSHI emissions than their actual fToken stake should earn, corrupting pool accounting and inflating reward distribution.",
    "paths": [
      "deposit(amount, msg.sender) -> manual balance/supply increment -> _mint(amount) increments again -> claimRewards() accrues against 2x balance",
      "repeat deposits across weeks -> earn disproportionate share of weeklyRewards with only half the intended collateral"
    ]
  },
