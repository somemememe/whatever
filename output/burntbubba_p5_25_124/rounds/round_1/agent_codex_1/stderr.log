   102	    function depositSigned(
   103	        uint256 assets,
   104	        uint256 _weeks,
   105	        address beneficiary,
   106	        uint256 deadline,
   107	        uint8 v,
   108	        bytes32 r,
   109	        bytes32 s
   110	    ) public override returns (uint256) {
   111	        IFSushi(asset).permit(msg.sender, address(this), assets, deadline, v, r, s);
   112	
   113	        return deposit(assets, _weeks, beneficiary);
   114	    }
   115	
   116	    function deposit(
   117	        uint256 assets,
   118	        uint256 _weeks,
   119	        address beneficiary
   120	    ) public override validWeeks(_weeks) returns (uint256) {
   121	        checkpoint();
   122	
   123	        uint256 max = (totalAssets > 0 || totalSupply == 0) ? type(uint256).max : 0;
   124	        if (assets > max) revert Bankrupt();
   125	
   126	        uint256 totalPower = _totalPower;
   127	        uint256 power = _toPower(assets, _weeks);
   128	        uint256 shares = _toShares(power, totalPower);
   129	
   130	        IERC20(asset).safeTransferFrom(msg.sender, address(this), assets);
   131	        _mint(beneficiary, shares);
   132	
   133	        _locks[msg.sender].enqueue(block.timestamp + _weeks * (1 weeks), assets, power, shares);
   134	
   135	        totalAssets += assets;
   136	        totalAssetsDuring[block.timestamp.toWeekNumber()] += assets;
   137	        _totalPower = totalPower + power;
   138	
   139	        emit Deposit(msg.sender, beneficiary, shares, assets);
   140	
   141	        return shares;
   142	    }
   143	
   144	    function withdraw(address beneficiary)
   145	        public
   146	        override
   147	        returns (
   148	            uint256 shares,
   149	            uint256 assets,
   150	            uint256 yield
   151	        )
   152	    {
   153	        checkpoint();
   154	
   155	        uint256 power;
   156	        (assets, power, shares) = _locks[msg.sender].drain(block.timestamp);
   157	        if (shares == 0) revert WithdrawalDenied();
   158	
   159	        yield = _getYield(shares);
   160	        totalAssets -= (assets + yield);
   161	        totalAssetsDuring[block.timestamp.toWeekNumber()] -= (assets + yield);
   162	        _totalPower -= power;
   163	        _totalYield -= yield;
   164	
   165	        _burn(msg.sender, shares);
   166	        IERC20(asset).safeTransfer(beneficiary, assets + yield);
   167	
   168	        emit Withdraw(msg.sender, beneficiary, shares, assets, yield);
   169	    }
   170	
   171	    function checkpointedTotalAssets() external override returns (uint256) {
   172	        checkpoint();
   173	        return totalAssets;
   174	    }
   175	
   176	    function checkpointedTotalAssetsDuring(uint256 week) external override returns (uint256) {
   177	        checkpoint();
   178	        return totalAssetsDuring[week];
   179	    }
   180	
   181	    /**
   182	     * @dev if this function doesn't get called for 512 weeks (around 9.8 years) this contract breaks
   183	     */
   184	    function checkpoint() public override {
   185	        uint256 oldTotalAssets = totalAssets;
   186	        uint256 newTotalAssets = IERC20(asset).balanceOf(address(this));
   187	        if (newTotalAssets > oldTotalAssets) {
   188	            totalAssets = newTotalAssets;
   189	            totalAssetsDuring[block.timestamp.toWeekNumber()] = newTotalAssets;
   190	            _totalPower += newTotalAssets - oldTotalAssets;
   191	            _totalYield += newTotalAssets - oldTotalAssets;
   192	        }
   193	
   194	        uint256 from = lastCheckpoint;
   195	        uint256 until = block.timestamp.toWeekNumber();
   196	        if (until <= from) return;
   197	
   198	        for (uint256 i; i < 512; ) {
   199	            uint256 week = from + i;
   200	            if (until <= week) break;
   201	
   202	            totalAssetsDuring[week + 1] = totalAssetsDuring[week];
   203	
   204	            unchecked {
   205	                ++i;
   206	            }
   207	        }
   208	
   209	        lastCheckpoint = until;
   210	    }
   211	
   212	    function _mint(address account, uint256 amount) internal {
   213	        if (account == address(0)) revert InvalidAccount();
   214	
   215	        totalSupply += amount;
   216	        unchecked {
   217	            balanceOf[account] += amount;
   218	        }
   219	
   220	        emit Transfer(address(0), account, amount);
   221	    }
   222	
   223	    function _burn(address account, uint256 amount) internal {
   224	        if (account == address(0)) revert InvalidAccount();
   225	
   226	        uint256 balance = balanceOf[account];
   227	        if (balance < amount) revert NotEnoughBalance();
   228	        unchecked {
   229	            balanceOf[account] = balance - amount;
   230	            totalSupply -= amount;
   231	        }
   232	
   233	        emit Transfer(account, address(0), amount);
   234	    }
   235	}

