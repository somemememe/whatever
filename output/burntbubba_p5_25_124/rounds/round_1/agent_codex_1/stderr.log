    50	        if (_weeks < MINIMUM_WEEKS || _weeks > MAXIMUM_WEEKS) revert InvalidDuration();
    51	        _;
    52	    }
    53	
    54	    constructor(address fSushi) {
    55	        asset = fSushi;
    56	
    57	        uint256 thisWeek = block.timestamp.toWeekNumber();
    58	        startWeek = thisWeek;
    59	        lastCheckpoint = thisWeek;
    60	    }
    61	
    62	    function previewDeposit(uint256 assets, uint256 _weeks)
    63	        public
    64	        view
    65	        override
    66	        validWeeks(_weeks)
    67	        returns (uint256 shares)
    68	    {
    69	        return _toShares(_toPower(assets, _weeks), _totalPower);
    70	    }
    71	
    72	    function previewWithdraw(address owner)
    73	        public
    74	        view
    75	        override
    76	        returns (
    77	            uint256 shares,
    78	            uint256 assets,
    79	            uint256 yield
    80	        )
    81	    {
    82	        (assets, , shares) = _locks[owner].enqueued(block.timestamp);
    83	        yield = _getYield(shares);
    84	    }
    85	
    86	    function _toShares(uint256 power, uint256 totalPower) internal view returns (uint256 shares) {
    87	        uint256 supply = totalSupply;
    88	        shares = (power == 0 || supply == 0) ? power : power.mulDiv(supply, totalPower, Math.Rounding.Down);
    89	    }
    90	
    91	    function _toPower(uint256 assets, uint256 _weeks) internal pure returns (uint256) {
    92	        return assets.mulDiv(_weeks, MAXIMUM_WEEKS, Math.Rounding.Up);
    93	    }
    94	
    95	    function _getYield(uint256 shares) internal view returns (uint256 yield) {
    96	        uint256 _totalSupply = totalSupply;
    97	        if (_totalSupply == 0) return 0;
    98	
    99	        return _totalYield.mulDiv(shares, _totalSupply, Math.Rounding.Down);
   100	    }
