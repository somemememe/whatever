    22	
    23	    error Expired();
    24	    error Claimed();
    25	
    26	    event Claim(
    27	        address indexed account,
    28	        uint256 amount,
    29	        address indexed beneficiary,
    30	        uint256 fromWeek,
    31	        uint256 untilWeek
    32	    );
    33	
    34	    constructor(address _votingEscrow, address _fSushi) {
    35	        votingEscrow = _votingEscrow;
    36	        fSushi = _fSushi;
    37	        startWeek = block.timestamp.toWeekNumber();
    38	        votingEscrowInterval = IVotingEscrow(_votingEscrow).interval();
    39	    }
    40	
    41	    function claim(address beneficiary) external returns (uint256 amount) {
    42	        IVotingEscrow(votingEscrow).checkpoint();
    43	
    44	        uint256 from = lastCheckpointOf[msg.sender];
    45	        if (from == 0) {
    46	            from = startWeek;
    47	        }
    48	        uint256 until = block.timestamp.toWeekNumber() + 1;
    49	
    50	        for (uint256 i; i < 512; ) {
    51	            uint256 week = from + i;
    52	            if (week >= until) break;
    53	
    54	            uint256 weekStart = week.toTimestamp();
    55	            uint256 balance = _votingEscrowBalanceOf(msg.sender, weekStart);
    56	            uint256 totalSupply = _votingEscrowTotalSupply(weekStart);
    57	
    58	            amount += ((INITIAL_SUPPLY_PER_WEEK >> (week - startWeek)) * balance) / totalSupply;
    59	
    60	            unchecked {
    61	                ++i;
    62	            }
    63	        }
    64	
    65	        lastCheckpointOf[msg.sender] = until;
    66	
    67	        if (amount > 0) {
    68	            IFSushi(fSushi).mint(beneficiary, amount);
    69	
    70	            emit Claim(msg.sender, amount, beneficiary, from, until);
    71	        }
    72	    }
    73	
    74	    function _votingEscrowBalanceOf(address account, uint256 timestamp) internal view returns (uint256) {
    75	        uint256 epoch = IVotingEscrow(votingEscrow).userPointEpoch(account);
    76	        if (epoch == 0) return 0;
    77	        else {
    78	            (int128 bias, int128 slope, uint256 ts, ) = IVotingEscrow(votingEscrow).userPointHistory(account, epoch);
    79	            unchecked {
    80	                bias -= slope * int128(int256(timestamp - ts));
    81	            }
    82	            if (bias < 0) bias = 0;
    83	            return uint256(uint128(bias));
    84	        }
    85	    }
    86	
    87	    function _votingEscrowTotalSupply(uint256 timestamp) internal returns (uint256) {
    88	        uint256 week = timestamp.toWeekNumber();
    89	        if (week < lastCheckpoint) return votingEscrowTotalSupply[week];
    90	
    91	        lastCheckpoint = timestamp.toWeekNumber() + 1;
    92	
    93	        uint256 epoch = IVotingEscrow(votingEscrow).epoch();
    94	        (int128 bias, int128 slope, uint256 ts, ) = IVotingEscrow(votingEscrow).pointHistory(epoch);
    95	        uint256 t_i = (ts / votingEscrowInterval) * votingEscrowInterval;
    96	        for (uint256 i; i < 255; i++) {
    97	            t_i += votingEscrowInterval;
    98	            int128 d_slope;
    99	            if (t_i > timestamp) t_i = timestamp;
   100	            else d_slope = IVotingEscrow(votingEscrow).slopeChanges(t_i);
   101	            unchecked {
   102	                bias -= slope * int128(int256(t_i - ts));
   103	            }
   104	            if (t_i == timestamp) break;
   105	            slope += d_slope;
   106	            ts = t_i;
   107	        }
