     8	
     9	contract FSushiAirdropsVotingEscrow {
    10	    using DateUtils for uint256;
    11	
    12	    uint256 private constant INITIAL_SUPPLY_PER_WEEK = 5000e18;
    13	
    14	    address public immutable votingEscrow;
    15	    address public immutable fSushi;
    16	    uint256 public immutable startWeek;
    17	    uint256 public immutable votingEscrowInterval;
