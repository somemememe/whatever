    58	        if (self.timestamps[i] > timestamp) return (0, 0, 0);
    59	
    60	        Snapshot memory snapshot = self.snapshots[self.timestamps[i]];
    61	        assets = snapshot.assets;
    62	        power = snapshot.power;
    63	        shares = snapshot.shares;
    64	
    65	        (uint256 assetsLeft, uint256 powerLeft, uint256 sharesLeft) = _dfs(self, timestamp, i * 2);
    66	        (uint256 assetsRight, uint256 powerRight, uint256 sharesRight) = _dfs(self, timestamp, i * 2 + 1);
    67	        return (assets + assetsLeft + assetsRight, power + powerLeft + powerRight, shares + sharesLeft + sharesRight);
    68	    }
    69	
    70	    function enqueue(
    71	        Heap storage self,
