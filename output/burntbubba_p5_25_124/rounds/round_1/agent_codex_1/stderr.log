            strategy,
            amountFLP,
            stakeDuration,
            address(this),
            false
        );

        address fToken = IFlashStrategySushiSwap(strategy).fToken();
        address bill = ISousChef(sousChef).getBill(pid);

        IERC20(fToken).approve(bill, fTokensToUser);
        IFSushiBill(bill).deposit(fTokensToUser, beneficiary);
    }
}

