   120	
   121	    function _updatePoints(
   122	        mapping(uint256 => uint256) storage _points,
   123	        uint256 balance,
   124	        uint256 lastTime
   125	    ) internal {
   126	        if (balance == 0) return;
   127	
   128	        if (lastTime == 0) {
   129	            uint256 startWeek = ISousChef(sousChef).startWeek();
   130	            lastTime = startWeek.toTimestamp();
