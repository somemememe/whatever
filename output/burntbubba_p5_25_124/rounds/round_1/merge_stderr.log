    58	        _CACHED_THIS = address(this);
    59	        _TYPE_HASH = typeHash;
    60	    }
    61	
    62	    function DOMAIN_SEPARATOR() external view override returns (bytes32) {
    63	        return _domainSeparatorV4();
    64	    }
    65	
    66	    function _domainSeparatorV4() internal view returns (bytes32) {
    67	        if (address(this) == _CACHED_THIS && block.chainid == _CACHED_CHAIN_ID) {
    68	            return _CACHED_DOMAIN_SEPARATOR;
    69	        } else {
    70	            return _buildDomainSeparator(_TYPE_HASH, _HASHED_NAME, _HASHED_VERSION);
    71	        }
    72	    }
    73	
    74	    function _buildDomainSeparator(
    75	        bytes32 typeHash,
    76	        bytes32 nameHash,
    77	        bytes32 versionHash
    78	    ) private view returns (bytes32) {
    79	        return keccak256(abi.encode(typeHash, nameHash, versionHash, block.chainid, address(this)));
    80	    }
    81	
    82	    function _hashTypedDataV4(bytes32 structHash) internal view virtual returns (bytes32) {
    83	        return ECDSA.toTypedDataHash(_domainSeparatorV4(), structHash);
    84	    }
    85	
    86	    function setMinter(address account, bool _isMinter) external override onlyOwner {
    87	        if (mintersLocked) revert MintersLocked();
    88	
    89	        isMinter[account] = _isMinter;
    90	
    91	        emit SetMinter(account, _isMinter);
    92	    }
    93	
    94	    function lockMinters() external onlyOwner {
    95	        mintersLocked = true;
    96	
    97	        emit LockMinters();
    98	    }
    99	
   100	    function permit(
   101	        address owner,
   102	        address spender,
   103	        uint256 value,
   104	        uint256 deadline,
   105	        uint8 v,
   106	        bytes32 r,
   107	        bytes32 s
   108	    ) external override {
   109	        if (block.timestamp > deadline) revert Expired();
   110	
   111	        bytes32 structHash = keccak256(abi.encode(_PERMIT_TYPEHASH, owner, spender, value, nonces[owner]++, deadline));
   112	
   113	        bytes32 hash = _hashTypedDataV4(structHash);
   114	
   115	        address signer = ECDSA.recover(hash, v, r, s);
   116	        if (signer != owner) revert InvalidSignature();
   117	
   118	        _approve(owner, spender, value);
   119	    }
   120	
   121	    function mint(address to, uint256 amount) external onlyMinter {
   122	        _mint(to, amount);
   123	
   124	        checkpoint();
   125	    }
   126	
   127	    function checkpointedTotalSupplyDuring(uint256 week) external override returns (uint256) {
   128	        checkpoint();
   129	        return totalSupplyDuring[week];
   130	    }
   131	
   132	    /**
   133	     * @dev if this function doesn't get called for 512 weeks (around 9.8 years) this contract breaks
   134	     */
   135	    function checkpoint() public {
   136	        uint256 from = lastCheckpoint;
   137	        uint256 until = block.timestamp.toWeekNumber();
   138	        if (until < from) return;
   139	
   140	        for (uint256 i; i < 512; ) {
   141	            uint256 week = from + i;
   142	            uint256 old = totalSupplyDuring[week];
   143	            if (week == until) {
   144	                uint256 current = totalSupply();
   145	                if (current > old) {
   146	                    totalSupplyDuring[week] = current;
   147	                }
   148	                break;
   149	            } else if (startWeek < week && old == 0) {
   150	                totalSupplyDuring[week] = totalSupplyDuring[week - 1];
   151	            }
   152	
   153	            unchecked {
   154	                ++i;
   155	            }
   156	        }
   157	
   158	        lastCheckpoint = until;
   159	
   160	        emit Checkpoint(until);
   161	    }
   162	}

