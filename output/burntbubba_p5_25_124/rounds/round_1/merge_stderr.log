   100	        uint256 prevCheckpoint = lastCheckpoint;
   101	        _updatePoints(points, _totalSupply, prevCheckpoint);
   102	        if (prevCheckpoint < block.timestamp) {
   103	            lastCheckpoint = block.timestamp;
   104	        }
   105	
   106	        emit Checkpoint();
   107	    }
   108	
   109	    function userCheckpoint(address account) public override {
   110	        checkpoint();
