   169	        uint256 totalRewards;
   170	        uint256 to = block.timestamp.toWeekNumber(); // exclusive last index
   171	        for (uint256 i; i < 512; ) {
   172	            uint256 week = from + i;
   173	            if (to <= week) break;
   174	            uint256 weeklyRewards = ISousChef(_sousChef).weeklyRewards(week);
   175	            uint256 weight = IFSushiKitchen(kitchen).relativeWeightAt(_pid, (week + 1).toTimestamp());
   176	            uint256 rewards = points[week] == 0
   177	                ? 0
   178	                : (weeklyRewards * weight * userPoints[msg.sender][week]) / points[week] / 1e18;
   179	            totalRewards += rewards;
   180	
