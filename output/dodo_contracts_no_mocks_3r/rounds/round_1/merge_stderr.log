// SPDX-License-Identifier: MIT
pragma solidity 0.8.26;

struct MessageContext { address sender; }

interface Callable {
    function onCall(MessageContext calldata context, bytes calldata message) external payable returns (bytes memory);
}

contract BadReceiver {
    function onCall(MessageContext calldata /*context*/, bytes calldata /*message*/) external payable returns (bytes4) {
        return bytes4(0);
    }
}

contract Caller {
    function callAuth(address dst, bytes calldata data) external returns (bytes memory) {
        return Callable(dst).onCall(MessageContext({sender: address(this)}), data);
    }

    function callAuthIgnore(address dst, bytes calldata data) external {
        Callable(dst).onCall(MessageContext({sender: address(this)}), data);
    }
}
EOF
cat > /tmp/abi_mismatch_test/test/Mismatch.t.sol <<'EOF'
// SPDX-License-Identifier: MIT
pragma solidity 0.8.26;

import \"forge-std/Test.sol\";
import {Caller, BadReceiver} from \"../src/Mismatch.sol\";

contract MismatchTest is Test {
    Caller c;
    BadReceiver b;
    function setUp() public {
        c = new Caller();
        b = new BadReceiver();
    }

    function test_callAuth_reverts() public {
        vm.expectRevert();
        c.callAuth(address(b), hex\"1234\");
    }

    function test_callAuthIgnore_reverts_or_not() public {
        // just execute to inspect behavior
        c.callAuthIgnore(address(b), hex\"1234\");
    }
}
EOF
