   557	    /// @notice Handles the liquidation of users' balances, once the users' amount of collateral is too low.
   558	    /// @param users An array of user addresses.
   559	    /// @param maxBorrowParts A one-to-one mapping to `users`, contains maximum (partial) borrow amounts (to liquidate) of the respective user.
   560	    /// @param to Address of the receiver in open liquidations if `swapper` is zero.
   561	    function liquidate(
   562	        address[] memory users,
   563	        uint256[] memory maxBorrowParts,
   564	        address to,
   565	        ISwapperV2 swapper,
   566	        bytes memory swapperData
   567	    ) public virtual {
   568	        // Oracle can fail but we still need to allow liquidations
   569	        (, uint256 _exchangeRate) = updateExchangeRate();
   570	        accrue();
   571	
   572	        uint256 allCollateralShare;
   573	        uint256 allBorrowAmount;
   574	        uint256 allBorrowPart;
   575	        Rebase memory bentoBoxTotals = bentoBox.totals(collateral);
   576	        _beforeUsersLiquidated(users, maxBorrowParts);
   577	
   578	        for (uint256 i = 0; i < users.length; i++) {
   579	            address user = users[i];
   580	            if (!_isSolvent(user, _exchangeRate)) {
   581	                uint256 borrowPart;
   582	                {
   583	                    uint256 availableBorrowPart = userBorrowPart[user];
   584	                    borrowPart = maxBorrowParts[i] > availableBorrowPart ? availableBorrowPart : maxBorrowParts[i];
   585	                    userBorrowPart[user] = availableBorrowPart.sub(borrowPart);
   586	                }
   587	                uint256 borrowAmount = totalBorrow.toElastic(borrowPart, false);
   588	                uint256 collateralShare =
   589	                    bentoBoxTotals.toBase(
   590	                        borrowAmount.mul(LIQUIDATION_MULTIPLIER).mul(_exchangeRate) /
   591	                            (LIQUIDATION_MULTIPLIER_PRECISION * EXCHANGE_RATE_PRECISION),
   592	                        false
   593	                    );
   594	
   595	                userCollateralShare[user] = userCollateralShare[user].sub(collateralShare);
   596	                _afterUserLiquidated(user, collateralShare);
   597	                emit LogRemoveCollateral(user, to, collateralShare);
   598	                emit LogRepay(msg.sender, user, borrowAmount, borrowPart);
   599	                emit LogLiquidation(msg.sender, user, to, collateralShare, borrowAmount, borrowPart);
   600	
   601	                // Keep totals
   602	                allCollateralShare = allCollateralShare.add(collateralShare);
   603	                allBorrowAmount = allBorrowAmount.add(borrowAmount);
   604	                allBorrowPart = allBorrowPart.add(borrowPart);
   605	            }
   606	        }
   607	        require(allBorrowAmount != 0, "Cauldron: all are solvent");
   608	        totalBorrow.elastic = totalBorrow.elastic.sub(allBorrowAmount.to128());
   609	        totalBorrow.base = totalBorrow.base.sub(allBorrowPart.to128());
   610	        totalCollateralShare = totalCollateralShare.sub(allCollateralShare);
   611	
   612	        // Apply a percentual fee share to sSpell holders
   613	        
   614	        {
   615	            uint256 distributionAmount = (allBorrowAmount.mul(LIQUIDATION_MULTIPLIER) / LIQUIDATION_MULTIPLIER_PRECISION).sub(allBorrowAmount).mul(DISTRIBUTION_PART) / DISTRIBUTION_PRECISION; // Distribution Amount
   616	            allBorrowAmount = allBorrowAmount.add(distributionAmount);
   617	            accrueInfo.feesEarned = accrueInfo.feesEarned.add(distributionAmount.to128());
   618	        }
