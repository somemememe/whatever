   697	        
   698	        if(skim) {
   699	            // ignore amount and take every mim in this contract since it could be taken by anyone, the next block.
   700	            amount = uint128(magicInternetMoney.balanceOf(address(this)));
   701	            bentoBox.deposit(magicInternetMoney, address(this), address(this), amount, 0);
   702	        } else {
   703	            bentoBox.transfer(magicInternetMoney, msg.sender, address(this), bentoBox.toShare(magicInternetMoney, amount, true));
   704	        }
