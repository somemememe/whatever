   624	        bentoBox.transfer(collateral, address(this), to, allCollateralShare);
   625	        if (swapper != ISwapperV2(address(0))) {
   626	            swapper.swap(address(collateral), address(magicInternetMoney), msg.sender, allBorrowShare, allCollateralShare, swapperData);
   627	        }
