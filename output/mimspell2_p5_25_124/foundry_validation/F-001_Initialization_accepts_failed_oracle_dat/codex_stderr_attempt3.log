-
-        return (address(0), _emptyPath(), 0);
-    }
-
-    function _routeProducesShares(
-        address router,
-        address bento,
-        address collateralToken,
-        uint256 amountIn,
-        address[] memory path,
-        uint256 minShareOut
-    ) internal view returns (bool) {
-        try IUniswapV2RouterLike(router).getAmountsOut(amountIn, path) returns (uint256[] memory amounts) {
