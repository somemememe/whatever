-            lo = mid;
-        }
-
-        return lo;
-    }
-
-    function _findMinimalShareAmount(address bento, address token, uint256 minShareOut) internal view returns (uint256) {
-        uint256[12] memory probes = [
-            uint256(1),
-            10,
-            100,
-            1_000,
-            10_000,
-            100_000,
-            1_000_000,
-            100_000_000,
-            10_000_000_000,
-            1_000_000_000_000,
-            100_000_000_000_000,
-            10_000_000_000_000_000
-        ];
