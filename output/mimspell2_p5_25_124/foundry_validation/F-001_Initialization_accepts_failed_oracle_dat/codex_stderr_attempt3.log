-            if (shareOut >= minShareOut) {
-                return probes[i];
-            }
-        }
-
-        return 0;
-    }
-
-    function _findSeedRouteAndAmount(
-        address bento,
-        address mim,
-        address collateralToken,
-        uint256 minShareOut
-    ) internal view returns (address router, address[] memory path, uint256 amountIn) {
-        uint256[12] memory probes = [
-            uint256(1),
-            10,
-            100,
-            1_000,
-            10_000,
-            100_000,
-            1_000_000,
-            100_000_000,
-            10_000_000_000,
-            1_000_000_000_000,
-            100_000_000_000_000,
-            10_000_000_000_000_000
