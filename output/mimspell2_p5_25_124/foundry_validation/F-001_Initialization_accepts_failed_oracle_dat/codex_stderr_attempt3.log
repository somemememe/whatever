-        path[0] = a;
-        path[1] = b;
-        path[2] = c;
-    }
-
-    function _emptyPath() internal pure returns (address[] memory path) {
-        path = new address[](0);
-    }
-
-    function _finalize(address mim) internal {
-        uint256 ending = IERC20Like(mim).balanceOf(address(this));
