-        uint256[12] memory probes = [
-            uint256(1),
-            10,
-            100,
-            1_000,
-            10_000,
-            100_000,
-            1_000_000,
-            100_000_000,
-            10_000_000_000,
-            1_000_000_000_000,
-            100_000_000_000_000,
-            10_000_000_000_000_000
-        ];
-
-        address[2] memory routers = [SUSHI_ROUTER, UNISWAP_V2_ROUTER];
-        address[4] memory mids = [WETH, USDC, USDT, DAI];
