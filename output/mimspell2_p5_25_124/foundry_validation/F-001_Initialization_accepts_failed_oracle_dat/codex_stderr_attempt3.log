-    }
-
-    function _path2(address a, address b) internal pure returns (address[] memory path) {
-        path = new address[](2);
-        path[0] = a;
-        path[1] = b;
-    }
-
-    function _path3(address a, address b, address c) internal pure returns (address[] memory path) {
