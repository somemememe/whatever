    function _considerRoute(
        bytes memory encoded,
        address routeRouter,
        address[] memory candidatePath,
        uint256 probe,
        uint256 bestProfit,
        address flashPair,
        address router,
        address[] memory path,
        uint256 seedMimAmount,
        uint256 borrowAmount
    ) internal pure {
        (address candidateFlashPair, uint256 candidateBorrow, uint256 candidateProfit) =
            abi.decode(encoded, (address, uint256, uint256));
        if (candidateFlashPair == address(0) || candidateProfit <= bestProfit) {
            return;
        }

        flashPair = candidateFlashPair;
        router = routeRouter;
        path = candidatePath;
        seedMimAmount = probe;
        borrowAmount = candidateBorrow;
    }

    function _evaluateCrossDexRoute(
        SearchConfig memory cfg,
        address routeRouter,
        address flashFactory,
        address[] memory candidatePath,
        uint256 probe,
        uint256 repay
    ) internal view returns (bytes memory encoded) {
        (, uint256 shareOut) = _quoteRoute(cfg.cauldron.bentoBox(), cfg.collateralToken, routeRouter, candidatePath, probe);
        if (shareOut == 0) {
            return abi.encode(address(0), uint256(0), uint256(0));
        }

        uint256 borrowSupported = _maxBorrowSupportedByShare(cfg.cauldron, cfg.poisonedRate, shareOut, cfg.borrowCap);
        uint256 keepShare = _requiredKeepShareForBorrow(cfg.cauldron, cfg.poisonedRate, borrowSupported);
        if (borrowSupported <= repay || shareOut <= keepShare) {
            return abi.encode(address(0), uint256(0), uint256(0));
        }

        address pair = _findFlashPairOnFactory(flashFactory, cfg.mim, probe);
        if (pair == address(0)) {
            return abi.encode(address(0), uint256(0), uint256(0));
        }

        return abi.encode(pair, borrowSupported, borrowSupported - repay);
    }

    function _findFlashPairOnFactory(
        address flashFactory,
        address mim,
        uint256 minMimLiquidity

