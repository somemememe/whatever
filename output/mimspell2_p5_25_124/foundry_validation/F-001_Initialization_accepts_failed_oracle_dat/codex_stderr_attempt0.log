+        try IUniswapV2RouterLike(router).getAmountsOut(amountIn, path) returns (uint256[] memory amounts) {
+            if (amounts.length == 0 || amounts[amounts.length - 1] == 0) {
+                return false;
+            }
+
+            try IBentoBoxLike(bento).toShare(collateralToken, amounts[amounts.length - 1], false) returns (uint256 shareOut) {
+                return shareOut > 0;
+            } catch {
+                return false;
+            }
+        } catch {
+            return false;
+        }
+    }
