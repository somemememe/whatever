+        // Mapping to exploit paths:
+        // historical init() poisoned exchangeRate = 0
+        // later oracle failures preserve cached 0
+        // borrow() now uses that poisoned cache in the solvent modifier
+        cauldron.addCollateral(address(this), true, shareOut);
