+        _flashLoanInFlight = false;
+        _finalize(mim);
+    }
+
+    function onFlashLoan(address sender, address token, uint256 amount, uint256 fee, bytes calldata data) external override {
+        require(_flashLoanInFlight, "flash not expected");
