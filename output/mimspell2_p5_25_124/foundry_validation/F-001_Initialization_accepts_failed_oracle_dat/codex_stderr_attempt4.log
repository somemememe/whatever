                int128(0),
                uint256(1)
            );
            (ok,) = TRICRYPTO_POOL.call(callData);
        }
        require(ok, "curve remove liquidity failed");
        usdtOut = IERC20Like(USDT).balanceOf(address(this)) - beforeBalance;
    }

