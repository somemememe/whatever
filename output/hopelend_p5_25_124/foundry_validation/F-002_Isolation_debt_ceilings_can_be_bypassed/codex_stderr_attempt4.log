      uint256 remainingCeilingUnits = debtCeiling > trackedDebt ? debtCeiling - trackedDebt : 0;

      for (uint256 j = 0; j < reserves.length; ++j) {
        address debtAsset = reserves[j];
        ReserveData memory debtReserve = POOL.getReserveData(debtAsset);
        uint256 debtConfig = debtReserve.configuration.data;
        if (!_isUsableBorrowableIsolationAsset(debtConfig)) {
          continue;
        }

        uint256 debtDecimals = _decimals(debtConfig);
        if (debtDecimals <= 2) {
          continue;
        }

        uint256 accountingUnit = 10 ** (debtDecimals - 2);
        uint256 chunk = accountingUnit - 1;
        uint256 targetBorrowRaw = remainingCeilingUnits == 0
          ? chunk
          : remainingCeilingUnits * accountingUnit + 1;
        uint256 borrowLoops = _ceilDiv(targetBorrowRaw, chunk);
        uint256 debtLiquidity = IERC20Like(debtAsset).balanceOf(debtReserve.hTokenAddress);
        uint256 debtPrice = IPriceOracleLike(oracle).getAssetPrice(debtAsset);

        Opportunity memory candidate = Opportunity({
          collateralAsset: collateralAsset,
          underlyingCollateralBalance: underlyingCollateralBalance,
          hTokenCollateralBalance: hTokenCollateralBalance,
          totalCollateralBalance: totalCollateralBalance,
          collateralLtv: collateralLtv,
          collateralDecimals: collateralDecimals,
          collateralOraclePrice: collateralPrice,
          debtCeiling: debtCeiling,
          trackedDebt: trackedDebt,
          remainingCeilingUnits: remainingCeilingUnits,
          debtAsset: debtAsset,
          debtAssetLiquidity: debtLiquidity,
          debtDecimals: debtDecimals,
          debtOraclePrice: debtPrice,
          maxBorrowableRaw: totalCollateralBalance == 0 || collateralPrice == 0 || debtPrice == 0
            ? 0
            : _maxBorrowableRaw(
              totalCollateralBalance,
              collateralDecimals,
              collateralPrice,
              collateralLtv,
              debtDecimals,
              debtPrice
            ),
          targetBorrowRaw: targetBorrowRaw,
          borrowLoops: borrowLoops
        });

        if (candidate.totalCollateralBalance != 0) {
          if (
            candidate.maxBorrowableRaw < candidate.targetBorrowRaw ||
            candidate.debtAssetLiquidity < candidate.targetBorrowRaw
          ) {
            continue;
          }
        }

