+    }
+
+    uint256 collateralValueBase =
+      (collateralBalance * collateralPrice) /
+      (10 ** collateralDecimals);
+    uint256 maxBorrowValueBase = (collateralValueBase * collateralLtv) / 10_000;
+    return (maxBorrowValueBase * (10 ** debtDecimals)) / debtPrice;
+  }
