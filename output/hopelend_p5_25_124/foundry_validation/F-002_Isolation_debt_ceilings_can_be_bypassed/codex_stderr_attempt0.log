+    selectedDebtAsset = address(0);
+    selectedCollateralBalance = 0;
+    selectedCollateralLtv = 0;
+    selectedDebtCeiling = 0;
+    selectedDebtDecimals = 0;
+    selectedDebtAssetLiquidity = 0;
+    accountingUnitRaw = 0;
