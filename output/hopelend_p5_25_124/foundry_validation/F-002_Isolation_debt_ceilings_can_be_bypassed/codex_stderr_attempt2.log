        'flashloan':(data>>FLASHLOAN_BIT)&1,
    }
    debt=(data>>DEBT_CEILING_BIT)&MASK
    print(name,'ltv',ltv,'lt',lt,'bonus',bonus,'dec',decimals,'debtCeil',debt,flags)
