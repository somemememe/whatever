       infeasibilityReason = REASON_LIQUIDITY_BELOW_REMAINING_CEILING;
       return;
     }
 
     if (requiredBorrowLoops > MAX_SINGLE_TX_BORROW_LOOPS) {
-      // Each loop is a full HopeLend borrow path. Crossing the ceiling requires
-      // roughly one borrow per remaining debt-ceiling cent, so large residual headroom
-      // becomes mechanically single-transaction-infeasible before economics matter.
       infeasibilityReason = REASON_LOOP_COUNT_EXCEEDS_SINGLE_TX_GAS;
       return;
     }
 
     if (opportunity.collateralBalance == 0) {
-      // The required path begins by supplying isolated collateral. With no verifier-held
-      // balance, the only realistic temporary-capital route would be flash-borrowing the
