  function borrow(
    address asset,
    uint256 amount,
    uint256 interestRateMode,
    uint16 referralCode,
    address onBehalfOf
  ) external;

  function setUserUseReserveAsCollateral(address asset, bool useAsCollateral) external;

  function getConfiguration(address asset) external view returns (ReserveConfigurationMap memory);

