      infeasibilityReason = REASON_NO_ISOLATED_COLLATERAL;
      return;
    }
    if (opportunity.debtAsset == address(0)) {
      infeasibilityReason = REASON_NO_BORROWABLE_ISOLATION_ASSET;
      return;
    }

