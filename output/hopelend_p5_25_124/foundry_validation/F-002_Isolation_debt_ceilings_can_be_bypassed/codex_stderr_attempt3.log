  uint8 public constant REASON_SUB_UNIT_BORROW_NOT_POSSIBLE = 3;
  uint8 public constant REASON_LIQUIDITY_BELOW_REMAINING_CEILING = 4;
  uint8 public constant REASON_LOOP_COUNT_EXCEEDS_SINGLE_TX_GAS = 5;
