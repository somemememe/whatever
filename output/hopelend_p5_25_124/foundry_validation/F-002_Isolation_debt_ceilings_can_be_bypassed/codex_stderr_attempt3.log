+      bootstrapProfitShortfallRaw = bootstrapFundingCostInDebtAssetRaw - actualCeilingToBypassRaw;
+      return false;
+    }
+
+    // At parity LTV=10000, the bootstrap is still short at least the flashloan/swap fee.
