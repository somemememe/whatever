        uint256 positiveCount = _countPositive(ranked);

        if (positiveCount == 0) {
            _profitAmount = 0;
            return;
        }

        uint256 maxRounds = positiveCount < MAX_PROGRESSIVE_ROUNDS ? positiveCount : MAX_PROGRESSIVE_ROUNDS;
        uint256 cumulativeRawProfit;
        uint256 bestRawProfit;

        if (maxRounds == 1) {
            cumulativeRawProfit = _attemptDrain(ranked[0]);
            _profitAmount = _normalizeProfit(cumulativeRawProfit);
            return;
