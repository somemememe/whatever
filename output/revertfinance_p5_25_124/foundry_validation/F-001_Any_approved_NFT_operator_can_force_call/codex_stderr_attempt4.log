    /// @notice Constructor
    /// @param _nonfungiblePositionManager Uniswap v3 position manager
    constructor(INonfungiblePositionManager _nonfungiblePositionManager) {
        weth = IWETH9(_nonfungiblePositionManager.WETH9());
