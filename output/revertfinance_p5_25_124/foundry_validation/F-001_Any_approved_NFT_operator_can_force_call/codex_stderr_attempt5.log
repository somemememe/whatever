    address internal constant OPENSEA_PROXY_REGISTRY = 0xa5409ec958C83C3f309868babACA7c86DCB077c1;

    uint256 internal constant CANDIDATE_TOKEN_ID = 422882;
    uint256 internal constant SEARCH_RADIUS = 64;

