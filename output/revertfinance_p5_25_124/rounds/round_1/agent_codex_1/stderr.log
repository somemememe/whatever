   458	    // swaps available tokens and prepares max amounts to be added to nonfungiblePositionManager
   459	    function _swapAndPrepareAmounts(SwapAndMintParams memory params, bool unwrap) internal returns (uint total0, uint total1) {
   460	        if (params.swapSourceToken == params.token0) { 
   461	            if (params.amount0 < params.amountIn1) {
   462	                revert AmountError();
   463	            }
   464	            (uint amountInDelta, uint256 amountOutDelta) = _swap(params.token0, params.token1, params.amountIn1, params.amountOut1Min, params.swapData1);
   465	            total0 = params.amount0 - amountInDelta;
   466	            total1 = params.amount1 + amountOutDelta;
   467	        } else if (params.swapSourceToken == params.token1) { 
   468	            if (params.amount1 < params.amountIn0) {
   469	                revert AmountError();
   470	            }
   471	            (uint amountInDelta, uint256 amountOutDelta) = _swap(params.token1, params.token0, params.amountIn0, params.amountOut0Min, params.swapData0);
   472	            total1 = params.amount1 - amountInDelta;
   473	            total0 = params.amount0 + amountOutDelta;
   474	        } else if (address(params.swapSourceToken) != address(0)) {
   475	
   476	            (uint amountInDelta0, uint256 amountOutDelta0) = _swap(params.swapSourceToken, params.token0, params.amountIn0, params.amountOut0Min, params.swapData0);
   477	            (uint amountInDelta1, uint256 amountOutDelta1) = _swap(params.swapSourceToken, params.token1, params.amountIn1, params.amountOut1Min, params.swapData1);
   478	            total0 = params.amount0 + amountOutDelta0;
   479	            total1 = params.amount1 + amountOutDelta1;
   480	
   481	            // return third token leftover if any
   482	            uint leftOver = params.amountIn0 + params.amountIn1 - amountInDelta0 - amountInDelta1;
   483	
   484	            if (leftOver > 0) {
   485	                _transferToken(params.recipient, params.swapSourceToken, leftOver, unwrap);
   486	            }
   487	        } else {
   488	            total0 = params.amount0;
   489	            total1 = params.amount1;
   490	        }
   491	
   492	        if (total0 > 0) {
   493	            params.token0.approve(address(nonfungiblePositionManager), total0);
   494	        }
   495	        if (total1 > 0) {
   496	            params.token1.approve(address(nonfungiblePositionManager), total1);
   497	        }
   498	    }
   499	
   500	    // returns leftover token balances
   501	    function _returnLeftoverTokens(address to, IERC20 token0, IERC20 token1, uint total0, uint total1, uint added0, uint added1, bool unwrap) internal {
   502	
   503	        uint left0 = total0 - added0;
   504	        uint left1 = total1 - added1;
   505	
   506	        // return leftovers
   507	        if (left0 > 0) {
   508	            _transferToken(to, token0, left0, unwrap);
   509	        }
   510	        if (left1 > 0) {
   511	            _transferToken(to, token1, left1, unwrap);
   512	        }
   513	    }
   514	
   515	    // transfers token (or unwraps WETH and sends ETH)
   516	    function _transferToken(address to, IERC20 token, uint amount, bool unwrap) internal {
   517	        if (address(weth) == address(token) && unwrap) {
   518	            weth.withdraw(amount);
   519	            (bool sent, ) = to.call{value: amount}("");
   520	            if (!sent) {
   521	                revert EtherSendFailed();
   522	            }
   523	        } else {
   524	            SafeERC20.safeTransfer(token, to, amount);
   525	        }
   526	    }
