   403	    // swap and mint logic
   404	    function _swapAndMint(SwapAndMintParams memory params, bool unwrap) internal returns (uint tokenId, uint128 liquidity, uint added0, uint added1) {
   405	
   406	        (uint total0, uint total1) = _swapAndPrepareAmounts(params, unwrap);
   407	
   408	        INonfungiblePositionManager.MintParams memory mintParams = 
   409	            INonfungiblePositionManager.MintParams(
   410	                address(params.token0), 
   411	                address(params.token1), 
   412	                params.fee, 
   413	                params.tickLower, 
   414	                params.tickUpper,
   415	                total0,
   416	                total1, 
   417	                params.amountAddMin0,
   418	                params.amountAddMin1,
   419	                address(this), // is sent to real recipient aftwards
   420	                params.deadline
   421	            );
   422	
   423	        // mint is done to address(this) because it is not a safemint and safeTransferFrom needs to be done manually afterwards
   424	        (tokenId,liquidity,added0,added1) = nonfungiblePositionManager.mint(mintParams);
   425	
   426	        // IMPORTANT to be able to pass msg.sender to receiving contract - this is added to return data - this breaks money lego style data :(
   427	        // other contracts recieving NFTs with data from V3Utils must implement this special behaviour
   428	        nonfungiblePositionManager.safeTransferFrom(address(this), params.recipientNFT, tokenId, abi.encode(msg.sender, params.returnData));
   429	
   430	        emit SwapAndMint(tokenId, liquidity, added0, added1);
   431	
   432	        _returnLeftoverTokens(params.recipient, params.token0, params.token1, total0, total1, added0, added1, unwrap);
   433	    }
