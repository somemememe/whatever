   568	    function _decreaseLiquidity(uint tokenId, uint128 liquidity, uint deadline, uint token0Min, uint token1Min) internal returns (uint256 amount0, uint256 amount1) {
   569	        if (liquidity > 0) {
   570	            (amount0, amount1) = nonfungiblePositionManager.decreaseLiquidity(
   571	                INonfungiblePositionManager.DecreaseLiquidityParams(
   572	                    tokenId, 
