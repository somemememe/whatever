   582	    // collects specified amount of fees from uniswap v3 position
   583	    function _collectFees(uint tokenId, IERC20 token0, IERC20 token1, uint128 collectAmount0, uint128 collectAmount1) internal returns (uint256 amount0, uint256 amount1) {
   584	        uint balanceBefore0 = token0.balanceOf(address(this));
   585	        uint balanceBefore1 = token1.balanceOf(address(this));
   586	        (amount0, amount1) = nonfungiblePositionManager.collect(
   587	            INonfungiblePositionManager.CollectParams(tokenId, address(this), collectAmount0, collectAmount1)
   588	        );
   589	        uint balanceAfter0 = token0.balanceOf(address(this));
   590	        uint balanceAfter1 = token1.balanceOf(address(this));
   591	
   592	        // reverts for fee-on-transfer tokens
   593	        if (balanceAfter0 - balanceBefore0 != amount0) {
   594	            revert CollectError();
   595	        }
   596	        if (balanceAfter1 - balanceBefore1 != amount1) {
   597	            revert CollectError();
   598	        }
   599	    }
