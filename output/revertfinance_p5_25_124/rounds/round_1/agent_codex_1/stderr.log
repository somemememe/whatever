   344	    // checks if required amounts are provided and are exact - wraps any provided ETH as WETH
   345	    // if less or more provided reverts
   346	    function _prepareAdd(IERC20 token0, IERC20 token1, IERC20 otherToken, uint amount0, uint amount1, uint amountOther) internal
   347	    {
   348	        uint amountAdded0;
   349	        uint amountAdded1;
   350	        uint amountAddedOther;
   351	
   352	        // wrap ether sent
   353	        if (msg.value > 0) {
   354	            weth.deposit{ value: msg.value }();
   355	
   356	            if (address(weth) == address(token0)) {
   357	                amountAdded0 = msg.value;
   358	                if (amountAdded0 > amount0) {
   359	                    revert TooMuchEtherSent();
   360	                }
   361	            } else if (address(weth) == address(token1)) {
   362	                amountAdded1 = msg.value;
   363	                if (amountAdded1 > amount1) {
   364	                    revert TooMuchEtherSent();
   365	                }
   366	            } else if (address(weth) == address(otherToken)) {
   367	                amountAddedOther = msg.value;
   368	                if (amountAddedOther > amountOther) {
   369	                    revert TooMuchEtherSent();
   370	                }
   371	            } else {
   372	                revert NoEtherToken();
   373	            }
   374	        }
   375	
   376	        // get missing tokens (fails if not enough provided)
   377	        if (amount0 > amountAdded0) {
   378	            uint balanceBefore = token0.balanceOf(address(this));
   379	            SafeERC20.safeTransferFrom(token0, msg.sender, address(this), amount0 - amountAdded0);
   380	            uint balanceAfter = token0.balanceOf(address(this));
   381	            if (balanceAfter - balanceBefore != amount0 - amountAdded0) {
   382	                revert TransferError(); // reverts for fee-on-transfer tokens
   383	            }
   384	        }
   385	        if (amount1 > amountAdded1) {
   386	            uint balanceBefore = token1.balanceOf(address(this));
   387	            SafeERC20.safeTransferFrom(token1, msg.sender, address(this), amount1 - amountAdded1);
   388	            uint balanceAfter = token1.balanceOf(address(this));
   389	            if (balanceAfter - balanceBefore != amount1 - amountAdded1) {
   390	                revert TransferError(); // reverts for fee-on-transfer tokens
   391	            }
   392	        }
   393	        if (address(otherToken) != address(0) && token0 != otherToken && token1 != otherToken && amountOther > amountAddedOther) {
   394	            uint balanceBefore = otherToken.balanceOf(address(this));
   395	            SafeERC20.safeTransferFrom(otherToken, msg.sender, address(this), amountOther - amountAddedOther);
   396	            uint balanceAfter = otherToken.balanceOf(address(this));
   397	            if (balanceAfter - balanceBefore != amountOther - amountAddedOther) {
   398	                revert TransferError(); // reverts for fee-on-transfer tokens
   399	            }
   400	        }
   401	    }
