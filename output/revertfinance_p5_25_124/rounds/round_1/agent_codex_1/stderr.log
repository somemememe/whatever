   528	    // general swap function which uses external router with off-chain calculated swap instructions
   529	    // does slippage check with amountOutMin param
   530	    // returns token amounts deltas after swap
   531	    function _swap(IERC20 tokenIn, IERC20 tokenOut, uint amountIn, uint amountOutMin, bytes memory swapData) internal returns (uint amountInDelta, uint256 amountOutDelta) {
   532	        if (amountIn > 0 && swapData.length > 0 && address(tokenOut) != address(0)) {
   533	            uint balanceInBefore = tokenIn.balanceOf(address(this));
   534	            uint balanceOutBefore = tokenOut.balanceOf(address(this));
   535	
   536	            // get router specific swap data
   537	            (address swapRouter, address allowanceTarget, bytes memory data) = abi.decode(swapData, (address, address, bytes));
   538	
   539	            // approve needed amount
   540	            tokenIn.approve(allowanceTarget, amountIn);
   541	
   542	            // execute swap
   543	            (bool success,) = swapRouter.call(data);
   544	            if (!success) {
   545	                revert SwapFailed();
   546	            }
   547	
   548	            // remove any remaining allowance
   549	            tokenIn.approve(allowanceTarget, 0);
   550	
   551	            uint balanceInAfter = tokenIn.balanceOf(address(this));
   552	            uint balanceOutAfter = tokenOut.balanceOf(address(this));
   553	
   554	            amountInDelta = balanceInBefore - balanceInAfter;
   555	            amountOutDelta = balanceOutAfter - balanceOutBefore;
   556	
   557	            // amountMin slippage check
   558	            if (amountOutDelta < amountOutMin) {
   559	                revert SlippageError();
   560	            }
   561	
   562	            // event for any swap with exact swapped value
   563	            emit Swap(address(tokenIn), address(tokenOut), amountInDelta, amountOutDelta);
   564	        }
   565	    }
