+        path[1] = DAI;
+
+        uint256 chunk = address(this).balance / rounds;
+        for (uint256 i = 0; i < rounds; i++) {
+            uint256 amountIn = i + 1 == rounds ? address(this).balance : chunk;
+            if (amountIn == 0) {
