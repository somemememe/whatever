+        } else {
+            IUniswapV2PairLike(sellPair).swap(0, wethOut, address(this), new bytes(0));
+        }
+
+        IERC20Like(weth).transfer(msg.sender, wethRepay);
+
+        uint256 profit = IERC20Like(weth).balanceOf(address(this));
