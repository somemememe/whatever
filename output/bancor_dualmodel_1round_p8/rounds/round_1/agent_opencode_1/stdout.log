[{"id": "F-001", "severity": "High", "confidence": "high", "title": "Legacy converter bypasses user-specified minReturn, allowing zero minimum", "locations": ["Contract.sol:1144"], "claim": "When converting via older (non-v28) converters, the minReturn parameter is hardcoded to 1 wei instead of using the user-provided _minReturn", "impact": "Users specifying a minReturn to protect against slippage have no actual protection when the conversion path includes legacy converters. The conversion will succeed even if the output is 0 wei, effectively allowing the converter to return any amount with no slippage protection.", "paths": ["User calls convertByPath with _minReturn=100, path includes legacy converter, converter returns 1 wei, transaction succeeds despite minReturn violation"]}, {"id": "F-002", "severity": "Medium", "confidence": "medium", "title": "Unchecked return value from legacy converter.change()", "locations": ["Contract.sol:1144"], "claim": "The return value from ILegacyConverter(stepData.converter).change() is not validated - if it returns 0 due to conversion failure, the code continues with toAmount=0", "impact": "If a legacy converter returns 0 (indicating failure), the conversion silently fails with 0 output. The subsequent minReturn check may pass or fail depending on _minReturn, but the user receives no tokens without clear error indication.", "paths": ["Legacy converter fails internally but returns 0, toAmount becomes 0, if _minReturn<=0 transaction proceeds incorrectly"]}, {"id": "F-003", "severity": "High", "confidence": "high", "title": "completeXConversion lacks access control - anyone can trigger conversion on their own behalf", "locations": ["Contract.sol:1090-1101"], "claim": "completeXConversion is a public function that allows any caller to convert tokens based on a conversionId from BancorX, using msg.sender as the beneficiary without any authorization check", "impact": "While the function does check _path[0] == _bancorX.token(), any user can trigger this function to convert tokens that were transferred to the BancorX contract. The main risk is that the function lacks proper access control - if BancorX has funds and a conversionId exists, anyone can trigger the conversion. The function is likely intended for a specific workflow but has no protection against misuse.", "paths": ["Attacker calls completeXConversion with any valid path and conversionId to trigger conversion"]}, {"id": "F-004", "severity": "Medium", "confidence": "medium", "title": "Affiliate fee calculation may lose precision due to integer division", "locations": ["Contract.sol:1152"], "claim": "Affiliate fee calculation uses integer division (toAmount.mul(_affiliateFee).div(AFFILIATE_FEE_RESOLUTION)), which truncates the result", "impact": "Small affiliate fees relative to the conversion amount will be truncated to 0, meaning affiliates receive 0 fee for small conversions. This may be intentional design but could lead to confusion or lost fees.", "paths": ["User converts 100 tokens with affiliate fee 100 PPM (0.01%), expected fee = 0.01 tokens but truncates to 0"]}]
