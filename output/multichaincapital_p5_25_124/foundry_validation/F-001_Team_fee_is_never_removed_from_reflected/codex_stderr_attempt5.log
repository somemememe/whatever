        }

        observedPreloadedSyntheticInventory = initialContractMccBalance >= TEAM_SWAP_THRESHOLD;
        if (!observedPreloadedSyntheticInventory) {
            outcomeCode = 2;
            _refreshFinalState(token, targetPair);
