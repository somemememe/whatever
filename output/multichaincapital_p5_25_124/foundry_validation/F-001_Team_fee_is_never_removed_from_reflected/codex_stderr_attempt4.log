        (uint256 richTokenReserve, uint256 richWethReserve) = _pairTokenAndWethReserves(richExitPair);
        if (cheapTokenReserve == 0 || cheapWethReserve == 0 || richTokenReserve == 0 || richWethReserve == 0) {
