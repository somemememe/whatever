      IERC20(token).safeTransferFrom(account, address(this), amount[0]);
      lvar[3] = IERC20(token).balanceOf(address(this)) - lvar[3];
    }
    else {
      inToken = wrappedETH;
      IWETH(wrappedETH).deposit{value: lvar[3]}();
    }

    if (path.path.length > 0) {
