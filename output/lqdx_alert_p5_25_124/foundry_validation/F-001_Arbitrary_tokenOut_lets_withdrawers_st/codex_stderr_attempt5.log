-    function _buildPlan(PairState memory state) internal pure returns (Plan memory best) {
-        uint256 maxBurnLp = _maxLpForStealCap(state.zapLpBalance, state.reserve0, state.reserve1, state.supply);
-        if (maxBurnLp == 0) {
-            return best;
